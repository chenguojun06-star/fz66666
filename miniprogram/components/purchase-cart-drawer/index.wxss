/* 购物车抽屉样式 */

.cart-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-overlay);
  z-index: 999;
  display: flex;
  justify-content: flex-end;
}

.cart-drawer {
  width: 80%;
  max-width: 400px;
  background: var(--color-bg-card);
  height: 100%;
  display: flex;
  flex-direction: column;
  animation: slideIn 0.3s ease;
}

@keyframes slideIn {
  from {
    transform: translateX(100%);
  }
  to {
    transform: translateX(0);
  }
}

/* 头部 */
.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid var(--color-border);
  background: var(--color-primary);
}

.cart-title {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cart-title-text {
  font-size: var(--font-size-4xl);
  font-weight: 600;
  color: var(--color-text-white);
}

.cart-count {
  background: rgba(255, 255, 255, 0.2);
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 12px;
  color: var(--color-text-white);
}

.cart-close-btn {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: var(--font-size-4xl);
  color: var(--color-text-white);
  font-weight: 400;
}

/* 内容区 */
.cart-content {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
}

/* 合并建议 */
.merge-suggestion {
  background: var(--color-primary-bg);
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
  border: 1px solid var(--color-primary-border);
}

.merge-header {
  margin-bottom: 8px;
}

.merge-title {
  font-size: var(--font-size-xl);
  font-weight: 500;
  color: var(--color-primary-dark);
}

.merge-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--color-border-light);
}

.merge-item:last-child {
  border-bottom: none;
}

.merge-text {
  font-size: var(--font-size-lg);
  color: var(--color-text-primary);
}

.merge-btn {
  background: transparent; color: var(--color-primary); border: 1.5px solid var(--color-primary);
  padding: 6px 16px;
  border-radius: 6px;
  font-size: var(--font-size-lg);
}

/* 购物车列表 */
.cart-item {
  display: flex;
  padding: 12px;
  background: var(--color-bg-card);
  border-radius: 8px;
  margin-bottom: 8px;
  box-shadow: var(--shadow-sm);
}

.item-left {
  display: flex;
  align-items: flex-start;
  padding-right: 12px;
}

.item-center {
  flex: 1;
}

.item-name {
  font-size: var(--font-size-2xl);
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 4px;
}

.item-spec {
  font-size: 12px;
  color: var(--color-text-secondary);
  margin-bottom: 4px;
}

.item-meta {
  margin-bottom: 8px;
}

.item-source {
  font-size: 11px;
  color: var(--color-text-tertiary);
  background: var(--color-bg-light);
  padding: 2px 8px;
  border-radius: 4px;
}

.item-edit {
  display: flex;
  align-items: center;
  margin-bottom: 6px;
}

.edit-label {
  font-size: 12px;
  color: var(--color-text-secondary);
  width: 50px;
}

.edit-input {
  flex: 1;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  padding: 6px 8px;
  font-size: var(--font-size-lg);
}

.quantity-control {
  flex: 1;
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 28px;
  height: 28px;
  background: var(--color-bg-light);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-3xl);
  font-weight: 500;
  color: var(--color-text-primary);
}

.quantity-input {
  flex: 1;
  text-align: center;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  padding: 6px 8px;
  margin: 0 4px;
  font-size: var(--font-size-lg);
}

.item-right {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding-left: 8px;
}

.item-split,
.item-delete {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-split {
  background: var(--color-warning-bg);
}

.split-icon {
  font-size: var(--font-size-3xl);
}

.item-delete {
  background: var(--color-danger-bg);
}

.delete-icon {
  font-size: var(--font-size-3xl);
}

/* 空状态 */
.cart-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-icon {
  font-size: var(--font-size-6xl);
  margin-bottom: 16px;
}

.empty-text {
  font-size: var(--font-size-xl);
  color: var(--color-text-tertiary);
}

/* 底部操作区 */
.cart-footer {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  border-top: 1px solid var(--color-border);
  background: var(--color-bg-card);
}

.footer-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.select-all-text {
  font-size: var(--font-size-lg);
  color: var(--color-text-primary);
}

.footer-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 4px;
}

.total-label {
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
}

.total-price {
  font-size: var(--font-size-4xl);
  font-weight: 600;
  color: var(--color-danger);
}

.footer-right {
  display: flex;
  gap: 8px;
  margin-left: 12px;
}

.preview-btn,
.confirm-btn {
  padding: 10px 16px;
  border-radius: 8px;
  font-size: var(--font-size-xl);
  font-weight: 500;
}

.preview-btn {
  background: var(--color-bg-light);
  color: var(--color-text-primary);
}

.confirm-btn {
  background: transparent; color: var(--color-primary); border: 1.5px solid var(--color-primary);
}

/* 预览弹窗 */
.preview-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-overlay);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px;
}

.preview-drawer {
  width: 100%;
  max-width: 400px;
  max-height: 80vh;
  background: var(--color-bg-card);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid var(--color-border);
}

.preview-title {
  font-size: var(--font-size-3xl);
  font-weight: 600;
  color: var(--color-text-primary);
}

.preview-close {
  font-size: var(--font-size-5xl);
  color: var(--color-text-tertiary);
}

.preview-content {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
}

.preview-group {
  background: var(--color-bg-light);
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.group-name {
  font-size: var(--font-size-2xl);
  font-weight: 500;
  color: var(--color-text-primary);
}

.group-total {
  font-size: var(--font-size-2xl);
  font-weight: 600;
  color: var(--color-danger);
}

.group-meta {
  display: flex;
  gap: 8px;
  margin-bottom: 8px;
}

.group-spec,
.group-quantity {
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
}

.group-source {
  padding-top: 8px;
  border-top: 1px solid var(--color-border);
}

.source-label {
  font-size: 12px;
  color: var(--color-text-tertiary);
  margin-right: 4px;
}

.source-item {
  font-size: 12px;
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  padding: 2px 8px;
  border-radius: 4px;
  margin-right: 4px;
  margin-bottom: 4px;
  display: inline-block;
}

.preview-footer {
  padding: 16px;
  border-top: 1px solid var(--color-border);
}

.preview-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.preview-total-label {
  font-size: var(--font-size-2xl);
  color: var(--color-text-primary);
}

.preview-total-price {
  font-size: var(--font-size-6xl);
  font-weight: 700;
  color: var(--color-danger);
}

.preview-confirm-btn {
  background: transparent; color: var(--color-primary); border: 1.5px solid var(--color-primary);
  text-align: center;
  padding: 14px;
  border-radius: 8px;
  font-size: var(--font-size-3xl);
  font-weight: 600;
}
