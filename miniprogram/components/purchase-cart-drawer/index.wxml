<!-- 购物车侧滑抽屉 -->
<view class="cart-overlay" wx:if="{{ visible }}" bindtap="onClose">
  <view class="cart-drawer" catchtap="onDrawTap">
    <!-- 头部 -->
    <view class="cart-header">
      <view class="cart-title">
        <text class="cart-title-text">采购购物车</text>
        <text class="cart-count" wx:if="{{ cart && cart.items && cart.items.length > 0 }}">({{ cart.items.length }})</text>
      </view>
      <view class="cart-close-btn" bindtap="onClose">
        <text class="close-icon">✕</text>
      </view>
    </view>

    <!-- 内容区 -->
    <scroll-view class="cart-content" scroll-y="true" wx:if="{{ cart && cart.items && cart.items.length > 0 }}">
      <!-- 合并建议 -->
      <view class="merge-suggestion" wx:if="{{ mergeSuggestions && mergeSuggestions.length > 0 }}">
        <view class="merge-header">
          <text class="merge-title">💡 智能合并建议</text>
        </view>
        <view class="merge-item" wx:for="{{ mergeSuggestions }}" wx:key="index">
          <text class="merge-text">{{ item.materialName }} 有 {{ item.count }} 条可合并</text>
          <view class="merge-btn" bindtap="onMerge" data-suggestion="{{ item }}">
            合并
          </view>
        </view>
      </view>

      <!-- 购物车物料列表 -->
      <view class="cart-item" wx:for="{{ cart.items }}" wx:key="id">
        <view class="item-left">
          <checkbox checked="{{ selectedItems.indexOf(item.id) !== -1 }}" bindtap="onToggleItem" data-id="{{ item.id }}" />
        </view>
        <view class="item-center">
          <view class="item-name">{{ item.materialName }}</view>
          <view class="item-spec">规格: {{ item.specifications || '-' }}</view>
          <view class="item-meta">
            <text class="item-source">来源: {{ item.sourceType === 'ORDER' ? '订单' : item.sourceType === 'SAMPLE' ? '样衣' : '手动' }}</text>
          </view>
          <view class="item-edit">
            <text class="edit-label">供应商:</text>
            <input class="edit-input" value="{{ item.supplierName }}" placeholder="请输入" bindblur="onSupplierChange" data-id="{{ item.id }}" />
          </view>
          <view class="item-edit">
            <text class="edit-label">单价:</text>
            <input class="edit-input" type="digit" value="{{ item.unitPrice }}" placeholder="0" bindblur="onPriceChange" data-id="{{ item.id }}" />
          </view>
          <view class="item-edit">
            <text class="edit-label">数量:</text>
            <view class="quantity-control">
              <view class="quantity-btn" bindtap="onQuantityMinus" data-id="{{ item.id }}">-</view>
              <input class="quantity-input" type="number" value="{{ item.quantity }}" bindblur="onQuantityChange" data-id="{{ item.id }}" />
              <view class="quantity-btn" bindtap="onQuantityPlus" data-id="{{ item.id }}">+</view>
            </view>
          </view>
        </view>
        <view class="item-right">
          <view class="item-split" bindtap="onSplit" wx:if="{{ item.quantity > 1 }}">
            <text class="split-icon">✂</text>
          </view>
          <view class="item-delete" bindtap="onDelete" data-id="{{ item.id }}">
            <text class="delete-icon">🗑</text>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 空状态 -->
    <view class="cart-empty" wx:else>
      <text class="empty-icon">🛒</text>
      <text class="empty-text">购物车是空的</text>
    </view>

    <!-- 底部操作区 -->
    <view class="cart-footer" wx:if="{{ cart && cart.items && cart.items.length > 0 }}">
      <view class="footer-left">
        <checkbox checked="{{ isAllSelected }}" bindtap="onToggleAll" />
        <text class="select-all-text">全选</text>
      </view>
      <view class="footer-center">
        <text class="total-label">合计:</text>
        <text class="total-price">¥{{ totalAmount || '0.00' }}</text>
      </view>
      <view class="footer-right">
        <view class="preview-btn" bindtap="onPreview">
          预览
        </view>
        <view class="confirm-btn" bindtap="onConfirm" wx:if="{{ selectedItems.length > 0 }}">
          下单 ({{ selectedItems.length }})
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 预览弹窗 -->
<view class="preview-overlay" wx:if="{{ previewVisible }}" bindtap="onClosePreview">
  <view class="preview-drawer" catchtap="onPreviewTap">
    <view class="preview-header">
      <text class="preview-title">采购单预览</text>
      <view class="preview-close" bindtap="onClosePreview">✕</view>
    </view>
    <scroll-view class="preview-content" scroll-y="true">
      <view class="preview-group" wx:for="{{ previewData && previewData.purchaseGroups }}" wx:key="index">
        <view class="group-header">
          <text class="group-name">{{ item.materialName }}</text>
          <text class="group-total">¥{{ item.totalAmount }}</text>
        </view>
        <view class="group-meta">
          <text class="group-spec">{{ item.specifications }}</text>
          <text class="group-quantity">x {{ item.totalQuantity }}</text>
        </view>
        <view class="group-source">
          <text class="source-label">来源:</text>
          <text class="source-item" wx:for="{{ item.sourceItems }}" wx:key="index" wx:for-item="src">
            {{ src.sourceType === 'ORDER' ? '订单' : '样衣' }}: {{ src.sourceNo }}
          </text>
        </view>
      </view>
    </scroll-view>
    <view class="preview-footer">
      <view class="preview-total">
        <text class="preview-total-label">总计:</text>
        <text class="preview-total-price">¥{{ previewData && previewData.totalAmount || '0.00' }}</text>
      </view>
      <view class="preview-confirm-btn" bindtap="onConfirmFromPreview">
        确认下单
      </view>
    </view>
  </view>
</view>
