.srt-table-wrap {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-bg-card);
  white-space: nowrap;
}

.srt-table-inner {
  display: inline-block;
  min-width: 100%;
}

.srt-table-header {
  display: flex;
  align-items: center;
  padding: 8px 10px;
  background: rgba(var(--color-primary-rgb), 0.1);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 2;
}

.srt-th {
  font-size: var(--font-size-xs);
  font-weight: 600;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  text-align: center;
}

.srt-table-row {
  display: flex;
  align-items: center;
  padding: 10px;
  border-bottom: 1px solid var(--color-border-light, rgba(226, 232, 240, 0.5));
}

/* 分块包装：display:contents 让节点对布局透明，仅用于减少 srt-table-inner 直接子节点数 */
.srt-chunk {
  display: contents;
}

.srt-table-row:last-child {
  border-bottom: none;
}

/* hover-class="srt-table-row-hover" 替代 :active */
.srt-table-row-hover {
  background: rgba(var(--color-primary-rgb), 0.04);
}

.srt-td {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  flex-shrink: 0;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
}

.srt-th-worker,
.srt-td-worker {
  width: 54px;
}

.srt-th-order,
.srt-td-order {
  width: 100px;
}

.srt-th-bundle,
.srt-td-bundle {
  width: 56px;
}

.srt-th-process,
.srt-td-process {
  width: 50px;
}

.srt-th-color,
.srt-td-color {
  width: 40px;
}

.srt-th-size,
.srt-td-size {
  width: 36px;
}

/* 颜色/码数 合并列：原来颜色40 + 码数36 = 76，新合并列直接给 78 兼顾两端文字 */
.srt-th-colorsize,
.srt-td-colorsize {
  width: 78px;
}

.srt-th-price,
.srt-td-price {
  width: 42px;
}

/* 单价/金额 合并列：原来单价42 + 金额56 = 98，新合并列 100 */
.srt-th-priceamt,
.srt-td-priceamt {
  width: 100px;
}

.srt-th-qty,
.srt-td-qty {
  width: 36px;
}

.srt-th-amount,
.srt-td-amount {
  width: 56px;
}

.srt-th-bed,
.srt-td-bed {
  width: 36px;
}

.srt-th-time,
.srt-td-time {
  width: 80px;
}
