<view class="print-template-renderer">
  <!-- 连接状态 -->
  <view class="status-bar">
    <view class="status-icon {{connected ? 'connected' : 'disconnected'}}">
      <image src="/images/bluetooth.png" mode="aspectFit" class="icon" />
    </view>
    <view class="status-text">
      <text>{{connected ? '已连接: ' + printerName : '未连接打印机'}}</text>
    </view>
  </view>

  <!-- 连接按钮 -->
  <view class="action-bar" wx:if="{{showConnectButton}}">
    <button 
      class="btn-connect" 
      bindtap="searchPrinters" 
      loading="{{connecting}}"
      disabled="{{connecting}}"
    >
      搜索打印机
    </button>
    <button 
      class="btn-print" 
      bindtap="doPrint"
      disabled="{{!connected}}"
    >
      打印
    </button>
  </view>

  <!-- 设备列表弹窗 -->
  <view class="device-list-modal" wx:if="{{showDeviceList}}">
    <view class="modal-content">
      <view class="modal-header">
        <text>选择打印机</text>
        <text class="close-btn" bindtap="closeDeviceList">×</text>
      </view>
      <view class="device-list">
        <view 
          class="device-item" 
          wx:for="{{devices}}" 
          wx:key="deviceId"
          data-device-id="{{item.deviceId}}"
          data-name="{{item.name}}"
          bindtap="connectPrinter"
        >
          <text class="device-name">{{item.name}}</text>
          <text class="device-id">{{item.deviceId}}</text>
        </view>
      </view>
    </view>
  </view>
</view>