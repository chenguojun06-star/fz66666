<!-- 扩展字段动态组件 -->
<!-- 无字段时隐藏 -->
<view class="ext-fields" wx:if="{{renderFields.length > 0}}">

  <!-- ══ 表单模式 ══ -->
  <block wx:if="{{mode === 'form'}}">
    <view class="ext-section-title" wx:if="{{customOnly}}">自定义字段</view>
    <block wx:for="{{renderFields}}" wx:key="fieldKey">
      <!-- 文本 -->
      <view class="ext-row" wx:if="{{item.fieldType === 'text'}}">
        <text class="ext-lbl">{{item.label}}</text>
        <input class="ext-inp" value="{{formValues[item.fieldKey]}}" data-field-key="{{item.fieldKey}}" bindinput="onInput" placeholder="请输入{{item.label}}" />
      </view>

      <!-- 数字 -->
      <view class="ext-row" wx:elif="{{item.fieldType === 'number' || item.fieldType === 'inputnumber'}}">
        <text class="ext-lbl">{{item.label}}</text>
        <input class="ext-inp" type="digit" value="{{formValues[item.fieldKey]}}" data-field-key="{{item.fieldKey}}" bindinput="onInput" placeholder="请输入{{item.label}}" />
      </view>

      <!-- 文本域 -->
      <view class="ext-row ext-row--textarea" wx:elif="{{item.fieldType === 'textarea'}}">
        <text class="ext-lbl">{{item.label}}</text>
        <textarea class="ext-area" value="{{formValues[item.fieldKey]}}" data-field-key="{{item.fieldKey}}" bindinput="onInput" placeholder="请输入{{item.label}}" auto-height maxlength="-1" />
      </view>

      <!-- 下拉单选 -->
      <view class="ext-row" wx:elif="{{item.fieldType === 'select'}}">
        <text class="ext-lbl">{{item.label}}</text>
        <picker range="{{optionsMap[item.fieldKey]}}" range-key="label" data-field-key="{{item.fieldKey}}" bindchange="onPickerChange">
          <view class="ext-pick">
            <text wx:if="{{formValues[item.fieldKey] !== '' && formValues[item.fieldKey] !== undefined}}">{{formValues[item.fieldKey]}}</text>
            <text class="ext-ph" wx:else>请选择{{item.label}}</text>
          </view>
        </picker>
      </view>

      <!-- 多选 -->
      <view class="ext-row" wx:elif="{{item.fieldType === 'multiselect'}}">
        <text class="ext-lbl">{{item.label}}</text>
        <picker mode="selector" range="{{optionsMap[item.fieldKey]}}" range-key="label" data-field-key="{{item.fieldKey}}" bindchange="onPickerChange">
          <view class="ext-pick">
            <text wx:if="{{formValues[item.fieldKey] !== '' && formValues[item.fieldKey] !== undefined}}">{{formValues[item.fieldKey]}}</text>
            <text class="ext-ph" wx:else>请选择{{item.label}}</text>
          </view>
        </picker>
      </view>

      <!-- 开关 -->
      <view class="ext-row" wx:elif="{{item.fieldType === 'switch' || item.fieldType === 'boolean'}}">
        <text class="ext-lbl">{{item.label}}</text>
        <switch checked="{{formValues[item.fieldKey] === 1 || formValues[item.fieldKey] === true}}" data-field-key="{{item.fieldKey}}" bindchange="onSwitchChange" />
      </view>

      <!-- 日期 -->
      <view class="ext-row" wx:elif="{{item.fieldType === 'date'}}">
        <text class="ext-lbl">{{item.label}}</text>
        <picker mode="date" value="{{formValues[item.fieldKey]}}" data-field-key="{{item.fieldKey}}" bindchange="onDateChange">
          <view class="ext-pick">
            <text wx:if="{{formValues[item.fieldKey]}}">{{formValues[item.fieldKey]}}</text>
            <text class="ext-ph" wx:else>请选择日期</text>
          </view>
        </picker>
      </view>

      <!-- 日期时间 -->
      <view class="ext-row" wx:elif="{{item.fieldType === 'datetime'}}">
        <text class="ext-lbl">{{item.label}}</text>
        <picker mode="date" value="{{formValues[item.fieldKey]}}" data-field-key="{{item.fieldKey}}" bindchange="onDateChange">
          <view class="ext-pick">
            <text wx:if="{{formValues[item.fieldKey]}}">{{formValues[item.fieldKey]}}</text>
            <text class="ext-ph" wx:else>请选择日期</text>
          </view>
        </picker>
      </view>

      <!-- 默认：文本 -->
      <view class="ext-row" wx:else>
        <text class="ext-lbl">{{item.label}}</text>
        <input class="ext-inp" value="{{formValues[item.fieldKey]}}" data-field-key="{{item.fieldKey}}" bindinput="onInput" placeholder="请输入{{item.label}}" />
      </view>
    </block>
  </block>

  <!-- ══ 详情展示模式 ══ -->
  <block wx:else>
    <block wx:for="{{renderFields}}" wx:key="fieldKey">
      <view class="ext-info-row">
        <text class="ext-info-lbl">{{item.label}}</text>
        <text class="ext-info-val">{{item._displayValue}}</text>
      </view>
    </block>
  </block>

</view>
