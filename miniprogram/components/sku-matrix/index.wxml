<!-- 紧凑模式：无滚动，表头"码数"，零值显示"-"，适合卡片头部 -->
<block wx:if="{{mode === 'compact'}}">
  <view class="sku-matrix">
    <view class="sku-matrix-row sku-matrix-header">
      <text class="sku-cell sku-col-label">码数</text>
      <text wx:for="{{sizeMatrix.sizes}}" wx:key="*this" class="sku-cell">{{item}}</text>
    </view>
    <view wx:for="{{sizeMatrix.rows}}" wx:key="color" class="sku-matrix-row" wx:for-item="row">
      <text class="sku-cell sku-col-label">{{row.color}}</text>
      <text wx:for="{{row.cells}}" wx:for-item="c" wx:key="size" class="sku-cell">{{c.quantity > 0 ? c.quantity : '-'}}</text>
    </view>
  </view>
</block>

<!-- 完整模式：横向滚动，表头"颜色"，直接显示数字，适合详情区段 -->
<block wx:else>
  <scroll-view scroll-x class="matrix-scroll">
    <view class="matrix-table">
      <view class="matrix-row matrix-header">
        <text class="matrix-cell cell-color">颜色</text>
        <text wx:for="{{sizeMatrix.sizes}}" wx:key="*this" class="matrix-cell">{{item}}</text>
      </view>
      <view wx:for="{{sizeMatrix.rows}}" wx:key="color" class="matrix-row">
        <text class="matrix-cell cell-color">{{item.color}}</text>
        <text wx:for="{{item.cells}}" wx:for-item="c" wx:key="size" class="matrix-cell">{{c.quantity}}</text>
      </view>
    </view>
  </scroll-view>
</block>
