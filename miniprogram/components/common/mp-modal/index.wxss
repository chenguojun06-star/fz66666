/* ============================================================
   mp-modal — 通用弹窗组件样式（v2: 参照扫码弹窗紧凑设计）
   负责：遮罩层 / 容器外形 / 标题栏
   body + actions 由各页面自定义，放入 slot 后自动继承页面 CSS
   设计规范：
     遮罩     rgba(0,0,0,0.45) / z-index 9999
     box宽度   90% / max-height 80vh（large=88vh）
     圆角     12rpx
     标题     28rpx / 600 / 居中 / 右侧绝对定位 ×
     动画     scale(0.92) → scale(1)  0.2s ease-out
   ============================================================ */

/* 遮罩层 —— fixed 全屏，flex 垂直水平居中 */
.mp-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

/* 弹窗主体 */
.mp-modal-box {
  width: 90%;
  max-height: 85vh;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.14);
  overflow: hidden;
  animation: mpModalIn 0.2s ease-out;
}

@keyframes mpModalIn {
  from { opacity: 0; transform: scale(0.92); }
  to   { opacity: 1; transform: scale(1); }
}

/* large 变体 */
.mp-modal-box.large {
  max-height: 92vh;
}

/* 标题栏 */
.mp-modal-head {
  position: relative;
  padding: 22rpx 80rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  line-height: 1.5;
}

.mp-modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 内容区 —— scroll-view 原生滚动 */
/* WeChat 小程序 scroll-view 必须有明确高度才能滚动，flex:1 不够用 */
/* max-height: 60vh 覆盖绝大多数弹窗场景，内容短时不留空白，内容长时出现滚动条 */
/* 宿主页面 <mp-modal> 标签上需加 catchtouchmove="stopPropagation" 阻止页面滚动 */
.mp-modal-body {
  max-height: 60vh;
  overflow: hidden;
  padding: 12rpx 24rpx;
  box-sizing: border-box;
}

/* large 变体内容区给更多高度 */
.mp-modal-box.large .mp-modal-body {
  max-height: 68vh;
}

/* 底部操作区 —— flex-shrink:0 固定在底部，不随内容滚动 */
.mp-modal-footer {
  flex-shrink: 0;
}

/* 关闭按钮（右上角绝对定位） */
.mp-modal-close {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  color: #bbb;
  font-size: 28rpx;
}
