.image-preview {
  display: block;
  width: 100%;
  height: 100%;
  position: relative;
}
.image-preview .img {
  width: 100%;
  height: 100%;
  display: block;
}
.image-preview .placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background: var(--color-bg-gray);
}
.placeholder-icon {
  font-size: var(--font-size-3xl);
}
.placeholder-text {
  font-size: var(--font-size-xxs);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}
