.image-preview {
  display: block;
  width: 100%;
  height: 100%;
  position: relative;
}
.image-preview .img {
  width: 100%;
  height: 100%;
  display: block;
}
.image-preview .placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  background: #f8fafc;
}
.placeholder-icon {
  font-size: 48rpx;
}
.placeholder-text {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}
