.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: var(--z-overlay);
  background-color: var(--color-bg-card);
  border-bottom: 0.5px solid var(--color-border);
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12px;
  box-sizing: border-box;
  position: relative;
}

.nav-left {
  display: flex;
  align-items: center;
  position: absolute;
  left: 12px;
  z-index: 1;
}

.back-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-hover);
}

.back-icon {
  font-size: var(--font-size-3xl);
  color: var(--color-text-primary);
  line-height: 1;
}

.nav-title-left {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-text-primary);
  text-align: center;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8px;
}

.search-box {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 200px;
  height: 30px;
  background: var(--color-bg-hover);
  border-radius: var(--radius-full);
  padding: 0 10px;
  box-sizing: border-box;
}

.search-icon {
  font-size: var(--font-size-xs);
  margin-right: 4px;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

.search-input::placeholder {
  color: var(--color-text-tertiary);
}

.clear-icon {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  padding: 2px;
}

.nav-right {
  display: flex;
  align-items: center;
  position: absolute;
  right: 12px;
  z-index: 1;
}

.nav-placeholder {
  width: 100%;
}
