.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: var(--z-overlay);
  background-color: var(--color-primary); /* @design-system: 统一蓝色导航栏 */
  color: #ffffff;
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12px;
  box-sizing: border-box;
  position: relative;
}

.nav-left {
  display: flex;
  align-items: center;
  position: absolute;
  left: 12px;
  z-index: 1;
}

.back-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18); /* 蓝色导航栏上的半透明白按钮 */
}

.back-icon {
  font-size: var(--font-size-3xl);
  color: #ffffff;
  line-height: 1;
}

.nav-title-left {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: #ffffff;
  text-align: center;
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8px;
}

.search-box {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 200px;
  height: 30px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-full);
  padding: 0 10px;
  box-sizing: border-box;
}

.search-icon {
  font-size: var(--font-size-xs);
  margin-right: 4px;
  color: rgba(255, 255, 255, 0.85);
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: var(--font-size-sm);
  color: #ffffff;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.7);
}

.clear-icon {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.7);
  padding: 2px;
}

.nav-right {
  display: flex;
  align-items: center;
  position: absolute;
  right: 12px;
  z-index: 1;
}

.nav-placeholder {
  width: 100%;
}
