.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background-color: var(--color-bg-card);
}

.status-bar {
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
  box-sizing: border-box;
}

.nav-left {
  display: flex;
  align-items: center;
  min-width: 60px;
}

.back-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
}

.back-icon {
  font-size: 24px;
  color: var(--color-text-primary);
  line-height: 1;
}

.nav-title-left {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.nav-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8px;
}

.search-box {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 200px;
  height: 30px;
  background: var(--color-bg-light);
  border-radius: 15px;
  padding: 0 10px;
  box-sizing: border-box;
}

.search-icon {
  font-size: 12px;
  margin-right: 4px;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 13px;
  color: var(--color-text-primary);
}

.search-input::placeholder {
  color: var(--color-text-disabled);
}

.clear-icon {
  font-size: 12px;
  color: var(--color-text-disabled);
  padding: 2px;
}

.nav-right {
  display: flex;
  align-items: center;
  min-width: 60px;
  justify-content: flex-end;
}

.nav-placeholder {
  width: 100%;
}
