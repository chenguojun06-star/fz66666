/* 自定义日期选择器 - 底部浮层风格（覆盖旧内嵌样式） */

.dp-root {
  width: 100%;
  position: relative;
}

/* ===== 触发行 ===== */
.dp-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
  height: 40px;
  background: var(--color-bg-light);
  border-radius: 8px;
  border: 1.5px solid var(--color-bg-gray);
  box-sizing: border-box;
}

.dp-trigger--has-value {
  border-color: var(--color-primary, var(--color-primary-light));
  background: var(--color-bg-light);
}

.dp-value {
  font-size: 14px;
  color: var(--color-text-primary);
  flex: 1;
}

.dp-placeholder {
  font-size: 14px;
  color: var(--color-text-disabled);
  flex: 1;
}

.dp-trigger-right {
  display: flex;
  align-items: center;
  gap: 6px;
}

.dp-clear {
  font-size: 16px;
  color: var(--color-text-disabled);
  line-height: 1;
  padding: 2px 4px;
}

/* ===== 遮罩 ===== */
.dp-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 9999;
}

/* ===== 底部浮层面板 ===== */
/* 用 wx:if 控制显隐，入场用 animation 实现滑入效果 */
@keyframes dp-slide-up {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.dp-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  background: var(--color-bg-card);
  border-radius: 16px 16px 0 0;
  transform: translateY(0);
  animation: dp-slide-up 0.28s cubic-bezier(0.32, 0.72, 0, 1) both;
  /* 底部安全区 */
  padding-bottom: env(safe-area-inset-bottom);
}

/* 面板头部 */
.dp-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px 10px;
  border-bottom: 1px solid var(--color-bg-light);
}

.dp-sheet-cancel {
  font-size: 16px;
  color: var(--color-text-secondary);
  padding: 4px 0;
  min-width: 48px;
}

.dp-sheet-preview {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 1px;
}

.dp-sheet-confirm {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-primary, var(--color-primary-light));
  padding: 4px 0;
  min-width: 48px;
  text-align: right;
}

/* picker-view 三列 */
.dp-picker-view {
  width: 100%;
  height: 240px;
}

.dp-indicator {
  border-top: 1px solid var(--color-bg-gray);
  border-bottom: 1px solid var(--color-bg-gray);
}

.dp-col-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  font-size: 17px;
  color: var(--color-text-primary);
  line-height: 48px;
}


