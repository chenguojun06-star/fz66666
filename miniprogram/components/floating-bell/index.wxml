<!-- 悬浮铃铛组件 - 显示待处理任务和紧急事件 -->
<view class="floating-bell-container">
  <!-- 悬浮铃铛按钮 -->
  <view class="floating-bell {{expanded ? 'expanded' : ''}}" bindtap="togglePanel" catchtouchmove="preventMove" hover-class="floating-bell-hover" hover-stay-time="50">
    <image class="bell-icon" src="/assets/icons/bell.svg" mode="aspectFit" />
    <view wx:if="{{totalCount > 0}}" class="bell-badge">{{totalCount > 99 ? '99+' : totalCount}}</view>
  </view>

  <!-- 任务面板 -->
  <view class="task-panel {{showPanel ? 'show' : ''}}">
    <view class="panel-header">
      <view class="panel-title">📋 待处理任务</view>
      <view class="panel-header-actions">
        <view class="refresh-btn-mini" bindtap="refreshTasks" hover-class="refresh-btn-mini-hover" hover-stay-time="50">🔄</view>
        <view class="panel-close" bindtap="closePanel" hover-class="panel-close-hover" hover-stay-time="50">✕</view>
      </view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="panel-loading">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <!-- 任务内容 -->
    <scroll-view wx:else class="panel-content" scroll-y>
      <!-- 紧急事件 -->
      <view wx:if="{{urgentEvents.length > 0}}" class="task-section">
        <view class="section-title urgent">
          <text class="section-icon">🚨</text>
          <text>紧急事件 ({{urgentEvents.length}})</text>
        </view>
        <view
          wx:for="{{urgentEvents}}"
          wx:key="id"
          class="task-item urgent"
          bindtap="onTaskClick"
          data-task="{{item}}"
          data-type="urgent"
          hover-class="task-item-hover"
          hover-stay-time="50"
        >
          <view class="task-main">
            <view class="task-title">{{item.title || '紧急事件'}}</view>
            <view class="task-desc">{{item.description || item.orderNo}}</view>
          </view>
          <view class="task-action">
            <text class="action-text">处理</text>
            <text class="action-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 裁剪任务 -->
      <view wx:if="{{cuttingTasks.length > 0}}" class="task-section">
        <view class="section-title cutting">
          <text class="section-icon">✂️</text>
          <text>裁剪任务 ({{cuttingTasks.length}})</text>
        </view>
        <view
          wx:for="{{cuttingTasks}}"
          wx:key="id"
          class="task-item"
          bindtap="onTaskClick"
          data-task="{{item}}"
          data-type="cutting"
          hover-class="task-item-hover"
          hover-stay-time="50"
        >
          <view class="task-main">
            <view class="task-title">{{item.productionOrderNo || item.orderNo}}</view>
            <view class="task-desc">款号: {{item.styleNo}} · 数量: {{item.orderQuantity}}</view>
            <view class="task-time">领取于 {{item.receivedTimeText}}</view>
          </view>
          <view class="task-action">
            <text class="action-text">查看详情</text>
            <text class="action-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 采购任务 -->
      <view wx:if="{{procurementTasks.length > 0}}" class="task-section">
        <view class="section-title procurement">
          <text class="section-icon">📦</text>
          <text>采购任务 ({{procurementTasks.length}})</text>
        </view>
        <view
          wx:for="{{procurementTasks}}"
          wx:key="id"
          class="task-item"
          bindtap="onTaskClick"
          data-task="{{item}}"
          data-type="procurement"
          hover-class="task-item-hover"
          hover-stay-time="50"
        >
          <view class="task-main">
            <view class="task-title">{{item.orderNo}}</view>
            <view class="task-desc">物料: {{item.materialName}} · 数量: {{item.purchaseQuantity}}{{item.unit}}</view>
            <view class="task-time">领取于 {{item.receivedTimeText}}</view>
          </view>
          <view class="task-action">
            <text class="action-text">确认提交</text>
            <text class="action-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 质检待处理 -->
      <view wx:if="{{qualityTasks.length > 0}}" class="task-section">
        <view class="section-title quality">
          <text class="section-icon">✅</text>
          <text>质检待处理 ({{qualityTasks.length}})</text>
        </view>
        <view
          wx:for="{{qualityTasks}}"
          wx:key="id"
          class="task-item"
          bindtap="onTaskClick"
          data-task="{{item}}"
          data-type="quality"
          hover-class="task-item-hover"
          hover-stay-time="50"
        >
          <view class="task-main">
            <view class="task-title">{{item.orderNo}}</view>
            <view class="task-desc">{{item.color || '-'}} · {{item.size || '-'}} · 数量: {{item.quantity}}</view>
            <view class="task-desc" wx:if="{{item.bundleNo || item.cuttingBundleNo}}">菲号: {{item.bundleNo || item.cuttingBundleNo}}</view>
            <view class="task-time">领取于 {{item.receivedTimeText}}</view>
            <view class="task-hint">📋 已领取，待录入质检结果</view>
          </view>
          <view class="task-action">
            <text class="action-text">录入结果</text>
            <text class="action-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 次品待返修 -->
      <view wx:if="{{repairTasks.length > 0}}" class="task-section">
        <view class="section-title repair">
          <text class="section-icon">🔧</text>
          <text>次品待返修 ({{repairTasks.length}})</text>
        </view>
        <view
          wx:for="{{repairTasks}}"
          wx:key="id"
          class="task-item repair-item"
          bindtap="onTaskClick"
          data-task="{{item}}"
          data-type="repair"
          hover-class="task-item-hover"
          hover-stay-time="50"
        >
          <view class="task-main">
            <view class="task-title">{{item.orderNo}}</view>
            <view class="task-desc">菲号: {{item.bundleNo}} · {{item.color || '-'}} · {{item.size || '-'}} · 次品: {{item.defectQty}}件</view>
            <view class="task-desc" wx:if="{{item.defectCategory}}">缺陷: {{item.defectCategory}}</view>
            <view class="task-hint">🔧 修好后扫码申报返修完成</view>
          </view>
          <view class="task-action">
            <text class="action-text">去扫码</text>
            <text class="action-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 延期订单 -->
      <view wx:if="{{overdueOrders.length > 0}}" class="task-section">
        <view class="section-title overdue">
          <text class="section-icon">⏰</text>
          <text>延期订单 ({{overdueOrders.length}})</text>
        </view>
        <!-- 延期订单统计卡片 -->
        <view class="overdue-summary">
          <view class="summary-item critical" wx:if="{{overdueSummary.criticalCount > 0}}">
            <text class="summary-label">严重延期 (>7天)</text>
            <text class="summary-value">{{overdueSummary.criticalCount}}</text>
          </view>
          <view class="summary-item urgent" wx:if="{{overdueSummary.urgentCount > 0}}">
            <text class="summary-label">紧急延期 (4-7天)</text>
            <text class="summary-value">{{overdueSummary.urgentCount}}</text>
          </view>
          <view class="summary-item warning" wx:if="{{overdueSummary.warningCount > 0}}">
            <text class="summary-label">轻度延期 (1-3天)</text>
            <text class="summary-value">{{overdueSummary.warningCount}}</text>
          </view>
        </view>
        <!-- 延期订单列表 -->
        <view
          wx:for="{{overdueOrders}}"
          wx:key="id"
          class="task-item overdue-item {{item.overdueLevel}}"
          bindtap="onTaskClick"
          data-task="{{item}}"
          data-type="overdue"
          hover-class="task-item-hover"
          hover-stay-time="50"
        >
          <view class="task-main">
            <view class="task-header">
              <view class="task-title">{{item.orderNo}}</view>
              <view class="overdue-badge {{item.overdueLevel}}">{{item.overdueText}}</view>
            </view>
            <view class="task-desc">
              <text>款号: {{item.styleNo}}</text>
              <text class="task-desc-sep">·</text>
              <text>{{item.factoryName}}</text>
            </view>
            <view class="task-meta">
              <text>工序: {{item.currentProcessName}}</text>
              <text class="task-desc-sep">·</text>
              <text>完成: {{item.completedQuantity}}/{{item.orderQuantity}} ({{item.completionRate}}%)</text>
            </view>
            <view class="task-progress">
              <view class="progress-bar">
                <view class="progress-fill" style="width: {{item.completionRate}}%"></view>
              </view>
            </view>
          </view>
          <view class="task-action">
            <text class="action-text">查看</text>
            <text class="action-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 超时提醒 -->
      <view wx:if="{{timeoutReminders.length > 0}}" class="task-section">
        <view class="section-title timeout">
          <text class="section-icon">⏰</text>
          <text>超时提醒 ({{timeoutReminders.length}})</text>
        </view>
        <view
          wx:for="{{timeoutReminders}}"
          wx:key="id"
          class="task-item timeout"
          bindtap="onTaskClick"
          data-task="{{item}}"
          data-type="reminder"
          hover-class="task-item-hover"
          hover-stay-time="50"
        >
          <view class="task-main">
            <view class="task-title">{{item.type}} - {{item.orderNo}}</view>
            <view class="task-desc">已超过 {{item.timeAgo}}</view>
          </view>
          <view class="task-action">
            <text class="action-text">处理</text>
            <text class="action-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 待审批用户（仅管理员可见） -->
      <view wx:if="{{isAdmin && pendingUsers.length > 0}}" class="task-section">
        <view class="section-title approval">
          <text class="section-icon">👤</text>
          <text>待审批用户 ({{pendingUsers.length}})</text>
        </view>
        <view
          wx:for="{{pendingUsers}}"
          wx:key="id"
          class="task-item approval-item"
        >
          <view class="task-main" bindtap="onTaskClick" data-task="{{item}}" data-type="approval">
            <view class="task-title">{{item.name}}</view>
            <view class="task-desc">{{item.phone || '无手机号'}} · {{item.timeText}}</view>
          </view>
          <view class="task-actions">
            <view class="action-btn approve-btn" catchtap="onApproveUser" data-user-id="{{item.id}}" data-action="approve" hover-class="approve-btn-hover" hover-stay-time="50">
              <text>✓ 通过</text>
            </view>
            <view class="action-btn reject-btn" catchtap="onApproveUser" data-user-id="{{item.id}}" data-action="reject" hover-class="reject-btn-hover" hover-stay-time="50">
              <text>✗ 拒绝</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 员工注册待审批（仅租户主账号可见） -->
      <view wx:if="{{isTenantOwner && pendingRegistrations.length > 0}}" class="task-section">
        <view class="section-title approval">
          <text class="section-icon">🧑‍🏭</text>
          <text>员工注册申请 ({{pendingRegistrations.length}})</text>
        </view>
        <view
          wx:for="{{pendingRegistrations}}"
          wx:key="id"
          class="task-item approval-item"
        >
          <view class="task-main" bindtap="onTaskClick" data-task="{{item}}" data-type="registration">
            <view class="task-title">{{item.name || item.username}}</view>
            <view class="task-desc">{{item.phone || '无手机号'}} · {{item.timeText}}</view>
          </view>
          <view class="task-actions">
            <view class="action-btn approve-btn" catchtap="onApproveRegistration" data-user-id="{{item.id}}" data-action="approve" hover-class="approve-btn-hover" hover-stay-time="50">
              <text>✓ 通过</text>
            </view>
            <view class="action-btn reject-btn" catchtap="onApproveRegistration" data-user-id="{{item.id}}" data-action="reject" hover-class="reject-btn-hover" hover-stay-time="50">
              <text>✗ 拒绝</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{!hasAnyTask}}" class="empty-state">
        <text class="empty-icon">✅</text>
        <text class="empty-text">暂无待处理任务</text>
        <text class="empty-hint">您的任务已全部完成</text>
      </view>
    </scroll-view>
  </view>

  <!-- 遮罩层 -->
  <view wx:if="{{showPanel}}" class="panel-mask" bindtap="closePanel" catchtouchmove="preventMove"></view>
</view>
