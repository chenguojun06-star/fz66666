.ai-assistant-container {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 10000;
}

.ai-trigger-btn {
  position: fixed;
  right: 24rpx;
  top: 110px;
  width: 100rpx;
  height: 100rpx;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.2s ease;
  z-index: 9999;
}

.ai-trigger-hover {
  transform: scale(0.95);
}

.mini-cloud-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-cloud-glow {
  position: absolute;
  inset: 8rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(74, 140, 255, 0.22), rgba(74, 140, 255, 0.04) 66%, transparent 78%);
  animation: glowPulse 5.2s ease-in-out infinite;
}

.mini-cloud {
  position: relative;
  width: 80rpx;
  height: 58rpx;
  animation: floatSoft 4.8s ease-in-out infinite;
}

.mini-cloud-part,
.mini-cloud-base {
  position: absolute;
  background: linear-gradient(180deg, #f8fbff 0%, #d9e7ff 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9),
    0 6rpx 14rpx rgba(31, 117, 234, 0.14);
}

.mini-cloud-part {
  border-radius: 50%;
}

.mini-cloud-part-left {
  width: 26rpx;
  height: 26rpx;
  left: 8rpx;
  top: 20rpx;
}

.mini-cloud-part-center {
  width: 34rpx;
  height: 34rpx;
  left: 22rpx;
  top: 6rpx;
}

.mini-cloud-part-right {
  width: 24rpx;
  height: 24rpx;
  right: 8rpx;
  top: 22rpx;
}

.mini-cloud-base {
  left: 10rpx;
  right: 10rpx;
  bottom: 8rpx;
  height: 22rpx;
  border-radius: 999rpx;
}

.mini-cloud-eye {
  position: absolute;
  top: 26rpx;
  width: 10rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #3a5ea7;
  z-index: 2;
  overflow: hidden;
  animation: cloudBlink 6.6s ease-in-out infinite;
}

.mini-cloud-eye-left {
  left: 20rpx;
}

.mini-cloud-eye-right {
  right: 20rpx;
}

.mini-cloud-eye-highlight {
  width: 4rpx;
  height: 4rpx;
  margin: 2rpx 0 0 2rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  animation: eyeHighlightTwinkle 4.2s ease-in-out infinite;
}

.mini-cloud-smile {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  width: 20rpx;
  height: 10rpx;
  margin-left: -10rpx;
  border-bottom: 3rpx solid #3a5ea7;
  border-radius: 0 0 20rpx 20rpx;
  z-index: 2;
  animation: cloudSmileTalk 3.8s ease-in-out infinite;
}

.mini-cloud-spark {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: #ffd700;
  border-radius: 50%;
  animation: sparkle 2s ease-in-out infinite;
  z-index: 3;
}

.mini-cloud-spark-left {
  left: 4rpx;
  top: 12rpx;
  animation-delay: 0s;
}

.mini-cloud-spark-right {
  right: 4rpx;
  top: 14rpx;
  animation-delay: 0.8s;
}

@keyframes floatSoft {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.02); }
}

@keyframes cloudBlink {
  0%, 90%, 100% { transform: scaleY(1); }
  95% { transform: scaleY(0.1); }
}

@keyframes eyeHighlightTwinkle {
  0%, 100% { opacity: 0.96; }
  50% { opacity: 0.6; }
}

@keyframes cloudSmileTalk {
  0%, 100% { transform: scaleY(1); }
  25% { transform: scaleY(1.3); }
  75% { transform: scaleY(0.8); }
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0.5); }
  50% { opacity: 1; transform: scale(1); }
}

.ai-badge {
  position: fixed;
  top: 102px;
  right: 16rpx;
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 44rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-sizing: border-box;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(255,59,48,0.5);
  z-index: 10001;
  pointer-events: none;
}

.chat-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  pointer-events: auto;
  z-index: 10001;
}

.chat-modal {
  position: fixed; bottom: 0; left: 0; right: 0; height: 75vh;
  background: #fff; border-top-left-radius: 24rpx; border-top-right-radius: 24rpx; overflow: hidden;
  display: flex; flex-direction: column; pointer-events: auto;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
  animation: slideUp 0.3s ease-out forwards;
  z-index: 10002;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.chat-header {
  padding: 20rpx 24rpx; display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1rpx solid #eee; background: #fff;
}
.chat-header-left { display: flex; align-items: center; gap: 16rpx; }
.chat-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: linear-gradient(135deg,#e8f4ff,#cce8ff); display: flex; align-items: center; justify-content: center; font-size: 28rpx; flex-shrink: 0; }
.chat-header-text { display: flex; flex-direction: column; justify-content: center; }
.chat-title { font-weight: bold; font-size: 30rpx; color: #1a1a1a; line-height: 1.3; }
.chat-subtitle { font-size: 22rpx; color: #999; line-height: 1.3; margin-top: 2rpx; }
.chat-header-actions { display: flex; align-items: center; gap: 8rpx; }
.header-action-btn { font-size: 34rpx; color: #aaa; padding: 8rpx 12rpx; border-radius: 8rpx; }
.header-action-btn-hover { background: #f0f0f0; }
.close-btn { font-size: 40rpx; color: #999; }

.quick-chips { display: flex; flex-direction: row; padding: 16rpx 24rpx 0; gap: 16rpx; flex-wrap: wrap; }
.quick-chip { background: #f0f7ff; color: #2D7FF9; border-radius: 32rpx; padding: 12rpx 24rpx; font-size: 24rpx; line-height: 1.4; border: 1rpx solid #d0e8ff; }
.quick-chip-hover { background: #d8edff; }
.chat-history { flex: 1; height: 0; width: 100%; box-sizing: border-box; padding: 24rpx; background: #f8f9fa; }
.message-row { display: flex; margin-bottom: 24rpx; align-items: flex-start; }
.my-message { flex-direction: row-reverse; }
.ai-message { flex-direction: row; }
.avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: #ddd; display: flex; align-items: center; justify-content: center; font-size: 24rpx; margin: 0 16rpx; flex-shrink: 0; }
.my-message .avatar { background: var(--primary-color, #2D7FF9); color: #fff; }
.my-message .bubble { background: var(--primary-color, #2D7FF9); color: #fff; border-radius: 16rpx 0 16rpx 16rpx; }
.ai-message .bubble { background: #fff; color: #333; border-radius: 0 16rpx 16rpx 16rpx; }
.bubble { padding: 16rpx 24rpx; max-width: 60%; font-size: 28rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.message-text { word-break: break-all; white-space: pre-wrap; line-height: 1.5; }
.chat-input-area { display: flex; padding: 16rpx 24rpx 48rpx; border-top: 1rpx solid #eee; background: #fff; align-items: center; gap: 12rpx; }
.chat-input { flex: 1; background: #f0f0f0; border-radius: 32rpx; padding: 12rpx 24rpx; font-size: 28rpx; height: 64rpx; box-sizing: border-box; }

.send-btn-mini {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 50%;
  flex-shrink: 0;
}

.send-btn-mini .send-icon {
  font-size: 28rpx;
  color: #fff;
}

.send-btn-mini.btn-disabled {
  background: #ccc;
}

.loading-indicator { text-align: center; color: #999; font-size: 24rpx; padding: 20rpx; }

.chat-main { flex: 1; display: flex; flex-direction: column; min-height: 0; width: 100%; overflow: hidden; }

.header-tabs {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.tab-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 24rpx;
  transition: all 0.2s;
}
.tab-item.active {
  color: #2D7FF9;
  background: rgba(45, 127, 249, 0.08);
  font-weight: 600;
}
.tab-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  border-radius: 32rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 6rpx;
}

.tasks-main {
  flex: 1;
  height: 0;
  padding: 20rpx 24rpx;
  background: #f8f9fa;
  box-sizing: border-box;
}

.tasks-main .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.tasks-main .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
.tasks-main .empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ──── Task sections ──── */
.task-section { margin-bottom: 24rpx; }

/* Section header pill */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}
.quality-header  { background: rgba(45,127,249,0.09); }
.cutting-header  { background: rgba(255,140,0,0.09); }
.purchase-header { background: rgba(123,94,167,0.09); }
.repair-header   { background: rgba(255,77,79,0.09); }
.overdue-header  { background: rgba(255,77,79,0.09); }
.pending-header  { background: rgba(16,185,129,0.09); }

.section-header-left { display: flex; align-items: center; gap: 10rpx; }
.section-icon { font-size: 32rpx; }
.section-name { font-size: 28rpx; font-weight: 700; color: #1a1a1a; }

.section-count-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  box-sizing: border-box;
}
.quality-badge  { background: #2D7FF9; }
.cutting-badge  { background: #FF8C00; }
.purchase-badge { background: #7B5EA7; }
.repair-badge   { background: #FF4D4F; }
.overdue-badge  { background: #FF4D4F; }
.pending-badge  { background: #10B981; }

/* Task card — left accent bar + two-column layout */
.task-card {
  background: #fff;
  border-radius: 18rpx;
  margin-bottom: 14rpx;
  overflow: hidden;
  display: flex;
  flex-direction: row;
  box-shadow: 0 2rpx 14rpx rgba(0,0,0,0.06);
}
.task-card-hover { background: #f8faff; }

.task-accent-bar { width: 6rpx; flex-shrink: 0; }
.task-type-quality  .task-accent-bar { background: #2D7FF9; }
.task-type-cutting  .task-accent-bar { background: #FF8C00; }
.task-type-purchase .task-accent-bar { background: #7B5EA7; }
.task-type-repair   .task-accent-bar { background: #FF4D4F; }
.task-type-overdue  .task-accent-bar { background: #FF4D4F; }
.task-type-pending  .task-accent-bar { background: #10B981; }

.task-card-main {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 18rpx 18rpx 18rpx 20rpx;
  gap: 14rpx;
  box-sizing: border-box;
  min-width: 0;
}
.task-card-info { flex: 1; min-width: 0; }

.task-order-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.task-order-no {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}
.task-style-tag {
  font-size: 22rpx;
  color: #2D7FF9;
  background: rgba(45,127,249,0.09);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.cutting-tag  { color: #FF8C00; background: rgba(255,140,0,0.09); }
.purchase-tag { color: #7B5EA7; background: rgba(123,94,167,0.09); }
.repair-tag   { color: #FF4D4F; background: rgba(255,77,79,0.09); }
.overdue-tag  { color: #FF4D4F; background: rgba(255,77,79,0.12); }

.task-name {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 10rpx;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.task-chips { display: flex; flex-wrap: wrap; gap: 8rpx; }
.task-chip {
  font-size: 22rpx;
  color: #888;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  line-height: 1.5;
}
.time-chip { color: #bbb; }

.task-action-col { flex-shrink: 0; display: flex; align-items: center; }
.task-action-btn {
  font-size: 24rpx;
  padding: 0 22rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 30rpx;
  color: #fff;
  border: none;
  white-space: nowrap;
  box-sizing: border-box;
}
.quality-btn  { background: linear-gradient(135deg, #5da8ff, #2D7FF9); }
.cutting-btn  { background: linear-gradient(135deg, #ffb347, #FF8C00); }
.purchase-btn { background: linear-gradient(135deg, #b09edd, #7B5EA7); }
.default-btn  { background: linear-gradient(135deg, #73d13d, #3f9e0e); }
.task-action-btn::after { border: none; }

/* Backward compat tags */
.tag-orange { color: #d46b08; background: rgba(250,173,20,0.12); }
.tag-red    { color: #cf1322; background: rgba(255,77,79,0.12); }
.tag-green  { color: #389e0d; background: rgba(82,196,26,0.12); }
.tag-blue   { color: #096dd9; background: rgba(24,144,255,0.12); }

.recommend-wrapper {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}
.recommend-title {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}
.recommend-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.recommend-pill {
  background: #f0f7ff;
  color: #2D7FF9;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid #d0e8ff;
}
.recommend-pill-hover {
  background: #d8edff;
}
