<view class="ai-assistant-container" hover-class="none" hover-stop-propagation="false" wx:if="{{visible}}">
  <view class="ai-trigger-btn" catchtap="toggleChat" hover-class="ai-trigger-hover" hover-stay-time="50" wx:if="{{!isOpen}}">
    <view class="mini-cloud-wrapper">
      <view class="mini-cloud-glow"></view>
      <view class="mini-cloud">
        <view class="mini-cloud-part mini-cloud-part-left"></view>
        <view class="mini-cloud-part mini-cloud-part-center"></view>
        <view class="mini-cloud-part mini-cloud-part-right"></view>
        <view class="mini-cloud-base"></view>
        <view class="mini-cloud-eye mini-cloud-eye-left">
          <view class="mini-cloud-eye-highlight"></view>
        </view>
        <view class="mini-cloud-eye mini-cloud-eye-right">
          <view class="mini-cloud-eye-highlight"></view>
        </view>
        <view class="mini-cloud-smile"></view>
        <view class="mini-cloud-spark mini-cloud-spark-left"></view>
        <view class="mini-cloud-spark mini-cloud-spark-right"></view>
      </view>
    </view>
  </view>
  <view class="ai-badge" wx:if="{{!isOpen && (totalTasks > 0 || noticeCount > 0)}}">{{totalTasks + noticeCount > 99 ? '99+' : totalTasks + noticeCount}}</view>

  <view class="chat-overlay" wx:if="{{isOpen}}" catchtap="toggleChat"></view>

  <view class="chat-modal" wx:if="{{isOpen}}">
    <view class="chat-header">
      <view class="header-tabs">
        <view class="tab-item {{currentTab === 'chat' ? 'active' : ''}}" catchtap="switchTab" data-tab="chat">
          <text>☁️ 小云助理</text>
        </view>
        <view class="tab-item {{currentTab === 'tasks' ? 'active' : ''}}" catchtap="switchTab" data-tab="tasks">
          <text>📋 待办任务</text>
          <view class="tab-badge" wx:if="{{totalTasks > 0}}">{{totalTasks > 99 ? '99+' : totalTasks}}</view>
        </view>
      </view>
      <view class="chat-header-actions">
        <view class="header-action-btn" catchtap="clearMessages" title="清空对话" wx:if="{{currentTab === 'chat'}}">🗑</view>
        <view class="header-action-btn close-btn" catchtap="toggleChat">×</view>
      </view>
    </view>

    <view class="chat-main" wx:if="{{currentTab === 'chat'}}">
    <view class="quick-chips" wx:if="{{messages.length <= 1 && !isLoading}}">
      <block wx:if="{{isManager}}">
        <view class="quick-chip" catchtap="autoAsk" data-question="帮我生成今日智能日报">📊 生成日报</view>
        <view class="quick-chip" catchtap="autoAsk" data-question="当前有哪些逾期或高风险订单？">⚠️ 风险订单</view>
        <view class="quick-chip" catchtap="autoAsk" data-question="今天工厂扫码情况如何？">🔍 今日扫码</view>
      </block>
      <block wx:else>
        <view class="quick-chip" catchtap="autoAsk" data-question="我今天负责的生产任务是什么？">📋 我的任务</view>
        <view class="quick-chip" catchtap="autoAsk" data-question="帮我查一下我最近的扫码记录">🔍 扫码记录</view>
        <view class="quick-chip" catchtap="autoAsk" data-question="我负责的订单当前进度怎么样？">📦 订单进度</view>
      </block>
    </view>
    <scroll-view class="chat-history" scroll-y scroll-into-view="{{scrollTo}}">
      <block wx:for="{{messages}}" wx:key="id">
        <view class="message-row {{item.role === 'user' ? 'my-message' : 'ai-message'}}" id="msg-{{item.id}}">
          <view class="avatar">{{item.role === 'user' ? '我' : '☁️'}}</view>
          <view class="bubble">
            <text class="message-text" user-select>{{item.content}}</text>
            <view class="recommend-wrapper" wx:if="{{item.recommendPills && item.recommendPills.length > 0}}">
              <view class="recommend-title">猜你想问</view>
              <view class="recommend-pills">
                <view
                  class="recommend-pill"
                  wx:for="{{item.recommendPills}}"
                  wx:for-item="pill"
                  wx:key="*this"
                  data-question="{{pill}}"
                  catchtap="autoAsk"
                >{{pill}}</view>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view class="loading-indicator" wx:if="{{isLoading}}">小云正在思考...</view>
    </scroll-view>
    <view class="chat-input-area">
      <input class="chat-input" value="{{inputValue}}" placeholder="问点什么..." bindinput="onInput" confirm-type="send" bindconfirm="sendMessage" />
      <view class="send-btn-mini {{(isLoading || !inputValue) ? 'btn-disabled' : ''}}" catchtap="sendMessage">
        <text class="send-icon">➤</text>
      </view>
    </view>
    </view>

    <scroll-view class="tasks-main" scroll-y wx:if="{{currentTab === 'tasks'}}">
      <view class="empty-state" wx:if="{{totalTasks === 0}}">
        <view class="empty-icon">🎉</view>
        <view class="empty-text">太棒了！所有任务都处理完了</view>
      </view>

      <view class="task-section" wx:if="{{qualityTasks && qualityTasks.length > 0}}">
        <view class="section-header quality-header">
          <view class="section-header-left">
            <text class="section-icon">🔍</text>
            <text class="section-name">待质检</text>
          </view>
          <view class="section-count-badge quality-badge">{{qualityTasks.length}}</view>
        </view>
        <view class="task-card task-type-quality" wx:for="{{qualityTasks}}" wx:key="orderId" catchtap="handleQualityTask" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo}}</text>
                <text class="task-style-tag">{{item.styleNo}}</text>
              </view>
              <text class="task-name">{{item.styleName || '暂无款式信息'}}</text>
              <view class="task-chips">
                <view class="task-chip" wx:if="{{item.orderQuantity}}">📦 {{item.orderQuantity}}件</view>
                <view class="task-chip" wx:if="{{item.customerName}}">{{item.customerName}}</view>
              </view>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn quality-btn" size="mini" catchtap="handleQualityTask" data-item="{{item}}">去质检</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{cuttingTasks && cuttingTasks.length > 0}}">
        <view class="section-header cutting-header">
          <view class="section-header-left">
            <text class="section-icon">✂️</text>
            <text class="section-name">待裁剪</text>
          </view>
          <view class="section-count-badge cutting-badge">{{cuttingTasks.length}}</view>
        </view>
        <view class="task-card task-type-cutting" wx:for="{{cuttingTasks}}" wx:key="orderId" catchtap="handleCuttingTask" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo}}</text>
                <text class="task-style-tag cutting-tag">{{item.styleNo}}</text>
              </view>
              <view class="task-chips">
                <view class="task-chip">📋 排单 {{item.orderQuantity || 0}}件</view>
              </view>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn cutting-btn" size="mini" catchtap="handleCuttingTask" data-item="{{item}}">去裁剪</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{purchaseTasks && purchaseTasks.length > 0}}">
        <view class="section-header purchase-header">
          <view class="section-header-left">
            <text class="section-icon">🛒</text>
            <text class="section-name">待采购</text>
          </view>
          <view class="section-count-badge purchase-badge">{{purchaseTasks.length}}</view>
        </view>
        <view class="task-card task-type-purchase" wx:for="{{purchaseTasks}}" wx:key="id" catchtap="handlePurchaseTask" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo || item.purchaseNo}}</text>
                <text class="task-style-tag purchase-tag">待处理</text>
              </view>
              <text class="task-name">{{item.materialName || '待采购物料'}}</text>
              <view class="task-chips">
                <view class="task-chip">📦 {{item.purchaseQuantity || 0}}{{item.unit || ''}}</view>
                <view class="task-chip time-chip" wx:if="{{item.receivedTimeText}}">{{item.receivedTimeText}}</view>
              </view>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn default-btn" size="mini" catchtap="handlePurchaseTask" data-item="{{item}}">查看</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{repairTasks && repairTasks.length > 0}}">
        <view class="section-header repair-header">
          <view class="section-header-left">
            <text class="section-icon">🔧</text>
            <text class="section-name">待返修</text>
          </view>
          <view class="section-count-badge repair-badge">{{repairTasks.length}}</view>
        </view>
        <view class="task-card task-type-repair" wx:for="{{repairTasks}}" wx:key="id">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo}}</text>
                <text class="task-style-tag repair-tag">{{item.bundleNo}}</text>
              </view>
              <text class="task-name">{{item.defectCategory || '次品待返修'}} · {{item.color}} {{item.size}}</text>
              <view class="task-chips">
                <view class="task-chip">⚠️ 次品 {{item.defectQty}}件</view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{overdueOrders && overdueOrders.length > 0}}">
        <view class="section-header overdue-header">
          <view class="section-header-left">
            <text class="section-icon">⏰</text>
            <text class="section-name">延期订单</text>
          </view>
          <view class="section-count-badge overdue-badge">{{overdueOrders.length}}</view>
        </view>
        <view class="task-card task-type-overdue" wx:for="{{overdueOrders}}" wx:key="id">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo}}</text>
                <text class="task-style-tag overdue-tag">逾期</text>
              </view>
              <text class="task-name">{{item.styleName || item.styleNo || ''}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{pendingUsers && pendingUsers.length > 0}}">
        <view class="section-header pending-header">
          <view class="section-header-left">
            <text class="section-icon">👤</text>
            <text class="section-name">待审批用户</text>
          </view>
          <view class="section-count-badge pending-badge">{{pendingUsers.length}}</view>
        </view>
        <view class="task-card task-type-pending" wx:for="{{pendingUsers}}" wx:key="id">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.name}}</text>
              </view>
              <view class="task-chips">
                <view class="task-chip">📱 {{item.phone}}</view>
                <view class="task-chip time-chip">{{item.timeText}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{pendingRegistrations && pendingRegistrations.length > 0}}">
        <view class="section-header pending-header">
          <view class="section-header-left">
            <text class="section-icon">📝</text>
            <text class="section-name">待审批注册</text>
          </view>
          <view class="section-count-badge pending-badge">{{pendingRegistrations.length}}</view>
        </view>
        <view class="task-card task-type-pending" wx:for="{{pendingRegistrations}}" wx:key="id">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.name}}</text>
              </view>
              <view class="task-chips">
                <view class="task-chip">📱 {{item.phone}}</view>
                <view class="task-chip time-chip">{{item.timeText}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>

    </scroll-view>
  </view>
</view>
