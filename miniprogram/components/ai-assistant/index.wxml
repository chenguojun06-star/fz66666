<view class="ai-assistant-container" hover-class="none" hover-stop-propagation="false" wx:if="{{visible}}">
  <view class="ai-trigger-btn" wx:if="{{!isOpen}}" catchtouchstart="onTriggerTouchStart" catchtouchmove="onTriggerTouchMove" catchtouchend="onTriggerTouchEnd" hover-class="ai-trigger-hover" hover-stay-time="50" style="left:{{triggerX}}px;top:{{triggerY}}px;border-radius:{{edgeSide==='left'?'0 16px 16px 0':'16px 0 0 16px'}};box-shadow:{{edgeSide==='left'?'3px 2px 10px rgba(0,0,0,0.14)':'-3px 2px 10px rgba(0,0,0,0.14)'}};z-index:9999;">
    <view class="mini-cloud-wrapper">
      <view class="mini-cloud-glow"></view>
      <view class="mini-cloud">
        <view class="mini-cloud-part mini-cloud-part-left"></view>
        <view class="mini-cloud-part mini-cloud-part-center"></view>
        <view class="mini-cloud-part mini-cloud-part-right"></view>
        <view class="mini-cloud-base"></view>
        <view class="mini-cloud-eye mini-cloud-eye-left">
          <view class="mini-cloud-eye-dot"></view>
        </view>
        <view class="mini-cloud-eye mini-cloud-eye-right">
          <view class="mini-cloud-eye-dot"></view>
        </view>
        <view class="mini-cloud-smile"></view>
        <view class="mini-cloud-spark mini-cloud-spark-left"></view>
        <view class="mini-cloud-spark mini-cloud-spark-right"></view>
      </view>
    </view>
  </view>
  <view class="ai-badge" wx:if="{{!isOpen && (totalTasks > 0 || noticeCount > 0)}}" style="left:{{edgeSide==='left'?triggerX+30:triggerX-8}}px;top:{{triggerY-8}}px;">{{totalTasks + noticeCount > 99 ? '99+' : totalTasks + noticeCount}}</view>

  <view class="chat-overlay" wx:if="{{isOpen}}" catchtap="toggleChat"></view>

  <view class="chat-modal" wx:if="{{isOpen}}">
    <view class="chat-header">
      <view class="header-tabs">
        <view class="tab-item {{currentTab === 'chat' ? 'active' : ''}}" catchtap="switchTab" data-tab="chat">
          <text>☁️ 小云帮助中心</text>
        </view>
        <view class="tab-item {{currentTab === 'tasks' ? 'active' : ''}}" catchtap="switchTab" data-tab="tasks">
          <view class="line-icon line-icon--sm icon-clipboard"></view><text>待办任务</text>
          <view class="tab-badge" wx:if="{{totalTasks > 0}}">{{totalTasks > 99 ? '99+' : totalTasks}}</view>
        </view>
      </view>
      <view class="chat-header-actions">
        <view class="header-action-btn" hover-class="header-action-btn-hover" hover-stay-time="100" catchtap="clearMessages" title="清空对话" wx:if="{{currentTab === 'chat'}}"><view class="line-icon line-icon--sm icon-trash"></view></view>
        <view class="header-action-btn close-btn" hover-class="header-action-btn-hover" hover-stay-time="100" catchtap="toggleChat">×</view>
      </view>
    </view>

    <view class="chat-main" wx:if="{{currentTab === 'chat'}}">
    <!-- 页面上下文感知建议 -->
    <view class="page-context-chips" wx:if="{{pageSuggestions.length > 0 && messages.length <= 1 && !isLoading}}">
      <view class="page-context-label">📍 当前页面相关</view>
      <view class="page-context-list">
        <view class="quick-chip" hover-class="quick-chip-hover" hover-stay-time="100" catchtap="autoAsk" data-question="{{item.question}}" wx:for="{{pageSuggestions}}" wx:key="question">
          <view class="line-icon line-icon--sm {{item.icon}}"></view><text>{{item.label}}</text>
        </view>
      </view>
    </view>
    <!-- 角色默认建议 -->
    <view class="dynamic-suggestions" wx:if="{{dynamicSuggestions.length > 0 && messages.length <= 1 && !isLoading}}">
      <view class="dynamic-suggestions-label">🔔 实时提醒</view>
      <view class="dynamic-suggestions-list">
        <view class="dynamic-suggestion-chip" hover-class="dynamic-suggestion-chip-hover" hover-stay-time="100" catchtap="autoAsk" data-question="{{item.question}}" wx:for="{{dynamicSuggestions}}" wx:key="label">
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>
    <view class="quick-chips" wx:if="{{messages.length <= 1 && !isLoading}}">
      <block wx:if="{{isManager}}">
        <view class="quick-chip" hover-class="quick-chip-hover" hover-stay-time="100" catchtap="autoAsk" data-question="帮我汇总今日日报"><view class="line-icon line-icon--sm icon-stats"></view><text>生成日报</text></view>
        <view class="quick-chip" hover-class="quick-chip-hover" hover-stay-time="100" catchtap="autoAsk" data-question="当前有哪些逾期或高风险订单？"><view class="line-icon line-icon--sm icon-alert"></view><text>风险订单</text></view>
        <view class="quick-chip" hover-class="quick-chip-hover" hover-stay-time="100" catchtap="autoAsk" data-question="今天工厂扫码情况如何？"><view class="line-icon line-icon--sm icon-search"></view><text>今日扫码</text></view>
      </block>
      <block wx:else>
        <view class="quick-chip" hover-class="quick-chip-hover" hover-stay-time="100" catchtap="autoAsk" data-question="我今天负责的生产任务是什么？"><view class="line-icon line-icon--sm icon-clipboard"></view><text>我的任务</text></view>
        <view class="quick-chip" hover-class="quick-chip-hover" hover-stay-time="100" catchtap="autoAsk" data-question="帮我查一下我最近的扫码记录"><view class="line-icon line-icon--sm icon-search"></view><text>扫码记录</text></view>
        <view class="quick-chip" hover-class="quick-chip-hover" hover-stay-time="100" catchtap="autoAsk" data-question="我负责的订单当前进度怎么样？"><view class="line-icon line-icon--sm icon-package"></view><text>订单进度</text></view>
      </block>
    </view>
    <view class="chat-history-wrapper">
      <scroll-view class="chat-history" scroll-y enhanced="{{true}}" scroll-into-view="{{scrollTo}}">
        <block wx:for="{{visibleMessages}}" wx:key="id">
          <view class="message-row {{item.role === 'user' ? 'my-message' : 'ai-message'}}" id="msg-{{item.id}}">
            <view wx:if="{{item.role === 'user'}}" class="avatar avatar-user">我</view>
            <view wx:else class="avatar avatar-ai">
              <view class="chat-cloud">
                <view class="chat-cloud-part chat-cloud-part-left"></view>
                <view class="chat-cloud-part chat-cloud-part-center"></view>
                <view class="chat-cloud-part chat-cloud-part-right"></view>
                <view class="chat-cloud-base"></view>
                <view class="chat-cloud-eye chat-cloud-eye-left"><view class="chat-cloud-eye-dot"></view></view>
                <view class="chat-cloud-eye chat-cloud-eye-right"><view class="chat-cloud-eye-dot"></view></view>
                <view class="chat-cloud-smile"></view>
              </view>
            </view>
            <view class="bubble">
              <image class="msg-image" src="{{item.imageUrl}}" mode="widthFix" catchtap="previewImage" data-src="{{item.imageUrl}}" wx:if="{{item.imageUrl}}" />
              <text class="message-text" user-select wx:if="{{item.content}}">{{item.content}}</text>
              <view class="action-cards" wx:if="{{item.actions && item.actions.length > 0}}">
                <view class="action-card" wx:for="{{item.actions}}" wx:for-item="act" wx:key="label">
                  <view class="action-card-body">
                    <view class="action-card-icon" wx:if="{{act.urgency === 'high'}}">🚨</view>
                    <view class="action-card-icon" wx:elif="{{act.urgency === 'medium'}}">⚠️</view>
                    <view class="action-card-icon" wx:else>📋</view>
                    <view class="action-card-info">
                      <text class="action-card-label">{{act.label}}</text>
                      <text class="action-card-desc" wx:if="{{act.description}}">{{act.description}}</text>
                    </view>
                  </view>
                  <view class="action-card-btn" hover-class="action-card-btn-hover" hover-stay-time="100" catchtap="onActionTap" data-action="{{act}}" wx:if="{{act.type !== 'info'}}">
                    <text>{{act.buttonText || '执行'}}</text>
                  </view>
                </view>
              </view>
              <view class="insight-cards" wx:if="{{item.insightCards && item.insightCards.length > 0}}">
                <view class="insight-card insight-{{ic.level || 'info'}}" wx:for="{{item.insightCards}}" wx:for-item="ic" wx:key="title">
                  <view class="insight-title">{{ic.level === 'danger' ? '🔴' : ic.level === 'warning' ? '🟠' : ic.level === 'success' ? '🟢' : '🔵'}} {{ic.title}}</view>
                  <view wx:if="{{ic.summary}}" class="insight-summary">{{ic.summary}}</view>
                  <view wx:if="{{ic.painPoint}}" class="insight-pain">⚠ {{ic.painPoint}}</view>
                  <view wx:if="{{ic.execute}}" class="insight-action">→ {{ic.execute}}</view>
                  <view wx:if="{{ic.evidence.length}}" class="insight-evidence">
                    <view wx:for="{{ic.evidence}}" wx:for-item="ev" wx:for-index="evi" wx:key="evi" class="insight-ev-item">· {{ev}}</view>
                  </view>
                </view>
              </view>
              <view class="clarification-card" wx:if="{{item.clarificationHints && item.clarificationHints.length > 0}}">
                <view class="clarification-label">🤔 需要补充信息：</view>
                <view class="clarification-btns">
                  <view wx:for="{{item.clarificationHints}}" wx:for-item="hint" wx:for-index="hi" wx:key="hi"
                    class="clarification-btn" hover-class="clarification-btn-hover"
                    catchtap="autoAsk" data-question="{{hint}}">{{hint}}</view>
                </view>
              </view>
              <view class="recommend-wrapper" wx:if="{{item.recommendPills && item.recommendPills.length > 0}}">
                <view class="recommend-title">猜你想问</view>
                <view class="recommend-pills">
                  <view
                    class="recommend-pill"
                    hover-class="recommend-pill-hover"
                    hover-stay-time="100"
                    wx:for="{{item.recommendPills}}"
                    wx:for-item="pill"
                    wx:key="*this"
                    data-question="{{pill}}"
                    catchtap="autoAsk"
                  >{{pill}}</view>
                </view>
              </view>
            </view>
          </view>
        </block>
        <view class="loading-indicator" wx:if="{{isLoading}}">
          <text class="loading-hint-text">小云正在思考，你可以继续输入下一个问题…</text>
        </view>
      </scroll-view>
    </view>
    <view class="chat-input-area">
      <input class="chat-input" value="{{inputValue}}" placeholder="输入关键字查询内部资料" bindinput="onInput" confirm-type="send" bindconfirm="sendMessage" />
      <view class="send-btn-mini {{(!inputValue) ? 'btn-disabled' : ''}}" catchtap="sendMessage">
        <text class="send-icon">➤</text>
      </view>
    </view>
    </view>

    <scroll-view class="tasks-main" scroll-y enhanced="{{true}}" wx:if="{{currentTab === 'tasks'}}">
      <view class="empty-state" wx:if="{{totalTasks === 0}}">
        <view class="line-icon line-icon--lg icon-checkmark" style="margin-bottom:12rpx"></view>
        <view class="empty-text">太棒了！所有任务都处理完了</view>
      </view>

      <view class="task-section" wx:if="{{qualityTasks && qualityTasks.length > 0}}">
        <view class="section-header quality-header">
          <view class="section-header-left">
            <view class="line-icon line-icon--sm icon-search"></view>
            <text class="section-name">待质检</text>
          </view>
          <view class="section-count-badge quality-badge">{{qualityTasks.length}}</view>
        </view>
        <view class="task-card task-type-quality" hover-class="task-card-hover" hover-stay-time="100" wx:for="{{qualityTasks}}" wx:key="orderId" catchtap="handleQualityTask" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo}}</text>
                <text class="task-style-tag">{{item.styleNo}}</text>
              </view>
              <text class="task-name">{{item.styleName || '暂无款式信息'}}</text>
              <view class="task-chips">
                <view class="task-chip" wx:if="{{item.orderQuantity}}">{{item.orderQuantity}}件</view>
                <view class="task-chip" wx:if="{{item.customerName}}">{{item.customerName}}</view>
              </view>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn quality-btn" size="mini" catchtap="handleQualityTask" data-item="{{item}}">去质检</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{cuttingTasks && cuttingTasks.length > 0}}">
        <view class="section-header cutting-header">
          <view class="section-header-left">
            <view class="line-icon line-icon--sm icon-cutting"></view>
            <text class="section-name">待裁剪</text>
          </view>
          <view class="section-count-badge cutting-badge">{{cuttingTasks.length}}</view>
        </view>
        <view class="task-card task-type-cutting" hover-class="task-card-hover" hover-stay-time="100" wx:for="{{cuttingTasks}}" wx:key="orderId" catchtap="handleCuttingTask" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo}}</text>
                <text class="task-style-tag cutting-tag">{{item.styleNo}}</text>
              </view>
              <view class="task-chips">
                <view class="task-chip">排单 {{item.orderQuantity || 0}}件</view>
              </view>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn cutting-btn" size="mini" catchtap="handleCuttingTask" data-item="{{item}}">去裁剪</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{purchaseTasks && purchaseTasks.length > 0}}">
        <view class="section-header purchase-header">
          <view class="section-header-left">
            <view class="line-icon line-icon--sm icon-cart"></view>
            <text class="section-name">待采购</text>
          </view>
          <view class="section-count-badge purchase-badge">{{purchaseTasks.length}}</view>
        </view>
        <view class="task-card task-type-purchase" hover-class="task-card-hover" hover-stay-time="100" wx:for="{{purchaseTasks}}" wx:key="id" catchtap="handlePurchaseTask" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo || item.purchaseNo}}</text>
                <text class="task-style-tag purchase-tag">待处理</text>
              </view>
              <text class="task-name">{{item.materialName || '待采购物料'}}</text>
              <view class="task-chips">
                <view class="task-chip">{{item.purchaseQuantity || 0}}{{item.unit || ''}}</view>
                <view class="task-chip time-chip" wx:if="{{item.receivedTimeText}}">{{item.receivedTimeText}}</view>
              </view>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn default-btn" size="mini" catchtap="handlePurchaseTask" data-item="{{item}}">查看</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{repairTasks && repairTasks.length > 0}}">
        <view class="section-header repair-header">
          <view class="section-header-left">
            <view class="line-icon line-icon--sm icon-wrench"></view>
            <text class="section-name">待返修</text>
          </view>
          <view class="section-count-badge repair-badge">{{repairTasks.length}}</view>
        </view>
        <view class="task-card task-type-repair" hover-class="task-card-hover" hover-stay-time="100" wx:for="{{repairTasks}}" wx:key="id" catchtap="handleRepairTask" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo}}</text>
                <text class="task-style-tag repair-tag">{{item.bundleNo}}</text>
              </view>
              <text class="task-name">{{item.defectCategory || '次品待返修'}} · {{item.color}} {{item.size}}</text>
              <view class="task-chips">
                <view class="task-chip">次品 {{item.defectQty}}件</view>
              </view>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn repair-btn" size="mini" catchtap="handleRepairTask" data-item="{{item}}">去返修</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{overdueOrders && overdueOrders.length > 0}}">
        <view class="section-header overdue-header">
          <view class="section-header-left">
            <view class="line-icon line-icon--sm icon-clock"></view>
            <text class="section-name">延期订单</text>
          </view>
          <view class="section-count-badge overdue-badge">{{overdueOrders.length}}</view>
        </view>
        <view class="task-card task-type-overdue" hover-class="task-card-hover" hover-stay-time="100" wx:for="{{overdueOrders}}" wx:key="id" catchtap="handleOverdueOrder" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo}}</text>
                <text class="task-style-tag overdue-tag">逾期</text>
              </view>
              <text class="task-name">{{item.styleName || item.styleNo || ''}}</text>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn default-btn" size="mini" catchtap="handleOverdueOrder" data-item="{{item}}">查看</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{pendingUsers && pendingUsers.length > 0}}">
        <view class="section-header pending-header">
          <view class="section-header-left">
            <view class="line-icon line-icon--sm icon-user"></view>
            <text class="section-name">待审批用户</text>
          </view>
          <view class="section-count-badge pending-badge">{{pendingUsers.length}}</view>
        </view>
        <view class="task-card task-type-pending" hover-class="task-card-hover" hover-stay-time="100" wx:for="{{pendingUsers}}" wx:key="id">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.name}}</text>
              </view>
              <view class="task-chips">
                <view class="task-chip">{{item.phone}}</view>
                <view class="task-chip time-chip">{{item.timeText}}</view>
              </view>
            </view>
            <view class="task-action-col task-approve-col">
              <button class="task-action-btn approve-btn" size="mini" catchtap="onApproveUser" data-user-id="{{item.id}}" data-action="approve">通过</button>
              <button class="task-action-btn reject-btn" size="mini" catchtap="onApproveUser" data-user-id="{{item.id}}" data-action="reject">拒绝</button>
            </view>
          </view>
        </view>
      </view>

      <view class="task-section" wx:if="{{pendingRegistrations && pendingRegistrations.length > 0}}">
        <view class="section-header pending-header">
          <view class="section-header-left">
            <view class="line-icon line-icon--sm icon-edit"></view>
            <text class="section-name">待审批注册</text>
          </view>
          <view class="section-count-badge pending-badge">{{pendingRegistrations.length}}</view>
        </view>
        <view class="task-card task-type-pending" hover-class="task-card-hover" hover-stay-time="100" wx:for="{{pendingRegistrations}}" wx:key="id">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.name}}</text>
              </view>
              <view class="task-chips">
                <view class="task-chip"><view class="line-icon line-icon--sm icon-phone"></view> {{item.phone}}</view>
                <view class="task-chip time-chip">{{item.timeText}}</view>
              </view>
            </view>
            <view class="task-action-col task-approve-col">
              <button class="task-action-btn approve-btn" size="mini" catchtap="onApproveRegistration" data-user-id="{{item.id}}" data-action="approve">通过</button>
              <button class="task-action-btn reject-btn" size="mini" catchtap="onApproveRegistration" data-user-id="{{item.id}}" data-action="reject">拒绝</button>
            </view>
          </view>
        </view>
      </view>

      <!-- 超时提醒 -->
      <view class="task-section" wx:if="{{timeoutReminders.length > 0}}">
        <view class="task-section-header">
          <view class="line-icon icon-clock"></view>
          <text class="section-title">超时提醒</text>
          <text class="section-badge">({{timeoutReminders.length}})</text>
        </view>
        <view class="task-card task-type-timeout" hover-class="task-card-hover" hover-stay-time="100" wx:for="{{timeoutReminders}}" wx:key="id" catchtap="handleReminderTask" data-item="{{item}}">
          <view class="task-accent-bar"></view>
          <view class="task-card-main">
            <view class="task-card-info">
              <view class="task-order-row">
                <text class="task-order-no">{{item.orderNo || item.title}}</text>
                <text class="task-style-tag timeout-tag">{{item.type || '超时'}}</text>
              </view>
              <text class="task-name">{{item.message || item.description || ''}}</text>
            </view>
            <view class="task-action-col">
              <button class="task-action-btn default-btn" size="mini" catchtap="handleReminderTask" data-item="{{item}}">处理</button>
            </view>
          </view>
        </view>
      </view>

    </scroll-view>
  </view>
</view>
