page {
  background: var(--color-bg-page);
  padding-bottom: calc(80px + env(safe-area-inset-bottom));
}

.container {
  padding: 12rpx var(--page-padding-x);
}

.card {
  margin: 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  border: 1px solid var(--color-border-light);
  padding: 16px;
}

.filter-row {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-pill {
  padding: 6px 14px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-pill-active {
  background: var(--color-primary);
  color: var(--color-text-white);
  font-weight: var(--font-weight-semibold);
}

.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 12px 0;
  background: var(--color-bg-gray);
  border-radius: var(--radius-lg);
  margin-bottom: 12px;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.stats-value {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
}

.stats-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.stats-error { color: var(--color-error); }
.stats-warning { color: var(--color-warning); }
.stats-info { color: var(--color-info); }
.stats-success { color: var(--color-success); }

.stats-divider {
  width: 1px;
  height: 24px;
  background: var(--color-border-light);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.defect-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-lg);
  padding: 14px;
  box-shadow: var(--shadow-sm);
}

.defect-card-urgent {
  border-left: 1px solid var(--color-error);
}

.defect-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.defect-header-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  min-width: 0;
}

.defect-status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-error { background: var(--color-error); }
.dot-warning { background: var(--color-warning); }
.dot-info { background: var(--color-info); }
.dot-success { background: var(--color-success); }

.defect-title-area {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.defect-order-no {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.defect-bundle-no {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.defect-header-right {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.defect-status-tag {
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
}

.tag-error {
  background: var(--color-error-bg);
  color: var(--color-error);
}

.tag-warning {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.tag-info {
  background: var(--color-info-bg);
  color: var(--color-info);
}

.tag-success {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.collapse-arrow {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  transition: transform 0.25s;
  padding: 4px 2px;
}

.collapse-up {
  transform: rotate(180deg);
}

.defect-summary {
  margin-top: 10px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.defect-info-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.defect-info-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  min-width: 56px;
  flex-shrink: 0;
}

.defect-info-value {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.defect-qty {
  color: var(--color-error);
  font-weight: var(--font-weight-bold);
}

.defect-detail {
  border-top: 1px solid var(--color-border-light);
  margin-top: 12px;
  padding-top: 12px;
}

.detail-section-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-semibold);
  margin-bottom: 8px;
  display: block;
}

.defect-images {
  margin-bottom: 12px;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.defect-photo {
  width: 72px;
  height: 72px;
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border-light);
}

.defect-remark-section {
  margin-bottom: 12px;
}

.defect-remark-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
}

.defect-actions {
  margin-top: 4px;
}

.action-row {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}

.action-btn {
  padding: 8px 20px;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  text-align: center;
}

.action-btn-primary {
  background: var(--color-primary);
  color: var(--color-text-white);
}

.action-btn-danger {
  background: var(--color-error);
  color: var(--color-text-white);
}

.load-more {
  margin-top: 12px;
  text-align: center;
}

.load-more-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 24px;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 24px;
}

.empty-icon {
  font-size: var(--font-size-6xl);
  margin-bottom: 16px;
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-align: center;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 24px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 12px;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}
