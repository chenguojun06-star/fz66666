    <!-- Shirt -->
    <svg class="garment garment-shirt" viewBox="0 0 80 80" fill="none">
      <path d="M28 4L24 0L30 0L34 2L40 0L46 2L50 0L56 0L52 4" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
