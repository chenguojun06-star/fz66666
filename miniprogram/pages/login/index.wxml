    </svg>
    <svg class="garment hanger hanger-2" viewBox="0 0 80 36" fill="none">
      <path d="M38 4C38 1.8 39.8 0 42 0C44.2 0 46 1.8 46 4C46 5.2 45.2 6.2 44 6.8" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"/>
      <path d="M44 6.8L76 28L74 32L42 16L10 32L6 28L40 6.8" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="42" cy="4" r="1.5" stroke="currentColor" stroke-width="0.5" opacity="0.5"/>
    </svg>
    <svg class="garment hanger hanger-3" viewBox="0 0 80 36" fill="none">
      <path d="M38 4C38 1.8 39.8 0 42 0C44.2 0 46 1.8 46 4C46 5.2 45.2 6.2 44 6.8" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"/>
      <path d="M44 6.8L76 28L74 32L42 16L10 32L6 28L40 6.8" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="42" cy="4" r="1.5" stroke="currentColor" stroke-width="0.5" opacity="0.5"/>
    </svg>
    <!-- Scissors -->
    <svg class="garment garment-accessory scissors" viewBox="0 0 50 60" fill="none">
      <circle cx="14" cy="48" r="8" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"/>
      <circle cx="36" cy="48" r="8" stroke="currentColor" stroke-width="0.8" stroke-linecap="round"/>
      <path d="M14 40L24 8L26 4" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M36 40L26 8L24 4" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="25" cy="38" r="2" stroke="currentColor" stroke-width="0.5" opacity="0.5"/>
    </svg>
    <!-- Background grid (subtle) -->
    <view class="login-subtle-grid"></view>
    <view class="login-soft-glow"></view>
  </view>

  <!-- Form panel -->
  <view class="login-shell">
    <view class="login-panel">
      <!-- Header: cloud mascot + title -->
      <view class="login-header">
        <view class="login-title-row">
          <view class="login-cloud-wrap">
            <view class="login-cloud-glow"></view>
            <view class="login-cloud">
              <view class="login-cloud-part login-cloud-part-left"></view>
              <view class="login-cloud-part login-cloud-part-center"></view>
              <view class="login-cloud-part login-cloud-part-right"></view>
              <view class="login-cloud-base"></view>
              <view class="login-cloud-eye login-cloud-eye-left">
                <view class="login-cloud-eye-dot"></view>
              </view>
              <view class="login-cloud-eye login-cloud-eye-right">
                <view class="login-cloud-eye-dot"></view>
              </view>
              <view class="login-cloud-smile"></view>
              <view class="login-cloud-spark login-cloud-spark-left"></view>
              <view class="login-cloud-spark login-cloud-spark-right"></view>
            </view>
          </view>
          <view class="login-title">{{i18nTexts.brand}}</view>
        </view>
        <view class="login-subtitle">衣智链小云</view>
      </view>

      <view wx:if="{{wechatChecking}}" class="wechat-checking">
        <view class="wechat-checking-badge">微信</view>
        <view class="wechat-checking-title">{{i18nTexts.wechatChecking}}</view>
      </view>

      <block wx:if="{{!wechatChecking}}">
        <view wx:if="{{inviteBanner}}" class="invite-banner">
          <text class="invite-banner-icon">✦</text>
          <text class="invite-banner-text">{{inviteBanner}}</text>
        </view>

        <!-- Company search (no label) -->
        <view class="login-field">
          <view class="login-input-wrap">
            <text class="login-input-icon login-input-icon-search">⌕</text>
            <input
              class="login-input"
              placeholder="{{tenantsLoading ? i18nTexts.loading : i18nTexts.companySearchPlaceholder}}"
              value="{{tenantSearchText}}"
              bindinput="onTenantSearch"
              bindfocus="onTenantSearchFocus"
              disabled="{{loading || tenantsLoading || inviteTenantFixed}}"
            />
            <text wx:if="{{selectedTenantName && !inviteTenantFixed}}" class="login-input-clear" bindtap="onClearTenant">✕</text>
          </view>
          <view wx:if="{{selectedTenantName}}" class="tenant-selected-tag">{{i18nTexts.companySelectedPrefix}}{{selectedTenantName}}</view>
          <view wx:if="{{showTenantResults && filteredTenants.length > 0}}" class="tenant-results">
            <view wx:for="{{filteredTenants}}" wx:key="id" class="tenant-result-item" data-index="{{index}}" bindtap="onTenantSelect" hover-class="tenant-result-item-hover" hover-stay-time="50">{{item.tenantName}}</view>
          </view>
          <view wx:if="{{showTenantResults && filteredTenants.length === 0 && tenantSearchText}}" class="tenant-results">
            <view class="tenant-result-empty">{{i18nTexts.companyNotFound}}</view>
          </view>
        </view>

        <!-- Username (no label) -->
        <view class="login-field">
          <view class="login-input-wrap">
            <text class="login-input-icon login-input-icon-user">◌</text>
            <input class="login-input" placeholder="{{i18nTexts.usernamePlaceholder}}" value="{{username}}" bindinput="onUsernameInput" disabled="{{loading}}" />
          </view>
        </view>

        <!-- Password (no label) -->
        <view class="login-field">
          <view class="login-input-wrap">
            <text class="login-input-icon login-input-icon-lock">◐</text>
            <input class="login-input" placeholder="{{i18nTexts.passwordPlaceholder}}" password="{{!showPassword}}" value="{{password}}" bindinput="onPasswordInput" disabled="{{loading}}" />
            <text class="login-input-eye" bindtap="togglePassword">{{showPassword ? '隐' : '显'}}</text>
          </view>
        </view>

        <view class="login-btn-wrap">
          <view class="login-btn {{loading || !selectedTenantId ? 'login-btn-disabled' : ''}}" bindtap="onLogin" hover-class="login-btn-hover" hover-stay-time="50">{{loading ? i18nTexts.submitting : i18nTexts.submit}}</view>
        </view>

        <view wx:if="{{showDevFields}}" class="login-field login-field-dev">
          <view class="login-input-wrap">
            <text class="login-input-icon login-input-icon-dev">◎</text>
            <input class="login-input" placeholder="{{i18nTexts.serverUrlPlaceholder}}" value="{{apiBaseUrl}}" bindinput="onApiBaseUrlInput" />
          </view>
        </view>

        <view class="login-register-section">
          <view class="login-register-link" bindtap="onManualRegister" hover-class="login-register-link-hover" hover-stay-time="50">{{i18nTexts.noAccount}}{{i18nTexts.registerNow}}</view>
        </view>
      </block>
    </view>
  </view>
</view>
