.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(170deg, #e8ecf4 0%, #f2f5fa 40%, var(--color-bg-page) 100%);
  position: relative;
  overflow: hidden;
  padding: 20px 16px;
  box-sizing: border-box;
}

.login-garments {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 0;
}

.garment {
  position: absolute;
}

.garment-dress {
  width: 56px;
  top: 8%;
  left: 42%;
  transform: rotate(-18deg);
  color: rgba(128, 140, 162, 0.28);
}

.garment-coat {
  width: 72px;
  top: 22%;
  left: 8%;
  transform: rotate(14deg);
  color: rgba(118, 130, 152, 0.32);
}

.garment-shirt {
  width: 64px;
  top: 48%;
  right: 4%;
  transform: rotate(-10deg);
  color: rgba(135, 145, 168, 0.30);
}

.garment-tshirt {
  width: 96px;
  bottom: 28%;
  left: 2%;
  transform: rotate(5deg);
  color: rgba(105, 118, 140, 0.36);
}

.garment-skirt {
  width: 110px;
  bottom: 6%;
  left: 38%;
  transform: translateX(-50%) rotate(-3deg);
  color: rgba(90, 105, 130, 0.44);
}

.garment-vest {
  width: 54px;
  top: 10%;
  right: 12%;
  transform: rotate(-8deg);
  color: rgba(125, 138, 160, 0.28);
}

.scissors {
  width: 36px;
  top: 32%;
  left: 18%;
  transform: rotate(25deg);
  color: rgba(140, 150, 170, 0.18);
}

.hanger-1 {
  width: 88px;
  top: 4%;
  left: 24%;
  transform: rotate(-5deg);
  color: rgba(148, 158, 175, 0.18);
}

.hanger-2 {
  width: 100px;
  bottom: 34%;
  right: 3%;
  transform: rotate(-10deg);
  color: rgba(115, 128, 148, 0.24);
}

.hanger-3 {
  width: 78px;
  top: 30%;
  right: 26%;
  transform: rotate(12deg);
  color: rgba(140, 150, 170, 0.16);
}

.login-subtle-grid {
  position: absolute;
  inset: -10%;
  background-image:
    linear-gradient(rgba(143, 167, 212, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(143, 167, 212, 0.04) 1px, transparent 1px);
  background-size: 48px 48px;
  -webkit-mask-image: radial-gradient(ellipse at 50% 40%, rgba(0,0,0,0.5), transparent 60%);
}

.login-soft-glow {
  position: absolute;
  width: 500px;
  height: 500px;
  top: 15%;
  right: -20%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(31,117,234,0.05), transparent 55%);
  filter: blur(60px);
}

.login-shell {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 420px;
}

.login-panel {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-xl);
  padding: 24px 20px 20px;
  box-shadow: 0 8px 40px rgba(31,60,110,0.06), 0 1px 0 rgba(255,255,255,0.9) inset;
  border: 1px solid rgba(37, 99, 235, 0.08);
}

.login-header {
  text-align: center;
  margin-bottom: var(--spacing-xl);
}

.login-title-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
}

.login-cloud-wrap {
  position: relative;
  width: 100px;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: cloudFloat 4.8s ease-in-out infinite;
}

.login-cloud-glow {
  position: absolute;
  inset: -8px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(74,140,255,0.18), transparent 66%);
  filter: blur(24px);
}

.login-cloud {
  position: relative;
  width: 76px;
  height: 52px;
}

.login-cloud-part {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(180deg, #f8fbff 0%, #d9e7ff 100%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 6px 14px rgba(31,117,234,0.1);
}

.login-cloud-part-left {
  width: 28px;
  height: 28px;
  left: 6%;
  top: 25%;
}

.login-cloud-part-center {
  width: 37px;
  height: 37px;
  left: 28%;
  top: 8%;
}

.login-cloud-part-right {
  width: 24px;
  height: 24px;
  right: 8%;
  top: 30%;
}

.login-cloud-base {
  position: absolute;
  left: 10%;
  right: 10%;
  bottom: 12%;
  height: 20px;
  border-radius: 999px;
  background: linear-gradient(180deg, #f8fbff 0%, #d9e7ff 100%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 6px 14px rgba(31,117,234,0.1);
}

.login-cloud-eye {
  position: absolute;
  top: 42%;
  width: 10px;
  height: 14px;
  border-radius: 999px;
  background: #3a5ea7;
  z-index: 2;
  overflow: hidden;
  animation: cloudBlink 6.6s ease-in-out infinite;
}

.login-cloud-eye-left {
  left: 26%;
}

.login-cloud-eye-right {
  right: 26%;
}

.login-cloud-eye-dot {
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(255,255,255,0.96);
  top: 2px;
  left: 2px;
}

.login-cloud-smile {
  position: absolute;
  left: 50%;
  bottom: 16%;
  width: 22px;
  height: 10px;
  border-bottom: 2.5px solid #3a5ea7;
  border-radius: 0 0 30px 30px;
  transform: translateX(-50%);
  z-index: 2;
}

.login-cloud-spark {
  position: absolute;
  width: 7px;
  height: 7px;
  background: #ffd86a;
  clip-path: polygon(50% 0%, 62% 38%, 100% 50%, 62% 62%, 50% 100%, 38% 62%, 0% 50%, 38% 38%);
}

.login-cloud-spark-left {
  left: 4%;
  top: 12%;
  animation: sparkle 2s ease-in-out infinite;
}

.login-cloud-spark-right {
  right: 2%;
  top: 8%;
  animation: sparkle 2s ease-in-out infinite 0.6s;
}

.login-title {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: #1a2d42;
  letter-spacing: 2px;
}

.login-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-xs);
  letter-spacing: 0.5px;
}

.wechat-checking {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
}

.wechat-checking-badge {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-full);
  padding: var(--spacing-xs) var(--spacing-lg);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
}

.wechat-checking-title {
  margin-top: var(--spacing-sm);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.invite-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-md);
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
}

.invite-banner-icon {
  color: var(--color-primary);
  font-size: var(--font-size-lg);
  margin-right: var(--spacing-xs);
}

.invite-banner-text {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

.login-field {
  margin-bottom: var(--spacing-md);
}

.login-input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.95);
  border: 1.5px solid rgba(37, 99, 235, 0.12);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  height: var(--input-height);
  transition: all 0.25s ease;
}

.login-input-wrap:focus-within {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.08);
}

.login-input-icon {
  font-size: 18px;
  margin-right: var(--spacing-sm);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  opacity: 0.7;
}

.login-input {
  flex: 1;
  height: 100%;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: transparent;
}

.login-input::placeholder {
  color: var(--color-text-placeholder);
}

.login-input-clear {
  font-size: var(--font-size-lg);
  color: var(--color-text-tertiary);
  padding: var(--spacing-xs);
}

.login-input-eye {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: var(--spacing-xs);
}

.tenant-selected-tag {
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  display: inline-block;
  padding: 2px var(--spacing-sm);
  border-radius: var(--radius-sm);
}

.tenant-results {
  margin-top: var(--spacing-xs);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  max-height: 160px;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.tenant-result-item {
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  border-bottom: 1px solid var(--color-border-light);
}

.tenant-result-item-hover {
  background: var(--color-primary-bg);
}

.tenant-result-empty {
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.login-btn-wrap {
  margin-top: var(--spacing-lg);
}

.login-btn {
  width: 100%;
  height: var(--btn-height-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--color-primary);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  border-radius: var(--radius-md);
  letter-spacing: 2px;
  border: 2px solid var(--color-primary);
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.15);
  transition: all 0.25s ease;
}

.login-btn-hover {
  background: var(--color-primary);
  color: var(--color-text-white);
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.25);
  transform: translateY(-1px);
}

.login-btn-disabled {
  border-color: var(--color-text-disabled);
  color: var(--color-text-disabled);
  box-shadow: none;
}

.login-field-dev {
  margin-top: var(--spacing-sm);
}

.login-field-dev .login-input {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.login-register-section {
  margin-top: var(--spacing-lg);
  text-align: center;
}

.login-register-link {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: var(--spacing-sm) var(--spacing-md);
  min-height: var(--input-height);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  border: 1px solid transparent;
  transition: all 0.2s ease;
}

.login-register-link-hover {
  color: var(--color-primary);
  background: rgba(37, 99, 235, 0.05);
  border-color: rgba(37, 99, 235, 0.1);
}

@keyframes cloudFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@keyframes cloudBlink {
  0%, 44%, 48%, 92%, 96%, 100% { transform: scaleY(1); }
  46%, 94% { transform: scaleY(0.18); }
}

@keyframes sparkle {
  0%, 100% { opacity: 0.3; transform: scale(0.85); }
  50% { opacity: 1; transform: scale(1.05); }
}
