/* ==========================================
   Login - Pencil-sketch garment style (PC-aligned)
   Clean inputs, no labels, pencil-drawn background
   ========================================== */

page {
  background: #edf1f7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(170deg, #e8ecf4 0%, #f2f5fa 40%, #edf1f7 100%);
  position: relative;
  overflow: hidden;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* ----- Pencil texture + garments ----- */

.login-garments {
  position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 0;
}

.garment { position: absolute; }

.garment-dress {
  width: 56px; top: 8%; left: 42%;
  transform: rotate(-18deg); filter: none;
  color: rgba(128, 140, 162, 0.28);
}
.garment-coat {
  width: 72px; top: 22%; left: 8%;
  transform: rotate(14deg); filter: none;
  color: rgba(118, 130, 152, 0.32);
}
.garment-shirt {
  width: 64px; top: 48%; right: 4%;
  transform: rotate(-10deg); filter: none;
  color: rgba(135, 145, 168, 0.30);
}
.garment-tshirt {
  width: 96px; bottom: 28%; left: 2%;
  transform: rotate(5deg); filter: none;
  color: rgba(105, 118, 140, 0.36);
}
.garment-skirt {
  width: 110px; bottom: 6%; left: 38%;
  transform: translateX(-50%) rotate(-3deg); filter: none;
  color: rgba(90, 105, 130, 0.44);
}
.garment-vest {
  width: 54px; top: 10%; right: 12%;
  transform: rotate(-8deg); filter: none;
  color: rgba(125, 138, 160, 0.28);
}
.garment-accessory { filter: none; }
.scissors {
  width: 36px; top: 32%; left: 18%;
  transform: rotate(25deg); color: rgba(140, 150, 170, 0.18);
}

.hanger { filter: none; }
.hanger-1 { width: 88px; top: 4%; left: 24%; transform: rotate(-5deg); color: rgba(148, 158, 175, 0.18); }
.hanger-2 { width: 100px; bottom: 34%; right: 3%; transform: rotate(-10deg); color: rgba(115, 128, 148, 0.24); }
.hanger-3 { width: 78px; top: 30%; right: 26%; transform: rotate(12deg); color: rgba(140, 150, 170, 0.16); }

/* subtle background grid */
.login-subtle-grid {
  position: absolute; inset: -10%;
  background-image:
    linear-gradient(rgba(143, 167, 212, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(143, 167, 212, 0.04) 1px, transparent 1px);
  background-size: 48px 48px;
  -webkit-mask-image: radial-gradient(ellipse at 50% 40%, rgba(0,0,0,0.5), transparent 60%);
}

.login-soft-glow {
  position: absolute;
  width: 500px; height: 500px;
  top: 15%; right: -20%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(31,117,234,0.05), transparent 55%);
  filter: blur(60px);
}

/* ----- Form panel ----- */
.login-shell {
  position: relative; z-index: 1; width: 100%; max-width: 420px;
}

.login-panel {
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 20px;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8px 40px rgba(31,60,110,0.06), 0 1px 0 rgba(255,255,255,0.9) inset;
  border: 1px solid rgba(31,117,234,0.08);
}

/* ----- Header: cloud + title ----- */
.login-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.login-title-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.login-cloud-wrap {
  position: relative;
  width: 100px; height: 72px;
  display: flex; align-items: center; justify-content: center;
  animation: cloudFloat 4.8s ease-in-out infinite;
}

.login-cloud-glow {
  position: absolute;
  inset: -8px; border-radius: 50%;
  background: radial-gradient(circle, rgba(74,140,255,0.18), transparent 66%);
  filter: blur(24px);
}

.login-cloud {
  position: relative;
  width: 76px; height: 52px;
}

.login-cloud-part {
  position: absolute; border-radius: 50%;
  background: linear-gradient(180deg, #f8fbff 0%, #d9e7ff 100%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 6px 14px rgba(31,117,234,0.1);
}
.login-cloud-part-left { width: 28px; height: 28px; left: 6%; top: 25%; }
.login-cloud-part-center { width: 37px; height: 37px; left: 28%; top: 8%; }
.login-cloud-part-right { width: 24px; height: 24px; right: 8%; top: 30%; }
.login-cloud-base {
  position: absolute; left: 10%; right: 10%; bottom: 12%;
  height: 20px; border-radius: 999px;
  background: linear-gradient(180deg, #f8fbff 0%, #d9e7ff 100%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 6px 14px rgba(31,117,234,0.1);
}

.login-cloud-eye {
  position: absolute; top: 42%;
  width: 10px; height: 14px; border-radius: 999px;
  background: #3a5ea7; z-index: 2;
  overflow: hidden;
  animation: cloudBlink 6.6s ease-in-out infinite;
}
.login-cloud-eye-left { left: 26%; }
.login-cloud-eye-right { right: 26%; }
.login-cloud-eye-dot {
  position: absolute;
  width: 4px; height: 4px; border-radius: 50%;
  background: rgba(255,255,255,0.96);
  top: 2px; left: 2px;
}

.login-cloud-smile {
  position: absolute; left: 50%; bottom: 16%;
  width: 22px; height: 10px;
  border-bottom: 2.5px solid #3a5ea7;
  border-radius: 0 0 30px 30px;
  transform: translateX(-50%);
  z-index: 2;
}

.login-cloud-spark {
  position: absolute;
  width: 7px; height: 7px; background: #ffd86a;
  clip-path: polygon(50% 0%, 62% 38%, 100% 50%, 62% 62%, 50% 100%, 38% 62%, 0% 50%, 38% 38%);
}
.login-cloud-spark-left { left: 4%; top: 12%; animation: sparkle 2s ease-in-out infinite; }
.login-cloud-spark-right { right: 2%; top: 8%; animation: sparkle 2s ease-in-out infinite 0.6s; }

.login-title {
  font-size: 38rpx; font-weight: 800; color: #1a2d42;
  letter-spacing: 4rpx;
}

.login-subtitle {
  font-size: 24rpx; color: #5a6a7e; margin-top: 8rpx;
  letter-spacing: 1rpx;
}

/* ----- WeChat checking ----- */
.wechat-checking {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 0;
}
.wechat-checking-badge {
  background: #1f75ea; color: #fff; border-radius: 999px;
  padding: 8rpx 28rpx; font-size: 26rpx; font-weight: 700;
}
.wechat-checking-title { margin-top: 16rpx; font-size: 26rpx; color: #8a96a6; }

/* ----- Invite banner ----- */
.invite-banner {
  display: flex; align-items: center; justify-content: center;
  padding: 16rpx 24rpx; margin-bottom: 24rpx;
  background: rgba(31,117,234,0.06); border-radius: 12rpx;
}
.invite-banner-icon { color: #1f75ea; font-size: 28rpx; margin-right: 8rpx; }
.invite-banner-text { font-size: 26rpx; color: #4a6a9a; }

/* ----- Fields (no labels, clean inputs) ----- */
.login-field { margin-bottom: 24rpx; }

.login-input-wrap {
  display: flex; align-items: center;
  background: rgba(255,255,255,0.9);
  border: 1px solid rgba(180,190,210,0.4);
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 88rpx;
  transition: all 0.2s ease;
}
.login-input-wrap:focus-within {
  border-color: #1f75ea;
  background: #fff;
  box-shadow: 0 0 0 6rpx rgba(31,117,234,0.06);
}

.login-input-icon { font-size: 34rpx; margin-right: 14rpx; color: #a0aab7; flex-shrink: 0; }

.login-input {
  flex: 1; height: 100%;
  font-size: 30rpx; color: #22384a;
  background: transparent;
}
.login-input::placeholder { color: #b0b8c4; }

.login-input-clear { font-size: 28rpx; color: #b0b8c4; padding: 16rpx 12rpx; min-width: 60rpx; text-align: center; }
.login-input-eye { font-size: 24rpx; color: #8a96a6; padding: 16rpx 12rpx; min-width: 60rpx; text-align: center; }

.tenant-selected-tag {
  margin-top: 12rpx; font-size: 24rpx; color: #1f75ea;
  background: rgba(31,117,234,0.06); display: inline-block;
  padding: 6rpx 18rpx; border-radius: 8rpx;
}

/* ----- Tenant dropdown ----- */
.tenant-results {
  margin-top: 8rpx;
  background: #fff; border-radius: 12rpx;
  box-shadow: 0 8px 28px rgba(0,0,0,0.08);
  max-height: 320rpx; overflow-y: auto;
}
.tenant-result-item {
  padding: 22rpx 28rpx; font-size: 28rpx; color: #22384a;
  border-bottom: 1px solid rgba(0,0,0,0.04);
}
.tenant-result-item-hover { background: rgba(31,117,234,0.06); }
.tenant-result-empty { padding: 22rpx 28rpx; font-size: 26rpx; color: #a0aab7; }

/* ----- Button ----- */
.login-btn-wrap { margin-top: 32rpx; }

.login-btn {
  width: 100%; height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  background: #1f75ea; color: #fff;
  font-size: 32rpx; font-weight: 700;
  border-radius: 14rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 10px 24px rgba(31,117,234,0.2);
  transition: all 0.2s ease;
}
.login-btn-hover { background: #1562d6; transform: translateY(-2rpx); box-shadow: 0 14px 30px rgba(31,117,234,0.28); }
.login-btn-disabled { background: #bcc7de; color: rgba(255,255,255,0.7); box-shadow: none; }

/* ----- Dev fields ----- */
.login-field-dev { margin-top: 16rpx; }
.login-field-dev .login-input {
  font-size: 24rpx; color: #8a96a6;
}

/* ----- Register link ----- */
.login-register-section {
  margin-top: 32rpx; text-align: center;
}
.login-register-link {
  font-size: 26rpx; color: #a0aab7;
}
.login-register-link-hover { color: #1f75ea; }

/* ----- Animations ----- */
@keyframes cloudFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}
@keyframes cloudBlink {
  0%, 44%, 48%, 92%, 96%, 100% { transform: scaleY(1); }
  46%, 94% { transform: scaleY(0.18); }
}
@keyframes sparkle {
  0%, 100% { opacity: 0.3; transform: scale(0.85); }
  50% { opacity: 1; transform: scale(1.05); }
}
