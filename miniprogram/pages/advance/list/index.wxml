<view class="page">
  <view class="filter-bar">
    <view class="filter-item">
      <picker mode="selector" range="{{_STATUS_OPTIONS}}" range-key="label" bindchange="onStatusFilterChange">
        <view class="picker-box">
          <text>{{statusFilter ? STATUS_MAP[statusFilter].text : '全部状态'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="filter-item">
      <picker mode="selector" range="{{_REPAY_OPTIONS}}" range-key="label" bindchange="onRepayFilterChange">
        <view class="picker-box">
          <text>{{repayFilter ? DEDUCT_MAP[repayFilter].text : '全部扣款'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="filter-section">
    <view class="search-row">
      <view class="search-box">
        <view class="line-icon line-icon--sm icon-search search-icon"></view>
        <input class="search-input" placeholder="搜索员工姓名" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="onKeywordSearch" />
      </view>
      <view class="search-btn" bindtap="onKeywordSearch" hover-class="search-btn-hover" hover-stay-time="50">搜索</view>
      <view class="clear-btn" wx:if="{{keyword}}" bindtap="onClearSearch" hover-class="clear-btn-hover" hover-stay-time="50">重置</view>
    </view>
  </view>

  <view class="list-section">
    <empty-state wx:if="{{!loading && list.length === 0}}" text="暂无借支记录" />

    <view class="advance-card" wx:for="{{list}}" wx:key="id" data-index="{{index}}" bindtap="onTapItem">
      <view class="card-header">
        <text class="advance-no">{{item.advanceNo || '—'}}</text>
        <text class="tag {{item.statusCls}}">{{item.statusText}}</text>
      </view>
      <view class="card-employee-row">
        <text class="employee-name">{{item.employeeName || '—'}}</text>
        <text class="employee-dot">·</text>
        <text class="factory-name">{{item.factoryName || '—'}}</text>
      </view>
      <view class="card-amount-row">
        <text class="amount-value">¥{{item.amountStr}}</text>
        <text class="tag tag-sm {{item.repayCls}}">{{item.repayText}}</text>
      </view>
      <text class="remaining-text" wx:if="{{item.status === 'approved'}}">剩余 ¥{{item.remainingStr}}</text>
      <view class="card-footer">
        <text class="time-text">{{item.createTime || ''}}</text>
        <text class="approve-hint" wx:if="{{item.status === 'pending'}}">点击审批</text>
      </view>
    </view>

    <view class="load-more {{!hasMore ? 'disabled' : ''}}" wx:if="{{loading || !hasMore}}">
      <text>{{loading ? '加载中...' : '没有更多了'}}</text>
    </view>
  </view>

  <view class="fab-btn" bindtap="onTapCreate">+</view>

  <view class="action-sheet-mask" wx:if="{{showActionSheet}}" bindtap="onCloseActionSheet"></view>
  <view class="action-sheet {{showActionSheet ? 'action-sheet-show' : ''}}">
    <view class="action-sheet-header">
      <text>{{currentAdvance.advanceNo || '操作'}}</text>
    </view>
    <view class="action-sheet-body">
      <view class="action-item action-approve" wx:if="{{canApprove && currentAdvance.status === 'pending'}}" bindtap="onActionApprove">
        <text>审批通过</text>
      </view>
      <view class="action-item action-reject" wx:if="{{canApprove && currentAdvance.status === 'pending'}}" bindtap="onActionReject">
        <text>驳回</text>
      </view>
      <view class="action-item action-cancel" bindtap="onCloseActionSheet">
        <text>取消</text>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showCreateModal}}" bindtap="onCancelCreate"></view>
  <view class="modal {{showCreateModal ? 'modal-show' : ''}}">
    <view class="modal-header">
      <text class="modal-title">申请借支</text>
      <text class="modal-close" bindtap="onCancelCreate">✕</text>
    </view>
    <view class="modal-body">
      <view class="mf-item">
        <text class="mf-label mf-required">员工姓名</text>
        <input class="mf-input" placeholder="请输入员工姓名" value="{{createForm.employeeName}}" data-field="employeeName" bindinput="onCreateFieldInput" />
      </view>
      <view class="mf-item">
        <text class="mf-label mf-required">借支金额</text>
        <input class="mf-input" type="digit" placeholder="请输入金额" value="{{createForm.amount}}" data-field="amount" bindinput="onCreateFieldInput" />
      </view>
      <view class="mf-item">
        <text class="mf-label mf-required">借支事由</text>
        <textarea class="mf-textarea" placeholder="请输入借支事由" value="{{createForm.reason}}" data-field="reason" bindinput="onCreateFieldInput" maxlength="200" />
      </view>
      <view class="mf-item">
        <text class="mf-label">关联订单号</text>
        <input class="mf-input" placeholder="选填" value="{{createForm.orderNo}}" data-field="orderNo" bindinput="onCreateFieldInput" />
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="onCancelCreate">取消</view>
      <view class="modal-btn confirm" bindtap="onSubmitCreate">提交</view>
    </view>
  </view>

</view>
