<view class="page">
  <!-- 吸顶区：搜索栏 + 状态统计标签 -->
  <view class="sticky-top">
    <!-- 搜索栏：输入框 4/5 + 扫码按钮 1/5 -->
    <view class="search-row">
      <view class="search-box {{keyword ? 'has-keyword' : ''}}">
        <view class="line-icon line-icon--sm icon-search search-icon"></view>
        <input
          class="search-input"
          placeholder="搜索款号/款式名"
          value="{{keyword}}"
          bindinput="onSearchInput"
          bindconfirm="_doSearch"
          confirm-type="search"
        />
        <view wx:if="{{keyword}}" class="line-icon line-icon--sm icon-close search-clear" bindtap="onSearchClear"></view>
      </view>
      <view class="scan-btn" bindtap="onScan">
        <view class="line-icon icon-scan scan-icon"></view>
      </view>
    </view>

    <!-- 状态统计标签（自动换行） -->
    <view class="stat-tags">
      <block wx:for="{{statusTabs}}" wx:key="key">
        <view wx:if="{{item.isSmart}}" class="stat-divider"></view>
        <view
          class="stat-tag {{activeFilter === item.key ? 'active' : ''}} stat-tag--{{item.color}}"
          data-key="{{item.key}}"
          bindtap="onFilterTap"
        >
          <view wx:if="{{item.isSmart}}" class="stat-tag__warn"></view>
          <text class="stat-tag__label">{{item.label}}</text>
          <text class="stat-tag__count">{{item.count}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="state-wrap">
    <view class="loading-spinner"></view>
    <text class="state-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{list.length === 0}}" class="state-wrap state-wrap--empty">
    <view class="line-icon line-icon--lg icon-inbox state-icon"></view>
    <text class="state-text">暂无样衣开发记录</text>
  </view>

  <!-- 卡片列表 -->
  <view wx:else class="card-list">
    <view
      class="card"
      wx:for="{{list}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-item="{{item}}"
      bindtap="onCardTap"
    >
      <!-- 封面 + 信息 -->
      <view class="card-top">
        <image
          wx:if="{{item._cover}}"
          class="card-cover"
          src="{{item._cover}}"
          mode="aspectFill"
          data-src="{{item._cover}}"
          catchtap="onPreviewImage"
        />
        <view wx:else class="card-cover-ph">
          <view class="line-icon line-icon--lg icon-shirt card-cover-icon"></view>
        </view>

        <view class="card-info">
          <!-- 款号 + 状态标签 + 交板标签 -->
          <view class="card-title-row">
            <text class="card-style-no">{{item.styleNo || '-'}}</text>
            <view class="card-tags">
              <view class="status-badge" style="background:{{item._statusColor}}">{{item._statusLabel}}</view>
              <view
                wx:if="{{item._deliveryTag}}"
                class="delivery-tag {{item._overdue ? 'overdue' : ''}} {{item._nearDue ? 'near-due' : ''}}"
              >交板 {{item._deliveryTag}}</view>
            </view>
          </view>
          <!-- 款式名 -->
          <text wx:if="{{item.styleName}}" class="card-style-name">{{item.styleName}}</text>
          <!-- 元信息行1：公司 · 跟单 · 品类 · 季节 -->
          <text wx:if="{{item._metaLine1}}" class="card-meta">{{item._metaLine1}}</text>
          <!-- 元信息行2：颜色 · 尺码 -->
          <text wx:if="{{item._metaLine2}}" class="card-meta card-meta--muted">{{item._metaLine2}}</text>
        </view>
      </view>

      <!-- 件数 + 延期/剩余天数 -->
      <view class="card-info-row">
        <text class="card-quantity">{{item.quantity ? item.quantity + '件' : ''}}</text>
        <text wx:if="{{item._daysLeftText}}" class="card-days-left {{item._overdue ? 'overdue' : ''}} {{item._nearDue ? 'near-due' : ''}}">{{item._daysLeftText}}</text>
      </view>

      <!-- 领取人 + 领取时间（订单级，如果有） -->
      <view class="card-receiver-row" wx:if="{{item.receiver || item.receiveTime}}">
        <view class="receiver-item" wx:if="{{item.receiver}}">
          <text class="receiver-label">领取人</text>
          <text class="receiver-value">{{item.receiver}}</text>
        </view>
        <view class="receiver-item" wx:if="{{item.receiveTime}}">
          <text class="receiver-label">领取时间</text>
          <text class="receiver-value">{{item._receiveTimeShort}}</text>
        </view>
      </view>

      <!-- 进度条 -->
      <view class="card-progress">
        <view class="card-progress-track">
          <view
            class="card-progress-fill"
            style="width: {{item._progressPercent || 0}}%; background: {{item._statusColor}};"
          ></view>
        </view>
        <text class="card-progress-percent">{{item._progressPercent || 0}}%</text>
      </view>

      <!-- 展开明细按钮 -->
      <view class="card-expand-btn" data-index="{{index}}" catchtap="onCardToggle">
        <text class="expand-btn-text">{{item.expanded ? '收起明细' : '展开明细（子工序·多码多色）'}}</text>
        <view class="expand-btn-arrow {{item.expanded ? 'expand-btn-arrow--up' : ''}}"></view>
      </view>

      <!-- 展开区：多码多色 + 子工序列表 -->
      <view class="card-expand-area" wx:if="{{item.expanded}}">
        <!-- 多码多色矩阵 -->
        <view wx:if="{{item._matrix.sizes.length > 0}}" class="expand-section">
          <text class="section-title">多码多色</text>
          <scroll-view scroll-x class="matrix-scroll" enhanced show-scrollbar="{{false}}">
            <view class="matrix-table">
              <view class="matrix-row matrix-row--head">
                <text class="matrix-cell matrix-cell--color">颜色</text>
                <text wx:for="{{item._matrix.sizes}}" wx:for-item="sz" wx:key="*this" class="matrix-cell">{{sz}}</text>
                <text class="matrix-cell matrix-cell--total">合计</text>
              </view>
              <view wx:for="{{item._matrix.rows}}" wx:for-item="row" wx:key="color" class="matrix-row">
                <text class="matrix-cell matrix-cell--color">{{row.color}}</text>
                <text wx:for="{{row.quantities}}" wx:for-item="qty" wx:for-index="qi" wx:key="qi" class="matrix-cell">{{qty}}</text>
                <text class="matrix-cell matrix-cell--total">{{row.rowTotal}}</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- 子工序列表（按 processName 分组的扫码记录） -->
        <view class="expand-section">
          <text class="section-title">子工序明细</text>
          <view wx:if="{{item._scanLoading}}" class="state-hint">加载中...</view>
          <view wx:elif="{{item._subProcesses.length === 0}}" class="state-hint">暂无扫码记录</view>
          <view wx:else class="sub-proc-list">
            <view wx:for="{{item._subProcesses}}" wx:for-item="sp" wx:key="processName" class="sub-proc-group">
              <view class="sub-proc-head">
                <text class="sub-proc-name">{{sp.processName}}</text>
                <text class="sub-proc-meta">{{sp.records.length}}条 · {{sp.totalQty}}件</text>
              </view>
              <view wx:for="{{sp.records}}" wx:for-item="rec" wx:key="id" class="sub-proc-rec">
                <view class="rec-row1">
                  <view class="rec-operator-wrap">
                    <view class="rec-dot"></view>
                    <text class="rec-operator">{{rec.operatorName || '-'}}</text>
                  </view>
                  <text class="rec-time">{{rec.scanTimeText}}</text>
                </view>
                <view class="rec-row2">
                  <text wx:if="{{rec.color}}" class="rec-tag rec-tag--color">{{rec.color}}</text>
                  <text wx:if="{{rec.size}}" class="rec-tag rec-tag--size">{{rec.size}}</text>
                  <text class="rec-qty">{{rec.quantity}}件</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="load-more">
      <text>{{loadingMore ? '加载中...' : '加载更多'}}</text>
    </view>
  </view>
</view>
