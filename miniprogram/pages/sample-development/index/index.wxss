@import '/styles/page-utils.wxss';

.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb), 0.06) 0%, transparent 60%),
    var(--color-bg-page);
  padding: 0 var(--page-padding-x) calc(40rpx + env(safe-area-inset-bottom));
}

/* ---- 样衣开发统计条（与 PC 端 PageStatCards hints 一致） ---- */
.stats-bar {
  display: flex;
  gap: var(--spacing-sm);
  margin: 0 0 var(--spacing-md);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-radius: var(--radius-lg);
  border: 1rpx solid transparent;
  background: var(--color-bg-gray);
}
.stat-item.stat-primary {
  background: linear-gradient(135deg, rgba(var(--color-primary-rgb), 0.10), rgba(var(--color-primary-rgb), 0.04));
  border-color: rgba(var(--color-primary-rgb), 0.18);
}
.stat-item.stat-overdue {
  background: rgba(220, 53, 69, 0.06);
  border-color: rgba(220, 53, 69, 0.15);
}
.stat-item.stat-warning {
  background: rgba(212, 107, 8, 0.06);
  border-color: rgba(212, 107, 8, 0.15);
}
.stat-item.stat-success {
  background: rgba(64, 158, 87, 0.06);
  border-color: rgba(64, 158, 87, 0.15);
}
.stat-item.stat-active {
  border-width: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}
.stat-item.stat-zero {
  opacity: 0.45;
}
.stat-val {
  font-size: var(--font-size-xl);
  font-weight: 600;
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
}
.stat-primary .stat-val { color: var(--color-primary); }
.stat-success .stat-val { color: #409e57; }
.stat-overdue .stat-val { color: #dc3545; }
.stat-warning .stat-val { color: #d46b08; }
.stat-lbl {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* ---- 清除筛选条 ---- */
.clear-filter-bar {
  display: flex;
  justify-content: center;
  margin-bottom: var(--spacing-sm);
}
.clear-filter-text {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  padding: 6rpx 24rpx;
  background: var(--color-primary-bg);
  border-radius: var(--radius-full, 999rpx);
}

/* ---- 跨岗位提示条 ---- */
.role-hint-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin: var(--spacing-sm) 0 var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--color-warning-bg);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-warning-border);
}
.role-hint-icon { font-size: var(--font-size-sm); flex-shrink: 0; }
.role-hint-text { font-size: var(--font-size-sm); color: var(--color-warning); line-height: 1.5; }

/* ---- 搜索栏（含扫码按钮） ---- */
.search-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0 var(--spacing-md);
}
.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-sm) var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}
.search-icon { font-size: var(--font-size-base); color: var(--color-text-tertiary); margin-right: var(--spacing-sm); }
.search-input {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}
.search-clear { font-size: var(--font-size-sm); color: var(--color-text-tertiary); padding: 0 var(--spacing-xs); }
.scan-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  padding: 0;
  background: var(--color-primary);
  color: var(--color-text-white);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(var(--color-primary-rgb), 0.25);
}
.scan-btn::after { display: none; }
.scan-btn .scan-icon { font-size: 36rpx; }
.scan-btn-hover { opacity: 0.8; }

/* ---- 统一筛选条 ---- */
.filter-tabs {
  display: flex;
  padding: var(--spacing-sm) 0 var(--spacing-md);
  gap: var(--spacing-sm);
  white-space: nowrap;
}
.filter-tab {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--radius-xl);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 1rpx solid transparent;
}
.filter-tab.active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}
.filter-tab.tab-overdue.active {
  background: #dc3545;
  border-color: #dc3545;
}
.filter-tab.tab-warning.active {
  background: #d46b08;
  border-color: #d46b08;
}
.filter-tab.tab-success.active {
  background: #409e57;
  border-color: #409e57;
}
.filter-count {
  font-size: 20rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  padding: 0 6rpx;
  border-radius: 14rpx;
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}
.filter-tab.active .filter-count {
  background: rgba(255, 255, 255, 0.25);
  color: var(--color-text-white);
}
.filter-count-overdue { background: rgba(220, 53, 69, 0.12); color: #dc3545; }
.filter-count-warning { background: rgba(212, 107, 8, 0.12); color: #d46b08; }

/* ---- 加载态 ---- */
.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-md);
}

/* ---- 任务卡片（精简版：整卡可点击） ---- */
.task-card {
  margin: 0 0 var(--card-gap);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  padding: var(--spacing-md) var(--spacing-lg);
}
.task-card-hover {
  opacity: 0.85;
  transform: scale(0.995);
}

/* ===== 第一行：封面图 + 主信息 ===== */
.card-main-row {
  display: flex;
  gap: var(--spacing-md);
  align-items: flex-start;
}
.card-cover-wrap {
  width: 120rpx;
  height: 150rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
  position: relative;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder-box {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-gray);
}
.cover-placeholder {
  font-size: 44rpx;
}

/* 右侧信息块 */
.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacing-sm);
}
.style-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
  font-variant-numeric: tabular-nums;
}
.style-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-meta-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
  flex-wrap: wrap;
}
.meta-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* 状态标签：与扫码页统一苹果系统色 */
.tag-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
  flex-shrink: 0;
}
.status-tag.tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: var(--font-size-xs);
  line-height: 1.6;
  font-weight: 500;
  white-space: nowrap;
}
.tag-default  { background: rgba(142, 142, 147, 0.12); color: #8e8e93; }
.tag-success  { background: rgba(52, 199, 89, 0.12);  color: #34c759; }
.tag-warning  { background: rgba(255, 149, 0, 0.12); color: #ff9500; }
.tag-error    { background: rgba(255, 59, 48, 0.12);  color: #ff3b30; }
.tag-processing { background: rgba(0, 122, 255, 0.12); color: #007aff; }

/* ===== 第二行：阶段进度条（紧凑 5 点） ===== */
.stage-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border-light);
}
.stage-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
}
.sb-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #e0e0e0;
  border: 2rpx solid #d0d0d0;
  transition: all 0.2s;
}
.sb-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: 1.2;
}
/* 状态颜色 */
.stage-bar-item.completed .sb-dot {
  background: #34c759;
  border-color: #34c759;
}
.stage-bar-item.completed .sb-name {
  color: #34c759;
  font-weight: 500;
}
.stage-bar-item.in_progress .sb-dot {
  background: #007aff;
  border-color: #007aff;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.15);
}
.stage-bar-item.in_progress .sb-name {
  color: #007aff;
  font-weight: 500;
}
.stage-bar-item.not_started .sb-dot {
  background: #f2f2f7;
  border-color: #d1d1d6;
}
.stage-bar-item.not_started .sb-name {
  color: #8e8e93;
}

/* ---- 加载更多 / 已显示全部 ---- */
.load-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-primary);
  font-size: var(--font-size-sm);
}
.no-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-xs);
}
