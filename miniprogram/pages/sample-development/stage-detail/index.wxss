/* ══ ⑦ 工序配置 ══ */
.process-stage-card {
  padding-top: 0;
  border-top: 1px solid var(--color-border-light);
}

.psc-action-bar {
  display: flex;
  justify-content: center;
  padding: 12px 0 0;
  margin-top: 8px;
  border-top: 1px solid var(--color-border-light);
}

.psc-undo-btn {
  font-size: var(--font-size-sm);
  color: var(--color-error);
}

/* ══ ⑧ 二次工艺 ══ */
/* 使用通用 data-card */

/* ══ ⑨ 生产制单 ══ */
.production-header-card {
  display: flex;
  gap: 16px;
  padding: var(--spacing-lg);
}

.ph-cover-wrap {
  width: 100px;
  height: 100px;
  flex-shrink: 0;
  border-radius: var(--radius-button);
  overflow: hidden;
}

.ph-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.ph-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.review-status {
  font-size: var(--font-size-sm);
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-tag);
}

.review-status-success {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.review-status-warning {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.review-status-error {
  background: var(--color-error-bg);
  color: var(--color-error);
}

.size-table-card {
  padding: 0;
  border-radius: var(--radius-card);
  overflow: hidden;
}

/* ══ ⑩ 码数单价 ══ */
/* 使用通用 data-card + size-table-wrap */

/* ══ ⑪ 附件区 ══ */
.attachment-section-label {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--color-border-light);
}

.attachment-upload-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--card-gap);
}

.aub-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.aub-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-primary);
}

.attachment-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--card-gap);
}

.att-icon {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-button);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-gray);
}

.att-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.att-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.att-meta {
  display: flex;
  align-items: center;
  gap: 8px;
}

.att-uploader, .att-time, .att-size {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.att-delete {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-button);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-error-bg);
}

.att-del-icon {
  font-size: var(--font-size-md);
  color: var(--color-error);
}

/* ══ ⑫ 备注日志 ══ */
.remark-section-label {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--color-border-light);
}

.remark-input-bar {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: var(--spacing-lg);
  margin-bottom: var(--card-gap);
}

.rib-role-row {
  display: flex;
  gap: 8px;
}

.rib-role-input {
  flex: 1;
  height: 36px;
  padding: 0 12px;
  border-radius: var(--radius-button);
  border: 1px solid var(--color-border);
  font-size: var(--font-size-sm);
}

.rib-submit-btn {
  padding: 0 20px;
  height: 36px;
  border-radius: var(--radius-button);
  background: var(--color-primary);
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--color-text-white);
  display: flex;
  align-items: center;
  justify-content: center;
}

.rib-submitting {
  opacity: 0.7;
}

.rib-textarea {
  width: 100%;
  height: 80px;
  margin-top: 12px;
  padding: 12px;
  border-radius: var(--radius-button);
  border: 1px solid var(--color-border);
  font-size: var(--font-size-sm);
  resize: none;
  box-sizing: border-box;
}

.remark-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: var(--spacing-lg);
  margin-bottom: var(--card-gap);
}

.rc-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}

.rc-author-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.rc-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-bg);
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-primary);
}

.rc-author-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.rc-author {
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--color-text-primary);
}

.rc-role {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.rc-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.rc-content {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.rc-images {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.rc-img {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-button);
  object-fit: cover;
}

/* ══ ⑬ 底部固定操作栏 ══ */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.08);
}

.bottom-bar-inner {
  display: flex;
  gap: 12px;
}

.bb-btn {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--spacing-lg);
  border-radius: var(--radius-button);
}

.bb-btn-secondary {
  background: transparent;
  border: 1px solid var(--color-border);
}

.bb-btn-primary {
  background: var(--color-primary);
}

.bb-btn-text {
  font-size: var(--font-size-sm);
  font-weight: 500;
}

.bb-btn-secondary .bb-btn-text {
  color: var(--color-text-secondary);
}

.bb-btn-primary .bb-btn-text {
  color: var(--color-text-white);
}
