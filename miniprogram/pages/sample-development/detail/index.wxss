.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.tab-nav {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  color: #666;
  font-size: 24rpx;
}

.tab-item.active {
  color: #2563eb;
  border-bottom: 4rpx solid #2563eb;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 26rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #2563eb;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.loading-inline {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-inline {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.tab-content {
  padding: 20rpx;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-card {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #666;
  font-size: 28rpx;
}

.info-value {
  color: #333;
  font-size: 28rpx;
}

.list-card {
  display: flex;
  flex-direction: column;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.item-main {
  flex: 1;
}

.item-title {
  display: block;
  color: #333;
  font-size: 28rpx;
}

.item-sub {
  display: block;
  color: #999;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.item-right {
  margin-left: 20rpx;
}

.item-qty {
  color: #2563eb;
  font-size: 28rpx;
  font-weight: 500;
}

.item-price {
  color: #52c41a;
  font-size: 28rpx;
  font-weight: 500;
}

.process-list {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.process-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.process-item:last-child {
  border-bottom: none;
}

.process-left {
  flex: 1;
}

.process-name {
  color: #333;
  font-size: 28rpx;
}

.process-code {
  color: #999;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.process-right {
  text-align: right;
}

.process-price {
  color: #52c41a;
  font-size: 32rpx;
  font-weight: 600;
}

.process-unit {
  color: #999;
  font-size: 24rpx;
}

.progress-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.progress-list {
  display: flex;
  flex-direction: column;
}

.progress-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.progress-item::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 50rpx;
  bottom: -20rpx;
  width: 2rpx;
  background: #e8e8e8;
}

.progress-item:last-child::before {
  display: none;
}

.progress-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.progress-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.progress-name {
  color: #333;
  font-size: 28rpx;
}

.progress-status {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.progress-time {
  color: #999;
  font-size: 24rpx;
  margin-left: 20rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.refresh-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #2563eb;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}
