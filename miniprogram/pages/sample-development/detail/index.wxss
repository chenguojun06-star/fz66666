/* =========================================
   样衣开发详情页 · 六段式结构样式
   对齐 order-detail 设计规范 & 统一 Token
   ========================================= */
@import '/styles/page-utils.wxss';

.detail-page {
  min-height: 100vh;
  padding: var(--page-padding-y) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 80rpx);
  background: var(--color-bg-page);
}

/* ============ 通用卡片 ============ */
.top-card, .section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  margin-bottom: var(--card-gap);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

/* ============ ① 顶部信息卡 ============ */
.top-card {
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}
.top-left {
  width: 160rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-icon {
  font-size: 80rpx;
  opacity: 0.3;
}
.top-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.top-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 4rpx;
}
.style-name-label {
  font-size: 30rpx;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}
.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.info-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  min-width: 56rpx;
  flex-shrink: 0;
}
.info-value {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}
.tag-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}

/* ============ ② 数量进度卡（样衣无精确进度数据，已并入基础信息卡） ============ */

/* ============ ③ 操作区 · 空心按钮 ============ */
.action-bar-inline {
  display: flex;
  gap: 12rpx;
  margin-bottom: var(--card-gap);
}
.action-btn-outline {
  flex: 1;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-primary-border);
  border-radius: var(--radius-lg);
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}
.action-btn-outline:active {
  background: var(--color-primary-bg);
}
.action-btn-outline .ab-label {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ============ ③-2 开发阶段快捷操作 ============ */
.stage-quick-card {
  margin-bottom: var(--card-gap);
}
.stage-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.stage-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 18rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  gap: 12rpx;
}
.stage-row.sr-active {
  background: var(--color-primary-bg);
  border: 1rpx solid var(--color-primary-border);
}
.stage-row.sr-done {
  opacity: 0.75;
}
.sr-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 1;
  min-width: 0;
}
.sr-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.sd-done { background: var(--color-success); }
.sd-active { background: var(--color-primary); }
.sd-pending { background: var(--color-text-tertiary); opacity: 0.4; }
.sr-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.sr-name {
  font-size: 26rpx;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  line-height: 1.3;
}
.sr-status {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}
.sr-status.ss-completed { color: var(--color-success); }
.sr-status.ss-in_progress { color: var(--color-primary); }
.sr-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.stage-btn {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: var(--font-weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
}
.sb-primary {
  background: var(--color-primary);
  color: #fff;
}
.sb-primary:active {
  background: var(--color-primary-active, var(--color-primary));
  opacity: 0.85;
}
.sb-danger {
  background: var(--color-bg-card);
  color: var(--color-error);
  border: 1rpx solid var(--color-error-border, rgba(220,53,69,0.3));
}
.sb-danger:active {
  opacity: 0.7;
}
.sr-done-mark {
  color: var(--color-success);
  font-size: 28rpx;
  font-weight: bold;
}

/* ============ ③-3 样衣生产工作流快捷操作 ============ */
.sample-wf-card {
  margin-bottom: var(--card-gap);
}
.sample-wf-actions {
  display: flex;
  gap: 12rpx;
}
.swf-btn {
  flex: 1;
  padding: 18rpx 0;
  font-size: 26rpx;
}

/* ============ 通用 section-card 头部 ============ */
.section-card {
  padding: 24rpx;
}
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.section-count {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* ============ ④ 执行进度区 · 生产工序 ============ */
.process-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.process-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 14rpx 16rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  gap: 12rpx;
}
.process-item.pi-active {
  background: var(--color-info-bg);
}
.process-item.pi-done {
  background: var(--color-bg-light);
}
.process-item.pi-locked {
  opacity: 0.55;
}
.pi-left {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}
.pi-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 10rpx;
}
.stage-done { background: var(--color-success); }
.stage-doing { background: var(--color-primary); }
.stage-pending { background: var(--color-text-tertiary); opacity: 0.5; }

.pi-main {
  flex: 1;
  min-width: 0;
}
.pi-name {
  display: block;
  font-size: 26rpx;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  line-height: 1.3;
}
.pi-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 6rpx;
}
.pi-meta-tag {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  background: var(--color-bg-card);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-sm);
}

.pi-right {
  flex-shrink: 0;
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  max-width: 200rpx;
}
.pi-status {
  font-size: 20rpx;
  font-weight: var(--font-weight-medium);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}
.pi-status.stage-done  { background: var(--color-success-bg); color: var(--color-success); }
.pi-status.stage-doing { background: var(--color-primary-bg); color: var(--color-primary); }
.pi-status.stage-pending { background: rgba(0,0,0,0.04); color: var(--color-text-tertiary); }
.pi-sub {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
  line-height: 1.3;
}

/* ============ ⑤ 明细数据区 · 通用列表样式 ============ */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 16rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  gap: 12rpx;
}
.ir-main {
  flex: 1;
  min-width: 0;
}
.ir-title {
  display: block;
  font-size: 26rpx;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  line-height: 1.3;
}
.ir-sub {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
  line-height: 1.3;
}
.ir-right {
  flex-shrink: 0;
  text-align: right;
  margin-left: 12rpx;
}
.ir-qty {
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.ir-price {
  font-size: 26rpx;
  color: var(--color-success);
  font-weight: var(--font-weight-semibold);
}
.ir-link {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ============ KV 列表（纸样 / 报价单） ============ */
.kv-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: 0 16rpx;
}
.kv-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  gap: 16rpx;
}
.kv-row:last-child { border-bottom: none; }
.kv-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  min-width: 120rpx;
}
.kv-value {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  text-align: right;
  flex: 1;
  line-height: 1.4;
}
.kv-long {
  text-align: left;
  white-space: pre-wrap;
}
.price-danger { color: var(--color-danger); font-size: 28rpx; font-weight: var(--font-weight-semibold); }
.price-success { color: var(--color-success); font-size: 28rpx; font-weight: var(--font-weight-semibold); }

/* ============ 生产制单 · 备注列表 ============ */
.note-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.note-item {
  padding: 16rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
}
.note-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 6rpx;
}
.note-value {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  white-space: pre-wrap;
}

/* ============ Loading & Empty ============ */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--color-bg-gray);
  border-top: 4rpx solid var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
.loading-text {
  margin-top: 16rpx;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
}
.empty-inline {
  padding: 40rpx 0;
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: 24rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
}

/* ============ 折叠提示（未展开时） ============ */
.collapse-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}
.collapse-hint-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ============ 底部间距 ============ */
.bottom-gap { height: 40rpx; }
