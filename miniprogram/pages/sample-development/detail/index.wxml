<!-- 样衣开发详情页 - 对照设计稿 sample-detail.html 重写 -->
<view class="page-root">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:elif="{{styleInfo}}">
    <!-- 1. 款式信息卡片（蓝色渐变） -->
    <view class="info-card">
      <view class="info-card__body">
        <view class="info-card__cover">
          <image wx:if="{{styleInfo._coverUrl}}" src="{{styleInfo._coverUrl}}" mode="aspectFill" class="info-card__img" />
          <view wx:else class="info-card__placeholder">
            <view class="icon-sample" style="width:28px;height:28px;"></view>
          </view>
        </view>
        <view class="info-card__content">
          <text class="info-card__no">{{styleInfo.styleNo || styleInfo.styleCode || '--'}}</text>
          <text class="info-card__name">{{styleInfo.styleName || styleInfo.name || '--'}}</text>
          <text wx:if="{{styleInfo._metaText}}" class="info-card__meta">{{styleInfo._metaText}}</text>
          <view class="info-card__tags">
            <view wx:if="{{styleInfo._statusTag}}" class="tag-status" style="background:{{styleInfo._statusColorVar}};color:var(--color-text-white);">
              {{styleInfo._statusTag}}
            </view>
            <view wx:if="{{patternSnapshot._receiver}}" class="tag-chip">{{patternSnapshot._receiver}}</view>
            <view wx:if="{{styleInfo._colorText}}" class="tag-chip">{{styleInfo._colorText}}</view>
            <view wx:if="{{styleInfo._sizeText}}" class="tag-chip">{{styleInfo._sizeText}}</view>
            <view wx:if="{{styleInfo._quantityText}}" class="tag-chip">{{styleInfo._quantityText}}件</view>
          </view>
        </view>
      </view>
      <!-- 交板日期栏 -->
      <view wx:if="{{styleInfo._deliveryDate}}" class="info-card__delivery">
        <view class="delivery-left">
          <text class="delivery-label">交板日期</text>
          <text class="delivery-date">{{styleInfo._deliveryDate}}</text>
        </view>
        <view wx:if="{{styleInfo._daysLeftText}}" class="delivery-right {{styleInfo._overdue ? 'is-overdue' : ''}}">
          <view class="icon-clock-gray" style="width:14px;height:14px;flex-shrink:0;"></view>
          <text class="delivery-countdown">{{styleInfo._daysLeftText}}</text>
        </view>
      </view>
    </view>

    <!-- 2. 开发进度 -->
    <view class="section-card">
      <!-- 领取按钮（未领取时显示） -->
      <view wx:if="{{patternSnapshot && !patternSnapshot._isReceived && !patternSnapshot._isScrapped && !patternSnapshot._isFullyCompleted}}" class="receive-row">
        <view class="receive-btn" bindtap="onReceivePattern">
          <text class="receive-btn__text">领取样衣</text>
        </view>
      </view>
      <!-- 三列统计 -->
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-value">{{progressPercent}}%</text>
          <text class="stats-label">总进度</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value">{{completedCount}}/{{totalCount}}</text>
          <text class="stats-label">已完成节点</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value stats-value--accent">{{styleInfo._daysLeftText || '--'}}</text>
          <text class="stats-label">距交板</text>
        </view>
      </view>
      <!-- 进度条 -->
      <view class="progress-bar-wrap">
        <view class="progress-bar-track">
          <view class="progress-bar-fill" style="width:{{progressPercent}}%;"></view>
        </view>
      </view>
      <!-- 横向滚动阶段时间线 -->
      <scroll-view scroll-x class="stages-scroll" enhanced show-scrollbar="{{false}}">
        <view class="stages-list">
          <view
            wx:for="{{stages}}"
            wx:key="key"
            class="stage-item {{expandedStageKey === item.key ? 'stage-item--active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onStageTap"
          >
            <view class="stage-circle stage-circle--{{item.status}}">
              <view wx:if="{{item.status === 'completed'}}" class="icon-check-sm" style="width:16px;height:16px;"></view>
              <text wx:else class="stage-num">{{item.index}}</text>
            </view>
            <text class="stage-name">{{item.name}}</text>
            <text class="stage-status stage-status--{{item.status}}">{{item.statusText}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 资料区（筛选条 + 内容合并为一个卡片） -->
    <view class="section-card tab-section-card">

    <!-- 资料标签栏（可滑动） -->
    <scroll-view scroll-x class="data-tabs" enhanced show-scrollbar="{{false}}">
      <view class="data-tabs__inner">
        <view
          wx:for="{{tabs}}"
          wx:key="key"
          class="data-tab {{activeTab === item.key ? 'data-tab--active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onTabChange"
        >{{item.name}}</view>
      </view>
    </scroll-view>

    <!-- 标签内容区 -->
    <view class="tab-content-wrap">

      <!-- BOM 物料 -->
      <view wx:if="{{activeTab === 'bom'}}" class="tab-card">
        <view class="tab-card__header">
          <text class="tab-card__title">BOM 物料</text>
          <text class="tab-card__count">{{bomList.length}}项</text>
        </view>
        <view wx:if="{{bomLoading}}" class="empty-hint"><text class="empty-hint__text">加载中...</text></view>
        <view wx:elif="{{bomList.length > 0}}" class="bom-list">
          <view wx:for="{{bomList}}" wx:key="id" class="bom-item">
            <view class="bom-item__main">
              <text class="bom-item__name">{{item.materialName || item.partName || '-'}}</text>
              <view class="bom-item__meta">
                <text wx:if="{{item.materialTypeText}}" class="bom-item__tag">{{item.materialTypeText}}</text>
                <text wx:if="{{item.color}}" class="bom-item__sub">{{item.color}}</text>
                <text wx:if="{{item.specification}}" class="bom-item__sub">{{item.specification}}</text>
              </view>
            </view>
            <view class="bom-item__right">
              <text wx:if="{{item.usageAmount}}" class="bom-item__qty">{{item.usageAmount}}{{item.unit || ''}}</text>
              <text wx:if="{{item.unitPrice}}" class="bom-item__price">¥{{item.unitPrice}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="empty-hint"><text class="empty-hint__text">暂无 BOM 物料，请在 PC 端配置</text></view>
      </view>

      <!-- 纸样（附件中 bizType=pattern） -->
      <view wx:if="{{activeTab === 'pattern'}}" class="tab-card">
        <view class="tab-card__header">
          <text class="tab-card__title">纸样文件</text>
        </view>
        <view wx:if="{{attachmentLoading}}" class="empty-hint"><text class="empty-hint__text">加载中...</text></view>
        <view wx:elif="{{attachmentList.length > 0}}" class="file-list">
          <block wx:for="{{attachmentList}}" wx:key="id">
            <view wx:if="{{item.bizType === 'pattern' || item.bizType === 'pattern_grading' || item.bizType === 'pattern_final'}}" class="file-item">
              <view class="file-item__icon file-item__icon--pattern"></view>
              <view class="file-item__info">
                <text class="file-item__name">{{item.fileName || '纸样文件'}}</text>
                <text class="file-item__meta">v{{item.version || 1}} · {{item.uploader || ''}} · {{item.createTime || ''}}</text>
              </view>
            </view>
          </block>
        </view>
        <view wx:else class="empty-hint"><text class="empty-hint__text">暂无纸样文件</text></view>
      </view>

      <!-- 尺寸表（横向：部位为行，尺码为列） -->
      <view wx:if="{{activeTab === 'size'}}" class="tab-card">
        <view class="tab-card__header">
          <text class="tab-card__title">尺寸表</text>
          <text class="tab-card__count">{{sizeRows.length}}个部位</text>
        </view>
        <view wx:if="{{sizeLoading}}" class="empty-hint"><text class="empty-hint__text">加载中...</text></view>
        <scroll-view scroll-x wx:elif="{{sizeRows.length > 0}}" class="size-scroll" enhanced show-scrollbar="{{false}}">
          <view class="size-table">
            <!-- 表头：部位 | S | M | L | ... -->
            <view class="size-row size-row--head">
              <text class="size-cell size-cell--part">部位</text>
              <text wx:for="{{sizeColumns}}" wx:key="*this" class="size-cell size-cell--size">{{item}}</text>
            </view>
            <!-- 数据行：胸围 | 90 | 94 | 98 | ... -->
            <view wx:for="{{sizeRows}}" wx:key="partName" class="size-row">
              <text class="size-cell size-cell--part">{{item.partName}}</text>
              <block wx:for="{{sizeColumns}}" wx:for-item="col" wx:key="*this">
                <text class="size-cell size-cell--val">{{item.values[col]}}</text>
              </block>
            </view>
          </view>
        </scroll-view>
        <view wx:else class="empty-hint"><text class="empty-hint__text">暂无尺寸表，请在 PC 端配置</text></view>
      </view>

      <!-- 工序（可点击展开，显示实际扫码进度+记录） -->
      <view wx:if="{{activeTab === 'process'}}" class="tab-card">
        <view class="tab-card__header">
          <text class="tab-card__title">工序进度</text>
          <text class="tab-card__count">{{allProcesses.length}}项</text>
        </view>
        <view wx:if="{{processLoading}}" class="empty-hint"><text class="empty-hint__text">加载中...</text></view>
        <view wx:elif="{{allProcesses.length > 0}}" class="process-list">
          <view
            wx:for="{{allProcesses}}"
            wx:key="_key"
            class="process-item {{index === allProcesses.length - 1 ? 'process-item--last' : ''}} {{item._expanded ? 'process-item--expanded' : ''}} {{item._scanCount > 0 ? 'process-item--clickable' : ''}}"
            data-idx="{{index}}"
            catchtap="onProcessItemTap"
          >
            <view class="process-item__main">
              <view class="process-item__left">
                <view class="process-item__index">{{index + 1}}</view>
                <view class="process-item__info">
                  <text class="process-item__name">{{item._name}}</text>
                  <view class="process-item__meta">
                    <text wx:if="{{item._stage}}" class="process-item__stage">{{item._stage}}</text>
                    <text wx:if="{{item.machineType}}" class="process-item__machine">{{item.machineType}}</text>
                    <text wx:if="{{item.difficulty}}" class="process-item__diff">{{item.difficulty}}</text>
                  </view>
                </view>
              </view>
              <view class="process-item__right">
                <text wx:if="{{item._price}}" class="process-item__price">¥{{item._price}}</text>
                <view class="process-item__status process-item__status--{{item._status}}">
                  <text class="status-dot"></text>
                  <text class="status-text">{{item._statusText}}</text>
                </view>
                <view wx:if="{{item._scanCount > 0}}" class="process-item__arrow {{item._expanded ? 'process-item__arrow--up' : ''}}"></view>
              </view>
            </view>

            <!-- 展开区：扫码记录列表 -->
            <view wx:if="{{item._expanded && item._scanRecords.length > 0}}" class="process-item__expand">
              <view class="scan-summary">
                <text class="scan-summary__label">扫码记录</text>
                <text class="scan-summary__count">{{item._scanCount}}条</text>
                <text wx:if="{{item._completedQty > 0}}" class="scan-summary__done">已完成 {{item._completedQty}}件</text>
                <text wx:if="{{item._receivedQty > 0}}" class="scan-summary__received">已领 {{item._receivedQty}}件</text>
              </view>
              <view class="scan-record-list">
                <view wx:for="{{item._scanRecords}}" wx:for-item="rec" wx:for-index="ri" wx:key="ri" class="scan-record-item">
                  <view class="scan-record-item__top">
                    <text class="scan-record-item__op scan-record-item__op--{{rec._operationClass}}">{{rec._operationText}}</text>
                    <text class="scan-record-item__time">{{rec._displayTime || '-'}}</text>
                  </view>
                  <view class="scan-record-item__body">
                    <text class="scan-record-item__operator">{{rec.operatorName}}</text>
                    <text wx:if="{{rec.color}}" class="scan-record-item__color">· {{rec.color}}</text>
                    <text wx:if="{{rec.size}}" class="scan-record-item__size">· {{rec.size}}</text>
                    <text wx:if="{{rec.quantity > 0}}" class="scan-record-item__qty">· {{rec.quantity}}件</text>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view wx:else class="empty-hint"><text class="empty-hint__text">暂无工序配置，请在 PC 端配置</text></view>
      </view>

      <!-- 二次工艺 -->
      <view wx:if="{{activeTab === 'secondary'}}" class="tab-card">
        <view class="tab-card__header">
          <text class="tab-card__title">二次工艺</text>
          <text class="tab-card__count">{{secondaryList.length}}项</text>
        </view>
        <view wx:if="{{secondaryLoading}}" class="empty-hint"><text class="empty-hint__text">加载中...</text></view>
        <view wx:elif="{{secondaryList.length > 0}}" class="bom-list">
          <view wx:for="{{secondaryList}}" wx:key="id" class="bom-item">
            <view class="bom-item__main">
              <text class="bom-item__name">{{item.processName || '-'}}</text>
              <view class="bom-item__meta">
                <text wx:if="{{item.processTypeText}}" class="bom-item__tag">{{item.processTypeText}}</text>
                <text wx:if="{{item.factoryName}}" class="bom-item__sub">{{item.factoryName}}</text>
                <text wx:if="{{item.statusText}}" class="bom-item__sub">{{item.statusText}}</text>
              </view>
            </view>
            <view class="bom-item__right">
              <text wx:if="{{item.quantity}}" class="bom-item__qty">{{item.quantity}}</text>
              <text wx:if="{{item.unitPrice}}" class="bom-item__price">¥{{item.unitPrice}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="empty-hint"><text class="empty-hint__text">暂无二次工艺</text></view>
      </view>

      <!-- 备注日志（与 PC 端同步：扫码操作/进度更新等动作会自动写入 t_order_remark where targetType=pattern） -->
      <view wx:if="{{activeTab === 'remark'}}" class="tab-card">
        <view class="tab-card__header">
          <text class="tab-card__title">备注日志</text>
          <text class="tab-card__count">{{patternRemarkList.length}}条</text>
        </view>
        <view wx:if="{{patternRemarkLoading}}" class="empty-hint"><text class="empty-hint__text">加载中...</text></view>
        <view wx:elif="{{patternRemarkList.length > 0}}" class="remark-timeline">
          <view wx:for="{{patternRemarkList}}" wx:key="id" class="remark-timeline__item {{index === patternRemarkList.length - 1 ? 'remark-timeline__item--last' : ''}}">
            <view class="remark-timeline__avatar" style="background:{{item._avatarColor}};">
              <text class="remark-timeline__avatar-text">{{item._avatarText}}</text>
            </view>
            <view class="remark-timeline__body">
              <view class="remark-timeline__header">
                <text class="remark-timeline__author">{{item._authorName}}</text>
                <text wx:if="{{item._roleLabel}}" class="remark-timeline__role">{{item._roleLabel}}</text>
                <text class="remark-timeline__time">{{item._timeText}}</text>
              </view>
              <view class="remark-timeline__content">{{item._content}}</view>
            </view>
          </view>
        </view>
        <view wx:else class="empty-hint"><text class="empty-hint__text">暂无备注日志</text></view>
      </view>

      <!-- 附件 -->
      <view wx:if="{{activeTab === 'attachment'}}" class="tab-card">
        <view class="tab-card__header">
          <text class="tab-card__title">附件</text>
          <text class="tab-card__count">{{attachmentList.length}}个</text>
        </view>
        <view wx:if="{{attachmentLoading}}" class="empty-hint"><text class="empty-hint__text">加载中...</text></view>
        <view wx:elif="{{attachmentList.length > 0}}" class="file-list">
          <view wx:for="{{attachmentList}}" wx:key="id" class="file-item">
            <view class="file-item__icon"></view>
            <view class="file-item__info">
              <text class="file-item__name">{{item.fileName || '附件'}}</text>
              <text class="file-item__meta">{{item.bizType || 'general'}} · {{item.uploader || ''}} · {{item.createTime || ''}}</text>
            </view>
          </view>
        </view>
        <view wx:else class="empty-hint"><text class="empty-hint__text">暂无附件</text></view>
      </view>

    </view>
    </view>
    <!-- 资料区结束 -->

    <!-- 3. 附件文件 -->
    <view class="section-card">
      <view class="section-card__header">
        <view class="section-card__title-row">
          <text class="section-card__title">附件文件</text>
          <text class="section-card__count">{{attachmentList.length || 0}} 个</text>
        </view>
        <view class="outline-btn" bindtap="onUploadAttachment">
          <view class="icon-plus-sm" style="width:14px;height:14px;"></view>
          <text class="outline-btn__text">上传</text>
        </view>
      </view>
      <view wx:if="{{attachmentList.length > 0}}" class="attachment-list">
        <view wx:for="{{attachmentList}}" wx:key="id" class="attachment-item {{index === attachmentList.length - 1 ? 'attachment-item--last' : ''}}">
          <view class="attachment-item__icon">
            <view class="icon-paperclip" style="width:18px;height:18px;"></view>
          </view>
          <view class="attachment-item__body">
            <text class="attachment-item__name">{{item.fileName || item.name || '--'}}</text>
            <text wx:if="{{item._metaText}}" class="attachment-item__meta">{{item._metaText}}</text>
          </view>
          <view class="attachment-item__actions">
            <view class="action-btn action-btn--download" data-url="{{item.fileUrl || item.url}}" data-name="{{item.fileName}}" bindtap="onDownloadAttachment">
              <view class="icon-cloud" style="width:16px;height:16px;"></view>
            </view>
            <view class="action-btn action-btn--delete" data-id="{{item.id}}" bindtap="onDeleteAttachment">
              <view class="icon-trash" style="width:16px;height:16px;"></view>
            </view>
          </view>
        </view>
      </view>
      <view wx:elif="{{!attachmentLoading}}" class="empty-hint">
        <text class="empty-hint__text">暂无附件</text>
      </view>
    </view>

    <!-- 4. 款式备注 -->
    <view class="remarks-section">
      <view class="remarks-title-row">
        <text class="remarks-title">款式备注</text>
        <text wx:if="{{styleInfo.styleNo}}" class="remarks-sub">{{styleInfo.styleNo}}</text>
        <text class="remarks-count">{{remarkList.length || 0}} 条</text>
      </view>
      <view class="remark-input-bar">
        <view class="remark-input-top">
          <picker class="remark-role-picker" range="{{remarkRoles}}" range-key="label" value="{{remarkRoleIndex}}" bindchange="onRemarkRoleChange">
            <view class="remark-role-trigger">
              <view class="icon-user" style="width:14px;height:14px;flex-shrink:0;"></view>
              <text class="remark-role-text">{{remarkRoles[remarkRoleIndex].label}}</text>
              <view class="remark-role-chevron"></view>
            </view>
          </picker>
          <view class="outline-btn outline-btn--sm {{(submittingRemark || !remarkInput) ? 'is-disabled' : ''}}" bindtap="onSubmitRemark">
            <text class="outline-btn__text">{{submittingRemark ? '提交中' : '提交'}}</text>
          </view>
        </view>
        <textarea
          class="remark-textarea"
          placeholder="输入备注内容..."
          placeholder-class="remark-placeholder"
          value="{{remarkInput}}"
          bindinput="onRemarkInput"
          maxlength="500"
          auto-height
        />
      </view>
      <view wx:if="{{remarkList.length > 0}}" class="remark-list">
        <view wx:for="{{remarkList}}" wx:key="id" class="remark-card">
          <view class="remark-avatar" style="background:{{item._avatarColor}};">
            <text class="remark-avatar__text">{{item._avatarText}}</text>
          </view>
          <view class="remark-card__body">
            <view class="remark-card__header">
              <text class="remark-card__author">{{item._authorName}}</text>
              <view wx:if="{{item._roleLabel}}" class="remark-card__role">{{item._roleLabel}}</view>
              <text wx:if="{{item._timeText}}" class="remark-card__time">{{item._timeText}}</text>
            </view>
            <text class="remark-card__content">{{item.content}}</text>
          </view>
        </view>
      </view>
      <view wx:elif="{{!remarkLoading}}" class="empty-hint">
        <text class="empty-hint__text">暂无备注</text>
      </view>
    </view>

    <view class="safe-area-bottom"></view>
  </block>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <view class="icon-sample" style="width:48px;height:48px;opacity:0.3;"></view>
    <text class="empty-state__text">未找到样衣信息</text>
  </view>
</view>

<!-- 进度编辑器（与 PC 端 progressEditor 对齐） -->
<view wx:if="{{progressEditor.visible}}" class="progress-editor-mask" bindtap="onProgressCancel">
  <view class="progress-editor" catchtap="">
    <view class="progress-editor__header">
      <text class="progress-editor__title">编辑进度 - {{progressEditor.stageName}}</text>
      <view class="progress-editor__close" bindtap="onProgressCancel">
        <text class="progress-editor__close-text">×</text>
      </view>
    </view>
    <view class="progress-editor__body">
      <view class="progress-editor__value-row">
        <view class="progress-editor__step-btn" data-delta="-10" bindtap="onProgressStep">
          <text class="progress-editor__step-text">-10</text>
        </view>
        <view class="progress-editor__value-display">
          <text class="progress-editor__value-num">{{progressEditor.percent}}</text>
          <text class="progress-editor__value-unit">%</text>
        </view>
        <view class="progress-editor__step-btn" data-delta="10" bindtap="onProgressStep">
          <text class="progress-editor__step-text">+10</text>
        </view>
      </view>
      <slider
        class="progress-editor__slider"
        min="0"
        max="100"
        step="5"
        value="{{progressEditor.percent}}"
        activeColor="var(--color-primary)"
        backgroundColor="var(--color-border)"
        block-color="var(--color-primary)"
        bindchange="onProgressSliderChange"
        bindchanging="onProgressSliderChange"
      />
      <view class="progress-editor__quick-row">
        <view class="progress-editor__quick-btn" data-delta="0" data-absolute="true" bindtap="onProgressStep">
          <text class="progress-editor__quick-text">归零</text>
        </view>
        <view class="progress-editor__quick-btn" data-delta="50" data-absolute="true" bindtap="onProgressStep">
          <text class="progress-editor__quick-text">半成</text>
        </view>
        <view class="progress-editor__quick-btn" data-delta="100" data-absolute="true" bindtap="onProgressStep">
          <text class="progress-editor__quick-text">完成</text>
        </view>
      </view>
    </view>
    <view class="progress-editor__footer">
      <view class="progress-editor__btn progress-editor__btn--cancel" bindtap="onProgressCancel">
        <text class="progress-editor__btn-text">取消</text>
      </view>
      <view class="progress-editor__btn progress-editor__btn--save {{progressSaving ? 'is-disabled' : ''}}" bindtap="onProgressSave">
        <text class="progress-editor__btn-text">{{progressSaving ? '保存中' : '保存'}}</text>
      </view>
    </view>
  </view>
</view>
