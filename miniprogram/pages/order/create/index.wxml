<view class="container">
  <custom-nav title="选择款式下单" show-search="{{false}}" />

  <view class="search-bar">
    <input class="search-inp" value="{{keyword}}" bindinput="onSearchInput" placeholder="搜索款号/款名" confirm-type="search" />
    <text wx:if="{{keyword}}" class="search-clr" bindtap="onSearchClear">✕</text>
  </view>

  <view wx:if="{{loading}}" class="state-wrap"><text>加载中...</text></view>

  <view wx:elif="{{filteredStyles.length === 0}}" class="state-wrap">
    <text>{{keyword ? '未找到匹配' : '暂无已完成入库的样衣'}}</text>
  </view>

  <scroll-view wx:else scroll-y class="grid-scroll">
    <view class="grid">
      <view class="card" wx:for="{{filteredStyles}}" wx:key="id" data-id="{{item.id}}" data-cover="{{item.displayCover}}" data-no="{{item.styleNo}}" data-name="{{item.styleName}}" data-colors="{{item.color}}" data-sizes="{{item.size}}" data-cat="{{item.displayCategory}}" bindtap="onStyleTap">
        <view class="card-img" catchtap="onCoverPreview" data-url="{{item.displayCover}}">
          <image wx:if="{{item.displayCover}}" src="{{item.displayCover}}" mode="aspectFill" lazy-load />
          <text wx:else class="card-img-ph">{{item.styleNo}}</text>
        </view>
        <view class="card-body">
          <text class="card-no">{{item.styleNo || '-'}}</text>
          <text class="card-name">{{item.styleName || '-'}}</text>
          <text wx:if="{{item.displayCategory}}" class="card-tag">{{item.displayCategory}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
