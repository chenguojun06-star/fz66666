page {
  background-color: var(--color-bg-page);
}

.tab-bar {
  display: flex;
  background: var(--color-bg-card);
  padding: 0 4px;
  margin: 0 var(--page-padding-x) 12px;
  border-radius: var(--radius-md);
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  background: var(--color-primary-bg);
}

.tab-content {
  min-height: 100vh;
}

.container {
  padding-top: env(safe-area-inset-top);
  min-height: 100vh;
}

.state-wrap {
  display: flex;
  justify-content: center;
  padding-top: 120px;
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

.grid-scroll {
  height: calc(100vh - env(safe-area-inset-top) - 120px);
  -webkit-overflow-scrolling: touch;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 4px var(--page-padding-x);
  box-sizing: border-box;
}

.card {
  width: calc(50% - 6px);
  margin: 0 12px 12px 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: var(--shadow-sm);
}

.card:nth-child(2n) {
  margin-right: 0;
}

.card-img {
  width: 100%;
  height: 130px;
  background: var(--color-bg-gray);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-img image {
  width: 100%;
  height: 100%;
  display: block;
}

.card-img-ph {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  word-break: break-all;
  padding: 8px;
  text-align: center;
}

.card-body {
  padding: 8px 10px 10px;
  display: flex;
  flex-direction: column;
}

.card-cat {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 1px 7px;
  border-radius: var(--radius-lg);
  display: inline-block;
  margin-bottom: 4px;
  align-self: flex-start;
}

.card-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-oc {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  margin-top: 6px;
}

.card-ld {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: 2px;
}

.no-data-upload-section {
  padding: 40px var(--page-padding-x);
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 60vh;
}

.upload-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40px;
}

.hint-icon {
  font-size: var(--font-size-3xl);
  margin-bottom: 16px;
}

.hint-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 8px;
}

.hint-desc {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  text-align: center;
}

.image-upload-large {
  width: 100%;
  max-width: 400px;
  height: 300px;
  border: 2px dashed var(--color-border);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  background: var(--color-bg-card);
  transition: all 0.3s ease;
}

.image-upload-large:active {
  background: var(--color-bg-gray);
  border-color: var(--color-primary);
}

.image-upload-large image {
  width: 100%;
  height: 100%;
}

.upload-placeholder-large {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  color: var(--color-text-tertiary);
}

.upload-icon-large {
  font-size: var(--font-size-3xl);
  opacity: 0.6;
}

.upload-text {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.upload-hint-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.delete-image-large {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 32px;
  height: 32px;
  background: rgba(250, 81, 81, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-white);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  box-shadow: 0 2px 8px rgba(250, 81, 81, 0.4);
  z-index: 10;
}

.next-btn {
  width: 100%;
  max-width: 400px;
  margin-top: 32px;
}
