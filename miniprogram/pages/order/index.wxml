<view class="container">
  <floating-bell />

  <!-- 搜索栏 -->
  <view class="search-row">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索款号/款名" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="doSearch" />
      <text wx:if="{{keyword}}" class="search-clear" bindtap="clearSearch">✕</text>
    </view>
    <view class="search-btn" hover-class="search-btn-hover" bindtap="doSearch">搜索</view>
  </view>

  <!-- 款式卡片列表 -->
  <view wx:if="{{loading && styles.length === 0}}" class="hint">加载中...</view>

  <!-- 错误提示（API 失败时显示） -->
  <view wx:elif="{{errorMsg}}" class="error-state">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{errorMsg}}</text>
    <view class="retry-btn" hover-class="retry-btn-hover" bindtap="retryLoad">点击重试</view>
  </view>

  <view wx:elif="{{!loading && styles.length === 0}}" class="empty-state">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无款式数据</text>
    <text class="empty-hint">请先在PC端创建款式</text>
    <view class="retry-btn" hover-class="retry-btn-hover" bindtap="retryLoad">刷新试试</view>
  </view>

  <!-- 排行统计 -->
  <view wx:if="{{styles.length > 0 && !keyword}}" class="rank-summary">
    <text class="rank-summary-title">下单排行 TOP{{styles.length}}</text>
    <text class="rank-summary-sub">按下单次数排序 · 数据与PC同步</text>
  </view>

  <view wx:for="{{styles}}" wx:key="id" class="wc-card od-card" hover-class="od-card-hover">
    <!-- 排名徽标（绝对定位） -->
    <view wx:if="{{item.rank && !keyword}}" class="rank-badge rank-{{item.rank <= 3 ? 'top' : 'normal'}}">{{item.rank}}</view>
    <!-- 封面图 -->
    <image wx:if="{{item.cover}}" class="wc-img" src="{{item.cover}}" mode="aspectFill" lazy-load data-index="{{index}}" binderror="onCoverImageError" />
    <view wx:else class="wc-img-placeholder">暂无\n图片</view>
    <!-- 右侧信息 -->
    <view class="wc-content">
      <!-- 款号与下单次数 tag 同行，tag 靠右对齐 -->
      <view class="wc-head">
        <text class="wc-title">{{item.styleNo || '-'}}</text>
        <text class="order-tag {{item.orderCount > 0 ? 'order-tag-has' : 'order-tag-none'}}">
          {{item.orderCount > 0 ? item.orderCount + '次下单' : '未下单'}}
        </text>
      </view>
      <text class="wc-subtitle">{{item.styleName || '-'}}</text>
      <view class="card-meta-row">
        <text class="meta-label">码数</text>
        <text class="meta-value">{{item.size || '-'}}</text>
        <text class="meta-sep">｜</text>
        <text class="meta-label">数量</text>
        <text class="meta-value meta-value-bold">{{item.displayQty}}</text>
      </view>
      <view class="card-meta-row">
        <text class="meta-label">下单</text>
        <text class="meta-value">{{item.latestOrderTimeShort || '-'}}</text>
        <text class="meta-sep">｜</text>
        <text class="meta-label">下单人</text>
        <text class="meta-value">{{item.latestOrderCreator || '-'}}</text>
      </view>
      <view class="wc-actions">
        <view class="wc-action-link" hover-class="od-action-hover" data-index="{{index}}" bindtap="openCreateOrder">下单</view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view wx:if="{{styles.length > 0}}" class="load-more-row">
    <view class="load-more-btn {{loading || !hasMore ? 'btn-disabled' : ''}}" bindtap="loadMore">
      {{loading ? '加载中...' : (hasMore ? '加载更多' : '没有更多了')}}
    </view>
  </view>

  <!-- 下单弹窗 -->
  <mp-modal visible="{{modal.visible}}" title="{{modal.title}}" size="large" bind:close="closeModal">
    <view class="mf-body" slot="body">
      <!-- 基础信息 -->
      <view class="mf-section">
        <text class="mf-section-title">基础信息</text>

        <!-- 订单号：标签+输入框 同行 -->
        <view class="mf-field">
          <text class="mf-field-label">订单号 <text class="mf-required">*</text></text>
          <view class="mf-field-ctrl mf-row-input">
            <input class="mf-input mf-flex-1" placeholder="自动生成" value="{{form.orderNo}}" data-field="orderNo" bindinput="onFormInput" />
            <view class="mf-mini-btn" hover-class="mf-mini-btn-hover" bindtap="generateOrderNo">生成</view>
          </view>
        </view>

        <!-- 加工厂：标签+选择器 同行 -->
        <view class="mf-field">
          <text class="mf-field-label">加工厂 <text class="mf-required">*</text></text>
          <view class="mf-field-ctrl">
            <picker mode="selector" range="{{factoryNames}}" value="{{form.factoryIndex}}" data-field="factoryIndex" bindchange="onFactoryChange">
              <view class="mf-picker">{{form.factoryIndex >= 0 ? factoryNames[form.factoryIndex] : '请选择加工厂'}}<text class="mf-picker-arrow">▾</text></view>
            </picker>
          </view>
        </view>

        <!-- 普通/急单 + 单型：去掉急单标题，同行排列 -->
        <view class="mf-urgency-row">
          <view class="mf-toggle-row">
            <view class="mf-toggle {{form.urgencyLevel === 'normal' ? 'active' : ''}}" data-val="normal" bindtap="setUrgency">普通</view>
            <view class="mf-toggle danger {{form.urgencyLevel === 'urgent' ? 'active' : ''}}" data-val="urgent" bindtap="setUrgency">急单</view>
          </view>
          <text class="mf-urgency-sep">单型</text>
          <view style="flex:1;min-width:0;">
            <picker mode="selector" range="{{plateTypes}}" range-key="label" value="{{form.plateTypeIndex}}" data-field="plateTypeIndex" bindchange="onPlateTypeChange">
              <view class="mf-picker">{{form.plateTypeIndex >= 0 ? plateTypes[form.plateTypeIndex].label : '选择单型'}}<text class="mf-picker-arrow">▾</text></view>
            </picker>
          </view>
        </view>

        <!-- 计划日期：标签+日期选择器 同行 -->
        <view class="mf-field">
          <text class="mf-field-label">计划日期</text>
          <view class="mf-field-ctrl mf-date-row">
            <picker mode="date" value="{{form.plannedStartDate}}" bindchange="onStartDateChange" class="mf-date-picker">
              <view class="mf-picker">{{form.plannedStartDate || '开始'}}<text class="mf-picker-arrow">▾</text></view>
            </picker>
            <text class="mf-date-sep">→</text>
            <picker mode="date" value="{{form.plannedEndDate}}" bindchange="onEndDateChange" class="mf-date-picker">
              <view class="mf-picker">{{form.plannedEndDate || '结束'}}<text class="mf-picker-arrow">▾</text></view>
            </picker>
          </view>
        </view>
      </view>

      <!-- 订单明细 -->
      <view class="mf-section">
        <view class="mf-section-head">
          <text class="mf-section-title">订单明细</text>
          <view style="display:flex;align-items:center;gap:6rpx;">
            <view class="mf-add-btn mf-import-btn" hover-class="mf-add-btn-hover" bindtap="importFiveSizes">导入5码</view>
            <view class="mf-add-btn" hover-class="mf-add-btn-hover" bindtap="addOrderLine">+ 添加</view>
          </view>
        </view>
        <view wx:if="{{form.orderLines.length === 0}}" class="mf-empty">请添加颜色/码数/数量</view>
        <!-- 表头标签 -->
        <view wx:if="{{form.orderLines.length > 0}}" class="mf-line-header">
          <text class="mf-line-label col-color">颜色</text>
          <text class="mf-line-label col-size">码数</text>
          <text class="mf-line-label col-qty">数量</text>
          <view class="mf-del-placeholder"></view>
        </view>
        <view wx:for="{{form.orderLines}}" wx:key="key" class="mf-line">
          <input class="mf-line-input col-color" placeholder="如:红" value="{{item.color}}" data-idx="{{index}}" data-field="color" bindinput="onLineInput" />
          <input class="mf-line-input col-size" placeholder="如:XL" value="{{item.size}}" data-idx="{{index}}" data-field="size" bindinput="onLineInput" />
          <input class="mf-line-input col-qty" type="number" placeholder="件数" value="{{item.quantity}}" data-idx="{{index}}" data-field="quantity" bindinput="onLineInput" />
          <view class="mf-del" data-idx="{{index}}" bindtap="removeOrderLine">✕</view>
        </view>
        <view wx:if="{{form.orderLines.length > 0}}" class="mf-total">
          <text class="mf-total-label">合计</text>
          <text class="mf-total-value">{{form.totalQuantity}} 件</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="mf-actions" slot="actions">
      <view class="mf-btn cancel" hover-class="mf-btn-hover" bindtap="closeModal">取消</view>
      <view class="mf-btn ok {{submitting ? 'disabled' : ''}}" hover-class="mf-btn-hover" bindtap="submitOrder">{{submitting ? '提交中...' : '确认下单'}}</view>
    </view>
  </mp-modal>
</view>
