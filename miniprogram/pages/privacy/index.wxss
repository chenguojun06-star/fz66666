.page {
  padding: 16px;
  background: var(--color-bg-page);
}

.section {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 16px;
  margin-bottom: 12px;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 6px;
}

.update-date {
  font-size: 12px;
  color: var(--color-text-disabled);
}

.heading {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8px;
}

.sub-heading {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-top: 10px;
  margin-bottom: 4px;
}

.body {
  font-size: 14px;
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

.footer {
  text-align: center;
  font-size: 12px;
  color: var(--color-text-disabled);
  padding: 16px 0 24px;
}
