.page {
  padding: 32rpx;
  background: var(--color-bg-page);
}

.section {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.update-date {
  font-size: 24rpx;
  color: var(--color-text-disabled);
}

.heading {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.sub-heading {
  font-size: 27rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-top: 20rpx;
  margin-bottom: 8rpx;
}

.body {
  font-size: 27rpx;
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

.footer {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-disabled);
  padding: 32rpx 0 48rpx;
}
