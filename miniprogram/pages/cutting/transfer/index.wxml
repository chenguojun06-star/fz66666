<view class="page-wrap">

  <view class="page-header">
    <text class="page-title">转单 · {{orderNo}}</text>
    <text class="page-sub">将订单转给其他工厂或人员</text>
  </view>

  <!-- 转单模式选择 -->
  <view class="mode-bar">
    <view
      wx:for="{{transferModes}}"
      wx:key="id"
      class="mode-item {{transferMode === item.id ? 'mode-item--active' : ''}}"
      bindtap="onTransferModeChange"
      data-mode="{{item.id}}"
    >{{item.name}}</view>
  </view>

  <!-- 整单转提示 -->
  <view class="whole-hint" wx:if="{{transferMode === 'whole'}}">
    <text class="whole-hint-text">整单转：将整个订单转给目标，所有菲号和工序一并转移</text>
  </view>

  <!-- 菲号裁片转：选择菲号 -->
  <view class="section-card" wx:if="{{transferMode === 'bundle'}}">
    <view class="section-hd">
      <text class="section-title">选择菲号</text>
      <view class="select-all-btn" bindtap="onToggleAllBundles">
        <view class="check-box {{allSelected ? 'check-box--checked' : ''}}"></view>
        <text class="select-all-text">全选</text>
      </view>
    </view>

    <view wx:if="{{bundlesLoading}}" class="loading-tip">加载中…</view>
    <view wx:elif="{{bundles.length === 0}}" class="empty-tip">暂无菲号数据，请先生成菲号</view>
    <view wx:else class="bundle-list">
      <view
        wx:for="{{bundles}}"
        wx:key="id"
        class="bundle-item {{selectedBundles[item.id] ? 'bundle-item--selected' : ''}} {{item._disabled ? 'bundle-item--disabled' : ''}}"
        bindtap="{{item._disabled ? '' : 'onToggleBundle'}}"
        data-id="{{item.id}}"
      >
        <view class="check-box {{selectedBundles[item.id] ? 'check-box--checked' : ''}} {{item._disabled ? 'check-box--disabled' : ''}}"></view>
        <view class="bundle-info">
          <text class="bundle-no">{{item.bundleNo || item.qrCode || '-'}}</text>
          <text class="bundle-meta">{{item.color || '-'}} / {{item.size || '-'}} · {{item.quantity || 0}}件</text>
          <text class="bundle-status-tag" wx:if="{{item._disabled}}">{{item._statusCn}}</text>
        </view>
      </view>
    </view>
    <view class="bundle-summary" wx:if="{{bundles.length > 0}}">
      <text class="bundle-summary-text">共 {{bundles.length}} 个菲号，已选 {{selectedBundleCount}} 个</text>
    </view>
  </view>

  <!-- Tab：转工厂 / 转人员 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'factory' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="factory">转工厂</view>
    <view class="tab-item {{activeTab === 'user' ? 'tab-item--active' : ''}}" bindtap="onTabChange" data-tab="user">转人员</view>
  </view>

  <!-- 工厂面板 -->
  <view class="section-card" wx:if="{{activeTab === 'factory'}}">
    <view class="search-row">
      <view class="search-bar-row">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索工厂名称或编码" value="{{factoryKeyword}}" bindinput="onFactoryKeywordInput" />
      </view>
    </view>

    <!-- 已选工厂 -->
    <view class="selected-target" wx:if="{{selectedFactory}}">
      <text class="selected-target-label">已选：</text>
      <text class="selected-target-name">{{selectedFactory.factoryName || selectedFactory.name}}</text>
      <text class="selected-target-meta" wx:if="{{selectedFactory.contactPerson}}">联系人：{{selectedFactory.contactPerson}} {{selectedFactory.contactPhone || ''}}</text>
    </view>

    <view wx:if="{{factoriesLoading && factories.length === 0}}" class="loading-tip">搜索中…</view>
    <view wx:elif="{{factories.length === 0}}" class="empty-tip">未找到工厂</view>
    <view wx:else class="target-list">
      <view
        wx:for="{{factories}}"
        wx:key="id"
        class="target-item {{selectedFactory && selectedFactory.id === item.id ? 'target-item--selected' : ''}}"
        bindtap="onSelectFactory"
        data-factory="{{item}}"
      >
        <view class="target-radio {{selectedFactory && selectedFactory.id === item.id ? 'target-radio--active' : ''}}"></view>
        <view class="target-info">
          <text class="target-name">{{item.factoryName || item.name || item.id}}</text>
          <view class="target-meta-row">
            <text class="target-meta" wx:if="{{item.factoryCode}}">{{item.factoryCode}}</text>
            <text class="target-meta" wx:if="{{item.contactPhone}}">{{item.contactPhone}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="load-more" wx:if="{{factoryHasMore}}" bindtap="onLoadMoreFactories">
      <text class="load-more-text">{{factoriesLoading ? '加载中…' : '加载更多'}}</text>
    </view>
  </view>

  <!-- 人员面板 -->
  <view class="section-card" wx:if="{{activeTab === 'user'}}">
    <view class="search-row">
      <view class="search-bar-row">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索人员姓名" value="{{userKeyword}}" bindinput="onUserKeywordInput" />
      </view>
    </view>

    <!-- 已选人员 -->
    <view class="selected-target" wx:if="{{selectedUser}}">
      <text class="selected-target-label">已选：</text>
      <text class="selected-target-name">{{selectedUser.name || selectedUser.username}}</text>
    </view>

    <view wx:if="{{usersLoading && users.length === 0}}" class="loading-tip">搜索中…</view>
    <view wx:elif="{{users.length === 0}}" class="empty-tip">请输入姓名搜索</view>
    <view wx:else class="target-list">
      <view
        wx:for="{{users}}"
        wx:key="id"
        class="target-item {{selectedUser && selectedUser.id === item.id ? 'target-item--selected' : ''}}"
        bindtap="onSelectUser"
        data-user="{{item}}"
      >
        <view class="target-radio {{selectedUser && selectedUser.id === item.id ? 'target-radio--active' : ''}}"></view>
        <view class="target-info">
          <text class="target-name">{{item.name || item.username || item.id}}</text>
          <text class="target-meta" wx:if="{{item.username}}">账号：{{item.username}}</text>
        </view>
      </view>
    </view>
    <view class="load-more" wx:if="{{userHasMore}}" bindtap="onLoadMoreUsers">
      <text class="load-more-text">{{usersLoading ? '加载中…' : '加载更多'}}</text>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section-card">
    <view class="section-title">备注（可选）</view>
    <textarea class="remark-input" placeholder="请输入备注信息…" value="{{remark}}" bindinput="onRemarkInput" maxlength="200" />
  </view>

  <!-- 底部提交 -->
  <view class="submit-bar">
    <view class="submit-info">
      <text wx:if="{{transferMode === 'whole'}}">整单转</text>
      <text wx:else>已选 <text class="submit-count">{{selectedBundleCount || 0}}</text> 个菲号</text>
    </view>
    <view class="submit-btn {{submitting ? 'submit-btn--disabled' : ''}}" bindtap="onSubmit">
      {{submitting ? '提交中…' : '确认转单'}}
    </view>
  </view>

</view>
