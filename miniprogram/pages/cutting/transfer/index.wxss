@import '/styles/modal-form.wxss';
@import '/styles/page-utils.wxss';

.page-wrap {
  padding: 24rpx 24rpx 200rpx;
  background: var(--color-bg-page, #f5f5f5);
  min-height: 100vh;
}

.page-header {
  padding: 12rpx 4rpx 20rpx;
}
.page-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
}
.page-sub {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 6rpx;
  display: block;
}

.mode-bar {
  display: flex;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl);
  padding: 8rpx;
  margin-bottom: 20rpx;
  gap: 8rpx;
  box-shadow: var(--shadow-sm);
}
.mode-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.mode-item--active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

.whole-hint {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}
.whole-hint-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.section-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
  display: block;
}
.section-hd .section-title {
  margin-bottom: 0;
}

.select-all-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.select-all-text {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  border: 2rpx solid var(--color-border-light, #ddd);
  background: #fff;
  flex-shrink: 0;
}
.check-box--checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
  position: relative;
}
.check-box--checked::after {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 10rpx;
  width: 12rpx;
  height: 20rpx;
  border: 3rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
}

.bundle-list {
  max-height: 600rpx;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.bundle-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-light, #eee);
  background: #fafafa;
}
.bundle-item--selected {
  background: rgba(var(--color-primary-rgb), 0.06);
  border-color: var(--color-primary);
}
.bundle-item--disabled {
  opacity: 0.5;
  background: #f5f5f5;
}
.check-box--disabled {
  background: #ddd;
  border-color: #ccc;
}
.bundle-status-tag {
  font-size: var(--font-size-xs);
  color: #ff4d4f;
  background: #fff1f0;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  display: inline-block;
  margin-top: 4rpx;
}
.bundle-info {
  flex: 1;
  min-width: 0;
}
.bundle-no {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
}
.bundle-meta {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  display: block;
}
.bundle-summary {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-light, #eee);
  margin-top: 12rpx;
}
.bundle-summary-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.tab-bar {
  display: flex;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl);
  padding: 8rpx;
  margin-bottom: 20rpx;
  gap: 8rpx;
  box-shadow: var(--shadow-sm);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: var(--radius-md);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.tab-item--active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

.search-row {
  margin-bottom: 20rpx;
}
.search-bar-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--color-bg-card, #fff);
  border-radius: 20rpx;
  border: 2rpx solid var(--color-border, #ddd);
  padding: 0 20rpx;
  height: 96rpx;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  height: 96rpx;
  font-size: var(--font-size-lg);
  color: var(--color-text-primary);
  background: transparent;
}

.selected-target {
  background: rgba(var(--color-primary-rgb), 0.06);
  border-radius: var(--radius-md);
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--color-primary);
}
.selected-target-label {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  margin-right: 8rpx;
}
.selected-target-name {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
}
.selected-target-meta {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
}

.target-list {
  max-height: 600rpx;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.target-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 16rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-light, #eee);
  background: #fafafa;
}
.target-item--selected {
  background: rgba(var(--color-primary-rgb), 0.06);
  border-color: var(--color-primary);
}
.target-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border-light, #ddd);
  flex-shrink: 0;
}
.target-radio--active {
  border-color: var(--color-primary);
  background: var(--color-primary);
  position: relative;
}
.target-radio--active::after {
  content: '';
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fff;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.target-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.target-name {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.target-meta-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 4rpx;
}
.target-meta {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.load-more {
  text-align: center;
  padding: 20rpx 0 8rpx;
}
.load-more-text {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}

.remark-input {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-light, #f5f5f5);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  box-sizing: border-box;
  margin-top: 12rpx;
}

.loading-tip,
.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card, #fff);
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.08);
}
.submit-info {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.submit-count {
  color: var(--color-primary);
  font-weight: 700;
}
.submit-btn {
  padding: 18rpx 60rpx;
  border-radius: var(--radius-xl);
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-size-sm);
  font-weight: 600;
}
.submit-btn--disabled {
  background: #ccc;
}
