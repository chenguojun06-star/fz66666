@import '/styles/page-utils.wxss';

.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb, 37,99,235), 0.06) 0%, transparent 60%),
    linear-gradient(180deg, rgba(var(--color-primary-rgb, 37,99,235), 0.03) 0%, var(--color-bg-page, #f5f7fa) 30%);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-secondary, #64748b);
  font-size: 28rpx;
}

/* ---- 信息卡片 ---- */
.info-card {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.info-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1e293b);
  margin-bottom: 16rpx;
}
.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 0;
}
.grid-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 4rpx 0;
}
.grid-label {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748b);
}
.grid-value {
  font-size: 26rpx;
  color: var(--color-text-primary, #1e293b);
}
.grid-value.bold {
  font-weight: 600;
}

/* ---- Section 卡片 ---- */
.section-card {
  margin: 16rpx 32rpx;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1e293b);
  margin-bottom: 20rpx;
}

/* ---- 公共输入 ---- */
.common-inputs {
  margin-bottom: 24rpx;
}
.input-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid var(--color-border-light, #f1f5f9);
}
.input-label {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary, #64748b);
}
.input-field {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary, #1e293b);
  padding: 8rpx 0;
}
.input-suffix {
  font-size: 24rpx;
  color: var(--color-text-tertiary, #94a3b8);
  margin-left: 8rpx;
}

/* ---- 裁剪明细表 ---- */
.cutting-table {
  border-top: 2px solid var(--color-border, #e5e7eb);
  padding-top: 12rpx;
}
.table-header {
  display: flex;
  align-items: center;
  padding: 10rpx 0 14rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748b);
  font-weight: 500;
}
.th { text-align: center; }
.th-color { width: 110rpx; text-align: left; }
.th-size  { width: 80rpx; }
.th-order { width: 80rpx; }
.th-cut   { width: 80rpx; }
.th-bundles { width: 80rpx; }
.th-last  { flex: 1; }

.table-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1px solid var(--color-border-light, #f1f5f9);
}
.td {
  font-size: 26rpx;
  color: var(--color-text-primary, #1e293b);
  text-align: center;
}
.td-color { width: 110rpx; text-align: left; font-size: 24rpx; color: var(--color-text-secondary, #64748b); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.td-size  { width: 80rpx; }
.td-order { width: 80rpx; }
.td-cut   { width: 80rpx; font-weight: 600; color: var(--color-primary, #2563eb); }
.td-cut.highlight { color: var(--color-primary, #2563eb); }
.td-bundles { width: 80rpx; }
.td-last  { flex: 1; display: flex; justify-content: center; }

.td-last-input {
  width: 100rpx;
  text-align: center;
  border: 1px solid var(--color-border, #e5e7eb);
  border-radius: var(--radius-md, 12rpx);
  padding: 8rpx 4rpx;
  font-size: 26rpx;
  color: var(--color-text-primary, #1e293b);
  background: var(--color-bg-page, #f5f7fa);
}

/* ---- 分扎描述 ---- */
.bundle-desc-area {
  margin-top: 16rpx;
  padding: 12rpx 0;
}
.bundle-desc-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}
.bundle-desc-label {
  width: 180rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748b);
}
.bundle-desc-value {
  flex: 1;
  font-size: 22rpx;
  color: var(--color-text-primary, #1e293b);
}

/* ---- 空数据提示 ---- */
.empty-hint-box {
  padding: 60rpx 0;
  text-align: center;
}
.empty-hint-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary, #94a3b8);
}

/* ---- 汇总 ---- */
.summary-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0 8rpx;
  border-top: 2px solid var(--color-border, #e5e7eb);
  margin-top: 12rpx;
}
.summary-item {
  text-align: center;
}
.summary-label {
  font-size: 22rpx;
  color: var(--color-text-secondary, #64748b);
  display: block;
}
.summary-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1e293b);
}
.summary-value.green {
  color: var(--color-success, #16a34a);
}
.summary-value.orange {
  color: #f97316;
}
.summary-value.purple {
  color: #8b5cf6;
}

/* ---- 底部按钮 ---- */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card, #fff);
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}
.submit-btn {
  text-align: center;
  padding: 24rpx 0;
  background: var(--color-primary, #2563eb);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-xl, 24rpx);
}
.submit-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}
