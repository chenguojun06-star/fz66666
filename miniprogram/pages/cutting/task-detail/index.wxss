@import '/styles/page-utils.wxss';

.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb), 0.06) 0%, transparent 60%),
    linear-gradient(180deg, rgba(var(--color-primary-rgb), 0.03) 0%, var(--color-bg-page) 30%);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.info-card {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
}
.info-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}
.info-card-body {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}
.cover-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-gray);
}
.placeholder-icon {
  font-size: 48rpx;
}
.info-grid {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 0;
}
.grid-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 4rpx 0;
}
.grid-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
.grid-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
}
.grid-value.bold {
  font-weight: 600;
}

.section-card {
  margin: 16rpx 32rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.common-inputs {
  margin-bottom: 24rpx;
}
.input-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid var(--color-border-light);
}
.input-label {
  width: 160rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
.input-field {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  padding: 8rpx 0;
}
.input-suffix {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-left: 8rpx;
}

.cutting-table {
  border-top: 1px solid var(--color-border);
  padding-top: 12rpx;
}
.table-header {
  display: flex;
  align-items: center;
  padding: 10rpx 0 14rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}
.th { text-align: center; }
.th-color { width: 110rpx; text-align: left; }
.th-size  { width: 80rpx; }
.th-order { width: 80rpx; }
.th-cut   { width: 80rpx; }
.th-bundles { width: 80rpx; }
.th-last  { flex: 1; }

.table-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1px solid var(--color-border-light);
}
.td {
  font-size: 26rpx;
  color: var(--color-text-primary);
  text-align: center;
}
.td-color { width: 110rpx; text-align: left; font-size: 24rpx; color: var(--color-text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.td-size  { width: 80rpx; }
.td-order { width: 80rpx; }
.td-cut   { width: 80rpx; font-weight: 600; color: var(--color-primary); }
.td-cut.highlight { color: var(--color-primary); }
.td-bundles { width: 80rpx; }
.td-last  { flex: 1; display: flex; justify-content: center; }

.td-last-input {
  width: 100rpx;
  text-align: center;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 8rpx 4rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-page);
}

.bundle-desc-area {
  margin-top: 16rpx;
  padding: 12rpx 0;
}
.bundle-desc-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}
.bundle-desc-label {
  width: 180rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
.bundle-desc-value {
  flex: 1;
  font-size: 22rpx;
  color: var(--color-text-primary);
}

.empty-hint-box {
  padding: 60rpx 0;
  text-align: center;
}
.empty-hint-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

.summary-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0 8rpx;
  border-top: 1px solid var(--color-border);
  margin-top: 12rpx;
}
.summary-item {
  text-align: center;
}
.summary-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
}
.summary-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}
.summary-value.green {
  color: var(--color-success);
}
.summary-value.orange {
  color: var(--color-warning);
}
.summary-value.purple {
  color: var(--color-purple);
}
