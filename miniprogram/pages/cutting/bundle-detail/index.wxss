/* =========================================
   裁剪详情页 · 统一设计 Token
   ========================================= */
@import '/styles/page-utils.wxss';

.detail-page {
  min-height: 100vh;
  padding: var(--spacing-sm) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 60px);
  background: var(--color-bg-page);
}

/* =========================================
   通用卡片（与 order-detail 对齐）
   ========================================= */
.top-card,
.section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.section-card {
  padding: var(--spacing-lg);
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-hd--compact {
  margin-bottom: var(--spacing-xs);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.section-count,
.section-sub {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

/* =========================================
   ① 顶部信息卡（左封面图 + 右双行信息）
   ========================================= */
.top-card {
  padding: var(--spacing-lg);
  display: flex;
  gap: var(--spacing-lg);
  align-items: flex-start;
}

/* ════════════ 裁剪任务领取条 ════════════ */
.task-receive-bar {
  margin: 0 var(--spacing-lg) var(--spacing-sm);
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-warning-bg);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-sm);
}

.task-receive-bar .receive-hint {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

.task-receive-bar .receive-hint--mine {
  color: var(--color-success);
}

.task-receive-bar .receive-hint--other {
  color: var(--color-text-secondary);
}

.task-receive-bar .receive-btn {
  flex-shrink: 0;
  padding: var(--spacing-xs) var(--spacing-lg);
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  font-size: var(--font-size-md);
  border-radius: var(--radius-sm);
  line-height: 1.4;
  font-weight: var(--font-weight-medium);
}

.top-left {
  width: 80px;
  height: 100px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-2xl);
  color: var(--color-text-tertiary);
}

.top-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.top-title {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  flex-wrap: wrap;
}

.order-no {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

/* 状态标签：统一类名前缀 status-tag + tag + tag-xxx */
.status-tag {
  display: inline-block;
}

.status-tag.tag {
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.status-tag.tag-warning {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-tag.tag-success {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.status-tag.tag-danger {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.status-tag.tag-processing {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

/* info-row：双行信息（label + value） */
.info-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
}

.info-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  min-width: 28px;
}

.info-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.info-value.highlight {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* =========================================
   订单选择列表（首页入口）
   ========================================= */
.order-list-wrap {
  padding: 0;
}

.order-list-loading,
.order-list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 0;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  gap: var(--spacing-sm);
}

.order-sel-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-lg);
  padding: var(--spacing-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.sel-cover-box {
  width: 60px;
  height: 80px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}

.sel-cover-img {
  width: 100%;
  height: 100%;
}

.sel-cover-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-2xl);
  color: var(--color-text-tertiary);
}

.sel-card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.info-top {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
  margin-bottom: 2px;
}

/* =========================================
   加载态
   ========================================= */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 150px;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

/* =========================================
   ② 裁剪分扎表单区
   ========================================= */
.cutting-inputs-row {
  display: flex;
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}

.half-input {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
}

.half-input .input-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  min-width: 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 5px 6px;
  box-sizing: border-box;
  height: var(--input-height-sm);
}

.input-suffix {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

/* 无数据提示 */
.empty-hint-box {
  padding: 30px 0;
  text-align: center;
}

.empty-hint-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

/* 裁剪明细表 */
.cutting-table {
  padding-top: var(--spacing-md);
  margin-top: var(--spacing-sm);
}

.table-header {
  display: flex;
  align-items: center;
  padding: 5px 0 7px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.th { text-align: center; flex-shrink: 0; }
.th-color { width: 55px; text-align: left; }
.th-size  { width: 40px; }
.th-order { width: 40px; }
.th-cut   { width: 40px; }
.th-bundles { width: 40px; }
.th-last  { flex: 1; }

.table-row {
  display: flex;
  align-items: center;
  padding: 7px 0;
}

.td {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
}

.td-color { width: 55px; text-align: left; font-size: var(--font-size-xs); color: var(--color-text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.td-size  { width: 40px; }
.td-order { width: 40px; }
.td-cut   { width: 40px; font-weight: var(--font-weight-semibold); color: var(--color-primary); }
.td-cut.highlight { color: var(--color-primary); }
.td-bundles { width: 40px; }
.td-last  { flex: 1; display: flex; justify-content: center; }

.td-last-input {
  width: 50px;
  text-align: center;
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 4px 2px;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  box-sizing: border-box;
  height: var(--input-height-xs);
}

/* 分扎描述 */
.bundle-desc-area {
  margin-top: var(--spacing-sm);
  padding: var(--spacing-xs) 0;
}

.bundle-desc-row {
  display: flex;
  align-items: center;
  padding: 3px 0;
}

.bundle-desc-label {
  width: 90px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.bundle-desc-value {
  flex: 1;
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
}

/* 汇总栏 */
.cutting-summary-bar {
  display: flex;
  justify-content: space-around;
  padding: var(--spacing-md) 0 var(--spacing-xs);
  margin-top: var(--spacing-md);
}

.cutting-summary-item {
  text-align: center;
}

.cutting-summary-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  display: block;
}

.cutting-summary-value {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.cutting-summary-value.green  { color: var(--color-success); }
.cutting-summary-value.orange { color: var(--color-warning); }
.cutting-summary-value.purple { color: #9333ea; }

/* =========================================
   Tab 切换栏（菲号明细 / 转单）
   ========================================= */
.tabs-bar {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-xs);
  box-shadow: var(--shadow-sm);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--spacing-sm) 0;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.tab-item--active {
  color: var(--color-text-white);
  background: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* =========================================
   ③ 数量明细 · 模式切换
   ========================================= */
.mode-toggle {
  display: flex;
  border-radius: var(--radius-full);
  overflow: hidden;
  background: var(--color-bg-card);
}

.mode-btn {
  padding: 3px var(--spacing-md);
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: transparent;
  line-height: 1.5;
}

.mode-btn--active {
  background: var(--color-primary);
  color: var(--color-text-white);
}

/* 统计行 */
.stat-bar {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
  flex-wrap: wrap;
  gap: 2px;
}

.stat-item {
  display: inline-flex;
  align-items: center;
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.stat-value {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
}

.stat-value.primary {
  color: var(--color-primary);
}

/* 裁货元信息 */
.cut-meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 4px;
  flex-wrap: wrap;
  gap: 4px 0;
}

.cut-meta-item {
  display: flex;
  flex-direction: column;
  min-width: 60px;
}

.cut-meta-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-bottom: 1px;
}

.cut-meta-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.cut-meta-time {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.cut-meta-value-sm {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* 空状态提示 */
.empty-hint {
  padding: 16px 0;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}

/* 简单模式列表 */
.simple-list {
  margin-top: 4px;
}

.simple-header {
  display: flex;
  background: var(--color-primary-bg);
  border-radius: var(--radius-sm);
  padding: 5px 6px;
  margin-bottom: 2px;
}

.simple-row {
  display: flex;
  padding: 6px 6px 10px;
}

.simple-cell {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

.simple-cell--color {
  flex: 1;
}

.simple-cell--qty {
  width: 80px;
  text-align: right;
  color: var(--color-primary);
}

.simple-cell.bold {
  font-weight: var(--font-weight-semibold);
}

/* =========================================
   ④ 菲号明细列表
   ========================================= */
.bundle-list {
  margin-top: 0;
}

.bundle-list-header {
  display: flex;
  align-items: center;
  background: var(--color-primary-bg);
  border-radius: var(--radius-sm);
  padding: var(--spacing-xs) 4px;
  margin-bottom: 2px;
}

.bundle-row {
  display: flex;
  align-items: center;
  padding: 7px 4px 10px;
}

.bl-cell {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  text-align: center;
}

.bl-cell--no { width: 40px; flex-shrink: 0; }
.bl-cell--code { width: 70px; flex-shrink: 0; font-size: var(--font-size-xs); color: var(--color-text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bl-cell--color { width: 50px; flex-shrink: 0; }
.bl-cell--size { width: 40px; flex-shrink: 0; }
.bl-cell--qty { flex: 1; text-align: right; padding-right: 4px; }

.bl-cell.bold {
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* 列表头文字样式 */
.bundle-list-header .bl-cell {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

/* =========================================
   转单 Panel 样式
   ========================================= */

/* 模式选择 */
.tf-mode-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.tf-mode-options {
  display: flex;
  gap: var(--spacing-sm);
  margin-left: var(--spacing-md);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: 2px;
}

.tf-mode-opt {
  padding: var(--spacing-xs) var(--spacing-lg);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.tf-mode-opt--active {
  background: var(--color-bg-card);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  box-shadow: var(--shadow-sm);
}

.tf-mode-opt--disabled {
  color: var(--color-text-disabled);
  opacity: 0.5;
  cursor: not-allowed;
}

/* 分区标题 */
.tf-section {
  padding: var(--spacing-md) 0 var(--spacing-lg);
}

.tf-label {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
  display: block;
}

.tf-flex-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.tf-select-all {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}

.tf-select-all-icon {
  font-size: var(--font-size-md);
}

.tf-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-left: var(--spacing-sm);
  flex: 1;
}

/* 菲号列表 */
.tf-bundles-list {
  max-height: 150px;
  -webkit-overflow-scrolling: touch;
}

.tf-bundle-item {
  display: flex;
  align-items: center;
  padding: 7px 0 10px;
}

.tf-bundle-item--disabled {
  opacity: 0.45;
}

.tf-bundle-item--checked {
  background: var(--color-info-bg);
  border-radius: var(--radius-sm);
  padding: 7px 4px;
  margin: 0 -4px;
}

.tf-bundle-check {
  width: 22px;
  font-size: var(--font-size-lg);
  color: var(--color-primary);
  text-align: center;
  flex-shrink: 0;
}

.tf-bundle-info {
  flex: 1;
  margin-left: 4px;
  min-width: 0;
}

.tf-bundle-label {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  display: block;
}

.tf-bundle-detail {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: 1px;
}

.tf-bundle-status {
  font-size: var(--font-size-xs);
  color: var(--color-danger);
  flex-shrink: 0;
}

/* 工序列表 */
.tf-processes-list {
  margin-top: 4px;
}

.tf-process-row {
  display: flex;
  align-items: flex-start;
  padding: var(--spacing-sm) 0 var(--spacing-md);
}

.tf-process-row--disabled {
  opacity: 0.5;
  pointer-events: none;
}

.tf-process-check {
  width: 26px;
  font-size: var(--font-size-xl);
  color: var(--color-primary);
  text-align: center;
  padding-top: 2px;
  flex-shrink: 0;
}

.tf-process-body {
  flex: 1;
  min-width: 0;
}

.tf-process-top {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
}

.tf-process-code {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  background: var(--color-bg-gray);
  padding: 1px 5px;
  border-radius: var(--radius-sm);
}

.tf-process-name {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  flex: 1;
}

.tf-process-price {
  font-size: var(--font-size-md);
  color: var(--color-danger);
  font-weight: var(--font-weight-semibold);
}

.tf-process-status {
  font-size: var(--font-size-xs);
  color: var(--color-danger);
  margin-left: var(--spacing-xs);
}

.tf-process-status--partial {
  color: var(--color-warning);
}

.tf-process-price-row {
  display: flex;
  align-items: center;
  margin-top: var(--spacing-sm);
  gap: var(--spacing-sm);
}

.tf-new-price-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.tf-price-input {
  width: 80px;
  height: 36px;
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  box-sizing: border-box;
}

.tf-price-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* 工厂/人员 Tab */
.tf-tab-row {
  display: flex;
  gap: 0;
  margin-bottom: var(--spacing-sm);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: 2px;
}

.tf-tab-item {
  flex: 1;
  text-align: center;
  padding: 7px 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
}

.tf-tab-item--active {
  color: var(--color-text-white);
  background: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* 搜索行 */
.search-row {
  display: flex;
  align-items: center;
  padding: 5px var(--spacing-md);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-sm);
  gap: var(--spacing-xs);
}

.search-icon {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.search-row-input {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: transparent;
}

/* 搜索结果 */
.tf-result-list {
  max-height: 160px;
  -webkit-overflow-scrolling: touch;
}

.tf-result-item {
  display: flex;
  align-items: center;
  padding: 9px 6px 12px;
  gap: var(--spacing-xs);
}

.tf-result-item--active {
  background: var(--color-info-bg);
  border-radius: var(--radius-sm);
}

.tf-result-name {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  flex: 1;
}

.tf-result-sub {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-right: var(--spacing-sm);
}

.tf-result-check {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

.tf-loading,
.tf-more {
  text-align: center;
  padding: var(--spacing-md) 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.tf-more {
  color: var(--color-primary);
}

/* 备注 */
.tf-remark {
  width: 100%;
  min-height: 50px;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm);
  box-sizing: border-box;
  border: 1px solid var(--color-border-light);
}

/* =========================================
   ⑤ 底部操作栏（固定）
   ========================================= */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card);
  padding: 10px var(--page-padding-x) calc(10px + env(safe-area-inset-bottom));
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.06);
  z-index: var(--z-dropdown);
  display: flex;
  gap: 10px;
  align-items: center;
}

/* 单主按钮：生成菲号 / 转单提交 */
.btn-primary {
  flex: 1;
  height: var(--btn-height-lg);
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  transition: all 0.2s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.btn-full {
  flex: 1;
}

/* 双按钮模式（白底蓝字空心）：打印 / 转单 */
.footer-bar--dual {
  justify-content: space-around;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  padding: 8px var(--spacing-lg);
  flex: 1;
  height: var(--btn-height-lg);
  border-radius: var(--radius-lg);
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.ab-icon {
  font-size: var(--font-size-xl);
  line-height: 1;
}

.ab-label {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* =========================================
   ⑥ 菲号标签打印弹窗
   ========================================= */
.bpo-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-overlay);
  z-index: var(--z-modal);
  display: flex;
  align-items: flex-end;
}

.bpo-panel {
  width: 100%;
  max-height: 90vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.bpo-panel-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-xl) var(--spacing-md);
  flex-shrink: 0;
  gap: var(--spacing-sm);
}

.bpo-panel-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.bpo-panel-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.bpo-panel-close {
  margin-left: auto;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--color-bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* 配置栏 */
.bpo-config-bar {
  display: flex;
  align-items: flex-start;
  padding: var(--spacing-sm) var(--spacing-xl);
  background: var(--color-bg-gray);
  flex-shrink: 0;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
}

.bpo-config-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  line-height: 28px;
}

.bpo-size-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.bpo-size-chip {
  padding: 4px var(--spacing-md);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  transition: all 0.15s ease;
}

.bpo-size-chip--active {
  color: var(--color-text-white);
  background: var(--color-primary);
  border-color: var(--color-primary);
  transform: scale(1.05);
}

/* 打印方式选择 */
.bpo-mode-options {
  display: flex;
  gap: var(--spacing-sm);
}

.bpo-mode-opt {
  padding: 4px var(--spacing-lg);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
}

.bpo-mode-opt--active {
  color: var(--color-text-white);
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* WiFi 配置 */
.bpo-wifi-bar {
  gap: var(--spacing-xs);
}

.bpo-wifi-input {
  flex: 1;
  height: 36px;
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 0 6px;
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  min-width: 0;
  box-sizing: border-box;
}

.bpo-wifi-port {
  flex: 0 0 60px;
}

.bpo-port-label {
  flex-shrink: 0;
}

.bpo-wifi-hint {
  padding: 4px var(--spacing-xl) 6px;
  background: var(--color-bg-gray);
}

.bpo-wifi-hint-text {
  font-size: 10px;
  color: var(--color-text-tertiary);
}

/* 打印方向 */
.bpo-orient-bar {
  padding: var(--spacing-md) var(--spacing-lg);
}

.bpo-orient-btn {
  padding: 3px var(--spacing-md);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  margin-left: 4px;
}

.bpo-orient-btn--active {
  color: var(--color-text-white);
  background: var(--color-primary);
}

/* 预览区 */
.bpo-panel-body {
  flex: 1;
  padding: var(--spacing-md) var(--spacing-lg);
  overflow-y: auto;
}

.bpo-label-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  align-items: center;
}

.bpo-size-indicator {
  width: 100%;
  text-align: center;
  padding: 4px 0;
}

.bpo-size-indicator-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* 菲号标签卡片 — 左QR + 右文字 */
.bpo-label-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  padding: var(--spacing-lg);
  box-sizing: border-box;
  display: flex;
  gap: var(--spacing-lg);
  margin: 0 auto;
  transition: width 0.2s ease, height 0.2s ease;
  box-shadow: var(--shadow-sm);
}

/* 竖版预览卡片 */
.bpo-label-card--vertical {
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
}

.bpol-qr {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr--vertical {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 5px;
}

.bpol-qr-img {
  border-radius: var(--radius-xs);
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr-loading {
  background: var(--color-bg-gray);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr-loading-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.bpol-text {
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  min-width: 0;
}

.bpol-text--vertical {
  width: 100%;
  text-align: center;
  align-items: center;
}

.bpol-line {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bpol-line--bold {
  font-weight: var(--font-weight-bold);
  font-size: var(--font-size-sm);
}

/* 弹层底部 */
.bpo-panel-footer {
  display: flex;
  gap: var(--spacing-lg);
  padding: var(--spacing-md) var(--spacing-xl);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.bpo-btn {
  flex: 1;
  height: var(--btn-height-md);
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.bpo-btn--cancel {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.bpo-btn--print {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

.bpo-btn::after {
  border: none;
}

/* =========================================
   底部间距
   ========================================= */
.bottom-gap {
  height: 20px;
}

/* =========================================
   隐藏的 QR Canvas
   ========================================= */
.qr-canvas-hidden {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 200px;
  height: 200px;
}
