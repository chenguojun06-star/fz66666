@import '/styles/page-utils.wxss';

/* ── 页面容器 ── */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, rgba(var(--color-primary-rgb), 0.1) 0%, var(--color-bg-page) 220rpx);
  padding: 0 var(--page-padding-x) 160rpx;
}

/* ── 加载状态 ── */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

/* ── 订单选择列表（无参入口模式）── */
.order-list-wrap { padding: 0; }
.order-search-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(var(--color-primary-rgb), 0.15);
  box-shadow: var(--shadow-sm);
}
.order-search-input {
  flex: 1;
  height: 80rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}
.order-search-icon {
  font-size: 36rpx;
  opacity: 0.5;
}
.order-list-loading,
.order-list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  gap: 16rpx;
}
.order-list-empty .empty-icon { font-size: 64rpx; }
.order-sel-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(var(--color-primary-rgb), 0.12);
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
}
/* 款式缩略图 */
.sel-cover-box {
  flex-shrink: 0;
  width: 100rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.sel-cover-img {
  width: 100%;
  height: 100%;
}
.sel-cover-empty {
  width: 100%;
  height: 100%;
  background: var(--color-bg-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}
/* 订单信息区 */
.sel-card-info {
  flex: 1;
  min-width: 0;
}
.sel-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.sel-order-no {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-primary);
}
.sel-status-tag {
  font-size: var(--font-size-xs);
  color: #fff;
  background: var(--color-primary);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}
.sel-card-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}
.sel-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.sel-value {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  margin-right: 24rpx;
}
.sel-value.primary { color: var(--color-primary); font-weight: 600; }
.ml { margin-left: 16rpx; }

/* ── 订单信息卡片 ── */
.info-card {
  margin: 12rpx 0 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.info-card-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.info-card-body {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}

.cover-wrap {
  width: 140rpx;
  height: 140rpx;
  flex-shrink: 0;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: #f3f4f6;
}

.cover-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
}

.placeholder-icon {
  font-size: 48rpx;
}

.info-grid {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
}

.grid-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
}

.grid-label {
  font-size: var(--font-size-xxs);
  color: var(--color-text-secondary);
  margin-bottom: 4rpx;
}

.grid-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

.grid-value.bold {
  font-weight: 600;
}

/* ── 工序导航行 ── */
/* ── 通用区块卡片 ── */
.section-card {
  margin: var(--card-gap-y) 0 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 24rpx 28rpx;
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ── 模式切换按钮组 ── */
.mode-toggle {
  display: flex;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid var(--color-primary);
}

.mode-btn {
  padding: 6rpx 20rpx;
  font-size: var(--font-size-xxs);
  color: var(--color-primary);
  background: transparent;
  line-height: 1.5;
}

.mode-btn-active {
  background: var(--color-primary);
  color: #fff;
}

/* ── 统计栏 ── */
.stat-bar {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 4rpx;
}

.stat-item {
  display: inline-flex;
  align-items: center;
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.stat-value {
  font-size: var(--font-size-xs);
  font-weight: 600;
}

.stat-value.primary {
  color: var(--color-primary);
}

.stat-value.warning {
  color: #f59e0b;
}

/* ── 右上角统计徽章 ── */
.stat-badge {
  background: rgba(var(--color-primary-rgb), 0.1);
  border-radius: 24rpx;
  padding: 4rpx 16rpx;
}

.stat-badge-text {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: 600;
}

/* ── 裁货元信息 ── */
.cut-meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
  gap: 8rpx 0;
}

.cut-meta-item {
  display: flex;
  flex-direction: column;
  min-width: 120rpx;
}

.cut-meta-label {
  font-size: var(--font-size-xxs);
  color: var(--color-text-secondary);
  margin-bottom: 2rpx;
}

.cut-meta-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: 500;
}

.cut-meta-value.primary {
  color: var(--color-primary);
  font-weight: 600;
}

.cut-meta-time {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.cut-meta-value-sm {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* ── 空状态提示 ── */
.empty-hint {
  padding: 32rpx 0;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}

/* ── 简单模式列表 ── */
.simple-list {
  margin-top: 8rpx;
}

.simple-header {
  display: flex;
  background: rgba(var(--color-primary-rgb), 0.06);
  border-radius: 8rpx;
  padding: 10rpx 12rpx;
  margin-bottom: 4rpx;
}

.simple-row {
  display: flex;
  padding: 12rpx 12rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.simple-row:last-child {
  border-bottom: none;
}

.simple-cell {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
}

.simple-cell.simple-cell-color {
  flex: 1;
}

.simple-cell.simple-cell-qty {
  width: 160rpx;
  text-align: right;
  color: var(--color-primary);
}

.simple-cell.bold {
  font-weight: 600;
}

/* ── 底部打印按钮 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card);
  padding: 20rpx 16rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 16rpx;
}

.print-btn {
  flex: 1;
  height: 88rpx;
  color: #fff;
  border-radius: var(--radius-xl);
  font-size: var(--font-size-sm);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
}

.print-btn--bundle {
  background: #1677ff;
}

.print-btn--transfer {
  background: #fa8c16;
}

.print-btn::after {
  border: none;
}

/* ── 菲号明细列表 ── */
.section-sub {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.bundle-list-header {
  display: flex;
  align-items: center;
  background: rgba(var(--color-primary-rgb), 0.06);
  border-radius: 8rpx;
  padding: 12rpx 8rpx;
  margin-bottom: 4rpx;
}

.bundle-row {
  display: flex;
  align-items: center;
  padding: 14rpx 8rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.bundle-row:last-child {
  border-bottom: none;
}

.blh-cell, .blc-cell {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  text-align: center;
}

.blh-cell {
  font-weight: 600;
  color: var(--color-text-secondary);
  font-size: var(--font-size-xxs);
}

.blc-cell--no, .blh-cell--no {
  width: 80rpx;
  flex-shrink: 0;
}

.blc-cell--code, .blh-cell--code {
  width: 140rpx;
  flex-shrink: 0;
  font-size: var(--font-size-xxs);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.blc-cell--color, .blh-cell--color {
  width: 100rpx;
  flex-shrink: 0;
}

.blc-cell--size, .blh-cell--size {
  width: 80rpx;
  flex-shrink: 0;
}

.blc-cell--qty, .blh-cell--qty {
  flex: 1;
  text-align: right;
  padding-right: 8rpx;
}

.blc-cell.bold {
  font-weight: 700;
  color: var(--color-primary);
}

/* ── 菲号标签预览弹层（与PC端 CuttingPrintPreviewModal 一致） ── */
.bpo-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.bpo-panel {
  width: 100%;
  height: 85vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.bpo-panel-header {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  gap: 16rpx;
}

.bpo-panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.bpo-panel-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.bpo-panel-close {
  margin-left: auto;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* ── 打印尺寸选择栏 ── */
.bpo-config-bar {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 32rpx;
  background: #fafafa;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  gap: 12rpx;
  flex-wrap: wrap;
}

.bpo-config-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  line-height: 56rpx;
}

.bpo-size-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.bpo-size-chip {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: #fff;
  border: 1rpx solid #d9d9d9;
  transition: all 0.15s ease;
}

.bpo-size-chip--active {
  color: #fff;
  background: #1677ff;
  border-color: #1677ff;
  transform: scale(1.05);
}

/* 打印方式选择 */
.bpo-mode-options {
  display: flex;
  gap: 12rpx;
}

.bpo-mode-opt {
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: #fff;
  border: 1rpx solid #d9d9d9;
}

.bpo-mode-opt--active {
  color: #fff;
  background: #1677ff;
  border-color: #1677ff;
}

/* WiFi 配置 */
.bpo-wifi-bar {
  gap: 8rpx;
}

.bpo-wifi-input {
  flex: 1;
  height: 52rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  color: var(--color-text-primary);
  background: #fff;
  min-width: 0;
}

.bpo-wifi-port {
  flex: 0 0 100rpx;
}

.bpo-port-label {
  flex-shrink: 0;
}

.bpo-wifi-hint {
  padding: 8rpx 32rpx 12rpx;
  background: #fafafa;
}

.bpo-wifi-hint-text {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

/* 打印方向选择（横版/竖版） */
.bpo-orient-bar {
  padding: 8rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.bpo-orient-btn {
  padding: 6rpx 20rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: #f5f5f5;
  margin-left: 8rpx;
}

.bpo-orient-btn--active {
  color: #fff;
  background: #1677ff;
}

/* 竖版预览卡片 */
.bpo-label-card--vertical {
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
}

.bpol-qr--vertical {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 10rpx;
}

.bpol-text--vertical {
  width: 100%;
  text-align: center;
  align-items: center;
}

.bpo-panel-body {
  flex: 1;
  padding: 20rpx 24rpx;
}

.bpo-label-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: center;
}

.bpo-size-indicator {
  width: 100%;
  text-align: center;
  padding: 8rpx 0;
}

.bpo-size-indicator-text {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 菲号标签卡片 — 左QR + 右文字，尺寸由 inline style 动态控制 */
.bpo-label-card {
  background: #fff;
  border: 2rpx solid #000;
  border-radius: 8rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  gap: 24rpx;
  margin: 0 auto;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr-img {
  border-radius: 4rpx;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr-loading {
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr-loading-text {
  font-size: 24rpx;
  color: #999;
}

/* 隐藏的 canvas 用于生成 QR 码 */

.bpol-text {
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  min-width: 0;
}

.bpol-line {
  font-size: 24rpx;
  color: #000;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bpol-line--bold {
  font-weight: 700;
  font-size: 28rpx;
}

/* 弹层底部 */
.bpo-panel-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.bpo-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.bpo-btn--cancel {
  background: #f5f5f5;
  color: #666;
}

.bpo-btn--print {
  background: #1677ff;
  color: #fff;
}

.bpo-btn::after {
  border: none;
}

/* ═══════ Tab 栏（菲号明细 | 转单）═══════ */
.hub-tabs {
  display: flex;
  gap: 0;
}

.hub-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #999;
  border-bottom: 2rpx solid transparent;
}

.hub-tab--active {
  color: #1677ff;
  font-weight: 600;
  border-bottom-color: #1677ff;
}

/* ═══════ 转单 Panel 样式 ═══════ */

/* 模式选择 */
.tf-mode-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.tf-mode-options {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 4rpx;
}

.tf-mode-opt {
  padding: 12rpx 28rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
}

.tf-mode-opt--active {
  background: #fff;
  color: #1677ff;
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}

/* 分区标题 */
.tf-section {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.tf-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.tf-flex-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.tf-select-all {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #1677ff;
}

.tf-select-all-icon {
  font-size: 28rpx;
}

.tf-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  flex: 1;
}

/* 菲号列表 */
.tf-bundles-list {
  max-height: 300rpx;
  -webkit-overflow-scrolling: touch;
}

.tf-bundle-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.tf-bundle-item--disabled {
  opacity: 0.45;
}

.tf-bundle-item--checked {
  background: rgba(22,119,255,0.04);
  border-radius: 8rpx;
  margin: 0 -8rpx;
  padding: 14rpx 8rpx;
}

.tf-bundle-check {
  width: 44rpx;
  font-size: 32rpx;
  color: #1677ff;
  text-align: center;
}

.tf-bundle-info {
  flex: 1;
  margin-left: 8rpx;
}

.tf-bundle-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.tf-bundle-detail {
  font-size: 22rpx;
  color: #999;
  margin-top: 2rpx;
}

.tf-bundle-status {
  font-size: 22rpx;
  color: #ff4d4f;
}

/* 部分已扫码 — 橙色警告 */
.tf-bundle-item--partial {
  opacity: 0.7;
}

/* 工序列表 */
.tf-processes-list {
  margin-top: 8rpx;
}

.tf-process-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.tf-process-row--disabled {
  opacity: 0.5;
  pointer-events: none;
}

.tf-process-check {
  width: 52rpx;
  font-size: 34rpx;
  color: #1677ff;
  text-align: center;
  padding-top: 4rpx;
}

.tf-process-body {
  flex: 1;
}

.tf-process-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tf-process-code {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.tf-process-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.tf-process-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.tf-process-status {
  font-size: 22rpx;
  color: #ff4d4f;
  margin-left: 8rpx;
}

.tf-process-status--partial {
  color: #fa8c16;
}

.tf-process-price-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}

.tf-new-price-label {
  font-size: 24rpx;
  color: #999;
}

.tf-price-input {
  width: 160rpx;
  height: 60rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333;
}

.tf-price-unit {
  font-size: 22rpx;
  color: #999;
}

/* 工厂/人员 Tab */
.tf-tab-row {
  display: flex;
  gap: 0;
  margin-bottom: 16rpx;
}

.tf-tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #999;
  border-bottom: 2rpx solid transparent;
}

.tf-tab-item--active {
  color: #1677ff;
  font-weight: 600;
  border-bottom-color: #1677ff;
}

/* 搜索结果 */
.tf-result-list {
  max-height: 320rpx;
  -webkit-overflow-scrolling: touch;
}

.tf-result-item {
  display: flex;
  align-items: center;
  padding: 18rpx 12rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.tf-result-item--active {
  background: rgba(22,119,255,0.06);
  border-radius: 8rpx;
}

.tf-result-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.tf-result-sub {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.tf-result-check {
  font-size: 28rpx;
  color: #1677ff;
  font-weight: 600;
}

.tf-loading,
.tf-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999;
}

.tf-more {
  color: #1677ff;
}

/* 备注 */
.tf-remark {
  width: 100%;
  min-height: 100rpx;
  font-size: 26rpx;
  color: #333;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

/* 提交按钮 */
.submit-btn {
  flex: 1;
  height: 88rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.submit-btn::after {
  border: none;
}

/* ═══════ 裁剪分扎表单（来自 task-detail，与 PC 端 CuttingRatioPanel 一致）═══════ */

.common-inputs {
  margin-bottom: 24rpx;
}

/* 同行输入：每扎件数 + 损耗加放 */
.common-inputs-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.half-input {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid var(--color-border-light);
}

.half-input .input-label {
  width: 120rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.input-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid var(--color-border-light);
}

.input-label {
  width: 160rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.input-field {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  padding: 8rpx 0;
}

.input-suffix {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-left: 8rpx;
}

.empty-hint-box {
  padding: 60rpx 0;
  text-align: center;
}

.empty-hint-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.cutting-table {
  border-top: 1px solid var(--color-border);
  padding-top: 12rpx;
  margin-top: 8rpx;
}

.table-header {
  display: flex;
  align-items: center;
  padding: 10rpx 0 14rpx;
  font-size: var(--font-size-xxs);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.th { text-align: center; }
.th-color { width: 110rpx; text-align: left; }
.th-size  { width: 80rpx; }
.th-order { width: 80rpx; }
.th-cut   { width: 80rpx; }
.th-bundles { width: 80rpx; }
.th-last  { flex: 1; }

.table-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1px solid var(--color-border-light);
}

.td {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
}

.td-color { width: 110rpx; text-align: left; font-size: var(--font-size-xs); color: var(--color-text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.td-size  { width: 80rpx; }
.td-order { width: 80rpx; }
.td-cut   { width: 80rpx; font-weight: 600; color: var(--color-primary); }
.td-cut.highlight { color: var(--color-primary); }
.td-bundles { width: 80rpx; }
.td-last  { flex: 1; display: flex; justify-content: center; }

.td-last-input {
  width: 100rpx;
  text-align: center;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 8rpx 4rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: var(--color-bg-page);
}

.bundle-desc-area {
  margin-top: 16rpx;
  padding: 12rpx 0;
}

.bundle-desc-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}

.bundle-desc-label {
  width: 180rpx;
  font-size: var(--font-size-xxs);
  color: var(--color-text-secondary);
}

.bundle-desc-value {
  flex: 1;
  font-size: var(--font-size-xxs);
  color: var(--color-text-primary);
}

.cutting-summary-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0 8rpx;
  border-top: 1px solid var(--color-border);
  margin-top: 12rpx;
}

.cutting-summary-item {
  text-align: center;
}

.cutting-summary-label {
  font-size: var(--font-size-xxs);
  color: var(--color-text-secondary);
  display: block;
}

.cutting-summary-value {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
}

.cutting-summary-value.green  { color: var(--color-success); }
.cutting-summary-value.orange { color: var(--color-warning); }
.cutting-summary-value.purple { color: var(--color-purple, #9333ea); }

.print-btn--generate {
  background: #1677ff;
  flex: 1;
}
