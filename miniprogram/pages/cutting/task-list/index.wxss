@import '/styles/page-utils.wxss';

.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb, 37,99,235), 0.06) 0%, transparent 60%),
    linear-gradient(180deg, rgba(var(--color-primary-rgb, 37,99,235), 0.03) 0%, var(--color-bg-page) 30%);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ---- 筛选 Tab ---- */
.filter-tabs {
  display: flex;
  padding: 20rpx 32rpx;
  gap: 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.filter-tab {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-xl, 24rpx);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}
.filter-tab.active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}
.tab-badge {
  font-size: var(--font-size-xxs);
  background: rgba(255,255,255,0.3);
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
}
.filter-tab.active .tab-badge {
  background: rgba(255,255,255,0.35);
}

/* ---- 加载状态 ---- */
.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-secondary);
  font-size: var(--font-size-md);
}

/* ---- 任务卡片 ---- */
.task-card {
  margin: 16rpx 32rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl, 24rpx);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  overflow: hidden;
}
.task-card-hover {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 12rpx;
}
.order-no {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
}
.status-tag {
  font-size: var(--font-size-xxs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-lg, 16rpx);
}

.card-body {
  padding: 0 28rpx 16rpx;
}
.info-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}
.info-label {
  width: 100rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.info-value {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}
.info-value.bold {
  font-weight: 600;
}

/* ---- 底部操作栏 ---- */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 16rpx 28rpx 20rpx;
  border-top: 1px solid var(--color-border-light);
  gap: 16rpx;
}
.btn-action {
  padding: 12rpx 32rpx;
  border-radius: var(--radius-lg, 16rpx);
  font-size: var(--font-size-sm);
  font-weight: 500;
}
.btn-primary {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.btn-disabled {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}
.card-arrow {
  font-size: var(--font-size-md-lg);
  color: var(--color-text-tertiary);
}
