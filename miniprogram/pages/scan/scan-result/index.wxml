<wxs src="../../../utils/money.wxs" module="money" />
<view class="container">

  <!-- 扫描成功状态卡片（对齐设计稿：白底 + 绿色圆圈 + 边框） -->
  <view class="success-card">
    <view class="success-icon-circle">
      <view class="line-icon line-icon--lg icon-check-white success-check"></view>
    </view>
    <view class="success-content">
      <text class="success-title">扫描成功</text>
      <text class="success-subtitle">{{detail.styleNo || detail.bundleNo || '-'}}</text>
    </view>
    <view wx:if="{{detail.deliveryDateDisplay}}" class="success-date">
      <text class="success-date-label">交期</text>
      <text class="success-date-value">{{detail.deliveryDateDisplay}}</text>
    </view>
  </view>

  <!-- 菲号信息（对齐设计稿：分区头 + 字段列表） -->
  <view class="group-section">
    <view class="group-header">
      <text class="group-header-title">菲号信息</text>
    </view>
    <view class="group-body">
      <view wx:if="{{detail.bundleNo}}" class="group-field-row">
        <text class="group-field-label">菲号</text>
        <text class="group-field-value">{{detail.bundleNo}}</text>
      </view>
      <view wx:if="{{detail.color}}" class="group-field-row">
        <text class="group-field-label">颜色</text>
        <text class="group-field-value">{{detail.color}}</text>
      </view>
      <view wx:if="{{detail.size}}" class="group-field-row">
        <text class="group-field-label">码数</text>
        <text class="group-field-value">{{detail.size}}</text>
      </view>
      <view wx:if="{{detail.displayQuantity}}" class="group-field-row">
        <text class="group-field-label">数量</text>
        <text class="group-field-value group-field-value--bold">{{detail.displayQuantity}} 件</text>
      </view>
      <view wx:if="{{detail.bedNo}}" class="group-field-row">
        <text class="group-field-label">床号</text>
        <text class="group-field-value">{{detail.bedNo}}</text>
      </view>
      <view wx:if="{{detail.cuttingDateDisplay}}" class="group-field-row">
        <text class="group-field-label">裁床日期</text>
        <text class="group-field-value">{{detail.cuttingDateDisplay}}</text>
      </view>
    </view>
  </view>

  <!-- 款式信息（对齐设计稿：缩略图 + 品名 + 标签） -->
  <view class="group-section">
    <view class="group-header">
      <text class="group-header-title">款式信息</text>
    </view>
    <view class="group-body style-body">
      <view class="style-header">
        <image-preview class="style-thumb" src="{{detail.coverImage || ''}}" mode="aspectFill" />
        <view class="style-header-info">
          <text class="style-header-name">{{detail.styleNo || detail.orderNo || '-'}}</text>
          <text class="style-header-sub" wx:if="{{detail.orderNo}}">{{detail.orderNo}}</text>
          <view class="style-tags">
            <text wx:if="{{detail.orderNo}}" class="style-tag">{{detail.orderNo}}</text>
            <text wx:if="{{detail.processName}}" class="style-tag style-tag--brand">{{detail.processName}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- AI 智能提示（保留生产功能） -->
  <view wx:if="{{imageInsight}}" class="insight-card">
    <view class="line-icon icon-ai insight-icon"></view>
    <text class="insight-text">{{imageInsight}}</text>
  </view>

  <!-- 生产提示（对齐设计稿：分区头 + 字段列表） -->
  <view wx:if="{{productionHints}}" class="group-section">
    <view class="group-header">
      <text class="group-header-title">生产提示</text>
    </view>
    <view class="group-body">
      <view wx:if="{{productionHints.difficultyLabel}}" class="group-field-row">
        <text class="group-field-label">难度</text>
        <view class="hint-value-wrap">
          <text class="hint-badge hint-badge--{{productionHints.difficultySeverity}}">{{productionHints.difficultyLabel}}</text>
          <text wx:if="{{productionHints.difficultyScore}}" class="hint-score">{{productionHints.difficultyScore}}/10</text>
        </view>
      </view>
      <view wx:if="{{productionHints.fabricComposition}}" class="group-field-row">
        <text class="group-field-label">面料</text>
        <text class="group-field-value">{{productionHints.fabricComposition}}</text>
      </view>
      <view wx:if="{{productionHints.needleHint}}" class="group-field-row">
        <text class="group-field-label">针号</text>
        <text class="group-field-value">{{productionHints.needleHint}}</text>
      </view>
      <view wx:if="{{productionHints.craftNotes}}" class="group-field-row group-field-row--block">
        <text class="group-field-label">工艺要点</text>
        <text class="group-field-value group-field-value--block">{{productionHints.craftNotes}}</text>
      </view>
      <view wx:if="{{productionHints.secondaryProcessText}}" class="group-field-row">
        <text class="group-field-label">二次工艺</text>
        <text class="group-field-value">{{productionHints.secondaryProcessText}}</text>
      </view>
    </view>
  </view>

  <!-- 菲号工序进度（保留生产功能） -->
  <view wx:if="{{detail.bundleStatusHints.length > 0}}" class="group-section">
    <view class="group-header">
      <text class="group-header-title">菲号工序进度</text>
    </view>
    <view class="group-body">
      <view wx:for="{{detail.bundleStatusHints}}" wx:key="index" class="stage-hint-item">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 选择工序（对齐设计稿：分区头 + 多选 + 汇总） -->
  <view class="group-section">
    <view class="group-header">
      <text class="group-header-title">选择工序（可多选）</text>
    </view>
    <view class="group-body">
      <scroll-view class="process-scroll" scroll-y style="max-height:600rpx">
        <view wx:for="{{processOptions}}" wx:key="value"
              class="process-chip {{item.checked ? 'active' : ''}}"
              data-value="{{item.value}}"
              bindtap="onProcessTap">
          <view class="process-chip-left">
            <view class="process-checkbox {{item.checked ? 'process-checkbox--checked' : ''}}">
              <view wx:if="{{item.checked}}" class="line-icon icon-check-white process-check"></view>
            </view>
            <text class="chip-label">{{item.label}}</text>
          </view>
          <text wx:if="{{!item.hidePrice}}" class="chip-price">¥{{money.toFixed2(item.unitPrice)}}</text>
        </view>
      </scroll-view>
    </view>
    <view class="summary-bar" wx:if="{{selectedCount > 0}}">
      <text class="summary-text">已选 {{selectedCount}} 个工序</text>
      <text wx:if="{{selectedAmount > 0}}" class="summary-amount">合计 ¥{{money.toFixed2(selectedAmount)}}</text>
    </view>
  </view>

  <!-- 目标仓库（保留生产功能） -->
  <view wx:if="{{showWarehouse}}" class="group-section">
    <view class="group-header">
      <text class="group-header-title">目标仓库</text>
    </view>
    <view class="group-body">
      <view class="warehouse-row">
        <view class="warehouse-name">
          <text class="warehouse-name-label">仓库：</text>
          <text class="warehouse-name-value">{{warehouseName}}</text>
        </view>
        <view class="warehouse-option-row" wx:if="{{warehouseOptions.length > 0}}">
          <view
            wx:for="{{warehouseOptions}}"
            wx:key="index"
            class="warehouse-chip {{warehouseCode === item ? 'warehouse-chip--active' : ''}}"
            bindtap="onWarehouseChipTap"
            data-value="{{item}}"
            hover-class="warehouse-chip-hover"
            hover-stay-time="100"
          >{{item}}</view>
          <view
            class="warehouse-chip warehouse-chip--clear {{warehouseCode ? '' : 'warehouse-chip--disabled'}}"
            bindtap="onWarehouseClear"
            hover-class="warehouse-chip-hover"
            hover-stay-time="100"
          >清除</view>
        </view>
        <input
          class="input-box"
          placeholder="{{warehouseOptions.length > 0 ? '或手动输入库位编号' : '请输入库位编号'}}"
          value="{{warehouseCode}}"
          bindinput="onWarehouseInput"
        />

        <!-- 库位选择 -->
        <view wx:if="{{warehouseCode && locationOptions.length > 0}}" class="warehouse-option-row" style="margin-top: 16rpx;">
          <view
            wx:for="{{locationOptions}}"
            wx:key="index"
            class="warehouse-chip {{warehouseLocationCode === item ? 'warehouse-chip--active' : ''}}"
            bindtap="onLocationChipTap"
            data-value="{{item}}"
            hover-class="warehouse-chip-hover"
            hover-stay-time="100"
          >{{item}}</view>
          <view
            class="warehouse-chip warehouse-chip--clear {{warehouseLocationCode ? '' : 'warehouse-chip--disabled'}}"
            bindtap="onLocationClear"
            hover-class="warehouse-chip-hover"
            hover-stay-time="100"
          >清除</view>
        </view>
        <input
          wx:if="{{warehouseCode}}"
          class="input-box"
          placeholder="或手动输入库位编号"
          value="{{warehouseLocationCode}}"
          bindinput="onLocationInput"
        />
      </view>
    </view>
  </view>

  <view class="footer-bar">
    <view class="btn-cancel" hover-class="footer-bar-hover" bindtap="goBack">取消</view>
    <view class="btn-submit {{loading || selectedCount === 0 ? 'btn-disabled' : ''}}" hover-class="footer-bar-hover" bindtap="submitScanResult">
      {{loading ? '提交中...' : (isQualityReceive ? '质检录入' : '确认提交')}}
    </view>
  </view>
  <ai-assistant />
</view>
