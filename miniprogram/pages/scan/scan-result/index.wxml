<wxs src="../../../utils/money.wxs" module="money" />
<view class="container">
  <!-- ============== 顶部 Hero 区（品牌色背景，关键信息突出） ============== -->
  <view class="hero">
    <view class="hero__main">
      <view class="hero__icon"></view>
      <view class="hero__mainText">
        <text class="hero__title">扫描成功</text>
        <text class="hero__styleNo">{{detail.styleNo || '—'}}</text>
      </view>
      <view wx:if="{{detail.deliveryDate}}" class="hero__delivery">
        <text class="hero__deliveryLabel">交期</text>
        <text class="hero__deliveryValue">{{detail.deliveryDate}}</text>
      </view>
    </view>

    <view class="hero__info">
      <view class="hero__infoItem">
        <text class="hero__infoLabel">菲号</text>
        <text class="hero__infoValue">{{detail.orderNo ? detail.orderNo + '-' : ''}}{{detail.bundleNo || '—'}}</text>
      </view>
      <view class="hero__infoDivider"></view>
      <view class="hero__infoItem">
        <text class="hero__infoLabel">颜色</text>
        <text class="hero__infoValue">{{detail.color || '—'}}</text>
      </view>
      <view class="hero__infoDivider"></view>
      <view class="hero__infoItem">
        <text class="hero__infoLabel">码数</text>
        <text class="hero__infoValue">{{detail.size || '—'}}</text>
      </view>
      <view class="hero__infoDivider"></view>
      <view class="hero__infoItem">
        <text class="hero__infoLabel">数量</text>
        <text class="hero__infoValue hero__infoValue--qty">{{detail.displayQuantity || detail.quantity || 0}}</text>
      </view>
    </view>
  </view>

  <!-- ============== ① 款式信息卡片 ============== -->
  <view class="card style-card">
    <view class="card__title">
      <text class="card__titleText">款式信息</text>
      <text wx:if="{{detail.processName}}" class="card__titleTag">当前：{{detail.processName}}</text>
    </view>
    <view class="style-card__body" bindtap="previewImage">
      <image-preview
        class="style-card__cover"
        src="{{detail.coverImage || detail.cover || ''}}"
        mode="aspectFill"
      />
      <view class="style-card__info">
        <text class="style-card__styleNo">{{detail.styleNo}}</text>
        <text wx:if="{{detail.styleName}}" class="style-card__styleName">{{detail.styleName}}</text>
        <view class="style-card__meta">
          <text wx:if="{{detail.orderNo}}" class="meta-tag">订单 {{detail.orderNo}}</text>
          <text wx:if="{{detail.customerName}}" class="meta-tag">客户 {{detail.customerName}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ============== ② 菲号信息卡片（详情列表式） ============== -->
  <view wx:if="{{detail.bundleNo || detail.color || detail.size || detail.displayQuantity}}" class="card">
    <view class="card__title">
      <text class="card__titleText">菲号信息</text>
    </view>
    <view class="detail-list">
      <view class="detail-row">
        <text class="detail-label">菲号</text>
        <text class="detail-value detail-value--bold">{{detail.orderNo ? detail.orderNo + '-' : ''}}{{detail.bundleNo}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">颜色</text>
        <text class="detail-value">{{detail.color || '—'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">码数</text>
        <text class="detail-value">{{detail.size || '—'}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">数量</text>
        <text class="detail-value detail-value--qty">{{detail.displayQuantity || detail.quantity || 0}} 件</text>
      </view>
      <view wx:if="{{detail.bundleLabel}}" class="detail-row">
        <text class="detail-label">标签</text>
        <text class="detail-value">{{detail.bundleLabel}}</text>
      </view>
      <view wx:if="{{detail.bedNoDisplay || detail.bedNo}}" class="detail-row">
        <text class="detail-label">床号</text>
        <text class="detail-value">{{detail.bedNoDisplay || detail.bedNo}}</text>
      </view>
    </view>
    <view wx:if="{{detail.bundleSplitHint}}" class="card__hint">
      <text>{{detail.bundleSplitHint}}</text>
    </view>
  </view>

  <!-- ============== ③ 生产提示卡片 ============== -->
  <view wx:if="{{detail.workerHint || detail.secondaryProcessHint || detail.difficultyLabel || detail.fabricComposition || detail.needleHint || (detail.processHints && detail.processHints.length > 0) || detail.imageInsight}}" class="card hint-card">
    <view class="card__title">
      <text class="card__titleText">生产提示</text>
      <text class="card__titleSub">样衣开发提醒</text>
    </view>

    <view class="hint-body">
      <!-- 难度徽章 -->
      <view wx:if="{{detail.difficultyLabel}}" class="hint-row hint-row--badge">
        <text class="hint-label">难度</text>
        <view class="hint-badge hint-badge--{{detail.difficultyLevelInfo.severity}}">
          <text class="hint-badge__label">{{detail.difficultyLabel}}</text>
          <text wx:if="{{detail.difficultyScore}}" class="hint-badge__score">{{detail.difficultyScore}}/10</text>
        </view>
      </view>

      <view wx:if="{{detail.fabricComposition}}" class="hint-row">
        <text class="hint-label">面料</text>
        <text class="hint-value">{{detail.fabricComposition}}</text>
      </view>

      <view wx:if="{{detail.needleHint}}" class="hint-row hint-row--column">
        <text class="hint-label">针号</text>
        <view class="hint-value-wrap">
          <text class="hint-value">{{detail.needleHint}}</text>
          <text wx:if="{{detail.needleReason}}" class="hint-sub">{{detail.needleReason}}</text>
        </view>
      </view>

      <view wx:if="{{detail.processHints && detail.processHints.length > 0}}" class="hint-row hint-row--column">
        <text class="hint-label">工艺要点</text>
        <view class="hint-chips">
          <text wx:for="{{detail.processHints}}" wx:key="*this" class="hint-chip">{{item}}</text>
        </view>
      </view>

      <view wx:if="{{detail.secondaryProcessHint}}" class="hint-row">
        <text class="hint-label">二次工艺</text>
        <text class="hint-value">{{detail.secondaryProcessHint}}</text>
      </view>

      <view wx:if="{{detail.description}}" class="hint-row hint-row--column">
        <text class="hint-label">款式备注</text>
        <text class="hint-value hint-value--desc">{{detail.description}}</text>
      </view>

      <view wx:if="{{detail.imageInsight}}" class="hint-row hint-row--insight">
        <text class="hint-label">系统提示</text>
        <text class="hint-value hint-value--insight">{{detail.imageInsight}}（仅供参考，以实际面料手感为准）</text>
      </view>

      <view wx:if="{{detail.workerHint && !detail.difficultyLabel && !detail.fabricComposition && !detail.needleHint && (!(detail.processHints && detail.processHints.length > 0))}}" class="hint-row hint-row--summary">
        <text class="hint-label">综合提示</text>
        <text class="hint-value hint-value--summary">{{detail.workerHint}}</text>
      </view>
    </view>
  </view>

  <!-- ============== ④ 工序选择 ============== -->
  <view class="card">
    <view class="card__title">
      <text class="card__titleText">选择工序</text>
      <text class="card__titleHint">可多选</text>
    </view>
    <scroll-view class="process-scroll" scroll-y style="max-height:600rpx">
      <view wx:for="{{processOptions}}" wx:key="value"
            class="process-item {{item.checked ? 'process-item--active' : ''}}"
            data-value="{{item.value}}"
            hover-class="process-item-hover"
            hover-stay-time="80"
            bindtap="onProcessTap">
        <view class="process-item__checkbox {{item.checked ? 'process-item__checkbox--checked' : ''}}"></view>
        <text class="process-item__name">{{item.label}}</text>
        <text wx:if="{{!item.hidePrice}}" class="process-item__price">¥{{money.toFixed2(item.unitPrice)}}</text>
      </view>
    </scroll-view>
    <view class="summary-bar" wx:if="{{selectedCount > 0}}">
      <text class="summary-text">已选 {{selectedCount}} 个工序</text>
      <text wx:if="{{selectedAmount > 0}}" class="summary-amount">合计 ¥{{money.toFixed2(selectedAmount)}}</text>
    </view>
  </view>

  <!-- ============== ⑤ 目标仓库（仅入库阶段） ============== -->
  <view wx:if="{{showWarehouse}}" class="card">
    <view class="card__title">
      <text class="card__titleText">目标仓库</text>
    </view>
    <view class="warehouse-row">
      <view class="warehouse-name">
        <text class="warehouse-name-label">仓库：</text>
        <text class="warehouse-name-value">{{warehouseName}}</text>
      </view>
      <view class="warehouse-option-row" wx:if="{{warehouseOptions.length > 0}}">
        <view
          wx:for="{{warehouseOptions}}"
          wx:key="index"
          class="warehouse-chip {{warehouseCode === item ? 'warehouse-chip--active' : ''}}"
          bindtap="onWarehouseChipTap"
          data-value="{{item}}"
          hover-class="warehouse-chip-hover"
          hover-stay-time="100"
        >{{item}}</view>
        <view
          class="warehouse-chip warehouse-chip--clear {{warehouseCode ? '' : 'warehouse-chip--disabled'}}"
          bindtap="onWarehouseClear"
          hover-class="warehouse-chip-hover"
          hover-stay-time="100"
        >清除</view>
      </view>
      <input
        class="input-box"
        placeholder="{{warehouseOptions.length > 0 ? '或手动输入库位编号…' : '请输入库位编号…'}}"
        value="{{warehouseCode}}"
        bindinput="onWarehouseInput"
      />

      <view wx:if="{{warehouseCode && locationOptions.length > 0}}" class="warehouse-option-row" style="margin-top: 16rpx;">
        <view
          wx:for="{{locationOptions}}"
          wx:key="index"
          class="warehouse-chip {{warehouseLocationCode === item ? 'warehouse-chip--active' : ''}}"
          bindtap="onLocationChipTap"
          data-value="{{item}}"
          hover-class="warehouse-chip-hover"
          hover-stay-time="100"
        >{{item}}</view>
        <view
          class="warehouse-chip warehouse-chip--clear {{warehouseLocationCode ? '' : 'warehouse-chip--disabled'}}"
          bindtap="onLocationClear"
          hover-class="warehouse-chip-hover"
          hover-stay-time="100"
        >清除</view>
      </view>
      <input
        wx:if="{{warehouseCode}}"
        class="input-box"
        placeholder="或手动输入库位编号…"
        value="{{warehouseLocationCode}}"
        bindinput="onLocationInput"
      />
    </view>
  </view>

  <!-- ============== ⑥ 底部固定按钮 ============== -->
  <view class="footer-bar">
    <view class="btn-cancel" hover-class="btn-hover" bindtap="goBack">取消</view>
    <view class="btn-submit {{loading || selectedCount === 0 ? 'btn-disabled' : ''}}" hover-class="btn-hover" bindtap="submitScanResult">
      {{loading ? '提交中…' : (isQualityReceive ? '质检录入' : '确认提交')}}
    </view>
  </view>
</view>
