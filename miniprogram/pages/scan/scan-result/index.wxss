/* ================ 大货扫码结果页 - 苹果风格（iOS Grouped List） ================ */

page {
  background: var(--color-bg-page);
}

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 0 calc(env(safe-area-inset-bottom) + 70px);
}

/* ================ 顶部状态卡（苹果风格大白卡） ================ */
.status-card {
  display: flex;
  align-items: center;
  margin: var(--spacing-lg) var(--page-padding-x) 0;
  padding: var(--spacing-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}
.status-card__icon {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-full);
  background: var(--color-success);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}
.status-card__check {
  width: 11px;
  height: 6px;
  border-left: 2.5px solid var(--color-text-white);
  border-bottom: 2.5px solid var(--color-text-white);
  transform: rotate(-45deg);
  margin-top: -3px;
}
.status-card__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  min-width: 0;
}
.status-card__title {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  line-height: var(--line-height-tight);
  letter-spacing: 0.5px;
}
.status-card__subtitle {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  line-height: var(--line-height-normal);
  letter-spacing: 0.5px;
  word-break: break-all;
}
.status-card__delivery {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
  background: var(--color-warning-bg);
  border-radius: var(--radius-md);
  flex-shrink: 0;
}
.status-card__deliveryLabel {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
  line-height: 1;
  margin-bottom: var(--spacing-xs);
  letter-spacing: 0.5px;
}
.status-card__deliveryValue {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-warning);
  line-height: var(--line-height-tight);
  font-variant-numeric: tabular-nums;
}

/* ================ 分组列表（iOS Grouped Table View） ================ */
.group {
  margin: var(--spacing-xl) var(--page-padding-x) 0;
}
.group__header {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: 0 var(--spacing-xs) var(--spacing-xs);
  letter-spacing: 0.25px;
  display: flex;
  align-items: baseline;
  gap: var(--spacing-xs);
}
.group__header--withHint {
  justify-content: space-between;
}
.group__hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-normal);
}
.group__body {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.group__footer {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  padding: var(--spacing-xs) var(--spacing-xs) 0;
  line-height: var(--line-height-medium);
}

/* ================ Cell 单元格 ================ */
.cell {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  min-height: 44px;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.cell-hover {
  background: var(--color-bg-hover);
}
.cell-divider {
  height: 1px;
  background: var(--color-border-light);
  margin-left: var(--spacing-lg);
}
.cell--column {
  flex-direction: column;
  align-items: flex-start;
  gap: var(--spacing-xs);
}
.cell--media {
  align-items: center;
  gap: var(--spacing-md);
}
.cell--toggle {
  cursor: pointer;
  transition: background-color 0.12s ease;
}
.cell--selected {
  background: var(--color-primary-bg);
}
.cell--summary {
  background: var(--color-bg-light);
}
.cell--input {
  padding: var(--spacing-sm) var(--spacing-lg);
}

.cell__label {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  flex-shrink: 0;
  min-width: 70px;
  line-height: var(--line-height-normal);
}
.cell__value {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  text-align: right;
  word-break: break-all;
  line-height: var(--line-height-normal);
  font-variant-numeric: tabular-nums;
}
.cell__value--bold {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.cell__value--qty {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.cell__value--accent {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}
.cell__value--desc {
  text-align: left;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  line-height: var(--line-height-medium);
}
.cell__value--insight {
  text-align: left;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-xs);
  line-height: var(--line-height-medium);
}
.cell__value--flex {
  flex: 1;
  text-align: left;
  font-weight: var(--font-weight-medium);
}
.cell__price {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-normal);
  margin-left: var(--spacing-xs);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.cell--selected .cell__price {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.cell--selected .cell__value {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* media cell 子元素 */
.cell__cover {
  width: 60px;
  height: 60px;
  border-radius: var(--radius-lg);
  background: var(--color-bg-gray);
  flex-shrink: 0;
  overflow: hidden;
}
.cell__mediaBody {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  min-width: 0;
}
.cell__styleNo {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  line-height: var(--line-height-tight);
  letter-spacing: 0.25px;
}
.cell__styleName {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-tight);
}
.cell__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-top: 2px;
}
.tag {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  padding: 2px 7px;
  border-radius: var(--radius-xs);
  line-height: var(--line-height-normal);
}

/* column cell 子元素 */
.cell__columnBody {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}
.cell__hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: var(--line-height-normal);
}
.cell__chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  width: 100%;
}
.chip {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: var(--radius-full);
  line-height: var(--line-height-normal);
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.chip--on {
  background: var(--color-primary);
  color: var(--color-text-white);
  font-weight: var(--font-weight-medium);
}
.chip--clear {
  color: var(--color-text-secondary);
}
.chip--disabled {
  opacity: 0.4;
}
.chip-hover {
  opacity: 0.6;
}

/* toggle 圆形 checkbox */
.cell__check {
  width: 20px;
  height: 20px;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  position: relative;
  background: var(--color-bg-card);
  transition: background-color 0.15s ease, border-color 0.15s ease;
}
.cell__check--on {
  background: var(--color-primary);
  border-color: var(--color-primary);
}
.cell__check--on::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 7px;
  height: 4px;
  border-left: 1.5px solid var(--color-text-white);
  border-bottom: 1.5px solid var(--color-text-white);
  transform: translate(-50%, -65%) rotate(-45deg);
}

/* input cell */
.cell__input {
  width: 100%;
  height: 32px;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: transparent;
}

/* ================ 难度徽章 ================ */
.cell__accessory {
  flex-shrink: 0;
  margin-left: var(--spacing-xs);
}
.badge {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
}
.badge__text {
  font-size: var(--font-size-sm);
  line-height: var(--line-height-tight);
}
.badge__score {
  font-size: var(--font-size-xs);
  opacity: 0.8;
  line-height: var(--line-height-tight);
}
.badge--critical {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}
.badge--high {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}
.badge--medium {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}
.badge--low {
  background: var(--color-success-bg);
  color: var(--color-success);
}

/* ================ 工序滚动区 ================ */
.process-scroll {
  padding: 0;
  max-height: 300px;
}

/* ================ 尊重用户减少动画偏好 ================ */
@media (prefers-reduced-motion: reduce) {
  .cell--toggle,
  .cell__check {
    transition: none !important;
    animation: none !important;
    transform: none !important;
  }
}
