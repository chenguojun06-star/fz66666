@import '/styles/design-tokens.wxss';

.container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 50% 0%, rgba(var(--color-primary-rgb,37,99,235),0.06) 0%, transparent 70%);
  padding: 24rpx 24rpx calc(env(safe-area-inset-bottom) + 160rpx);
}

/* 信息卡片 */
.info-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}
.card-header {
  display: flex;
  align-items: flex-start;
}
.cover-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #f1f5f9;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
}
.placeholder-icon {
  font-size: 48rpx;
}
.header-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.style-no {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1e293b);
}
.sub-info {
  font-size: 28rpx;
  color: var(--color-text-secondary, #64748b);
}
.sub-info.time {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #94a3b8);
}

/* 字段列表 */
.field-list {
  border-top: 1rpx solid var(--color-border, #f0f0f0);
  padding-top: 16rpx;
  margin-top: 16rpx;
}
.field-row {
  display: flex;
  align-items: baseline;
  padding: 10rpx 0;
}
.field-label {
  width: 140rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary, #64748b);
  flex-shrink: 0;
}
.field-value {
  flex: 1;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary, #1e293b);
}
.field-value.highlight {
  font-weight: 700;
  color: rgba(var(--color-primary-rgb,37,99,235),1);
}

/* AI 洞察卡片 */
.insight-card {
  display: flex;
  align-items: flex-start;
  background: rgba(var(--color-primary-rgb,37,99,235),0.06);
  border-radius: var(--radius-xl, 24rpx);
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.insight-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.insight-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--color-text-primary, #1e293b);
  line-height: 1.6;
}

/* 工序选择区 */
.section-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}
.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1e293b);
  margin-bottom: 20rpx;
}
.process-scroll {
  padding: 4rpx 0;
}
.process-chip {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.process-chip.active {
  background: rgba(var(--color-primary-rgb,37,99,235),0.1);
  border-color: rgba(var(--color-primary-rgb,37,99,235),0.5);
}
.chip-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary, #1e293b);
}
.process-chip.active .chip-label {
  color: rgba(var(--color-primary-rgb,37,99,235),1);
  font-weight: 600;
}
.chip-price {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #94a3b8);
  margin-left: 12rpx;
  flex-shrink: 0;
}
.process-chip.active .chip-price {
  color: rgba(var(--color-primary-rgb,37,99,235),0.7);
}

/* 选择汇总 */
.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border, #f0f0f0);
}
.summary-text {
  font-size: 24rpx;
  color: var(--color-text-secondary, #64748b);
}
.summary-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(var(--color-primary-rgb,37,99,235),1);
}

/* 输入框 */
.input-box {
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border, #e2e8f0);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary, #1e293b);
}

/* 底部操作栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
  gap: 20rpx;
}
.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #f1f5f9;
  color: #64748b;
}
.btn-submit {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: rgba(var(--color-primary-rgb,37,99,235),1);
  color: #fff;
}
.btn-submit.off {
  opacity: 0.5;
}
.btn-hover {
  opacity: 0.7;
}
