
.container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 50% 0%, rgba(var(--color-primary-rgb),0.06) 0%, transparent 70%);
  padding: 24rpx 24rpx calc(env(safe-area-inset-bottom) + 160rpx);
}

.info-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}
.card-header {
  display: flex;
  align-items: flex-start;
}
.cover-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-gray);
}
.placeholder-icon {
  font-size: 48rpx;
}
.header-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bundle-meta {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-top: 6rpx;
}
.meta-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.style-no {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}
.sub-info {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
.sub-info.time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.field-list {
  border-top: 1rpx solid var(--color-border);
  padding-top: 16rpx;
  margin-top: 16rpx;
}
.field-row {
  display: flex;
  align-items: baseline;
  padding: 10rpx 0;
}
.field-label {
  width: 160rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}
.field-value {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}
.field-value.highlight {
  font-weight: 700;
  color: var(--color-primary);
}

.insight-card {
  display: flex;
  align-items: flex-start;
  background: var(--color-info-bg);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.insight-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.insight-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}
.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}
.process-scroll {
  padding: 4rpx 0;
}
.process-chip {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-gray);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.process-chip.active {
  background: var(--color-blue-light);
  border-color: var(--color-border-blue);
}
.chip-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}
.process-chip.active .chip-label {
  color: var(--color-primary);
  font-weight: 600;
}
.chip-price {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-left: 12rpx;
  flex-shrink: 0;
}
.process-chip.active .chip-price {
  color: var(--color-primary-light);
}

.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}
.summary-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}
.summary-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.input-box {
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.warehouse-chip {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-gray);
  border: 2rpx solid transparent;
  font-size: 26rpx;
  color: var(--color-text-primary);
}
.warehouse-chip--active {
  background: var(--color-blue-light);
  border-color: var(--color-border-blue);
  color: var(--color-primary);
  font-weight: 600;
}
.warehouse-chip--clear {
  color: var(--color-text-secondary);
}
.warehouse-chip--disabled {
  opacity: 0.35;
}
.warehouse-chip-hover {
  opacity: 0.7;
}
