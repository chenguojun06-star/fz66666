/* ================ 大货扫码结果页 - 美团风格重设计 ================ */

.container {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 140rpx);
}

/* ================ Hero 顶部区（品牌色背景） ================ */
.hero {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  padding: 32rpx 32rpx 28rpx;
  color: #fff;
}
.hero__main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.hero__icon {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}
.hero__icon::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 12rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: translate(-50%, -65%) rotate(-45deg);
}
.hero__mainText {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.hero__title {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.2;
}
.hero__styleNo {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
  letter-spacing: 1rpx;
  word-break: break-all;
}
.hero__delivery {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 12rpx;
  flex-shrink: 0;
}
.hero__deliveryLabel {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1;
  margin-bottom: 4rpx;
}
.hero__deliveryValue {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
}

.hero__info {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.12);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
}
.hero__infoItem {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
}
.hero__infoLabel {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1;
}
.hero__infoValue {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1.3;
  word-break: break-all;
  text-align: center;
  font-variant-numeric: tabular-nums;
}
.hero__infoValue--qty {
  color: #fef08a;
  font-weight: 700;
}
.hero__infoDivider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.2);
  flex-shrink: 0;
}

/* ================ 通用卡片 ================ */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card__title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f1f3;
}
.card__titleText {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  position: relative;
  padding-left: 16rpx;
  line-height: 1.2;
}
.card__titleText::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 26rpx;
  background: #2563eb;
  border-radius: 4rpx;
}
.card__titleTag {
  font-size: 22rpx;
  color: #2563eb;
  background: rgba(37,99,235,0.08);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: auto;
}
.card__titleSub {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: auto;
}
.card__titleHint {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: auto;
}
.card__hint {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  background: #fff7ed;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #c2410c;
  border-left: 4rpx solid #fb923c;
}

/* ================ 款式信息卡片 ================ */
.style-card__body {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.style-card__cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f2f4f7;
  flex-shrink: 0;
  overflow: hidden;
}
.style-card__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.style-card__styleNo {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.3;
  letter-spacing: 1rpx;
}
.style-card__styleName {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.3;
}
.style-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}
.meta-tag {
  font-size: 22rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* ================ 详情列表（菲号信息） ================ */
.detail-list {
  display: flex;
  flex-direction: column;
}
.detail-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f6f8;
}
.detail-row:last-child {
  border-bottom: none;
}
.detail-label {
  width: 120rpx;
  font-size: 26rpx;
  color: #9ca3af;
  flex-shrink: 0;
}
.detail-value {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  word-break: break-all;
  font-variant-numeric: tabular-nums;
}
.detail-value--bold {
  font-weight: 700;
  color: #111827;
}
.detail-value--qty {
  color: #2563eb;
  font-weight: 700;
}

/* ================ 生产提示卡片 ================ */
.hint-card {
  background: #fff;
}
.hint-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.hint-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.hint-row--column {
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}
.hint-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #6b7280;
  flex-shrink: 0;
  line-height: 1.5;
}
.hint-row--column .hint-label {
  width: auto;
}
.hint-value {
  flex: 1;
  font-size: 26rpx;
  color: #1f2937;
  line-height: 1.5;
  word-break: break-all;
}
.hint-value--desc {
  color: #4b5563;
  font-size: 25rpx;
}
.hint-value--insight {
  color: #6b7280;
  font-size: 24rpx;
}
.hint-value--summary {
  color: #1f2937;
}
.hint-value-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.hint-sub {
  font-size: 22rpx;
  color: #9ca3af;
}
.hint-row--badge {
  align-items: center;
}
.hint-row--insight {
  background: #f9fafb;
  padding: 12rpx 14rpx;
  border-radius: 10rpx;
  border-left: 4rpx solid #d1d5db;
}
.hint-row--summary {
  background: #fef3c7;
  padding: 12rpx 14rpx;
  border-radius: 10rpx;
  border-left: 4rpx solid #f59e0b;
}

/* 难度徽章 */
.hint-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}
.hint-badge__label {
  font-size: 24rpx;
}
.hint-badge__score {
  font-size: 20rpx;
  opacity: 0.85;
}
.hint-badge--critical {
  background: #fef2f2;
  color: #b91c1c;
  border: 2rpx solid #fca5a5;
}
.hint-badge--high {
  background: #fff7ed;
  color: #c2410c;
  border: 2rpx solid #fdba74;
}
.hint-badge--medium {
  background: #fef9c3;
  color: #854d0e;
  border: 2rpx solid #facc15;
}
.hint-badge--low {
  background: #f0fdf4;
  color: #15803d;
  border: 2rpx solid #86efac;
}

/* 工艺要点 chips */
.hint-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.hint-chip {
  font-size: 22rpx;
  color: #4b7cd1;
  background: #eef4ff;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  line-height: 1.4;
}

/* ================ 工序选择（列表式 checkbox） ================ */
.process-scroll {
  padding: 4rpx 0;
}
.process-item {
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  background: #f9fafb;
  border: 2rpx solid transparent;
  transition: background-color 0.15s ease, border-color 0.15s ease;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.process-item-hover {
  opacity: 0.7;
  transform: scale(0.99);
}
.process-item--active {
  background: rgba(37,99,235,0.06);
  border-color: #2563eb;
}
.process-item__checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
  background: #fff;
  transition: background-color 0.15s ease, border-color 0.15s ease;
}
.process-item__checkbox--checked {
  background: #2563eb;
  border-color: #2563eb;
}
.process-item__checkbox--checked::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: translate(-50%, -65%) rotate(-45deg);
}
.process-item__name {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  line-height: 1.3;
}
.process-item--active .process-item__name {
  color: #2563eb;
  font-weight: 600;
}
.process-item__price {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.process-item--active .process-item__price {
  color: #2563eb;
  font-weight: 700;
}

.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f1f3;
}
.summary-text {
  font-size: 24rpx;
  color: #6b7280;
}
.summary-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #2563eb;
  font-variant-numeric: tabular-nums;
}

/* ================ 仓库选择 ================ */
.warehouse-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.warehouse-name {
  display: flex;
  align-items: center;
}
.warehouse-name-label {
  font-size: 26rpx;
  color: #6b7280;
  margin-right: 8rpx;
}
.warehouse-name-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}
.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.warehouse-chip {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  border: 2rpx solid transparent;
  font-size: 24rpx;
  color: #1f2937;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.warehouse-chip--active {
  background: rgba(37,99,235,0.08);
  border-color: #2563eb;
  color: #2563eb;
  font-weight: 600;
}
.warehouse-chip--clear {
  color: #6b7280;
}
.warehouse-chip--disabled {
  opacity: 0.4;
}
.warehouse-chip-hover {
  opacity: 0.7;
}

.input-box {
  height: 72rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #1f2937;
  background: #fff;
}

/* ================ 底部固定按钮栏 ================ */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  background: #fff;
  border-top: 1rpx solid #f0f1f3;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
  z-index: 100;
}
.btn-cancel,
.btn-submit {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  transition: opacity 0.12s ease, transform 0.12s ease;
}
.btn-cancel {
  background: #f3f4f6;
  color: #4b5563;
}
.btn-submit {
  background: #2563eb;
  color: #fff;
}
.btn-disabled {
  opacity: 0.5;
}
.btn-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ================ 尊重用户减少动画偏好 ================ */
@media (prefers-reduced-motion: reduce) {
  .process-item,
  .process-item-hover,
  .btn-cancel,
  .btn-submit,
  .btn-hover,
  .process-item__checkbox {
    transition: none !important;
    animation: none !important;
    transform: none !important;
  }
}
