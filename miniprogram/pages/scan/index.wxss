/* 玻璃质感扫码页 */
page {
  background: linear-gradient(135deg, #e8f0fe 0%, #f3e8ff 100%);
  min-height: 100vh;
}

.page {
  padding: 12px;
  padding-bottom: 30px;
}

/* 玻璃效果卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.5);
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 10px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

.glass-card.success {
  background: rgba(236, 253, 245, 0.8);
  border-color: rgba(167, 243, 208, 0.6);
}

.glass-card.error {
  background: rgba(254, 242, 242, 0.8);
  border-color: rgba(254, 202, 202, 0.6);
}

/* 顶部栏 */
.glass-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 14px;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  border-radius: 12px;
  margin-bottom: 10px;
  border: 1px solid rgba(255, 255, 255, 0.5);
}

.header-title {
  font-size: 17px;
  font-weight: 600;
  color: #1f2937;
}

.type-chip {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  border-radius: 16px;
  font-size: 13px;
  font-weight: 500;
}

.chip-arrow {
  font-size: 14px;
  opacity: 0.8;
}

/* 扫码行 */
.scan-row {
  display: flex;
  gap: 10px;
}

.input-wrap {
  flex: 1;
}

.qty-input {
  width: 100%;
  height: 40px;
  background: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(209, 213, 219, 0.5);
  border-radius: 8px;
  padding: 0 12px;
  font-size: 15px;
  box-sizing: border-box;
}

.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20px;
  height: 40px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
}

.scan-btn.disabled {
  opacity: 0.6;
}

/* 质检选项 */
.quality-row {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.chip {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  background: rgba(243, 244, 246, 0.8);
  border-radius: 8px;
  font-size: 13px;
  color: #6b7280;
  transition: all 0.2s;
}

.chip.active {
  color: #fff;
  font-weight: 500;
}

.chip.active.green {
  background: linear-gradient(135deg, #10b981, #059669);
}

.chip.active.orange {
  background: linear-gradient(135deg, #f59e0b, #d97706);
}

.chip.active.blue {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
}

/* 次品区 */
.defect-area {
  margin-top: 12px;
  padding: 12px;
  background: rgba(255, 251, 235, 0.6);
  border-radius: 8px;
  border: 1px solid rgba(254, 243, 199, 0.8);
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.form-row:last-child {
  margin-bottom: 0;
}

.form-label {
  width: 50px;
  font-size: 13px;
  color: #6b7280;
  flex-shrink: 0;
}

.form-picker, .form-input {
  flex: 1;
  height: 36px;
  line-height: 36px;
  background: rgba(255, 255, 255, 0.8);
  border: 1px solid rgba(209, 213, 219, 0.5);
  border-radius: 6px;
  padding: 0 10px;
  font-size: 13px;
  color: #374151;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.form-unit {
  margin-left: 6px;
  font-size: 12px;
  color: #9ca3af;
}

.arrow {
  color: #9ca3af;
  font-size: 12px;
}

/* 照片行 */
.photo-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 10px;
}

.photo-thumb {
  position: relative;
  width: 56px;
  height: 56px;
  border-radius: 6px;
  overflow: hidden;
}

.photo-thumb image {
  width: 100%;
  height: 100%;
}

.del-btn {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 16px;
  height: 16px;
  line-height: 14px;
  text-align: center;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  font-size: 12px;
}

.photo-add {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.8);
  border: 1px dashed #d1d5db;
  border-radius: 6px;
  font-size: 20px;
  color: #9ca3af;
}

.photo-add.disabled {
  opacity: 0.5;
}

/* 结果区 */
.result-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.result-msg {
  font-size: 14px;
  font-weight: 500;
  color: #374151;
}

.undo-link {
  font-size: 12px;
  color: #ef4444;
  padding: 4px 8px;
  background: rgba(254, 226, 226, 0.6);
  border-radius: 4px;
}

.result-info {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
  font-size: 13px;
  color: #1f2937;
}

.result-info .sub {
  color: #6b7280;
}

.result-info .tag {
  padding: 2px 8px;
  background: rgba(99, 102, 241, 0.1);
  color: #6366f1;
  border-radius: 4px;
  font-size: 11px;
}

.result-detail {
  display: flex;
  gap: 12px;
  margin-top: 6px;
  font-size: 12px;
  color: #6b7280;
}

/* 卡片标题 */
.card-title {
  font-size: 14px;
  font-weight: 600;
  color: #374151;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
}

.badge {
  margin-left: 6px;
  padding: 1px 6px;
  background: #6366f1;
  color: #fff;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 500;
}

.refresh {
  margin-left: auto;
  font-size: 12px;
  color: #6366f1;
  font-weight: 400;
}

.refresh.disabled {
  opacity: 0.5;
}

/* 采购项 */
.purchase-item {
  padding: 10px;
  background: rgba(248, 250, 252, 0.6);
  border-radius: 8px;
  margin-bottom: 8px;
}

.purchase-item:last-child {
  margin-bottom: 0;
}

.purchase-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.purchase-name {
  font-size: 14px;
  font-weight: 500;
  color: #1f2937;
}

.purchase-status {
  font-size: 11px;
  padding: 2px 8px;
  background: rgba(251, 191, 36, 0.2);
  color: #d97706;
  border-radius: 4px;
}

.purchase-status.done {
  background: rgba(16, 185, 129, 0.1);
  color: #059669;
}

.purchase-grid {
  display: flex;
  gap: 8px;
}

.grid-cell {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 6px;
}

.cell-val {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #1f2937;
}

.cell-lbl {
  display: block;
  font-size: 10px;
  color: #9ca3af;
  margin-top: 2px;
}

.receiver-row {
  margin-top: 8px;
  font-size: 12px;
  color: #059669;
}

.purchase-action {
  margin-top: 10px;
}

.arrival-form {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid rgba(229, 231, 235, 0.5);
}

/* 按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 500;
  margin-top: 10px;
}

.btn-primary.disabled {
  opacity: 0.6;
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36px;
  background: rgba(243, 244, 246, 0.8);
  color: #6b7280;
  border-radius: 8px;
  font-size: 13px;
}

/* 统计 */
.stats-row {
  display: flex;
  gap: 8px;
}

.stat-cell {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  background: rgba(248, 250, 252, 0.6);
  border-radius: 8px;
}

.stat-cell.highlight {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.15), rgba(245, 158, 11, 0.15));
}

.stat-num {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #1f2937;
}

.stat-lbl {
  display: block;
  font-size: 10px;
  color: #9ca3af;
  margin-top: 2px;
}

/* 历史 */
.empty {
  text-align: center;
  padding: 20px;
  color: #9ca3af;
  font-size: 13px;
}

.history-item {
  padding: 10px;
  background: rgba(248, 250, 252, 0.6);
  border-radius: 8px;
  margin-bottom: 6px;
}

.history-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-order {
  font-size: 13px;
  font-weight: 500;
  color: #1f2937;
}

.history-tag {
  font-size: 11px;
  padding: 2px 6px;
  background: rgba(99, 102, 241, 0.1);
  color: #6366f1;
  border-radius: 4px;
}

.history-sub {
  display: flex;
  justify-content: space-between;
  margin-top: 4px;
  font-size: 12px;
  color: #6b7280;
}

.history-qty {
  font-weight: 500;
  color: #374151;
}

.load-more {
  text-align: center;
  padding: 12px;
  font-size: 12px;
  color: #6366f1;
}

.load-more .no-more {
  color: #9ca3af;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px;
  box-sizing: border-box;
}

.modal-glass {
  width: 100%;
  max-width: 300px;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.6);
}

.modal-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  font-size: 15px;
  font-weight: 500;
}

.countdown {
  font-size: 13px;
  opacity: 0.9;
}

.modal-body {
  padding: 14px 16px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  border-bottom: 1px solid rgba(229, 231, 235, 0.5);
}

.info-row:last-child {
  border-bottom: none;
}

.info-lbl {
  font-size: 13px;
  color: #6b7280;
}

.info-val {
  font-size: 13px;
  color: #1f2937;
  max-width: 160px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.modal-foot {
  display: flex;
  gap: 10px;
  padding: 12px 16px;
  border-top: 1px solid rgba(229, 231, 235, 0.5);
}

.modal-foot .btn-ghost,
.modal-foot .btn-primary {
  flex: 1;
  margin-top: 0;
}
