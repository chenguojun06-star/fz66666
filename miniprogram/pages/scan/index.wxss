/* 极简紧凑风格 */
page { background: #f7f8fa; min-height: 100vh; }
.page { padding: 8px; padding-bottom: 24px; }

/* ===== 顶部标签栏 ===== */
.top-bar {
  background: #fff;
  border-radius: 10px;
  padding: 8px;
  margin-bottom: 8px;
}
.type-tabs {
  display: flex;
  gap: 4px;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6px 2px;
  border-radius: 8px;
  font-size: 10px;
  color: #666;
  background: #f5f6f8;
}
.tab.on {
  background: #e6f0ff;
  color: #2b7de9;
}
.tab-ico {
  width: 18px;
  height: 18px;
  margin-bottom: 2px;
}
.tab.on .tab-ico { filter: none; }
.tab.more {
  max-width: 32px;
  justify-content: center;
}
.more-dot {
  font-size: 14px;
  letter-spacing: -2px;
  color: #999;
}

/* ===== 扫码区 ===== */
.scan-area {
  display: flex;
  gap: 8px;
  background: #fff;
  border-radius: 10px;
  padding: 10px;
  margin-bottom: 8px;
}
.scan-input {
  flex: 1;
  background: #f5f6f8;
  border-radius: 20px;
  padding: 0 12px;
  height: 36px;
  display: flex;
  align-items: center;
}
.scan-input input {
  width: 100%;
  height: 36px;
  font-size: 14px;
}
.scan-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0 16px;
  height: 36px;
  background: #2b7de9;
  color: #fff;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 500;
}
.scan-btn.off { opacity: 0.5; }
.scan-ico {
  width: 16px;
  height: 16px;
}

/* ===== 质检选项 ===== */
.qc-bar {
  display: flex;
  gap: 6px;
  background: #fff;
  border-radius: 10px;
  padding: 8px;
  margin-bottom: 8px;
}
.qc-opt {
  flex: 1;
  text-align: center;
  padding: 8px 4px;
  border-radius: 8px;
  font-size: 12px;
  color: #666;
  background: #f5f6f8;
}
.qc-opt.on.pass { background: #e8f5e9; color: #2e7d32; }
.qc-opt.on.fail { background: #fff3e0; color: #e65100; }
.qc-opt.on.fix { background: #e3f2fd; color: #1565c0; }

/* ===== 次品详情 ===== */
.defect-box {
  background: #fffbf5;
  border-radius: 10px;
  padding: 10px;
  margin-bottom: 8px;
}
.df-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid #f5f0e8;
}
.df-row:last-child { border-bottom: none; }
.df-label {
  width: 36px;
  font-size: 11px;
  color: #999;
}
.df-picker { flex: 1; }
.df-val {
  font-size: 13px;
  color: #333;
}
.df-photos {
  display: flex;
  gap: 6px;
  flex: 1;
}
.df-photo {
  position: relative;
  width: 40px;
  height: 40px;
  border-radius: 6px;
  overflow: hidden;
}
.df-photo image { width: 100%; height: 100%; }
.df-del {
  position: absolute;
  top: 0;
  right: 0;
  width: 14px;
  height: 14px;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 10px;
  text-align: center;
  line-height: 14px;
  border-radius: 0 6px 0 6px;
}
.df-add {
  width: 40px;
  height: 40px;
  border: 1px dashed #ccc;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #ccc;
}
.df-add.off { opacity: 0.4; }

/* ===== 仓库输入 ===== */
.wh-box {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  border-radius: 10px;
  padding: 10px 12px;
  margin-bottom: 8px;
}
.wh-label {
  font-size: 12px;
  color: #999;
}
.wh-input {
  flex: 1;
  font-size: 14px;
}

/* ===== 扫码结果 ===== */
.result {
  border-radius: 10px;
  padding: 10px;
  margin-bottom: 8px;
}
.result.ok { background: #e8f5e9; }
.result.err { background: #ffebee; }
.res-top {
  display: flex;
  align-items: center;
  gap: 8px;
}
.res-tag {
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 500;
}
.res-tag.ok { background: #2e7d32; color: #fff; }
.res-tag.err { background: #c62828; color: #fff; }
.res-msg {
  flex: 1;
  font-size: 12px;
  color: #666;
}
.res-undo {
  padding: 4px 10px;
  background: #fff;
  border: 1px solid #c62828;
  color: #c62828;
  border-radius: 12px;
  font-size: 11px;
}
.res-info {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
  font-size: 12px;
  color: #666;
}
.res-order { color: #2b7de9; font-weight: 500; }
.res-style { color: #333; }
.res-proc {
  padding: 1px 6px;
  background: #e6f0ff;
  color: #2b7de9;
  border-radius: 6px;
  font-size: 10px;
}

/* ===== 区块通用 ===== */
.section {
  background: #fff;
  border-radius: 10px;
  padding: 10px;
  margin-bottom: 8px;
}
.sec-head {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}
.sec-title {
  flex: 1;
  font-size: 13px;
  font-weight: 500;
  color: #333;
}
.sec-count {
  display: inline-block;
  padding: 0 6px;
  background: #2b7de9;
  color: #fff;
  border-radius: 8px;
  font-size: 10px;
  margin-left: 4px;
}
.sec-refresh {
  padding: 2px 8px;
  background: #f5f6f8;
  border-radius: 10px;
  font-size: 11px;
  color: #666;
}
.sec-refresh.off { opacity: 0.4; }

/* ===== 物料卡片 ===== */
.mat-card {
  background: #f9fafb;
  border-radius: 8px;
  padding: 10px;
  margin-bottom: 8px;
}
.mat-card:last-child { margin-bottom: 0; }
.mat-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.mat-name {
  font-size: 13px;
  font-weight: 500;
  color: #333;
}
.mat-tag {
  padding: 2px 8px;
  background: #fff3e0;
  color: #e65100;
  border-radius: 8px;
  font-size: 10px;
}
.mat-tag.done { background: #e8f5e9; color: #2e7d32; }
.mat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
  margin-bottom: 8px;
}
.mat-cell {
  background: #fff;
  padding: 6px;
  border-radius: 6px;
  text-align: center;
}
.mc-label {
  display: block;
  font-size: 10px;
  color: #999;
}
.mc-val {
  display: block;
  font-size: 12px;
  color: #333;
  font-weight: 500;
  margin-top: 2px;
}
.mc-val.hl { color: #2b7de9; }
.mc-val.gr { color: #2e7d32; }
.mat-receiver {
  padding: 6px 8px;
  background: #e8f5e9;
  border-radius: 6px;
  font-size: 11px;
  color: #2e7d32;
  margin-bottom: 8px;
}
.mat-time {
  float: right;
  color: #999;
  font-size: 10px;
}
.mat-action { text-align: center; }
.btn-receive {
  display: inline-block;
  padding: 8px 20px;
  background: #2b7de9;
  color: #fff;
  border-radius: 16px;
  font-size: 12px;
}
.mat-form {
  background: #fff;
  border-radius: 6px;
  padding: 8px;
}
.mf-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}
.mf-row:last-child { margin-bottom: 0; }
.mf-label {
  width: 32px;
  font-size: 11px;
  color: #999;
}
.mf-row input {
  flex: 1;
  height: 32px;
  padding: 0 8px;
  background: #f5f6f8;
  border-radius: 6px;
  font-size: 13px;
}
.mf-unit {
  font-size: 11px;
  color: #999;
}
.btn-confirm {
  margin-top: 8px;
  padding: 8px;
  background: #2e7d32;
  color: #fff;
  border-radius: 16px;
  text-align: center;
  font-size: 12px;
}

/* ===== 统计 ===== */
.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
}
.st {
  text-align: center;
  padding: 8px 4px;
  background: #f5f6f8;
  border-radius: 8px;
}
.st.hl { background: #e6f0ff; }
.st-num {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #333;
}
.st.hl .st-num { color: #2b7de9; }
.st-label {
  display: block;
  font-size: 10px;
  color: #999;
  margin-top: 2px;
}

/* ===== 历史记录 ===== */
.empty {
  text-align: center;
  padding: 20px;
  font-size: 12px;
  color: #999;
}
.hist {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f5f6f8;
}
.hist:last-of-type { border-bottom: none; }
.hist-left { flex: 1; }
.hist-order {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: #333;
}
.hist-detail {
  display: block;
  font-size: 10px;
  color: #999;
  margin-top: 2px;
}
.hist-right {
  display: flex;
  align-items: center;
  gap: 6px;
}
.hist-tag {
  padding: 2px 6px;
  background: #f5f6f8;
  color: #2b7de9;
  border-radius: 6px;
  font-size: 10px;
}
.hist-qty {
  font-size: 12px;
  color: #666;
  font-weight: 500;
}
.load-more {
  text-align: center;
  padding: 10px;
  font-size: 11px;
  color: #2b7de9;
}
.load-more .no-more { color: #ccc; }

/* ===== 弹窗 ===== */
.modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 16px;
}
.modal-box {
  width: 100%;
  max-width: 300px;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}
.modal-head {
  padding: 12px 14px;
  background: #2b7de9;
  color: #fff;
  font-size: 14px;
  font-weight: 500;
}
.modal-cd {
  float: right;
  padding: 2px 8px;
  background: rgba(255,255,255,0.2);
  border-radius: 8px;
  font-size: 12px;
}
.modal-body {
  padding: 12px;
  max-height: 240px;
  overflow-y: auto;
}
.cf-list {
  background: #f9fafb;
  border-radius: 8px;
  padding: 8px;
}
.cf-item {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  border-bottom: 1px solid #eee;
}
.cf-item:last-child { border-bottom: none; }
.cf-k {
  font-size: 11px;
  color: #999;
}
.cf-v {
  font-size: 12px;
  color: #333;
  max-width: 160px;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cf-v.mono { font-family: monospace; font-size: 10px; }
.cf-v.hl { color: #2b7de9; font-weight: 500; }
.modal-btns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  padding: 10px 12px;
  border-top: 1px solid #f0f0f0;
}
.mbtn {
  padding: 10px;
  border-radius: 18px;
  text-align: center;
  font-size: 13px;
  font-weight: 500;
}
.mbtn.cancel { background: #f5f6f8; color: #666; }
.mbtn.ok { background: #2b7de9; color: #fff; }
.mbtn.ok.off { opacity: 0.5; }
