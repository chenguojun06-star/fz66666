/* 清爽现代风格 - 椭圆形小图标 */
page {
  background: #f5f5f5;
  min-height: 100vh;
}

.page {
  padding: 10px;
  padding-bottom: 30px;
}

/* ========== 通用卡片 ========== */
.card {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 10px;
}

/* ========== 顶部区域 ========== */
.header {
  background: #fff;
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 10px;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-badge {
  display: flex;
  align-items: center;
  gap: 8px;
}

.badge-icon {
  width: 28px;
  height: 28px;
  background: #4a90d9;
  color: #fff;
  border-radius: 14px;
  font-size: 12px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title-text {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.type-picker {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  background: #f0f5fa;
  border-radius: 16px;
  font-size: 13px;
  color: #4a90d9;
}

.picker-arrow {
  font-size: 14px;
  color: #999;
}

/* 快捷按钮 */
.quick-btns {
  display: flex;
  justify-content: space-between;
  margin-top: 12px;
  gap: 6px;
}

.qbtn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 8px 4px;
  border-radius: 10px;
  background: #f8f9fa;
  font-size: 11px;
  color: #666;
}

.qbtn.active {
  background: #e8f2fc;
  color: #4a90d9;
}

.qbtn-icon {
  width: 24px;
  height: 24px;
  background: #e0e6ed;
  color: #666;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qbtn.active .qbtn-icon {
  background: #4a90d9;
  color: #fff;
}

/* ========== 扫码卡片 ========== */
.scan-card {
  padding: 16px;
}

.scan-row {
  display: flex;
  gap: 10px;
  align-items: center;
}

.qty-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f7f9;
  border-radius: 20px;
  padding: 0 14px;
  height: 40px;
}

.qty-label {
  font-size: 13px;
  color: #999;
  margin-right: 8px;
}

.qty-input input {
  flex: 1;
  height: 40px;
  font-size: 15px;
  color: #333;
}

.scan-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 20px;
  height: 40px;
  background: #4a90d9;
  color: #fff;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 500;
}

.scan-btn.disabled {
  opacity: 0.6;
}

.scan-btn-icon {
  width: 20px;
  height: 20px;
  background: rgba(255,255,255,0.2);
  border-radius: 10px;
  font-size: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hint {
  margin-top: 8px;
  font-size: 11px;
  color: #999;
  padding-left: 4px;
}

/* 质检选项 */
.quality-opts {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid #f0f0f0;
}

.opts-title {
  font-size: 13px;
  font-weight: 500;
  color: #333;
  margin-bottom: 10px;
}

.opts-row {
  display: flex;
  gap: 10px;
}

.opt {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  background: #f5f7f9;
  border-radius: 18px;
  font-size: 12px;
  color: #666;
}

.opt.active {
  font-weight: 500;
}

.opt.active.green {
  background: #e8f7ed;
  color: #2e9e5a;
}

.opt.active.orange {
  background: #fef5e8;
  color: #d98d2c;
}

.opt.active.blue {
  background: #e8f2fc;
  color: #4a90d9;
}

.opt-dot {
  width: 8px;
  height: 8px;
  border-radius: 4px;
  background: #ccc;
}

.opt-dot.green { background: #2e9e5a; }
.opt-dot.orange { background: #d98d2c; }
.opt-dot.blue { background: #4a90d9; }

/* 次品表单 */
.defect-form {
  margin-top: 12px;
  padding: 12px;
  background: #fffbf0;
  border-radius: 10px;
}

.form-item {
  margin-bottom: 10px;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 12px;
  color: #999;
  margin-bottom: 6px;
  display: block;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 12px;
  background: #fff;
  border-radius: 8px;
  font-size: 13px;
  color: #333;
}

.photo-list {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.photo-thumb {
  position: relative;
  width: 56px;
  height: 56px;
  border-radius: 8px;
  overflow: hidden;
}

.photo-thumb image {
  width: 100%;
  height: 100%;
}

.photo-close {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 16px;
  height: 16px;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 8px;
  font-size: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add {
  width: 56px;
  height: 56px;
  border: 1px dashed #ddd;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.photo-add.disabled {
  opacity: 0.5;
}

.add-plus {
  font-size: 20px;
  color: #ccc;
}

/* 仓库输入 */
.warehouse-input {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid #f0f0f0;
}

.warehouse-input input {
  margin-top: 6px;
  padding: 10px 12px;
  background: #f5f7f9;
  border-radius: 8px;
  font-size: 14px;
}

/* ========== 结果卡片 ========== */
.result-card.success {
  background: #f0f9f4;
  border: 1px solid #d4edda;
}

.result-card.error {
  background: #fef5f5;
  border: 1px solid #f5c6cb;
}

.result-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.result-status {
  display: flex;
  align-items: center;
  gap: 8px;
}

.status-badge {
  padding: 3px 10px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 500;
}

.status-badge.green {
  background: #2e9e5a;
  color: #fff;
}

.status-badge.red {
  background: #dc3545;
  color: #fff;
}

.result-msg {
  font-size: 13px;
  color: #666;
}

.undo-btn {
  padding: 5px 12px;
  background: #fff;
  border: 1px solid #dc3545;
  color: #dc3545;
  border-radius: 14px;
  font-size: 12px;
}

.result-info {
  padding: 10px;
  background: rgba(255,255,255,0.6);
  border-radius: 8px;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 4px 0;
}

.info-item.small {
  flex: 1;
}

.info-row {
  display: flex;
  gap: 12px;
}

.info-label {
  font-size: 12px;
  color: #999;
  min-width: 40px;
}

.info-value {
  font-size: 13px;
  color: #333;
}

.info-value.primary {
  color: #4a90d9;
  font-weight: 500;
}

.tag-badge {
  padding: 2px 8px;
  background: #e8f2fc;
  color: #4a90d9;
  border-radius: 8px;
  font-size: 11px;
}

.result-tip {
  margin-top: 8px;
  font-size: 11px;
  color: #999;
  text-align: center;
}

/* ========== 卡片头部 ========== */
.card-head {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.head-badge {
  width: 22px;
  height: 22px;
  background: #4a90d9;
  color: #fff;
  border-radius: 11px;
  font-size: 10px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.head-title {
  flex: 1;
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.count-badge {
  padding: 2px 8px;
  background: #4a90d9;
  color: #fff;
  border-radius: 10px;
  font-size: 11px;
}

.refresh-btn {
  padding: 4px 10px;
  background: #f5f7f9;
  border-radius: 12px;
  font-size: 11px;
  color: #666;
}

.refresh-btn.disabled {
  opacity: 0.5;
}

/* ========== 物料卡片 ========== */
.material-card {
  padding: 12px;
  background: #f8f9fa;
  border-radius: 10px;
  margin-bottom: 10px;
}

.material-card:last-child {
  margin-bottom: 0;
}

.material-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10px;
}

.material-name {
  flex: 1;
}

.name-main {
  font-size: 14px;
  font-weight: 500;
  color: #333;
  display: block;
}

.type-tag {
  display: inline-block;
  padding: 2px 6px;
  background: #e8f2fc;
  color: #4a90d9;
  border-radius: 6px;
  font-size: 10px;
  margin-top: 4px;
}

.status-tag {
  padding: 3px 8px;
  background: #fef5e8;
  color: #d98d2c;
  border-radius: 8px;
  font-size: 11px;
}

.status-tag.done {
  background: #e8f7ed;
  color: #2e9e5a;
}

.material-data {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-bottom: 10px;
}

.data-item {
  background: #fff;
  padding: 8px;
  border-radius: 6px;
}

.data-item.highlight {
  background: #e8f2fc;
}

.data-label {
  font-size: 10px;
  color: #999;
  display: block;
}

.data-value {
  font-size: 12px;
  color: #333;
  font-weight: 500;
  margin-top: 2px;
  display: block;
}

.data-value.big {
  font-size: 14px;
  color: #4a90d9;
}

.data-value.green {
  color: #2e9e5a;
}

.receiver-row {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 10px;
  background: #e8f7ed;
  border-radius: 8px;
  font-size: 12px;
  color: #2e9e5a;
  margin-bottom: 10px;
}

.receiver-badge {
  width: 18px;
  height: 18px;
  background: #2e9e5a;
  color: #fff;
  border-radius: 9px;
  font-size: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-text {
  margin-left: auto;
  color: #999;
  font-size: 11px;
}

/* 物料操作 */
.material-action {
  margin-top: 10px;
}

.action-receive {
  text-align: center;
}

.btn-primary {
  display: inline-block;
  padding: 10px 24px;
  background: #4a90d9;
  color: #fff;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 500;
}

.action-tip {
  margin-top: 6px;
  font-size: 11px;
  color: #999;
}

.arrival-form {
  padding: 12px;
  background: #fff;
  border-radius: 8px;
}

.form-row {
  margin-bottom: 10px;
}

.form-row:last-child {
  margin-bottom: 0;
}

.input-wrap {
  display: flex;
  align-items: center;
  margin-top: 6px;
  background: #f5f7f9;
  border-radius: 8px;
  padding: 0 10px;
}

.input-wrap input {
  flex: 1;
  height: 36px;
  font-size: 14px;
}

.unit {
  font-size: 12px;
  color: #999;
}

.arrival-form textarea {
  margin-top: 6px;
  width: 100%;
  min-height: 50px;
  padding: 8px 10px;
  background: #f5f7f9;
  border-radius: 8px;
  font-size: 13px;
  box-sizing: border-box;
}

.btn-confirm {
  margin-top: 10px;
  padding: 10px;
  background: #2e9e5a;
  color: #fff;
  border-radius: 20px;
  text-align: center;
  font-size: 13px;
  font-weight: 500;
}

/* ========== 统计 ========== */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.stat-box {
  text-align: center;
  padding: 12px 8px;
  background: #f8f9fa;
  border-radius: 10px;
}

.stat-box.primary {
  background: #e8f2fc;
}

.stat-num {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  display: block;
}

.stat-box.primary .stat-num {
  color: #4a90d9;
}

.stat-name {
  font-size: 11px;
  color: #999;
  margin-top: 4px;
  display: block;
}

/* ========== 历史记录 ========== */
.empty {
  text-align: center;
  padding: 30px 20px;
}

.empty-text {
  font-size: 13px;
  color: #999;
}

.history-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #f5f5f5;
}

.history-row:last-child {
  border-bottom: none;
}

.history-left {
  flex: 1;
}

.history-order {
  font-size: 13px;
  font-weight: 500;
  color: #333;
  display: block;
}

.history-detail {
  font-size: 11px;
  color: #999;
  margin-top: 2px;
  display: block;
}

.history-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.history-tag {
  padding: 2px 8px;
  background: #f0f5fa;
  color: #4a90d9;
  border-radius: 8px;
  font-size: 10px;
}

.history-qty {
  font-size: 12px;
  color: #666;
  font-weight: 500;
}

.load-more {
  text-align: center;
  padding: 12px;
  font-size: 12px;
  color: #4a90d9;
}

.load-more .no-more {
  color: #ccc;
}

/* ========== 弹窗 ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 20px;
}

.modal-box {
  width: 100%;
  max-width: 320px;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
}

.modal-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: #4a90d9;
  color: #fff;
}

.modal-title {
  font-size: 15px;
  font-weight: 500;
}

.modal-timer {
  padding: 2px 10px;
  background: rgba(255,255,255,0.2);
  border-radius: 10px;
  font-size: 13px;
}

.modal-content {
  padding: 16px;
  max-height: 280px;
  overflow-y: auto;
}

.confirm-list {
  background: #f8f9fa;
  border-radius: 10px;
  padding: 10px;
}

.confirm-item {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-bottom: 1px solid #eee;
}

.confirm-item:last-child {
  border-bottom: none;
}

.confirm-label {
  font-size: 12px;
  color: #999;
}

.confirm-value {
  font-size: 13px;
  color: #333;
  max-width: 180px;
  overflow: hidden;
  text-overflow: ellipsis;
}

.confirm-value.mono {
  font-family: monospace;
  font-size: 11px;
}

.confirm-value.primary {
  color: #4a90d9;
  font-weight: 500;
}

.modal-btns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding: 12px 16px;
  border-top: 1px solid #f0f0f0;
}

.modal-btn {
  padding: 10px;
  border-radius: 20px;
  text-align: center;
  font-size: 14px;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #f5f7f9;
  color: #666;
}

.modal-btn.confirm {
  background: #4a90d9;
  color: #fff;
}

.modal-btn.confirm.disabled {
  opacity: 0.6;
}
