/* 极简紧凑风格 */
page {
  background: #f7f8fa;
  min-height: 100vh;
}
.page {
  padding: 10px;
  padding-bottom: 24px;
}

/* ===== 顶部标签栏 ===== */
.top-bar {
  background: #fff;
  border-radius: 18px;
  padding: 8px;
  margin-bottom: 8px;
  border: 1px solid #e5e7eb;
}

.auto-detect-switch {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px 12px;
  margin-bottom: 8px;
  background: #f9fafb;
  border-radius: 12px;
  gap: 8px;
}

.switch-label {
  font-size: 13px; /* 菜单字体 */
  color: #475569;
  font-weight: 500;
}

.auto-mode-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px;
  background: linear-gradient(135deg, #e0f2fe 0%, #e0e7ff 100%);
  border-radius: 12px;
  gap: 8px;
}

.tip-icon {
  font-size: 18px; /* 一级标题/图标 */
}

.tip-text {
  font-size: 13px; /* 菜单字体 */
  color: #1e40af;
  font-weight: 500;
}

.type-tabs {
  display: flex;
  gap: 4px;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6px 2px;
  border-radius: 999px;
  font-size: 12px; /* 辅助字体 */
  color: #6b7280;
  background: #f3f4f6;
}
.tab.on {
  background: #f3f5f9;
  color: #1f2937;
  border: 1px solid #e5e7eb;
}
.tab-ico {
  width: 16px;
  height: 16px;
  margin-bottom: 2px;
}
.tab.on .tab-ico {
  filter: none;
}
.tab.more {
  max-width: 32px;
  justify-content: center;
}
.more-dot {
  font-size: 14px;
  letter-spacing: -2px;
  color: #9ca3af;
}

/* ===== 扫码区 ===== */
.scan-area {
  display: flex;
  gap: 8px;
  background: #fff;
  border-radius: 18px;
  padding: 8px;
  margin-bottom: 8px;
  border: 1px solid #e5e7eb;
}
.scan-input {
  flex: 1;
  background: #f9fafb;
  border-radius: 999px;
  padding: 0 12px;
  height: 34px;
  display: flex;
  align-items: center;
  border: 1px solid #e5e7eb;
}
.scan-input input {
  width: 100%;
  height: 34px;
  font-size: 12px;
}
.scan-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0 14px;
  height: 34px;
  background: rgba(255, 255, 255, 0.72);
  color: #1f2937;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 600;
}
.scan-btn.off {
  opacity: 0.5;
}
.scan-ico {
  width: 16px;
  height: 16px;
}

/* ===== 质检选项 ===== */
.qc-bar {
  display: flex;
  gap: 6px;
  background: #fff;
  border-radius: 18px;
  padding: 8px;
  margin-bottom: 8px;
  border: 1px solid #e5e7eb;
}
.qc-opt {
  flex: 1;
  text-align: center;
  padding: 6px 4px;
  border-radius: 999px;
  font-size: 12px;
  color: #6b7280;
  background: #f3f4f6;
}
.qc-opt.on.pass {
  background: #e8f5e9;
  color: #2e7d32;
}
.qc-opt.on.fail {
  background: #fff3e0;
  color: #e65100;
}
.qc-opt.on.fix {
  background: #f3f5f9;
  color: #475569;
}

/* ===== 次品详情 ===== */
.defect-box {
  background: #fff7ed;
  border-radius: 18px;
  padding: 10px;
  margin-bottom: 8px;
  border: 1px solid #fed7aa;
}
.df-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid #f5f0e8;
}
.df-row:last-child {
  border-bottom: none;
}
.df-label {
  width: 36px;
  font-size: 11px;
  color: #9ca3af;
}
.df-picker {
  flex: 1;
}
.df-val {
  font-size: 12px;
  color: #111827;
}
.df-photos {
  display: flex;
  gap: 6px;
  flex: 1;
}
.df-photo {
  position: relative;
  width: 40px;
  height: 40px;
  border-radius: 12px;
  overflow: hidden;
}
.df-photo image {
  width: 100%;
  height: 100%;
}
.df-del {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 16px;
  height: 16px;
  background: rgba(15, 23, 42, 0.7);
  color: #fff;
  font-size: 10px;
  text-align: center;
  line-height: 16px;
  border-radius: 999px;
}
.df-add {
  width: 40px;
  height: 40px;
  border: 1px dashed #d1d5db;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px; /* 一级标题/图标 */
  color: #cbd5e1;
}
.df-add.off {
  opacity: 0.4;
}

/* ===== 仓库输入 ===== */
.wh-box {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  border-radius: 999px;
  padding: 8px 12px;
  margin-bottom: 8px;
  border: 1px solid #e5e7eb;
}
.wh-label {
  font-size: 12px;
  color: #9ca3af;
}
.wh-input {
  flex: 1;
  font-size: 12px;
}

/* ===== 扫码结果 ===== */
.result {
  border-radius: 18px;
  padding: 10px;
  margin-bottom: 8px;
}
.result.ok {
  background: #e8f5e9;
}
.result.err {
  background: #ffebee;
}
.res-top {
  display: flex;
  align-items: center;
  gap: 8px;
}
.res-tag {
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
}
.res-tag.ok {
  background: #2e7d32;
  color: #fff;
}
.res-tag.err {
  background: #c62828;
  color: #fff;
}
.res-msg {
  flex: 1;
  font-size: 12px;
  color: #6b7280;
}
.res-undo {
  padding: 4px 10px;
  background: #fff;
  border: 1px solid #c62828;
  color: #c62828;
  border-radius: 999px;
  font-size: 11px;
}
.res-info {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
  font-size: 12px;
  color: #6b7280;
}
.res-order {
  color: #475569;
  font-weight: 500;
}
.res-style {
  color: #1f2937;
}
.res-proc {
  padding: 2px 8px;
  background: rgba(148, 163, 184, 0.18);
  color: #475569;
  border-radius: 999px;
  font-size: 11px;
}

/* ===== 区块通用 ===== */
.section {
  background: #fff;
  border-radius: 18px;
  padding: 10px;
  margin-bottom: 8px;
  border: 1px solid #e5e7eb;
}
.sec-head {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}
.sec-title {
  flex: 1;
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}
.sec-count {
  display: inline-block;
  padding: 0 6px;
  background: rgba(255, 255, 255, 0.72);
  color: #1f2937;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  font-size: 11px;
  margin-left: 4px;
}
.sec-refresh {
  padding: 2px 8px;
  background: #f5f6f8;
  border-radius: 10px;
  font-size: 11px;
  color: #6b7280;
}
.sec-refresh.off {
  opacity: 0.4;
}

/* ===== 物料卡片 ===== */
.mat-card {
  background: #f9fafb;
  border-radius: 8px;
  padding: 10px;
  margin-bottom: 8px;
}
.mat-card:last-child {
  margin-bottom: 0;
}
.mat-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.mat-name {
  font-size: 12px;
  font-weight: 500;
  color: #1f2937;
}
.mat-tag {
  padding: 2px 8px;
  background: #fff3e0;
  color: #e65100;
  border-radius: 8px;
  font-size: 11px;
}
.mat-tag.done {
  background: #e8f5e9;
  color: #2e7d32;
}
.mat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6px;
  margin-bottom: 8px;
}
.mat-cell {
  background: #fff;
  padding: 6px;
  border-radius: 6px;
  text-align: center;
}
.mc-label {
  display: block;
  font-size: 11px;
  color: #9ca3af;
}
.mc-val {
  display: block;
  font-size: 12px;
  color: #1f2937;
  font-weight: 500;
  margin-top: 2px;
}
.mc-val.hl {
  color: #475569;
}
.mc-val.gr {
  color: #2e7d32;
}
.mat-receiver {
  padding: 6px 8px;
  background: #e8f5e9;
  border-radius: 6px;
  font-size: 11px;
  color: #2e7d32;
  margin-bottom: 8px;
}
.mat-time {
  float: right;
  color: #999;
  font-size: 10px;
}
.mat-action {
  text-align: center;
}
.btn-receive {
  display: inline-block;
  padding: 8px 20px;
  background: rgba(255, 255, 255, 0.72);
  color: #1f2937;
  border: 1px solid #e5e7eb;
  border-radius: 16px;
  font-size: 12px;
}
.mat-form {
  background: #fff;
  border-radius: 6px;
  padding: 8px;
}
.mf-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}
.mf-row:last-child {
  margin-bottom: 0;
}
.mf-label {
  width: 32px;
  font-size: 11px;
  color: #999;
}
.mf-row input {
  flex: 1;
  height: 32px;
  padding: 0 8px;
  background: #f5f6f8;
  border-radius: 6px;
  font-size: 13px;
}
.mf-unit {
  font-size: 11px;
  color: #999;
}
.btn-confirm {
  margin-top: 8px;
  padding: 8px;
  background: #2e7d32;
  color: #fff;
  border-radius: 16px;
  text-align: center;
  font-size: 12px;
}

/* ===== 统计 ===== */
.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
}
.st {
  text-align: center;
  padding: 8px 4px;
  background: #f5f6f8;
  border-radius: 8px;
}
.st.hl {
  background: #f3f5f9;
}
.st-num {
  display: block;
  font-size: 16px; /* 二级标题/数值强调 */
  font-weight: 600;
  color: #333;
}
.st.hl .st-num {
  color: #475569;
}
.st-label {
  display: block;
  font-size: 10px;
  color: #999;
  margin-top: 2px;
}

/* ===== 历史记录 ===== */
.empty {
  text-align: center;
  padding: 20px;
  font-size: 12px;
  color: #999;
}
.hist {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid #f5f6f8;
}
.hist:last-of-type {
  border-bottom: none;
}
.hist-left {
  flex: 1;
}
.hist-order {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: #333;
}
.hist-detail {
  display: block;
  font-size: 10px;
  color: #999;
  margin-top: 2px;
}
.hist-right {
  display: flex;
  align-items: center;
  gap: 6px;
}
.hist-tag {
  padding: 2px 6px;
  background: #f5f6f8;
  color: #475569;
  border-radius: 6px;
  font-size: 10px;
}
.hist-tag.pending {
  color: #ff9800;
  background: #fff3e0;
  font-weight: 500;
}
.hist-qty {
  font-size: 12px;
  color: #666;
  font-weight: 500;
}
.hist-action {
  font-size: 10px;
  color: #1890ff;
  padding: 3px 8px;
  border: 1px solid #1890ff;
  border-radius: 4px;
  margin-left: 4px;
  background: #e6f7ff;
  font-weight: 500;
}
.load-more {
  text-align: center;
  padding: 10px;
  font-size: 11px;
  color: #475569;
}
.load-more .no-more {
  color: #ccc;
}

/* ===== 弹窗 ===== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 16px;
}
.modal-box {
  width: 100%;
  max-width: 300px;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}

.modal-box.wide {
  max-width: 90vw;
}

.modal-head {
  padding: 12px 14px;
  background: rgba(255, 255, 255, 0.8);
  color: #1f2937;
  border-bottom: 1px solid #e5e7eb;
  font-size: 14px;
  font-weight: 500;
}
.modal-cd {
  float: right;
  padding: 2px 8px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  font-size: 12px;
}
.modal-body {
  padding: 12px;
  max-height: 400px;
  overflow-y: auto;
}
.cf-list {
  background: #f9fafb;
  border-radius: 8px;
  padding: 8px;
  margin-bottom: 10px;
}

/* 质检选项 - 弹窗内 */
.qc-modal-bar {
  margin-top: 10px;
  padding: 10px 0;
  border-top: 1px solid #f0f0f0;
}
.qc-modal-label {
  display: block;
  font-size: 11px;
  color: #999;
  margin-bottom: 8px;
}

.qc-defect-input {
  width: 100%;
  height: 40px;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  padding: 0 12px;
  font-size: 14px;
  box-sizing: border-box;
}

.qc-receive-tip {
  margin-top: 12px;
  padding: 10px 12px;
  background: #f0f9ff;
  border-left: 3px solid #3b82f6;
  border-radius: 6px;
}

.qc-tip-text {
  font-size: 12px;
  color: #1e40af;
  line-height: 1.5;
}

.qc-modal-opts {
  display: flex;
  gap: 6px;
}
.qc-modal-opt {
  flex: 1;
  text-align: center;
  padding: 8px 4px;
  border-radius: 12px;
  font-size: 12px;
  color: #6b7280;
  background: #f3f4f6;
  border: 1px solid transparent;
}
.qc-modal-opt.on.pass {
  background: #e8f5e9;
  color: #2e7d32;
  border-color: #a5d6a7;
}
.qc-modal-opt.on.fail {
  background: #fff3e0;
  color: #e65100;
  border-color: #ffcc80;
}
.qc-modal-opt.on.fix {
  background: #f3f5f9;
  color: #475569;
  border-color: #cbd5e1;
}

/* 次品详情 - 弹窗内 */
.defect-modal-box {
  margin-top: 10px;
  background: #fff7ed;
  border-radius: 12px;
  padding: 10px;
  border: 1px solid #fed7aa;
}

/* 面料采购列表 - 弹窗内 */
.purchase-modal-list {
  margin-top: 10px;
  max-height: 300px;
  overflow-y: auto;
}

.purchase-modal-item {
  background: #f9fafb;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 10px;
  border: 1px solid #e5e7eb;
}

.purchase-modal-item:last-child {
  margin-bottom: 0;
}

.pmi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
  padding-bottom: 8px;
  border-bottom: 1px solid #e5e7eb;
}

.pmi-name {
  font-size: 13px;
  font-weight: 600;
  color: #1f2937;
}

.pmi-unit {
  font-size: 11px;
  color: #9ca3af;
  background: #f3f4f6;
  padding: 2px 8px;
  border-radius: 8px;
}

.pmi-row {
  display: flex;
  align-items: center;
  margin-bottom: 6px;
}

.pmi-row:last-child {
  margin-bottom: 0;
}

.pmi-label {
  width: 70px;
  font-size: 11px;
  color: #6b7280;
  flex-shrink: 0;
}

.pmi-value {
  flex: 1;
  font-size: 13px;
  color: #1f2937;
}

.pmi-value.demand {
  color: #2563eb;
  font-weight: 600;
}

.pmi-input {
  flex: 1;
  background: #fff;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  padding: 6px 10px;
  font-size: 12px;
  height: 32px;
}
.cf-item {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  border-bottom: 1px solid #eee;
}
.cf-item:last-child {
  border-bottom: none;
}
.cf-k {
  font-size: 11px;
  color: #999;
}
.cf-v {
  font-size: 12px;
  color: #333;
  max-width: 160px;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cf-input {
  flex: 1;
  font-size: 12px;
  color: #333;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  padding: 4px 8px;
  text-align: right;
  max-width: 160px;
}

.cf-v.mono {
  font-family: monospace;
  font-size: 10px;
}
.cf-v.hl {
  color: #475569;
  font-weight: 500;
}
.modal-btns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  padding: 10px 12px;
  border-top: 1px solid #f0f0f0;
}
.mbtn {
  padding: 10px;
  border-radius: 18px;
  text-align: center;
  font-size: 13px;
  font-weight: 500;
}
.mbtn.cancel {
  background: #f5f6f8;
  color: #666;
}
.mbtn.ok {
  background: rgba(255, 255, 255, 0.72);
  color: #1f2937;
  border: 1px solid #e5e7eb;
}
.mbtn.ok.off {
  opacity: 0.5;
}

/* 质检处理弹窗 */
.quality-modal .modal-container {
  max-height: 80vh;
  overflow-y: auto;
}

.qm-info {
  display: flex;
  align-items: center;
  padding: 8px 0;
  font-size: 13px;
  border-bottom: 1px solid #f5f5f5;
}

.qm-label {
  color: #999;
  width: 70px;
  flex-shrink: 0;
}

.qm-value {
  color: #333;
  font-weight: 500;
}

.qm-section {
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid #e5e7eb;
}

.qm-section-title {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 12px;
}

.qm-radio-group {
  display: flex;
  gap: 12px;
}

.qm-radio {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  font-size: 14px;
  color: #666;
  background: #fff;
  transition: all 0.2s;
}

.qm-radio.active {
  border-color: #1890ff;
  background: #e6f7ff;
  color: #1890ff;
  font-weight: 500;
}

.qm-radio-icon {
  width: 18px;
  height: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #d9d9d9;
  border-radius: 50%;
  font-size: 12px;
  color: #fff;
}

.qm-radio.active .qm-radio-icon {
  background: #1890ff;
  border-color: #1890ff;
}

.qm-defective {
  margin-top: 16px;
}

.qm-field {
  margin-bottom: 16px;
}

.qm-field-label {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}

.qm-input {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  font-size: 14px;
  background: #fff;
}

.qm-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 40px;
  padding: 0 12px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  background: #fff;
}

.qm-picker-value {
  font-size: 14px;
  color: #333;
  flex: 1;
}

.qm-picker-arrow {
  font-size: 18px; /* 一级标题/图标 */
  color: #999;
  transform: rotate(90deg);
}

.qm-textarea {
  width: 100%;
  min-height: 80px;
  padding: 10px 12px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  font-size: 14px;
  background: #fff;
  line-height: 1.6;
}

/* 物料采购处理弹窗 */
.procurement-modal .modal-container {
  max-height: 80vh;
  overflow-y: auto;
}

.pm-info {
  display: flex;
  align-items: center;
  padding: 8px 0;
  font-size: 13px;
  border-bottom: 1px solid #f5f5f5;
  margin-bottom: 16px;
}

.pm-label {
  color: #999;
  width: 70px;
  flex-shrink: 0;
}

.pm-value {
  color: #333;
  font-weight: 500;
}

.pm-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.pm-item {
  padding: 12px;
  background: #f9fafb;
  border-radius: 8px;
  border: 1px solid #e5e7eb;
}

.pm-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid #e5e7eb;
}

.pm-item-name {
  font-size: 14px;
  font-weight: 500;
  color: #333;
}

.pm-item-unit {
  font-size: 12px;
  color: #999;
  padding: 2px 8px;
  background: #fff;
  border-radius: 4px;
}

.pm-field {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.pm-field:last-child {
  margin-bottom: 0;
}

.pm-field-label {
  font-size: 13px;
  color: #666;
  width: 70px;
  flex-shrink: 0;
}

.pm-field-value {
  flex: 1;
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.pm-field-value.demand {
  color: #1890ff;
}

.pm-input {
  flex: 1;
  height: 36px;
  padding: 0 10px;
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  font-size: 14px;
  background: #fff;
}

