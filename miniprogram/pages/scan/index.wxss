page {
  background: linear-gradient(135deg, rgba(169, 201, 255, 0.18), rgba(255, 255, 255, 0.72));
}

.container .card {
  background: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 26px;
  padding: 14px;
  box-shadow: none;
}

.title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 10px;
  color: #1f2937;
}

.input {
  background: rgba(255, 255, 255, 0.65);
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 18px;
  padding: 8px 12px;
}

.btn-primary {
  border-radius: 999px;
  padding: 10px 14px;
  font-size: 12px;
}

.btn-secondary {
  background: rgba(148, 163, 184, 0.18);
  color: #374151;
  border-radius: 999px;
  padding: 8px 12px;
  text-align: center;
  font-size: 12px;
}

.btn-danger {
  background: rgba(255, 59, 48, 0.9);
  color: #ffffff;
  border: none;
  border-radius: 999px;
  padding: 10px 14px;
  text-align: center;
  font-size: 12px;
}

.qty-hint {
  margin-top: 6px;
  font-size: 12px;
  color: #8e8e93;
  line-height: 1.4;
}

.textarea {
  min-height: 76px;
  padding-top: 10px;
  padding-bottom: 10px;
}

.img-grid {
  margin-top: 8px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.img-item {
  position: relative;
  width: 78px;
  height: 78px;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid #e5e5ea;
  background: #ffffff;
}

.img {
  width: 100%;
  height: 100%;
}

.img-del {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 18px;
  height: 18px;
  line-height: 18px;
  text-align: center;
  border-radius: 999px;
  background: rgba(17, 24, 39, 0.75);
  color: #ffffff;
  font-size: 14px;
}

.img-add {
  width: 78px;
  height: 78px;
  border-radius: 10px;
  border: 1px dashed #d1d5db;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #8e8e93;
}

.img-add-plus {
  font-size: 20px;
  line-height: 20px;
}

.img-add-text {
  margin-top: 6px;
  font-size: 12px;
}

.scan-tip {
  margin-top: 10px;
  font-size: 12px;
  color: #8e8e93;
}

.my-panel {
  margin-top: 12px;
  padding: 12px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.55);
}

.my-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.my-title {
  font-size: 13px;
  font-weight: 600;
  color: #2c2c2e;
}

.my-refresh {
  padding: 8px 10px;
  border-radius: 10px;
  font-size: 12px;
}

.my-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: 10px;
}

.my-stat {
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 22px;
  padding: 10px 12px;
  background: rgba(255, 255, 255, 0.6);
  box-shadow: none;
}

.my-stat-value {
  font-size: 16px;
  font-weight: 600;
  color: #1c1c1e;
}

.my-stat-label {
  font-size: 12px;
  color: #8e8e93;
}

.list-item {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 12px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.55);
  margin-top: 10px;
}

.purchase-panel {
  margin-top: 12px;
  padding: 12px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.55);
}

.purchase-item {
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 22px;
  padding: 12px;
  margin-top: 10px;
  background: rgba(255, 255, 255, 0.55);
}

.confirm-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 16px;
  box-sizing: border-box;
}

.confirm-card {
  width: 100%;
  max-width: 420px;
  background: #ffffff;
  border-radius: 24px;
  padding: 16px;
  box-sizing: border-box;
}

.confirm-title {
  font-size: 13px;
  font-weight: 600;
  color: #1c1c1e;
}

.confirm-sub {
  margin-top: 6px;
  font-size: 12px;
  color: #8e8e93;
}

.confirm-body {
  margin-top: 10px;
  max-height: 260px;
  overflow: auto;
}

.confirm-row {
  margin-top: 6px;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.confirm-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 14px;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: 13px;
  font-weight: 600;
}

.item-sub {
  display: block;
  width: 100%;
  margin-top: 6px;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

/* 面辅料采购高亮样式 */
.item-highlight {
  color: #1d4ed8;
  font-weight: 600;
  background: rgba(59, 130, 246, 0.1);
  padding: 6px 10px;
  border-radius: 8px;
  margin-top: 8px;
}

.status-received {
  color: #059669;
  font-weight: 500;
}

.status-pending {
  color: #d97706;
  font-weight: 500;
}

.arrival-section {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px dashed rgba(148, 163, 184, 0.4);
}

.hint-text {
  margin-top: 10px;
  padding: 10px;
  background: rgba(251, 191, 36, 0.15);
  border-radius: 10px;
  font-size: 12px;
  color: #92400e;
  text-align: center;
}
