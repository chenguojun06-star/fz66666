<view class="page">
  <!-- 顶部操作栏 - 紧凑型 -->
  <view class="top-bar">
    <view class="type-tabs">
      <view class="tab {{scanTypeIndex === 0 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="0">
        <image class="tab-ico" src="/assets/icons/cut.svg" mode="aspectFit" />
        <text>裁剪</text>
      </view>
      <view class="tab {{scanTypeIndex === 1 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="1">
        <image class="tab-ico" src="/assets/icons/sew.svg" mode="aspectFit" />
        <text>缝制</text>
      </view>
      <view class="tab {{scanTypeIndex === 4 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="4">
        <image class="tab-ico" src="/assets/icons/check.svg" mode="aspectFit" />
        <text>质检</text>
      </view>
      <view class="tab {{scanTypeIndex === 5 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="5">
        <image class="tab-ico" src="/assets/icons/pack.svg" mode="aspectFit" />
        <text>包装</text>
      </view>
      <view class="tab {{scanTypeIndex === 6 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="6">
        <image class="tab-ico" src="/assets/icons/store.svg" mode="aspectFit" />
        <text>入库</text>
      </view>
      <picker class="more-picker" mode="selector" range="{{scanTypeOptions}}" range-key="label" value="{{scanTypeIndex}}" bindchange="onScanTypeChange">
        <view class="tab more">
          <text class="more-dot">···</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 扫码区 -->
  <view class="scan-area">
    <view class="scan-input">
      <input type="digit" placeholder="数量" value="{{quantity}}" bindinput="onQuantityInput" />
    </view>
    <view class="scan-btn {{loading ? 'off' : ''}}" bindtap="onScan">
      <image class="scan-ico" src="/assets/icons/scan.svg" mode="aspectFit" />
      <text>{{loading ? '...' : '扫码'}}</text>
    </view>
  </view>

  <!-- 质检选项 - 扫码后在确认弹窗中选择，不要提前显示 -->

  <!-- 入库仓库 -->
  <view wx:if="{{scanTypeOptions[scanTypeIndex].value === 'warehouse'}}" class="wh-box">
    <text class="wh-label">仓库</text>
    <input class="wh-input" placeholder="请输入仓库名" value="{{warehouse}}" bindinput="onWarehouseInput" />
  </view>

  <!-- 扫码结果 -->
  <view wx:if="{{lastResult}}" class="result {{lastResult.success ? 'ok' : 'err'}}">
    <view class="res-top">
      <text class="res-tag {{lastResult.success ? 'ok' : 'err'}}">{{lastResult.success ? '成功' : '失败'}}</text>
      <text class="res-msg">{{lastResult.message}}</text>
      <text wx:if="{{lastResult.success && undo.canUndo}}" class="res-undo" bindtap="onUndoLast">{{undo.loading ? '...' : '撤销'}}</text>
    </view>
    <view class="res-info">
      <text wx:if="{{lastResult.orderNo}}" class="res-order">{{lastResult.orderNo}}</text>
      <text wx:if="{{lastResult.styleNo}}" class="res-style">{{lastResult.styleNo}}</text>
      <text wx:if="{{lastResult.color}}">{{lastResult.color}}</text>
      <text wx:if="{{lastResult.size}}">{{lastResult.size}}</text>
      <text wx:if="{{lastResult.processName}}" class="res-proc">{{lastResult.processName}}</text>
      <text wx:if="{{lastResult.unitPrice != null}}">¥{{lastResult.unitPrice}}</text>
    </view>
  </view>

  <!-- 面辅料采购 - 已移至扫码确认弹窗 -->
  <view wx:if="false" class="section">
    <view class="sec-head">
      <text class="sec-title">📦 面辅料 <text class="sec-count">{{materialPurchases.length}}</text></text>
    </view>
    <view wx:for="{{materialPurchases}}" wx:key="id" class="mat-card">
      <view class="mat-top">
        <text class="mat-name">{{item.materialName || item.materialCode || '物料'}}</text>
        <text class="mat-tag {{item.receiverName ? 'done' : ''}}">{{item.receiverName ? '已领' : '待领'}}</text>
      </view>
      <view class="mat-grid">
        <view class="mat-cell"><text class="mc-label">需求</text><text class="mc-val hl">{{item.demandQuantity || item.purchaseQuantity || 0}}{{item.unit || '米'}}</text></view>
        <view class="mat-cell"><text class="mc-label">采购</text><text class="mc-val">{{item.purchaseQuantity || 0}}{{item.unit || '米'}}</text></view>
        <view class="mat-cell"><text class="mc-label">到货</text><text class="mc-val {{item.arrivedQuantity > 0 ? 'gr' : ''}}">{{item.arrivedQuantity || 0}}{{item.unit || '米'}}</text></view>
      </view>
      <view wx:if="{{item.receiverName}}" class="mat-receiver">👤 {{item.receiverName}} <text wx:if="{{item.receivedTime}}" class="mat-time">{{item.receivedTime}}</text></view>
      
      <view wx:if="{{!item.receiverName && item.status !== 'completed' && item.status !== 'cancelled'}}" class="mat-action">
        <view class="btn-receive" bindtap="onReceivePurchase" data-idx="{{index}}">领取任务</view>
      </view>
      <view wx:if="{{item.receiverName}}" class="mat-form">
        <view class="mf-row">
          <text class="mf-label">到货</text>
          <input type="digit" placeholder="0" value="{{item.arrivedInput}}" bindinput="onPurchaseArrivedInput" data-idx="{{index}}" />
          <text class="mf-unit">{{item.unit || '米'}}</text>
        </view>
        <view class="mf-row">
          <text class="mf-label">备注</text>
          <input placeholder="选填" value="{{item.remarkInput}}" bindinput="onPurchaseRemarkInput" data-idx="{{index}}" />
        </view>
        <view class="btn-confirm" bindtap="onConfirmPurchaseArrived" data-idx="{{index}}">确认到货</view>
      </view>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="section">
    <view class="sec-head">
      <text class="sec-title">📊 今日统计</text>
      <text class="sec-refresh {{my.loadingStats ? 'off' : ''}}" bindtap="refreshMy">刷新</text>
    </view>
    <view class="stats">
      <view class="st"><text class="st-num">{{my.stats.scanCount || 0}}</text><text class="st-label">扫码</text></view>
      <view class="st"><text class="st-num">{{my.stats.orderCount || 0}}</text><text class="st-label">订单</text></view>
      <view class="st"><text class="st-num">{{my.stats.totalQuantity || 0}}</text><text class="st-label">数量</text></view>
      <view class="st hl"><text class="st-num">¥{{my.stats.totalAmount || 0}}</text><text class="st-label">收入</text></view>
    </view>
  </view>

  <!-- 扫码记录 -->
  <view class="section">
    <view class="sec-head">
      <text class="sec-title">📋 扫码记录</text>
    </view>
    <view wx:if="{{my.history.list.length === 0 && !my.loadingHistory}}" class="empty">暂无记录</view>
    <view wx:for="{{my.history.list}}" wx:key="id" class="hist">
      <view class="hist-left">
        <text class="hist-order">{{item.orderNo || '-'}}</text>
        <text class="hist-detail">{{item.styleNo || '-'}} · {{item.color || '-'}} · {{item.size || '-'}}</text>
      </view>
      <view class="hist-right">
        <text class="hist-tag">{{item.processName || item.progressStage || '-'}}</text>
        <text class="hist-qty">×{{item.quantity || 0}}</text>
      </view>
    </view>
    <view class="load-more" bindtap="loadMoreMyHistory">
      <text wx:if="{{my.loadingHistory}}">加载中...</text>
      <text wx:elif="{{my.history.hasMore}}">加载更多</text>
      <text wx:else class="no-more">— END —</text>
    </view>
  </view>

  <!-- 确认弹窗 -->
  <view wx:if="{{scanConfirm.visible}}" class="modal">
    <view class="modal-box {{scanConfirm.detail.isProcurement ? 'wide' : ''}}">
      <view class="modal-head">
        {{scanConfirm.detail.isProcurement ? '面辅料采购' : '确认提交'}} 
        <text class="modal-cd">{{scanConfirm.remain}}s</text>
      </view>
      <view class="modal-body">
        <view wx:if="{{scanConfirm.detail}}" class="cf-list">
          <view class="cf-item"><text class="cf-k">二维码</text><text class="cf-v mono">{{scanConfirm.detail.scanCode}}</text></view>
          <view wx:if="{{!scanConfirm.detail.isProcurement}}" class="cf-item"><text class="cf-k">数量</text><text class="cf-v">{{scanConfirm.detail.quantity}}</text></view>
          <view wx:if="{{scanConfirm.detail.orderNo}}" class="cf-item"><text class="cf-k">订单</text><text class="cf-v hl">{{scanConfirm.detail.orderNo}}</text></view>
          <view wx:if="{{scanConfirm.detail.styleNo}}" class="cf-item"><text class="cf-k">款号</text><text class="cf-v">{{scanConfirm.detail.styleNo}}</text></view>
          <view wx:if="{{scanConfirm.detail.progressStage && !scanConfirm.detail.isProcurement}}" class="cf-item"><text class="cf-k">环节</text><text class="cf-v">{{scanConfirm.detail.progressStage}}</text></view>
        </view>
        
        <!-- 面辅料采购列表 - 在弹窗中显示 -->
        <view wx:if="{{scanConfirm.detail.isProcurement && scanConfirm.materialPurchases && scanConfirm.materialPurchases.length}}" class="purchase-modal-list">
          <view wx:for="{{scanConfirm.materialPurchases}}" wx:key="id" class="purchase-modal-item">
            <view class="pmi-header">
              <text class="pmi-name">{{item.materialName || item.materialCode || '物料'}}</text>
              <text class="pmi-unit">{{item.unit || '米'}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">需求数量</text>
              <text class="pmi-value demand">{{item.demandQuantity || item.purchaseQuantity || 0}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">采购数量</text>
              <input class="pmi-input" type="digit" placeholder="请填写实际采购数量" value="{{item.purchaseInput}}" bindinput="onModalPurchaseInput" data-idx="{{index}}" />
            </view>
            <view class="pmi-row">
              <text class="pmi-label">备注</text>
              <input class="pmi-input" placeholder="选填" value="{{item.remarkInput}}" bindinput="onModalPurchaseRemarkInput" data-idx="{{index}}" />
            </view>
          </view>
        </view>
        
        <!-- 质检次品数量 -->
        <view wx:if="{{scanTypeOptions[scanTypeIndex].value === 'quality' && !scanConfirm.detail.isProcurement}}" class="qc-modal-bar">
          <text class="qc-modal-label">次品数量</text>
          <input class="qc-defect-input" type="number" placeholder="默认全部合格，填写次品数" value="{{defectQuantity}}" bindinput="onDefectQuantityInput" />
        </view>
        
        <!-- 次品详情 -->
        <view wx:if="{{scanTypeOptions[scanTypeIndex].value === 'quality' && defectQuantity > 0 && !scanConfirm.detail.isProcurement}}" class="defect-modal-box">
          <view class="df-row">
            <text class="df-label">类型</text>
            <picker class="df-picker" mode="selector" range="{{defectCategoryOptions}}" range-key="label" value="{{defectCategoryIndex}}" bindchange="onDefectCategoryChange">
              <text class="df-val">{{defectCategoryOptions[defectCategoryIndex].label}} ›</text>
            </picker>
          </view>
          <view class="df-row">
            <text class="df-label">处理</text>
            <picker class="df-picker" mode="selector" range="{{defectRemarkOptions}}" range-key="label" value="{{defectRemarkIndex}}" bindchange="onDefectRemarkChange">
              <text class="df-val">{{defectRemarkOptions[defectRemarkIndex].label}} ›</text>
            </picker>
          </view>
        </view>
      </view>
      <view class="modal-btns">
        <view class="mbtn cancel" bindtap="onCancelScan">取消</view>
        <view class="mbtn ok {{scanConfirm.loading ? 'off' : ''}}" bindtap="onConfirmScan">{{scanConfirm.loading ? '...' : (scanConfirm.detail.isProcurement ? '领取并提交' : '确认')}}</view>
      </view>
    </view>
  </view>
</view>
