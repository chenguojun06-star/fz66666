<wxs module="utils">
  // 格式化相对时间
  function formatRelativeTime(timeStr) {
    if (!timeStr) return '-';

    var now = getDate().getTime();
    var time = getDate(timeStr).getTime();
    var diff = now - time;

    var minute = 60 * 1000;
    var hour = 60 * minute;
    var day = 24 * hour;

    if (diff < minute) {
      return '刚刚';
    } else if (diff < hour) {
      return Math.floor(diff / minute) + '分钟前';
    } else if (diff < day) {
      return Math.floor(diff / hour) + '小时前';
    } else if (diff < 7 * day) {
      return Math.floor(diff / day) + '天前';
    } else {
      var date = getDate(timeStr);
      var month = '' + (date.getMonth() + 1);
      var dayNum = '' + date.getDate();
      var hours = '' + date.getHours();
      var minutes = '' + date.getMinutes();

      if (month.length < 2) month = '0' + month;
      if (dayNum.length < 2) dayNum = '0' + dayNum;
      if (hours.length < 2) hours = '0' + hours;
      if (minutes.length < 2) minutes = '0' + minutes;

      return month + '-' + dayNum + ' ' + hours + ':' + minutes;
    }
  }

  module.exports = {
    formatRelativeTime: formatRelativeTime
  };
</wxs>

<view class="page">
  <!-- 通用悬浮铃铛组件 -->
  <floating-bell />

  <!-- 扫码区 -->
  <view class="scan-area">
    <!-- 生产节点选择器 -->
    <picker class="scan-type-picker" mode="selector" range="{{scanTypeOptions}}" range-key="label" value="{{scanTypeIndex}}" bindchange="onScanTypeChange">
      <view class="picker-display">
        <text class="picker-label">{{scanTypeOptions[scanTypeIndex].label}}</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>

    <view class="scan-input">
      <input type="digit" placeholder="数量" value="{{quantity}}" bindinput="onQuantityInput" />
    </view>
    <view class="scan-btn {{loading ? 'off' : ''}}" bindtap="onScan">
      <text>{{loading ? '...' : '扫码'}}</text>
    </view>
  </view>

  <!-- 质检选项 - 扫码后在确认弹窗中选择，不要提前显示 -->

  <!-- 入库仓库 -->
  <view wx:if="{{scanTypeOptions[scanTypeIndex].value === 'warehouse'}}" class="wh-box">
    <text class="wh-label">仓库</text>
    <input class="wh-input" placeholder="请输入仓库名" value="{{warehouse}}" bindinput="onWarehouseInput" />
  </view>

  <!-- 扫码结果 -->
  <view wx:if="{{lastResult}}" class="result {{lastResult.success ? 'ok' : 'err'}}">
    <view class="res-top">
      <text class="res-tag {{lastResult.success ? 'ok' : 'err'}}">{{lastResult.success ? '成功' : '失败'}}</text>
      <text class="res-msg">{{lastResult.message}}</text>
      <text wx:if="{{lastResult.success && undo.canUndo}}" class="res-undo" bindtap="onUndoLast">{{undo.loading ? '...' : '撤销'}}</text>
    </view>
    <view class="res-info">
      <text wx:if="{{lastResult.orderNo}}" class="res-order">{{lastResult.orderNo}}</text>
      <text wx:if="{{lastResult.styleNo}}" class="res-style">{{lastResult.styleNo}}</text>
      <text wx:if="{{lastResult.color}}">{{lastResult.color}}</text>
      <text wx:if="{{lastResult.size}}">{{lastResult.size}}</text>
      <text wx:if="{{lastResult.processName}}" class="res-proc">{{lastResult.processName}}</text>
      <text wx:if="{{lastResult.unitPrice != null}}" class="{{lastResult.unitPriceHint ? 'res-price-warn' : ''}}">¥{{lastResult.unitPrice}}{{lastResult.unitPriceHint ? ' ⚠️' : ''}}</text>
    </view>
    <!-- 单价提示信息 -->
    <view wx:if="{{lastResult.unitPriceHint}}" class="res-hint">
      <text class="hint-icon">⚠️</text>
      <text class="hint-text">{{lastResult.unitPriceHint}}</text>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="section">
    <view class="sec-head">
      <text class="section-title">📊 今日统计</text>
      <text class="sec-refresh {{my.loadingStats ? 'off' : ''}}" bindtap="refreshMy">刷新</text>
    </view>
    <view class="stats">
      <view class="st"><text class="st-num">{{my.stats.scanCount || 0}}</text><text class="st-label">扫码</text></view>
      <view class="st"><text class="st-num">{{my.stats.orderCount || 0}}</text><text class="st-label">订单</text></view>
      <view class="st"><text class="st-num">{{my.stats.totalQuantity || 0}}</text><text class="st-label">数量</text></view>
      <view class="st hl"><text class="st-num">¥{{my.stats.totalAmount || 0}}</text><text class="st-label">收入</text></view>
    </view>
  </view>

  <!-- 我的裁剪任务 -->
  <view wx:if="{{my.cuttingTasks && my.cuttingTasks.length > 0}}" class="section">
    <view class="sec-head">
      <text class="section-title">✂️ 我的裁剪任务</text>
    </view>
    <view wx:for="{{my.cuttingTasks}}" wx:key="id" class="procurement-task-card">
      <view class="ptc-header">
        <text class="ptc-order">订单: {{item.productionOrderNo}}</text>
        <text class="ptc-style">款号: {{item.styleNo}}</text>
      </view>
      <view wx:if="{{item.color}}" class="ptc-name">颜色: {{item.color}}</view>
      <view class="ptc-footer">
        <text class="ptc-count">数量: {{item.orderQuantity || 0}}</text>
        <view class="ptc-btn" bindtap="onHandleCutting" data-task-id="{{item.id}}">生成菲号</view>
      </view>
    </view>
  </view>

  <!-- 我的采购任务 -->
  <view wx:if="{{my.procurementTasks && my.procurementTasks.length > 0}}" class="section">
    <view class="sec-head">
      <text class="section-title">🛒 我的采购任务</text>
    </view>
    <view wx:for="{{my.procurementTasks}}" wx:key="orderNo" class="procurement-task-card">
      <view class="ptc-header">
        <text class="ptc-order">订单: {{item.orderNo}}</text>
        <text class="ptc-style">款号: {{item.styleNo}}</text>
      </view>
      <view wx:if="{{item.styleName}}" class="ptc-name">{{item.styleName}}</view>
      <view class="ptc-footer">
        <text class="ptc-count">{{item.totalCount}}项待采购</text>
        <view class="ptc-btn" bindtap="onHandleProcurement" data-order-no="{{item.orderNo}}">填写数量</view>
      </view>
    </view>
  </view>

  <!-- 扫码记录 -->
  <view class="section">
    <view class="sec-head">
      <text class="section-title">📋 扫码记录</text>
    </view>
    <view wx:if="{{my.groupedHistory.length === 0 && !my.loadingHistory}}" class="empty">暂无记录</view>

    <!-- 聚合后的分组显示 -->
    <view wx:for="{{my.groupedHistory}}" wx:key="id" class="hist-group">
      <!-- 分组头部：折叠显示 -->
      <view class="hist-group-header" bindtap="toggleGroupExpand" data-group-id="{{item.id}}">
        <view class="hgh-main">
          <text class="hgh-order">{{item.orderNo}}</text>
          <text class="hgh-style">款号: {{item.styleNo}}</text>
          <text class="hgh-stage">{{item.stage}}</text>
        </view>
        <view class="hgh-summary">
          <view class="hgh-left">
            <text class="hgh-total">共{{item.totalQuantity}}件</text>
            <text wx:if="{{item.qualifiedCount > 0}}" class="hgh-stat qualified">✓{{item.qualifiedCount}}</text>
            <text wx:if="{{item.defectiveCount > 0}}" class="hgh-stat defective">✗{{item.defectiveCount}}</text>
          </view>
          <view class="hgh-right">
            <text class="hgh-time">最新: {{utils.formatRelativeTime(item.latestTime)}}</text>
          </view>
        </view>
      </view>

      <!-- 分组详情：展开显示 -->
      <view wx:if="{{item.expanded}}" class="hist-group-details">
        <view wx:for="{{item.items}}" wx:for-item="record" wx:for-index="recordIdx" wx:key="id" class="hist-detail-item">
          <view class="hdi-row">
            <text class="hdi-label">颜色:</text>
            <text class="hdi-value">{{record.color || '-'}}</text>
            <text class="hdi-label">码数:</text>
            <text class="hdi-value">{{record.size || '-'}}</text>
          </view>
          <view class="hdi-row">
            <text class="hdi-label">数量:</text>
            <text class="hdi-value">{{record.quantity || 0}}件</text>
            <text class="hdi-label">单价:</text>
            <text class="hdi-value">¥{{record.unitPrice || '-'}}</text>
          </view>
          <view class="hdi-row">
            <text class="hdi-time">{{record.createdAt || record.scanTime || record.time}}</text>
            <view wx:if="{{record.scanType === 'quality'}}" class="hdi-action" bindtap="onHandleQuality" data-group-id="{{item.id}}" data-record-idx="{{recordIdx}}">处理</view>
            <view wx:if="{{record.isProcurement && !record.procurementCompleted}}" class="hdi-action" bindtap="onHandleProcurement" data-group-id="{{item.id}}" data-record-idx="{{recordIdx}}">处理</view>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" bindtap="loadMoreMyHistory">
      <text wx:if="{{my.loadingHistory}}">加载中...</text>
      <text wx:elif="{{my.history.hasMore}}">加载更多</text>
      <text wx:else class="no-more">— END —</text>
    </view>
  </view>

  <!-- 确认弹窗 -->
  <view wx:if="{{scanConfirm.visible}}" class="modal">
    <view class="modal-box {{scanConfirm.detail.isProcurement ? 'wide' : ''}}">
      <view class="modal-head">
        {{scanConfirm.detail.isProcurement ? '面辅料采购' : '确认提交'}}
        <text class="modal-cd">{{scanConfirm.remain}}s</text>
      </view>
      <view class="modal-body">
        <view wx:if="{{scanConfirm.detail}}" class="cf-list">
          <!-- 只在非采购类型时显示二维码 -->
          <view wx:if="{{!scanConfirm.detail.isProcurement}}" class="cf-item"><text class="cf-k">二维码</text><text class="cf-v mono">{{scanConfirm.detail.scanCode}}</text></view>
          <view wx:if="{{!scanConfirm.detail.isProcurement}}" class="cf-item">
            <text class="cf-k">数量</text>
            <text class="cf-v">{{scanConfirm.detail.quantity}}</text>
          </view>
          <view wx:if="{{scanConfirm.detail.orderNo}}" class="cf-item"><text class="cf-k">订单</text><text class="cf-v hl">{{scanConfirm.detail.orderNo}}</text></view>
          <view wx:if="{{scanConfirm.detail.styleNo}}" class="cf-item"><text class="cf-k">款号</text><text class="cf-v">{{scanConfirm.detail.styleNo}}</text></view>
          <view wx:if="{{scanConfirm.detail.sizeDetails}}" class="cf-item compact"><text class="cf-k">码数明细</text><text class="cf-v wrap">{{scanConfirm.detail.sizeDetails}}</text></view>
          <view wx:if="{{scanConfirm.detail.progressStage && !scanConfirm.detail.isProcurement}}" class="cf-item"><text class="cf-k">环节</text><text class="cf-v">{{scanConfirm.detail.progressStage}}</text></view>
        </view>

        <!--裁剪任务列表 - 在弹窗中显示 -->
        <view wx:if="{{scanConfirm.detail.progressStage === '裁剪' && scanConfirm.cuttingTasks && scanConfirm.cuttingTasks.length}}" class="purchase-modal-list">
          <!-- 一键导入按钮（仅来自"我的任务"时显示） -->
          <view wx:if="{{scanConfirm.fromMyTasks}}" class="cutting-action-bar">
            <view class="cutting-btn auto" bindtap="onAutoImportCutting">一键导入(20件/扎)</view>
            <view class="cutting-btn clear" bindtap="onClearCuttingInput">清空</view>
          </view>

          <view wx:for="{{scanConfirm.cuttingTasks}}" wx:key="index" class="purchase-modal-item">
            <view class="pmi-header">
              <text class="pmi-name">{{item.color || '颜色'}} - {{item.size || '尺码'}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">计划数量</text>
              <text class="pmi-value demand">{{item.plannedQuantity || 0}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">裁剪数量</text>
              <input
                class="pmi-input"
                type="digit"
                placeholder="请填写实际裁剪数量"
                value="{{item.cuttingInput}}"
                bindinput="onModalCuttingInput"
                data-color="{{item.color}}"
                data-size="{{item.size}}"
                data-idx="{{index}}"
              />
            </view>
          </view>
        </view>

        <!-- ✅ 采购任务：显示面料采购明细 -->
        <view wx:if="{{scanConfirm.detail.isProcurement && scanConfirm.materialPurchases && scanConfirm.materialPurchases.length > 0}}" class="purchase-modal-list">
          <!-- 面料统计摘要 -->
          <view class="sku-summary">
            <view class="summary-stat">
              <text class="summary-label">面料总数:</text>
              <text class="summary-value">{{scanConfirm.materialPurchases.length}}</text>
            </view>
          </view>

          <view wx:for="{{scanConfirm.materialPurchases}}" wx:key="id" class="purchase-modal-item">
            <view class="pmi-header">
              <text class="pmi-name">{{item.materialName || '未命名'}}</text>
              <text wx:if="{{item.materialCode}}" class="pmi-code">({{item.materialCode}})</text>
            </view>
            <view wx:if="{{item.purchaseNo}}" class="pmi-row">
              <text class="pmi-label">采购单号</text>
              <text class="pmi-value" style="font-size: 12px; color: #666;">{{item.purchaseNo}}</text>
            </view>
            <view wx:if="{{item.specifications}}" class="pmi-row">
              <text class="pmi-label">规格:</text>
              <text class="pmi-value">{{item.specifications}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">需采购</text>
              <text class="pmi-value demand">{{item.purchaseQuantity || 0}} {{item.unit || '米'}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">已到货</text>
              <text class="pmi-value">{{item.arrivedQuantity || 0}} {{item.unit || '米'}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">本次到货</text>
              <input
                class="pmi-input"
                type="digit"
                placeholder="数量"
                value="{{item.inputQuantity}}"
                bindinput="onMaterialInput"
                data-id="{{item.id}}"
              />
              <text class="pmi-unit">{{item.unit || '米'}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">备注</text>
              <input
                class="pmi-input"
                placeholder="选填（到货<70%必填）"
                value="{{item.remarkInput}}"
                bindinput="onMaterialRemarkInput"
                data-id="{{item.id}}"
              />
            </view>
          </view>
        </view>

        <!-- ✅ 非采购模式（或采购但没有面料数据）：显示 SKU 列表 -->
        <view wx:if="{{scanConfirm.detail.isProcurement && scanConfirm.skuList && scanConfirm.skuList.length && (!scanConfirm.materialPurchases || scanConfirm.materialPurchases.length === 0)}}" class="purchase-modal-list">
          <!-- SKU统计摘要 -->
          <view wx:if="{{scanConfirm.summary}}" class="sku-summary">
            <view class="summary-stat">
              <text class="summary-label">SKU总数:</text>
              <text class="summary-value">{{scanConfirm.summary.totalSKUs}}</text>
            </view>
            <view class="summary-stat">
              <text class="summary-label">已选:</text>
              <text class="summary-value">{{scanConfirm.summary.completedSKUs}}</text>
            </view>
            <view class="summary-stat">
              <text class="summary-label">进度:</text>
              <text class="summary-value">{{scanConfirm.summary.overallProgress}}%</text>
            </view>
          </view>

          <view wx:for="{{scanConfirm.skuList}}" wx:key="index" class="purchase-modal-item">
            <view class="pmi-header">
              <text class="pmi-name">{{item.color}} - {{item.size}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">需采购</text>
              <text class="pmi-value demand">{{item.totalQuantity || 0}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">本次采购</text>
              <input
                class="pmi-input"
                type="digit"
                placeholder="数量"
                value="{{item.inputQuantity}}"
                bindinput="onModalSkuInput"
                data-idx="{{index}}"
              />
            </view>
          </view>
        </view>

        <!-- 通用 SKU 列表 (非采购、非裁剪) -->
        <view wx:if="{{!scanConfirm.detail.isProcurement && scanConfirm.detail.progressStage !== '裁剪' && scanConfirm.skuList && scanConfirm.skuList.length}}" class="purchase-modal-list">
          <!-- ✅ 新增: SKU统计摘要 -->
          <view wx:if="{{scanConfirm.summary}}" class="sku-summary">
            <view class="summary-stat">
              <text class="summary-label">SKU总数:</text>
              <text class="summary-value">{{scanConfirm.summary.totalSKUs}}</text>
            </view>
            <view class="summary-stat">
              <text class="summary-label">已选:</text>
              <text class="summary-value">{{scanConfirm.summary.completedSKUs}}</text>
            </view>
            <view class="summary-stat">
              <text class="summary-label">进度:</text>
              <text class="summary-value">{{scanConfirm.summary.overallProgress}}%</text>
            </view>
          </view>

          <view wx:for="{{scanConfirm.skuList}}" wx:key="index" class="purchase-modal-item">
            <view class="pmi-header">
              <text class="pmi-name">{{item.color}} - {{item.size}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">待完成</text>
              <text class="pmi-value demand">{{item.quantity || item.num || 0}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">本次完成</text>
              <input
                class="pmi-input"
                type="digit"
                placeholder="数量"
                value="{{item.inputQuantity}}"
                bindinput="onModalSkuInput"
                data-idx="{{index}}"
              />
            </view>
          </view>
        </view>

        <!-- 质检领取提示 -->
        <view wx:if="{{scanTypeOptions[scanTypeIndex].value === 'quality' && !scanConfirm.detail.isProcurement}}" class="qc-receive-tip">
          <text class="qc-tip-text">领取后可在"我的任务"中填写质检结果</text>
        </view>

        <!-- 裁剪任务已领取提示 -->
        <view wx:if="{{scanConfirm.detail.progressStage === '裁剪' && scanConfirm.cuttingTaskReceived}}" class="qc-receive-tip" style="background: #f6ffed; border-color: #b7eb8f;">
          <text class="qc-tip-text" style="color: #52c41a;">✓ 任务已领取，可修改数量生成菲号</text>
        </view>
      </view>
      <view class="modal-btns">
        <view class="mbtn cancel" bindtap="onCancelScan">取消</view>
        <!-- 裁剪模式：扫码时只显示"领取任务"（未领取状态） -->
        <view wx:if="{{scanConfirm.detail.progressStage === '裁剪' && !scanConfirm.cuttingTaskReceived && !scanConfirm.fromMyTasks}}" class="mbtn" style="background: #52c41a; {{scanConfirm.loading ? 'opacity: 0.6;' : ''}}" bindtap="onReceiveOnly">
          {{scanConfirm.loading ? '...' : '领取任务'}}
        </view>
        <!-- 裁剪模式：来自"我的任务"显示"生成菲号" -->
        <view wx:if="{{scanConfirm.detail.progressStage === '裁剪' && scanConfirm.fromMyTasks}}" class="mbtn ok {{scanConfirm.loading ? 'off' : ''}}" bindtap="onRegenerateCuttingBundles">
          {{scanConfirm.loading ? '...' : '生成菲号'}}
        </view>
        <!-- 采购模式 -->
        <!-- 扫码领取：只显示"领取任务"按钮 -->
        <view wx:if="{{scanConfirm.detail.isProcurement && !scanConfirm.fromMyTasks}}" class="mbtn" style="background: #52c41a; {{scanConfirm.loading ? 'opacity: 0.6;' : ''}}" bindtap="onReceiveOnly">
          {{scanConfirm.loading ? '...' : '领取任务'}}
        </view>
        <!-- 来自"我的任务"：只显示"确认提交"按钮 -->
        <view wx:if="{{scanConfirm.detail.isProcurement && scanConfirm.fromMyTasks}}" class="mbtn ok {{scanConfirm.loading ? 'off' : ''}}" bindtap="onSubmitProcurement">
          {{scanConfirm.loading ? '...' : '确认提交'}}
        </view>
        <!-- 其他模式 -->
        <view wx:if="{{!scanConfirm.detail.isProcurement && scanConfirm.detail.progressStage !== '裁剪'}}" class="mbtn ok {{scanConfirm.loading ? 'off' : ''}}" bindtap="onConfirmScan">
          {{scanConfirm.loading ? '...' : (scanTypeOptions[scanTypeIndex].value === 'quality' ? '领取' : '确认')}}
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 质检结果弹窗 -->
<view class="modal-backdrop" wx:if="{{qualityModal.show}}" catchtap="closeQualityModal"></view>
<view wx:if="{{qualityModal.show}}" class="modal-wrap quality-modal show">
  <view class="modal-container" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">质检结果录入</text>
      <view class="modal-close" catchtap="closeQualityModal">×</view>
    </view>

    <view class="modal-body">
      <!-- 订单信息 -->
      <view class="qm-info">
        <text class="qm-label">订单号：</text>
        <text class="qm-value">{{qualityModal.detail.orderNo}}</text>
      </view>
      <view class="qm-info" wx:if="{{qualityModal.detail.bundleNo}}">
        <text class="qm-label">菲号：</text>
        <text class="qm-value">{{qualityModal.detail.bundleNo}}</text>
      </view>
      <view class="qm-info">
        <text class="qm-label">款号/颜色：</text>
        <text class="qm-value">{{qualityModal.detail.styleNo}} · {{qualityModal.detail.color || '-'}}</text>
      </view>
      <view class="qm-info">
        <text class="qm-label">数量：</text>
        <text class="qm-value">{{qualityModal.detail.quantity || 1}}</text>
      </view>

      <!-- 选择仓库 -->
      <view class="qm-section">
        <text class="qm-section-title">入库仓库 <text style="color: #ef4444;">*</text></text>
        <picker mode="selector" range="{{warehouseOptions}}" value="{{qualityModal.warehouseIndex}}" bindchange="onWarehouseChange">
          <view class="qm-picker">
            <text class="qm-picker-value">{{warehouseOptions[qualityModal.warehouseIndex] || '请选择仓库'}}</text>
            <text class="qm-picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeQualityModal">取消</button>
      <button class="modal-btn confirm" bindtap="submitQualityResult">确认提交</button>
    </view>
  </view>
</view>

<!-- 物料采购处理弹窗 -->
<view class="modal-backdrop" wx:if="{{procurementModal.show}}" catchtap="closeProcurementModal"></view>
<view wx:if="{{procurementModal.show}}" class="modal-wrap procurement-modal show">
  <view class="modal-container" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">物料采购</text>
      <view class="modal-close" catchtap="closeProcurementModal">×</view>
    </view>

    <view class="modal-body">
      <!-- 订单信息 -->
      <view class="pm-info">
        <text class="pm-label">订单号：</text>
        <text class="pm-value">{{procurementModal.orderNo}}</text>
      </view>

      <!-- 物料列表 -->
      <view wx:if="{{procurementModal.materials && procurementModal.materials.length}}" class="pm-list">
        <view wx:for="{{procurementModal.materials}}" wx:key="id" class="pm-item">
          <view class="pm-item-header">
            <text class="pm-item-name">{{item.materialName || item.materialCode || '物料'}}</text>
            <text class="pm-item-unit">{{item.unit || '米'}}</text>
          </view>

          <view wx:if="{{item.purchaseNo}}" class="pm-field">
            <text class="pm-field-label">采购单号</text>
            <text class="pm-field-value" style="font-size: 12px; color: #666;">{{item.purchaseNo}}</text>
          </view>

          <view class="pm-field">
            <text class="pm-field-label">需求数量</text>
            <text class="pm-field-value demand">{{item.demandQuantity || item.purchaseQuantity || 0}}</text>
          </view>

          <view class="pm-field">
            <text class="pm-field-label">采购数量</text>
            <input class="pm-input" type="digit" placeholder="请填写实际采购数量" value="{{item.purchaseInput}}" bindinput="onProcurementQuantityInput" data-idx="{{index}}" />
          </view>

          <view class="pm-field">
            <text class="pm-field-label">备注</text>
            <input class="pm-input" placeholder="选填" value="{{item.remarkInput}}" bindinput="onProcurementRemarkInput" data-idx="{{index}}" />
          </view>
        </view>
      </view>
    </view>

    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeProcurementModal">取消</button>
      <button class="modal-btn confirm" bindtap="submitProcurementResult">提交</button>
    </view>
  </view>
</view>
