<wxs module="utils">
  // 格式化相对时间
  function formatRelativeTime(timeStr) {
    if (!timeStr) return '-';
    
    var now = getDate().getTime();
    var time = getDate(timeStr).getTime();
    var diff = now - time;
    
    var minute = 60 * 1000;
    var hour = 60 * minute;
    var day = 24 * hour;
    
    if (diff < minute) {
      return '刚刚';
    } else if (diff < hour) {
      return Math.floor(diff / minute) + '分钟前';
    } else if (diff < day) {
      return Math.floor(diff / hour) + '小时前';
    } else if (diff < 7 * day) {
      return Math.floor(diff / day) + '天前';
    } else {
      var date = getDate(timeStr);
      var month = '' + (date.getMonth() + 1);
      var dayNum = '' + date.getDate();
      var hours = '' + date.getHours();
      var minutes = '' + date.getMinutes();
      
      if (month.length < 2) month = '0' + month;
      if (dayNum.length < 2) dayNum = '0' + dayNum;
      if (hours.length < 2) hours = '0' + hours;
      if (minutes.length < 2) minutes = '0' + minutes;
      
      return month + '-' + dayNum + ' ' + hours + ':' + minutes;
    }
  }
  
  module.exports = {
    formatRelativeTime: formatRelativeTime
  };
</wxs>

<view class="page">
  <!-- 顶部操作栏 - 紧凑型 -->
  <view class="top-bar">
    <!-- 自动识别开关 -->
    <view class="auto-detect-switch">
      <switch checked="{{autoDetectEnabled}}" bindchange="onAutoDetectChange" color="#1890ff" />
      <text class="switch-label">自动识别进度</text>
    </view>
    
    <view class="type-tabs" wx:if="{{!autoDetectEnabled}}">
      <view class="tab {{scanTypeIndex === 0 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="0">
        <image class="tab-ico" src="/assets/icons/cut.svg" mode="aspectFit" />
        <text>裁剪</text>
      </view>
      <view class="tab {{scanTypeIndex === 1 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="1">
        <image class="tab-ico" src="/assets/icons/sew.svg" mode="aspectFit" />
        <text>缝制</text>
      </view>
      <view class="tab {{scanTypeIndex === 4 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="4">
        <image class="tab-ico" src="/assets/icons/check.svg" mode="aspectFit" />
        <text>质检</text>
      </view>
      <view class="tab {{scanTypeIndex === 5 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="5">
        <image class="tab-ico" src="/assets/icons/pack.svg" mode="aspectFit" />
        <text>包装</text>
      </view>
      <view class="tab {{scanTypeIndex === 6 ? 'on' : ''}}" bindtap="onQuickScanType" data-idx="6">
        <image class="tab-ico" src="/assets/icons/store.svg" mode="aspectFit" />
        <text>入库</text>
      </view>
      <picker class="more-picker" mode="selector" range="{{scanTypeOptions}}" range-key="label" value="{{scanTypeIndex}}" bindchange="onScanTypeChange">
        <view class="tab more">
          <text class="more-dot">···</text>
        </view>
      </picker>
    </view>
    
    <view wx:if="{{autoDetectEnabled}}" class="auto-mode-tip">
      <text class="tip-icon">🤖</text>
      <text class="tip-text">扫码自动识别当前进度节点</text>
    </view>
  </view>

  <!-- 扫码区 -->
  <view class="scan-area">
    <view class="scan-input">
      <input type="digit" placeholder="数量" value="{{quantity}}" bindinput="onQuantityInput" />
    </view>
    <view class="scan-btn {{loading ? 'off' : ''}}" bindtap="onScan">
      <image class="scan-ico" src="/assets/icons/scan.svg" mode="aspectFit" />
      <text>{{loading ? '...' : '扫码'}}</text>
    </view>
  </view>

  <!-- 质检选项 - 扫码后在确认弹窗中选择，不要提前显示 -->

  <!-- 入库仓库 -->
  <view wx:if="{{scanTypeOptions[scanTypeIndex].value === 'warehouse'}}" class="wh-box">
    <text class="wh-label">仓库</text>
    <input class="wh-input" placeholder="请输入仓库名" value="{{warehouse}}" bindinput="onWarehouseInput" />
  </view>

  <!-- 扫码结果 -->
  <view wx:if="{{lastResult}}" class="result {{lastResult.success ? 'ok' : 'err'}}">
    <view class="res-top">
      <text class="res-tag {{lastResult.success ? 'ok' : 'err'}}">{{lastResult.success ? '成功' : '失败'}}</text>
      <text class="res-msg">{{lastResult.message}}</text>
      <text wx:if="{{lastResult.success && undo.canUndo}}" class="res-undo" bindtap="onUndoLast">{{undo.loading ? '...' : '撤销'}}</text>
    </view>
    <view class="res-info">
      <text wx:if="{{lastResult.orderNo}}" class="res-order">{{lastResult.orderNo}}</text>
      <text wx:if="{{lastResult.styleNo}}" class="res-style">{{lastResult.styleNo}}</text>
      <text wx:if="{{lastResult.color}}">{{lastResult.color}}</text>
      <text wx:if="{{lastResult.size}}">{{lastResult.size}}</text>
      <text wx:if="{{lastResult.processName}}" class="res-proc">{{lastResult.processName}}</text>
      <text wx:if="{{lastResult.unitPrice != null}}">¥{{lastResult.unitPrice}}</text>
    </view>
  </view>

  <!-- 面辅料采购 - 已移至扫码确认弹窗 -->
  <view wx:if="false" class="section">
    <view class="sec-head">
      <text class="sec-title">📦 面辅料 <text class="sec-count">{{materialPurchases.length}}</text></text>
    </view>
    <view wx:for="{{materialPurchases}}" wx:key="id" class="mat-card">
      <view class="mat-top">
        <text class="mat-name">{{item.materialName || item.materialCode || '物料'}}</text>
        <text class="mat-tag {{item.receiverName ? 'done' : ''}}">{{item.receiverName ? '已领' : '待领'}}</text>
      </view>
      <view class="mat-grid">
        <view class="mat-cell"><text class="mc-label">需求</text><text class="mc-val hl">{{item.demandQuantity || item.purchaseQuantity || 0}}{{item.unit || '米'}}</text></view>
        <view class="mat-cell"><text class="mc-label">采购</text><text class="mc-val">{{item.purchaseQuantity || 0}}{{item.unit || '米'}}</text></view>
        <view class="mat-cell"><text class="mc-label">到货</text><text class="mc-val {{item.arrivedQuantity > 0 ? 'gr' : ''}}">{{item.arrivedQuantity || 0}}{{item.unit || '米'}}</text></view>
      </view>
      <view wx:if="{{item.receiverName}}" class="mat-receiver">👤 {{item.receiverName}} <text wx:if="{{item.receivedTime}}" class="mat-time">{{item.receivedTime}}</text></view>
      
      <view wx:if="{{!item.receiverName && item.status !== 'completed' && item.status !== 'cancelled'}}" class="mat-action">
        <view class="btn-receive" bindtap="onReceivePurchase" data-idx="{{index}}">领取任务</view>
      </view>
      <view wx:if="{{item.receiverName}}" class="mat-form">
        <view class="mf-row">
          <text class="mf-label">到货</text>
          <input type="digit" placeholder="0" value="{{item.arrivedInput}}" bindinput="onPurchaseArrivedInput" data-idx="{{index}}" />
          <text class="mf-unit">{{item.unit || '米'}}</text>
        </view>
        <view class="mf-row">
          <text class="mf-label">备注</text>
          <input placeholder="选填" value="{{item.remarkInput}}" bindinput="onPurchaseRemarkInput" data-idx="{{index}}" />
        </view>
        <view class="btn-confirm" bindtap="onConfirmPurchaseArrived" data-idx="{{index}}">确认到货</view>
      </view>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="section">
    <view class="sec-head">
      <text class="sec-title">📊 今日统计</text>
      <text class="sec-refresh {{my.loadingStats ? 'off' : ''}}" bindtap="refreshMy">刷新</text>
    </view>
    <view class="stats">
      <view class="st"><text class="st-num">{{my.stats.scanCount || 0}}</text><text class="st-label">扫码</text></view>
      <view class="st"><text class="st-num">{{my.stats.orderCount || 0}}</text><text class="st-label">订单</text></view>
      <view class="st"><text class="st-num">{{my.stats.totalQuantity || 0}}</text><text class="st-label">数量</text></view>
      <view class="st hl"><text class="st-num">¥{{my.stats.totalAmount || 0}}</text><text class="st-label">收入</text></view>
    </view>
  </view>

  <!-- 扫码记录 -->
  <view class="section">
    <view class="sec-head">
      <text class="sec-title">📋 扫码记录</text>
    </view>
    <view wx:if="{{my.groupedHistory.length === 0 && !my.loadingHistory}}" class="empty">暂无记录</view>
    
    <!-- 聚合后的分组显示 -->
    <view wx:for="{{my.groupedHistory}}" wx:key="id" class="hist-group">
      <!-- 分组头部：折叠显示 -->
      <view class="hist-group-header" bindtap="toggleGroupExpand" data-group-id="{{item.id}}">
        <view class="hgh-main">
          <text class="hgh-order">📦 {{item.orderNo}}</text>
          <text class="hgh-style">款号: {{item.styleNo}}</text>
          <text class="hgh-stage">{{item.stage}}</text>
        </view>
        <view class="hgh-summary">
          <text class="hgh-total">共{{item.totalQuantity}}件</text>
          <text wx:if="{{item.qualifiedCount > 0}}" class="hgh-stat qualified">✓{{item.qualifiedCount}}</text>
          <text wx:if="{{item.defectiveCount > 0}}" class="hgh-stat defective">✗{{item.defectiveCount}}</text>
        </view>
        <view class="hgh-footer">
          <text class="hgh-time">最新: {{utils.formatRelativeTime(item.latestTime)}}</text>
          <text class="hgh-expand">{{item.expanded ? '▲' : '▼'}}</text>
        </view>
      </view>
      
      <!-- 分组详情：展开显示 -->
      <view wx:if="{{item.expanded}}" class="hist-group-details">
        <view wx:for="{{item.items}}" wx:for-item="record" wx:for-index="recordIdx" wx:key="id" class="hist-detail-item">
          <view class="hdi-row">
            <text class="hdi-label">颜色:</text>
            <text class="hdi-value">{{record.color || '-'}}</text>
            <text class="hdi-label">码数:</text>
            <text class="hdi-value">{{record.size || '-'}}</text>
          </view>
          <view class="hdi-row">
            <text class="hdi-label">数量:</text>
            <text class="hdi-value">{{record.quantity || 0}}件</text>
            <text class="hdi-label">单价:</text>
            <text class="hdi-value">¥{{record.unitPrice || '-'}}</text>
          </view>
          <view class="hdi-row">
            <text class="hdi-time">{{record.createdAt || record.scanTime || record.time}}</text>
            <view wx:if="{{record.scanType === 'quality'}}" class="hdi-action" bindtap="onHandleQuality" data-group-id="{{item.id}}" data-record-idx="{{recordIdx}}">处理</view>
            <view wx:if="{{record.isProcurement && !record.procurementCompleted}}" class="hdi-action" bindtap="onHandleProcurement" data-group-id="{{item.id}}" data-record-idx="{{recordIdx}}">处理</view>
          </view>
        </view>
      </view>
    </view>
    
    <view class="load-more" bindtap="loadMoreMyHistory">
      <text wx:if="{{my.loadingHistory}}">加载中...</text>
      <text wx:elif="{{my.history.hasMore}}">加载更多</text>
      <text wx:else class="no-more">— END —</text>
    </view>
  </view>

  <!-- 确认弹窗 -->
  <view wx:if="{{scanConfirm.visible}}" class="modal">
    <view class="modal-box {{scanConfirm.detail.isProcurement ? 'wide' : ''}}">
      <view class="modal-head">
        {{scanConfirm.detail.isProcurement ? '面辅料采购' : '确认提交'}} 
        <text class="modal-cd">{{scanConfirm.remain}}s</text>
      </view>
      <view class="modal-body">
        <view wx:if="{{scanConfirm.detail}}" class="cf-list">
          <view class="cf-item"><text class="cf-k">二维码</text><text class="cf-v mono">{{scanConfirm.detail.scanCode}}</text></view>
          <view wx:if="{{!scanConfirm.detail.isProcurement}}" class="cf-item">
            <text class="cf-k">数量</text>
            <text class="cf-v">{{scanConfirm.detail.quantity}}</text>
          </view>
          <view wx:if="{{scanConfirm.detail.orderNo}}" class="cf-item"><text class="cf-k">订单</text><text class="cf-v hl">{{scanConfirm.detail.orderNo}}</text></view>
          <view wx:if="{{scanConfirm.detail.styleNo}}" class="cf-item"><text class="cf-k">款号</text><text class="cf-v">{{scanConfirm.detail.styleNo}}</text></view>
          <view wx:if="{{scanConfirm.detail.progressStage && !scanConfirm.detail.isProcurement}}" class="cf-item"><text class="cf-k">环节</text><text class="cf-v">{{scanConfirm.detail.progressStage}}</text></view>
        </view>
        
        <!-- 面辅料采购列表 - 在弹窗中显示 -->
        <view wx:if="{{scanConfirm.detail.isProcurement && scanConfirm.materialPurchases && scanConfirm.materialPurchases.length}}" class="purchase-modal-list">
          <view wx:for="{{scanConfirm.materialPurchases}}" wx:key="id" class="purchase-modal-item">
            <view class="pmi-header">
              <text class="pmi-name">{{item.materialName || item.materialCode || '物料'}}</text>
              <text class="pmi-unit">{{item.unit || '米'}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">需求数量</text>
              <text class="pmi-value demand">{{item.demandQuantity || item.purchaseQuantity || 0}}</text>
            </view>
            <view class="pmi-row">
              <text class="pmi-label">采购数量</text>
              <input class="pmi-input" type="digit" placeholder="请填写实际采购数量" value="{{item.purchaseInput}}" bindinput="onModalPurchaseInput" data-idx="{{index}}" />
            </view>
            <view class="pmi-row">
              <text class="pmi-label">备注</text>
              <input class="pmi-input" placeholder="选填" value="{{item.remarkInput}}" bindinput="onModalPurchaseRemarkInput" data-idx="{{index}}" />
            </view>
          </view>
        </view>
        
        <!-- 质检领取提示 -->
        <view wx:if="{{scanTypeOptions[scanTypeIndex].value === 'quality' && !scanConfirm.detail.isProcurement}}" class="qc-receive-tip">
          <text class="qc-tip-text">领取后可在"我的任务"中填写质检结果</text>
        </view>
      </view>
      <view class="modal-btns">
        <view class="mbtn cancel" bindtap="onCancelScan">取消</view>
        <view class="mbtn ok {{scanConfirm.loading ? 'off' : ''}}" bindtap="onConfirmScan">
          {{scanConfirm.loading ? '...' : (scanConfirm.detail.isProcurement ? '领取并提交' : (scanTypeOptions[scanTypeIndex].value === 'quality' ? '领取' : '确认'))}}
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 质检处理弹窗 -->
<view class="modal-backdrop" wx:if="{{qualityModal.show}}" catchtap="closeQualityModal"></view>
<view class="modal-wrap quality-modal {{qualityModal.show ? 'show' : ''}}">
  <view class="modal-container" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">质检结果</text>
      <view class="modal-close" catchtap="closeQualityModal">×</view>
    </view>
    
    <view class="modal-body">
      <!-- 订单信息 -->
      <view class="qm-info">
        <text class="qm-label">订单号：</text>
        <text class="qm-value">{{qualityModal.detail.orderNo}}</text>
      </view>
      <view class="qm-info">
        <text class="qm-label">款号：</text>
        <text class="qm-value">{{qualityModal.detail.styleNo}} · {{qualityModal.detail.color}} · {{qualityModal.detail.size}}</text>
      </view>
      <view class="qm-info">
        <text class="qm-label">数量：</text>
        <text class="qm-value">{{qualityModal.detail.quantity}}</text>
      </view>

      <!-- 合格/次品选择 -->
      <view class="qm-section">
        <text class="qm-section-title">检验结果</text>
        <view class="qm-radio-group">
          <view class="qm-radio {{qualityModal.result === 'qualified' ? 'active' : ''}}" bindtap="onSelectQualityResult" data-value="qualified">
            <text class="qm-radio-icon">{{qualityModal.result === 'qualified' ? '✓' : ''}}</text>
            <text>合格</text>
          </view>
          <view class="qm-radio {{qualityModal.result === 'defective' ? 'active' : ''}}" bindtap="onSelectQualityResult" data-value="defective">
            <text class="qm-radio-icon">{{qualityModal.result === 'defective' ? '✓' : ''}}</text>
            <text>次品</text>
          </view>
        </view>
      </view>

      <!-- 次品详情 -->
      <view wx:if="{{qualityModal.result === 'defective'}}" class="qm-defective">
        <view class="qm-field">
          <text class="qm-field-label">次品数量</text>
          <input class="qm-input" type="number" placeholder="请输入次品数量" value="{{qualityModal.defectiveQuantity}}" bindinput="onDefectiveQuantityInput" />
        </view>
        
        <view class="qm-field">
          <text class="qm-field-label">问题类型</text>
          <picker mode="multiSelector" range="{{defectTypes}}" value="{{qualityModal.selectedDefectTypes}}" bindchange="onDefectTypesChange">
            <view class="qm-picker">
              <text class="qm-picker-value">{{qualityModal.defectTypesText || '请选择问题类型'}}</text>
              <text class="qm-picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="qm-field">
          <text class="qm-field-label">处理方式</text>
          <picker mode="selector" range="{{handleMethods}}" value="{{qualityModal.handleMethod}}" bindchange="onHandleMethodChange">
            <view class="qm-picker">
              <text class="qm-picker-value">{{handleMethods[qualityModal.handleMethod] || '请选择处理方式'}}</text>
              <text class="qm-picker-arrow">›</text>
            </view>
          </picker>
        </view>

        <view class="qm-field">
          <text class="qm-field-label">备注</text>
          <textarea class="qm-textarea" placeholder="请输入备注信息（选填）" value="{{qualityModal.remark}}" bindinput="onRemarkInput" maxlength="200"></textarea>
        </view>
      </view>
    </view>

    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeQualityModal">取消</button>
      <button class="modal-btn confirm" bindtap="submitQualityResult">提交</button>
    </view>
  </view>
</view>

<!-- 物料采购处理弹窗 -->
<view class="modal-backdrop" wx:if="{{procurementModal.show}}" catchtap="closeProcurementModal"></view>
<view class="modal-wrap procurement-modal {{procurementModal.show ? 'show' : ''}}">
  <view class="modal-container" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">物料采购</text>
      <view class="modal-close" catchtap="closeProcurementModal">×</view>
    </view>
    
    <view class="modal-body">
      <!-- 订单信息 -->
      <view class="pm-info">
        <text class="pm-label">订单号：</text>
        <text class="pm-value">{{procurementModal.orderNo}}</text>
      </view>

      <!-- 物料列表 -->
      <view wx:if="{{procurementModal.materials && procurementModal.materials.length}}" class="pm-list">
        <view wx:for="{{procurementModal.materials}}" wx:key="id" class="pm-item">
          <view class="pm-item-header">
            <text class="pm-item-name">{{item.materialName || item.materialCode || '物料'}}</text>
            <text class="pm-item-unit">{{item.unit || '米'}}</text>
          </view>
          
          <view class="pm-field">
            <text class="pm-field-label">需求数量</text>
            <text class="pm-field-value demand">{{item.demandQuantity || item.purchaseQuantity || 0}}</text>
          </view>
          
          <view class="pm-field">
            <text class="pm-field-label">采购数量</text>
            <input class="pm-input" type="digit" placeholder="请填写实际采购数量" value="{{item.purchaseInput}}" bindinput="onProcurementQuantityInput" data-idx="{{index}}" />
          </view>
          
          <view class="pm-field">
            <text class="pm-field-label">备注</text>
            <input class="pm-input" placeholder="选填" value="{{item.remarkInput}}" bindinput="onProcurementRemarkInput" data-idx="{{index}}" />
          </view>
        </view>
      </view>
    </view>

    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeProcurementModal">取消</button>
      <button class="modal-btn confirm" bindtap="submitProcurementResult">提交</button>
    </view>
  </view>
</view>
