@import '/styles/page-utils.wxss';

/* ===== 新视图：工序选择视图 ===== */
.select-view {
  padding: var(--spacing-2xl);
  min-height: 100vh;
  background: var(--color-bg-page);
}

.pattern-brief-card {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.pattern-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  margin-right: var(--spacing-lg);
}
.pattern-brief-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.pattern-style-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}
.pattern-color {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.select-title {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
  margin: var(--spacing-lg) 4rpx var(--spacing-md);
}

/* 工序选择列表 */
.process-select-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-2xl);
}
.process-select-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}
.process-select-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-lg);
  font-size: var(--font-size-sm);
  background: var(--color-border-light);
  color: var(--color-text-secondary);
}
.process-select-item.done .process-select-dot {
  background: var(--color-success);
  color: var(--color-text-white);
}
.process-select-item.can-operate {
  border: 2rpx solid var(--color-primary-border);
}
.process-select-item.can-operate .process-select-dot {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.process-select-item.locked .process-select-dot {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}
.process-select-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}
.process-select-name {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}
.process-select-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.process-select-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md) var(--spacing-xl);
  margin: 4rpx 0 8rpx 0;
}
.process-select-meta .meta-item {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.can-hint { color: var(--color-primary); font-weight: var(--font-weight-medium); }
.done-hint { color: var(--color-success); }
.lock-hint { color: var(--color-warning); }

.select-footer {
  display: flex;
  gap: var(--spacing-xl);
  justify-content: center;
  padding: var(--spacing-2xl) 0;
}
.select-footer .btn-cancel {
  width: 40%;
  padding: var(--spacing-lg);
  text-align: center;
  font-size: var(--font-size-base);
  border-radius: var(--radius-md);
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
}

/* ===== 扫码主页容器 ===== */
.page-container,
.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb), 0.06), transparent 60%),
    linear-gradient(180deg, rgba(var(--color-primary-rgb), 0.03), var(--color-bg-page) 30%);
  padding: var(--page-padding-x) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 160rpx);
}

/* ========= 信息卡片 ========= */
.info-card {
  position: relative;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl) var(--spacing-2xl) var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-2xl);
}

/* --- 状态标签（右上角） --- */
.status-badge {
  position: absolute;
  top: var(--spacing-xl);
  right: var(--spacing-2xl);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}
.status-badge.status-pending   { background: var(--color-warning-bg); color: var(--color-warning); }
.status-badge.status-progress  { background: var(--color-info-bg); color: var(--color-primary); }
.status-badge.status-completed { background: var(--color-success-bg); color: var(--color-success); }
.status-badge.status-received  { background: var(--color-success-bg); color: var(--color-success); }

/* --- 头部：封面图 + 款号/品名 --- */
.card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--spacing-lg);
  padding-right: 120rpx;
}
.cover-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-border-light);
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-border-light);
}
.cover-placeholder-icon {
  font-size: var(--font-size-2xl);
}
.header-info {
  flex: 1;
  margin-left: var(--spacing-xl);
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 140rpx;
}
.style-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.4;
}
.style-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

/* --- 详情字段列表 --- */
.field-list {
  border-top: 1rpx solid var(--color-border-light);
  padding-top: var(--spacing-lg);
}
.field-row {
  display: flex;
  align-items: baseline;
  padding: 10rpx 0;
}
.field-label {
  width: 120rpx;
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.field-value {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  word-break: break-all;
}
.field-value.highlight {
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* ================ 三行清晰式信息布局（与大货扫码一致） ================ */
.info-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  font-size: 26rpx;
  line-height: 40rpx;
}
.info-row--meta {
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}
.info-row--specs {
  border-top: 1rpx solid var(--color-border-light, #eef1f6);
  margin-top: 8rpx;
  padding-top: 12rpx;
}
.info-row--extra {
  border-top: 1rpx solid var(--color-border-light, #eef1f6);
  margin-top: 8rpx;
  padding-top: 12rpx;
  color: var(--color-text-secondary);
}
.info-meta-item {
  font-size: 24rpx;
  color: #6b7280;
  background: #f5f7fa;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.info-meta-item--delivery {
  color: #c2410c;
  background: #fff7ed;
  font-weight: 600;
}
.info-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-right: 8rpx;
  flex-shrink: 0;
}
.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}
.info-value--qty {
  font-weight: 700;
  color: #2563eb;
}
.info-divider {
  color: var(--color-text-tertiary);
  font-size: 26rpx;
  margin: 0 12rpx;
}

/* --- 颜色码数聚合矩阵 --- */
.matrix-section {
  margin-top: var(--spacing-lg);
  padding-top: var(--spacing-lg);
  border-top: 1rpx dashed var(--color-border-light);
}
.matrix-table {
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.matrix-row {
  display: flex;
  border-bottom: 1rpx solid var(--color-border-light);
}
.matrix-row:last-child {
  border-bottom: none;
}
.matrix-header {
  background: var(--color-bg-page);
}
.matrix-header .matrix-cell {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}
.matrix-cell {
  flex: 1;
  text-align: center;
  padding: 14rpx 4rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  min-width: 0;
}
.matrix-label-cell {
  flex: 0 0 120rpx;
  text-align: left;
  padding-left: var(--spacing-lg);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.matrix-total-cell {
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}
.matrix-footer {
  padding: var(--spacing-md) var(--spacing-lg);
  text-align: right;
}
.matrix-grand-total {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

/* ========= 操作区域卡片 ========= */
.section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-xl);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-2xl);
}
.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-lg);
}

/* --- 工序选择器 --- */
.ops-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
}
.selector-list {
  max-height: 340rpx;
  background: var(--color-info-bg);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: var(--spacing-lg);
}
.selector-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-md);
  margin-bottom: 6rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.selector-item.active {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
}
.selector-item.disabled {
  opacity: 0.4;
}
.selector-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  margin-right: var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.selector-radio.checked {
  border-color: var(--color-primary);
  background: var(--color-primary);
}
.selector-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-bg-card);
}
.selector-label {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

/* --- 审核提示 --- */
.review-warning {
  background: var(--color-warning-bg);
  border: 1rpx solid var(--color-warning-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
}
.review-warning-text {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
}

.review-selector {
  margin-bottom: var(--spacing-lg);
}
.review-options {
  display: flex;
  gap: var(--spacing-lg);
  margin-top: var(--spacing-md);
}
.review-option {
  flex: 1;
  text-align: center;
  padding: var(--spacing-md) 0;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
  border: 2rpx solid var(--color-border);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.review-option-active {
  background: var(--color-primary-bg);
  border-color: var(--color-primary);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* --- 输入行 --- */
.input-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}
.input-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  width: 140rpx;
  flex-shrink: 0;
}
.input-field {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-lg);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--color-bg-card);
}
.input-suffix {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-left: var(--spacing-md);
}

/* --- 备注 --- */
.remark-row {
  margin-bottom: 8rpx;
}
.remark-area {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: var(--color-primary-bg);
  box-sizing: border-box;
  margin-top: 8rpx;
}

/* 仓库选择 */
.warehouse-section {
  margin-bottom: var(--spacing-lg);
  padding: var(--spacing-md);
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-light);
}

.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.warehouse-chip {
  padding: 4px 14px;
  border-radius: var(--radius-xl);
  font-size: var(--font-size-sm);
  border: 1rpx solid var(--color-border);
  background: var(--color-bg-light);
  color: var(--color-text-primary);
}

.warehouse-chip--active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

.warehouse-chip--clear {
  background: var(--color-primary-bg);
  border-color: var(--color-primary-border);
  color: var(--color-danger);
}

.warehouse-chip--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.warehouse-chip-hover {
  opacity: 0.75;
}

/* ===== SKU列表 ===== */
.sku-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.sku-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-sm);
  background: var(--color-bg-gray);
}
.sku-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  flex: 1;
  min-width: 0;
}
.sku-label {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.sku-total {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.sku-qty-wrap {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}
.sku-qty-input {
  width: 100rpx;
  height: 64rpx;
  text-align: center;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-xs);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  background: var(--color-bg-card);
}
.sku-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ===== 汇总卡片 ===== */
.summary-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-xl);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid var(--color-border-light);
}
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 0;
}
.summary-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.summary-value {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

/* ===== 审核图片上传 ===== */
.review-images-section {
  margin-bottom: var(--spacing-md);
}
.review-images-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-lg);
  margin-top: 12rpx;
}
.review-image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1rpx solid var(--color-border-light);
}
.review-image {
  width: 100%;
  height: 100%;
}
.review-image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: var(--color-text-white);
  font-size: var(--font-size-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}
.review-image-add {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--color-border);
  background: var(--color-bg-gray);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.add-icon {
  font-size: var(--font-size-xl);
  color: var(--color-text-tertiary);
  line-height: 1;
}
.add-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
