@import '/styles/page-utils.wxss';

/* ================ 样衣扫码页 - 美团风格（与大货扫码一致） ================ */

.container {
  min-height: 100vh;
  background: #f5f6f8;
}

.select-view {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: calc(env(safe-area-inset-bottom) + 140rpx);
}

/* ================ Hero 顶部区（与大货扫码一致） ================ */
.hero {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  padding: 32rpx 32rpx 28rpx;
  color: #fff;
}
.hero__main {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}
.hero__icon {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}
.hero__icon::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 12rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: translate(-50%, -65%) rotate(-45deg);
}
.hero__mainText {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.hero__title {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1.2;
}
.hero__styleNo {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.3;
  letter-spacing: 1rpx;
  word-break: break-all;
}
.hero__delivery {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 12rpx;
  flex-shrink: 0;
}
.hero__deliveryLabel {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
  line-height: 1;
  margin-bottom: 4rpx;
}
.hero__deliveryValue {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
}

.hero__info {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.12);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
}
.hero__infoItem {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
}
.hero__infoLabel {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1;
}
.hero__infoValue {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  line-height: 1.3;
  word-break: break-all;
  text-align: center;
  font-variant-numeric: tabular-nums;
}
.hero__infoValue--qty {
  color: #fef08a;
  font-weight: 700;
}
.hero__infoDivider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.2);
  flex-shrink: 0;
}

/* ================ 通用卡片 ================ */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card__title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f1f3;
}
.card__titleText {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  position: relative;
  padding-left: 16rpx;
  line-height: 1.2;
}
.card__titleText::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 26rpx;
  background: #2563eb;
  border-radius: 4rpx;
}
.card__titleTag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-left: auto;
}
.card__titleTag--default {
  color: #6b7280;
  background: #f3f4f6;
}
.card__titleTag--success {
  color: #15803d;
  background: #f0fdf4;
}
.card__titleTag--warning {
  color: #c2410c;
  background: #fff7ed;
}
.card__titleTag--danger {
  color: #b91c1c;
  background: #fef2f2;
}
.card__titleTag--info {
  color: #2563eb;
  background: rgba(37,99,235,0.08);
}
.card__titleSub {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: auto;
}
.card__titleHint {
  font-size: 22rpx;
  color: #9ca3af;
  margin-left: auto;
}
.card__hint {
  margin-bottom: 16rpx;
  padding: 14rpx 16rpx;
  background: #fff7ed;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #c2410c;
  border-left: 4rpx solid #fb923c;
}

/* ================ 款式信息卡片 ================ */
.style-card__body {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.style-card__cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f2f4f7;
  flex-shrink: 0;
  overflow: hidden;
}
.style-card__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}
.style-card__styleNo {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.3;
  letter-spacing: 1rpx;
}
.style-card__styleName {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.3;
}
.style-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}
.meta-tag {
  font-size: 22rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* ================ 工序选择（列表式 checkbox） ================ */
.process-scroll {
  padding: 4rpx 0;
}
.process-item {
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  background: #f9fafb;
  border: 2rpx solid transparent;
  transition: background-color 0.15s ease, border-color 0.15s ease;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.process-item-hover {
  opacity: 0.7;
  transform: scale(0.99);
}
.process-item--active {
  background: rgba(37,99,235,0.06);
  border-color: #2563eb;
}
.process-item__checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
  background: #fff;
  transition: background-color 0.15s ease, border-color 0.15s ease;
}
.process-item__checkbox--checked {
  background: #2563eb;
  border-color: #2563eb;
}
.process-item__checkbox--checked::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: translate(-50%, -65%) rotate(-45deg);
}
.process-item__name {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
  line-height: 1.3;
}
.process-item--active .process-item__name {
  color: #2563eb;
  font-weight: 600;
}
.process-item__price {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.process-item--active .process-item__price {
  color: #2563eb;
  font-weight: 700;
}

.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f1f3;
}
.summary-text {
  font-size: 24rpx;
  color: #6b7280;
}
.summary-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #2563eb;
  font-variant-numeric: tabular-nums;
}

/* ================ 输入区域 ================ */
.input-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}
.input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.input-field {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #1f2937;
  background: #fff;
}
.input-suffix {
  font-size: 22rpx;
  color: #9ca3af;
  flex-shrink: 0;
}
.remark-row {
  margin-top: 16rpx;
}
.remark-area {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #1f2937;
  background: #fff;
  box-sizing: border-box;
}

/* ================ SKU 列表 ================ */
.sku-section {
  margin-bottom: 16rpx;
}
.sku-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.sku-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #f9fafb;
  border-radius: 10rpx;
}
.sku-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.sku-label {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}
.sku-total {
  font-size: 22rpx;
  color: #9ca3af;
}
.sku-qty-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.sku-qty-input {
  width: 120rpx;
  height: 60rpx;
  padding: 0 12rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #1f2937;
  text-align: center;
}
.sku-unit {
  font-size: 22rpx;
  color: #9ca3af;
}

/* ================ 审核操作 ================ */
.review-section {
  margin-bottom: 20rpx;
}
.review-options {
  display: flex;
  gap: 12rpx;
}
.review-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 10rpx;
  background: #f3f4f6;
  border: 2rpx solid transparent;
  font-size: 26rpx;
  color: #4b5563;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.review-option--active {
  font-weight: 600;
}
.review-option--pass {
  background: #f0fdf4;
  border-color: #86efac;
  color: #15803d;
}
.review-option--rework {
  background: #fff7ed;
  border-color: #fdba74;
  color: #c2410c;
}
.review-option--reject {
  background: #fef2f2;
  border-color: #fca5a5;
  color: #b91c1c;
}

.review-images-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.review-image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 10rpx;
  overflow: hidden;
}
.review-image {
  width: 100%;
  height: 100%;
}
.review-image-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
.review-image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #d1d5db;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  background: #f9fafb;
}
.add-icon {
  font-size: 40rpx;
  color: #9ca3af;
  line-height: 1;
}
.add-text {
  font-size: 22rpx;
  color: #9ca3af;
}

/* ================ 仓库选择 ================ */
.warehouse-section {
  margin-bottom: 16rpx;
}
.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.warehouse-chip {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  border: 2rpx solid transparent;
  font-size: 24rpx;
  color: #1f2937;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.warehouse-chip--active {
  background: rgba(37,99,235,0.08);
  border-color: #2563eb;
  color: #2563eb;
  font-weight: 600;
}
.warehouse-chip--clear {
  color: #6b7280;
}
.warehouse-chip--disabled {
  opacity: 0.4;
}
.warehouse-chip-hover {
  opacity: 0.7;
}

/* ================ 底部固定按钮栏 ================ */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  background: #fff;
  border-top: 1rpx solid #f0f1f3;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
  z-index: 100;
}
.btn-cancel,
.btn-submit {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  transition: opacity 0.12s ease, transform 0.12s ease;
}
.btn-cancel {
  background: #f3f4f6;
  color: #4b5563;
}
.btn-submit {
  background: #2563eb;
  color: #fff;
}
.btn-disabled {
  opacity: 0.5;
}
.btn-hover {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ================ 加载中 ================ */
.loading-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f6f8;
}
.loading-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* ================ 尊重用户减少动画偏好 ================ */
@media (prefers-reduced-motion: reduce) {
  .process-item,
  .process-item-hover,
  .btn-cancel,
  .btn-submit,
  .btn-hover,
  .process-item__checkbox {
    transition: none !important;
    animation: none !important;
    transform: none !important;
  }
}
