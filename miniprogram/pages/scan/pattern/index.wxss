@import '/styles/design-tokens.wxss';

/* ========= 页面容器（参考裁剪详情风格） ========= */
.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb, 37,99,235), 0.06), transparent 60%),
    linear-gradient(180deg, rgba(var(--color-primary-rgb, 37,99,235), 0.03), var(--color-bg-page, #f0f2f5) 30%);
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 160rpx);
}

/* ========= 信息卡片 ========= */
.info-card {
  position: relative;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 28rpx 28rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}

/* --- 状态标签（右上角） --- */
.status-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #64748b;
}
.status-badge.status-pending   { background: #fef3c7; color: #d97706; }
.status-badge.status-progress  { background: rgba(var(--color-primary-rgb, 37,99,235), 0.08); color: rgba(var(--color-primary-rgb, 37,99,235), 1); }
.status-badge.status-completed { background: #d1fae5; color: #059669; }
.status-badge.status-received  { background: #d1fae5; color: #059669; }

/* --- 头部：封面图 + 款号/品名 --- */
.card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-right: 120rpx;
}
.cover-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-border-light, #f1f5f9);
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-border-light, #f1f5f9);
}
.cover-placeholder-icon {
  font-size: 48rpx;
}
.header-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 140rpx;
}
.style-no {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1e293b);
  line-height: 1.3;
}
.style-name {
  font-size: 24rpx;
  color: var(--color-text-secondary, #64748b);
  margin-top: 8rpx;
}

/* --- 详情字段列表（对齐PC端样衣开发卡片） --- */
.field-list {
  border-top: 1rpx solid var(--color-border-light, #f1f5f9);
  padding-top: 16rpx;
}
.field-row {
  display: flex;
  align-items: baseline;
  padding: 10rpx 0;
}
.field-label {
  width: 120rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: var(--color-text-secondary, #64748b);
}
.field-value {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary, #1e293b);
  font-weight: 500;
  word-break: break-all;
}
.field-value.highlight {
  font-weight: 700;
  color: rgba(var(--color-primary-rgb, 37,99,235), 1);
}

/* --- 颜色码数聚合矩阵 --- */
.matrix-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed var(--color-border-light, #e8e8e8);
}
.matrix-table {
  border: 1rpx solid var(--color-border-light, #e8e8e8);
  border-radius: 12rpx;
  overflow: hidden;
}
.matrix-row {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}
.matrix-row:last-child {
  border-bottom: none;
}
.matrix-header {
  background: #f5f7fa;
}
.matrix-header .matrix-cell {
  font-weight: 600;
  color: var(--color-text-secondary, #64748b);
  font-size: 22rpx;
}
.matrix-cell {
  flex: 1;
  text-align: center;
  padding: 14rpx 4rpx;
  font-size: 24rpx;
  color: var(--color-text-primary, #1e293b);
  min-width: 0;
}
.matrix-label-cell {
  flex: 0 0 120rpx;
  text-align: left;
  padding-left: 16rpx;
  font-weight: 500;
  color: var(--color-text-secondary, #64748b);
}
.matrix-total-cell {
  font-weight: 600;
  color: rgba(var(--color-primary-rgb, 37,99,235), 1);
}
.matrix-footer {
  padding: 12rpx 16rpx;
  text-align: right;
}
.matrix-grand-total {
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(var(--color-primary-rgb, 37,99,235), 1);
}

/* ========= 操作区域卡片 ========= */
.section-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1e293b);
  margin-bottom: 20rpx;
}

/* --- 工序选择器 --- */
.ops-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #64748b);
  margin-bottom: 12rpx;
}
.selector-list {
  max-height: 340rpx;
  background: rgba(var(--color-primary-rgb, 37,99,235), 0.02);
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}
.selector-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 6rpx;
  border: 2rpx solid transparent;
  transition: all .15s;
}
.selector-item.active {
  background: rgba(var(--color-primary-rgb, 37,99,235), 0.08);
  border-color: rgba(var(--color-primary-rgb, 37,99,235), 1);
}
.selector-item.disabled {
  opacity: 0.4;
}
.selector-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.selector-radio.checked {
  border-color: rgba(var(--color-primary-rgb, 37,99,235), 1);
  background: rgba(var(--color-primary-rgb, 37,99,235), 1);
}
.selector-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #fff;
}
.selector-label {
  font-size: 28rpx;
  color: var(--color-text-primary, #1e293b);
  font-weight: 500;
}

/* --- 审核提示 --- */
.review-warning {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.review-warning-text {
  font-size: 24rpx;
  color: #d48806;
}

/* --- 输入行 --- */
.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.input-label {
  font-size: 26rpx;
  color: var(--color-text-secondary, #64748b);
  width: 140rpx;
  flex-shrink: 0;
}
.input-field {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--color-border-light, #f1f5f9);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--color-text-primary, #1e293b);
  background: rgba(var(--color-primary-rgb, 37,99,235), 0.02);
}
.input-suffix {
  font-size: 26rpx;
  color: var(--color-text-secondary, #64748b);
  margin-left: 12rpx;
}

/* --- 备注 --- */
.remark-row {
  margin-bottom: 8rpx;
}
.remark-area {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--color-border-light, #f1f5f9);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: var(--color-text-primary, #1e293b);
  background: rgba(var(--color-primary-rgb, 37,99,235), 0.02);
  box-sizing: border-box;
  margin-top: 8rpx;
}

/* ========= 底部按钮栏 ========= */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: var(--color-bg-card, #fff);
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.btn-cancel {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: var(--color-border-light, #f1f5f9);
  color: var(--color-text-secondary, #64748b);
}
.btn-submit {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: rgba(var(--color-primary-rgb, 37,99,235), 1);
  color: #fff;
}
.btn-submit.off {
  opacity: 0.5;
  pointer-events: none;
}
.btn-hover {
  opacity: 0.75;
}
