<!-- 样板生产操作页 -->
<view class="container">

  <!-- 样板信息卡片（对齐PC端样衣开发卡片排列） -->
  <view class="info-card">
    <!-- 状态标签 -->
    <view class="status-badge status-{{detail.statusType}}">{{detail.statusLabel || '-'}}</view>

    <!-- 头部：封面图 + 款号/品名 -->
    <view class="card-header">
      <image-preview class="cover-wrap" src="{{detail.coverImage}}" mode="aspectFill" />
      <view class="header-info">
        <text class="style-no">{{(detail.styleNo || '-') + (detail.styleName ? ' · ' + detail.styleName : '')}}</text>
      </view>
    </view>

    <!-- 详情字段列表 -->
    <view class="field-list">
      <view class="field-row" wx:if="{{detail.sourceLabel}}">
        <text class="field-label">来源</text>
        <text class="field-value">{{detail.sourceLabel}}</text>
      </view>
      <view class="field-row" wx:if="{{detail.categoryLabel}}">
        <text class="field-label">品类</text>
        <text class="field-value">{{detail.categoryLabel}}</text>
      </view>

      <!-- 颜色码数聚合矩阵 -->
      <view wx:if="{{detail.hasMatrix}}" class="matrix-section">
        <view class="matrix-table">
          <!-- 表头 -->
          <view class="matrix-row matrix-header">
            <view class="matrix-cell matrix-label-cell">码数</view>
            <view wx:for="{{detail.matrixSizes}}" wx:key="*this" class="matrix-cell">{{item}}</view>
          </view>
          <!-- 数据行 -->
          <view wx:for="{{detail.matrixRows}}" wx:for-item="row" wx:key="color" class="matrix-row">
            <view class="matrix-cell matrix-label-cell">{{row.color}}</view>
            <view wx:for="{{row.quantities}}" wx:for-item="qty" wx:for-index="qIdx" wx:key="qIdx" class="matrix-cell">{{qty}}</view>
          </view>
        </view>
        <view class="matrix-footer">
          <text class="matrix-grand-total">总数: {{detail.matrixTotal}} 件</text>
        </view>
      </view>

      <view class="field-row">
        <text class="field-label">交板</text>
        <text class="field-value">{{detail.deliveryTime || '-'}}</text>
      </view>
      <view class="field-row" wx:if="{{detail.customer}}">
        <text class="field-label">客户</text>
        <text class="field-value">{{detail.customer}}</text>
      </view>
      <view class="field-row">
        <text class="field-label">设计师</text>
        <text class="field-value">{{detail.designer || '-'}}</text>
      </view>
      <view class="field-row">
        <text class="field-label">纸样师</text>
        <text class="field-value">{{detail.patternDeveloper || '-'}}</text>
      </view>
    </view>
  </view>

  <!-- 操作区域 -->
  <view class="section-card">
    <view class="section-title">✂️ 样衣操作</view>



    <!-- 审核未完成提示 -->
    <view wx:if="{{detail.requiresReviewBeforeInbound}}" class="review-warning">
      <text class="review-warning-text">⚠ 当前未完成样衣审核，本次会先提交审核再执行入库</text>
    </view>

    <!-- 数量输入 -->
    <view class="input-row">
      <text class="input-label">数量</text>
      <input
        class="input-field"
        type="digit"
        placeholder="请输入数量"
        value="{{detail.quantity}}"
        bindinput="onQuantityInput"
      />
      <text class="input-suffix">件</text>
    </view>

    <!-- 仓位编号（仓库操作时显示） -->
    <view wx:if="{{detail.requiresWarehouseInput}}" class="input-row">
      <text class="input-label">仓位编号</text>
      <input
        class="input-field"
        placeholder="例如 A-01-01"
        value="{{detail.warehouseCode}}"
        bindinput="onWarehouseInput"
      />
    </view>

    <!-- 备注 -->
    <view class="remark-row">
      <text class="input-label">备注</text>
      <textarea
        class="remark-area"
        placeholder="请输入备注信息..."
        value="{{detail.remark}}"
        bindinput="onRemarkInput"
        maxlength="200"
      />
    </view>
  </view>

  <!-- 底部按钮：取消 + 领取 -->
  <view class="footer-bar">
    <view class="btn-cancel" hover-class="btn-hover" bindtap="goBack">取消</view>
    <view class="btn-submit {{loading ? 'off' : ''}}" hover-class="btn-hover" bindtap="submitOp">
      {{loading ? '提交中...' : (detail.submitLabel || '领取')}}
    </view>
  </view>
</view>
