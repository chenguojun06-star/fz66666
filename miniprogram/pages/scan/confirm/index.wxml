<view class="container">

  <!-- ===== 采购模式头部 ===== -->
  <view wx:if="{{isProcurement}}" class="info-card procurement-card">
    <view class="card-header">
      <image-preview class="cover-wrap" src="{{detail.coverImage || ''}}" mode="aspectFill" />
      <view class="header-info">
        <view class="procurement-badge">面辅料采购</view>
        <text class="style-no">{{detail.styleNo || detail.orderNo}}</text>
        <text class="sub-info">订单 {{detail.orderNo}}</text>
        <sku-matrix wx:if="{{sizeMatrix.rows.length > 0}}" size-matrix="{{sizeMatrix}}" mode="compact" />
      </view>
    </view>
  </view>

  <!-- ===== 非采购模式头部 ===== -->
  <view wx:else class="info-card">
    <view class="card-header">
      <image-preview class="cover-wrap" src="{{detail.coverImage || ''}}" mode="aspectFill" />
      <view class="header-info">
        <text class="style-no">{{detail.styleNo || detail.orderNo}}</text>
        <text class="sub-info">订单 {{detail.orderNo}}</text>
        <text wx:if="{{detail.bundleNo}}" class="sub-info">菲号 {{detail.bundleNo}}</text>
        <text wx:if="{{detail.processName}}" class="sub-info tag-process">{{detail.processName}}</text>
      </view>
    </view>
  </view>

  <!-- BOM 兜底提示（采购模式） -->
  <view wx:if="{{isProcurement && detail.bomFallback}}" class="warn-card">
    <text class="warn-icon">⚠️</text>
    <text class="warn-text">未找到采购单，当前为BOM物料参考信息</text>
  </view>

  <!-- ===== 面辅料采购明细 ===== -->
  <view wx:if="{{isProcurement && materialPurchases.length > 0}}" class="section-card">
    <text class="section-title">面辅料采购明细（{{materialPurchases.length}}项）</text>
    <view class="material-list">
      <view wx:for="{{materialPurchases}}" wx:key="id" class="material-item">
        <view class="material-header">
          <text class="material-name">{{item.materialName || '未知物料'}}</text>
          <text wx:if="{{item.materialCode}}" class="material-code">{{item.materialCode}}</text>
        </view>
        <view class="material-details">
          <view wx:if="{{item.materialTypeCN}}" class="material-field">
            <text class="field-label">类型</text>
            <text class="field-value">{{item.materialTypeCN}}</text>
          </view>
          <view wx:if="{{item.specifications}}" class="material-field">
            <text class="field-label">规格</text>
            <text class="field-value">{{item.specifications}}</text>
          </view>
          <view class="material-field">
            <text class="field-label">单位</text>
            <text class="field-value">{{item.unit || '-'}}</text>
          </view>
          <view wx:if="{{item.unitPrice}}" class="material-field">
            <text class="field-label">单价</text>
            <text class="field-value price">¥{{item.unitPrice}}</text>
          </view>
        </view>
        <view class="material-qty-row">
          <view class="qty-block">
            <text class="qty-num demand">{{item.purchaseQuantity || 0}}</text>
            <text class="qty-label">需求</text>
          </view>
          <view class="qty-block">
            <text class="qty-num arrived">{{item.arrivedQuantity || 0}}</text>
            <text class="qty-label">已到</text>
          </view>
          <view class="qty-block">
            <text class="qty-num pending">{{item.pendingQuantity || 0}}</text>
            <text class="qty-label">待到</text>
          </view>
        </view>
        <view wx:if="{{item.remark}}" class="material-remark">
          <text class="remark-text">备注: {{item.remark}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 面辅料汇总（采购模式） -->
  <view wx:if="{{isProcurement && materialPurchases.length > 0}}" class="summary-card">
    <view class="summary-row">
      <text class="summary-label">总需求量</text>
      <text class="summary-value">{{materialSummary.totalDemand}}</text>
    </view>
    <view class="summary-row">
      <text class="summary-label">已到货量</text>
      <text class="summary-value arrived-text">{{materialSummary.totalArrived}}</text>
    </view>
    <view class="summary-row">
      <text class="summary-label">待到货量</text>
      <text class="summary-value pending-text">{{materialSummary.totalPending}}</text>
    </view>
  </view>

  <!-- AI 工艺提醒（非采购模式） -->
  <view wx:if="{{!isProcurement && aiTipData}}" class="insight-card">
    <text class="insight-icon">💡</text>
    <text class="insight-text">{{aiTipData.aiTip}}</text>
  </view>

  <!-- BOM 提示（非采购模式） -->
  <view wx:if="{{!isProcurement && detail.bomFallback}}" class="warn-card">
    <text class="warn-icon">⚠️</text>
    <text class="warn-text">未匹配到BOM工价，当前使用默认工价</text>
  </view>

  <!-- SKU 输入列表 -->
  <view class="section-card">
    <text class="section-title">{{isProcurement ? '领取明细' : '扫码明细'}}（{{skuList.length}}项）</text>
    <view class="sku-list">
      <view wx:for="{{skuList}}" wx:key="id" class="sku-item">
        <view class="sku-info">
          <text class="sku-label">{{item.label}}</text>
          <text class="sku-total">订单 {{item.totalQuantity}} 件</text>
        </view>
        <view class="sku-qty-wrap">
          <input class="sku-qty-input" type="number"
                 value="{{item.inputQuantity}}"
                 data-index="{{index}}" bindinput="onSkuInput"
                 placeholder="数量" />
          <text class="sku-unit">件</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 汇总（非采购模式） -->
  <view wx:if="{{!isProcurement}}" class="summary-card">
    <view class="summary-row">
      <text class="summary-label">总数量</text>
      <text class="summary-value">{{summary.totalQuantity}} 件</text>
    </view>
    <view wx:if="{{summary.totalAmount > 0}}" class="summary-row">
      <text class="summary-label">预估工价</text>
      <text class="summary-value amount">¥{{summary.totalAmount}}</text>
    </view>
  </view>

  <!-- 颜色尺码矩阵 -->
  <view wx:if="{{sizeMatrix.rows.length > 0}}" class="section-card">
    <text class="section-title">颜色尺码汇总</text>
    <sku-matrix size-matrix="{{sizeMatrix}}" mode="full" />
  </view>

  <!-- 底部操作栏 -->
  <view class="footer-bar">
    <view class="btn-cancel" hover-class="btn-hover" bindtap="goBack">取消</view>
    <view class="btn-submit {{loading ? 'off' : ''}}" hover-class="btn-hover" bindtap="confirmScan">
      {{loading ? '提交中...' : buttonText}}
    </view>
  </view>

</view>
