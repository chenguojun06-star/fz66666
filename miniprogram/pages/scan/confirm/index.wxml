<view class="container">

  <view class="info-card">
    <view class="card-header">
      <view class="cover-wrap" bindtap="previewImage">
        <image-preview src="{{detail.coverImage}}" mode="aspectFill" />
      </view>
      <view class="header-info">
        <view wx:if="{{isProcurement}}" class="procurement-badge">面辅料采购</view>
        <view wx:if="{{isCutting}}" class="cutting-badge">裁剪领取</view>
        <text class="style-no">{{detail.styleNo || '-'}}</text>
        <text class="sub-info">{{detail.orderNo || '-'}}</text>
        <text wx:if="{{!isProcurement && !isCutting && detail.processName}}" class="tag-process">{{detail.processName}}</text>
      </view>
    </view>

    <view wx:if="{{sizeMatrix.rows.length > 0}}" class="matrix-section">
      <text class="matrix-label">下单明细</text>
      <sku-matrix size-matrix="{{sizeMatrix}}" mode="compact" />
    </view>
  </view>

  <!-- ===== 采购模式：面辅料明细 ===== -->
  <block wx:if="{{isProcurement}}">
    <view wx:if="{{detail.bomFallback}}" class="warn-card">
      <text class="warn-icon">⚠️</text>
      <text class="warn-text">未找到采购单，当前为BOM物料参考信息</text>
    </view>

    <view wx:if="{{materialPurchases.length > 0}}" class="section-card">
      <text class="section-title">面辅料采购明细（{{materialPurchases.length}}项）</text>
      <view class="material-list">
        <view wx:for="{{materialPurchases}}" wx:key="id" class="material-item">
          <view class="mat-row">
            <text wx:if="{{item.materialTypeCN}}" class="mat-tag">{{item.materialTypeCN}}</text>
            <text wx:if="{{item.materialCode}}" class="mat-text">编号 {{item.materialCode}}</text>
            <text wx:if="{{item.specifications}}" class="mat-text">规格 {{item.specifications}}</text>
            <text class="mat-text">单位 {{item.unit || '米'}}</text>
          </view>
          <view class="mat-row mat-row-qty">
            <view class="qty-item">
              <text class="qty-lbl">需求</text>
              <text class="qty-val">{{item.purchaseQuantity || 0}}</text>
            </view>
            <view class="qty-item">
              <text class="qty-lbl">已到</text>
              <text class="qty-val arrived">{{item.arrivedQuantity || 0}}</text>
            </view>
            <view class="qty-item">
              <text class="qty-lbl">待到</text>
              <text class="qty-val pending">{{item.pendingQuantity || 0}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{materialPurchases.length > 0}}" class="summary-card">
      <view class="summary-row">
        <text class="summary-label">总需求</text>
        <text class="summary-value">{{materialSummary.totalDemand}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">已到货</text>
        <text class="summary-value arrived-text">{{materialSummary.totalArrived}}</text>
      </view>
      <view class="summary-row">
        <text class="summary-label">待到货</text>
        <text class="summary-value pending-text">{{materialSummary.totalPending}}</text>
      </view>
    </view>
  </block>

  <!-- ===== 裁剪模式：任务领取 ===== -->
  <block wx:elif="{{isCutting}}">
    <view class="section-card">
      <text class="section-title">裁剪任务信息</text>
      <view wx:if="{{cuttingTask}}" class="cutting-info">
        <view class="cutting-row">
          <text class="cutting-lbl">款号</text>
          <text class="cutting-val">{{cuttingTask.styleNo || detail.styleNo || '-'}}</text>
        </view>
        <view class="cutting-row">
          <text class="cutting-lbl">颜色</text>
          <text class="cutting-val">{{cuttingTask.color || '全部颜色'}}</text>
        </view>
        <view class="cutting-row">
          <text class="cutting-lbl">数量</text>
          <text class="cutting-val">{{cuttingTask.orderQuantity || detail.quantity || 0}} 件</text>
        </view>
        <view class="cutting-row">
          <text class="cutting-lbl">状态</text>
          <text class="cutting-val {{cuttingTask.status === 'pending' || cuttingTask.status === 'not_started' ? 'status-pending' : 'status-received'}}">{{cuttingTask.statusText || '待领取'}}</text>
        </view>
        <view wx:if="{{cuttingTask.receiverName}}" class="cutting-row">
          <text class="cutting-lbl">领取人</text>
          <text class="cutting-val">{{cuttingTask.receiverName}}</text>
        </view>
      </view>
      <view wx:else class="empty-cutting">
        <text class="empty-cutting-text">暂无裁剪任务</text>
        <text class="empty-cutting-hint">请等待任务分配后扫码领取</text>
      </view>
    </view>

    <view class="tip-card">
      <text class="tip-icon">📋</text>
      <text class="tip-text">领取后请到「小云助手」任务列表中点击任务进行分扎，生成菲号</text>
    </view>
  </block>

  <!-- ===== 普通模式：SKU输入 ===== -->
  <block wx:else>
    <view wx:if="{{aiTipData}}" class="insight-card">
      <text class="insight-icon">💡</text>
      <text class="insight-text">{{aiTipData.aiTip}}</text>
    </view>

    <view wx:if="{{detail.bomFallback}}" class="warn-card">
      <text class="warn-icon">⚠️</text>
      <text class="warn-text">未匹配到BOM工价，当前使用默认工价</text>
    </view>

    <view class="section-card">
      <text class="section-title">扫码明细（{{skuList.length}}项）</text>
      <view class="sku-list">
        <view wx:for="{{skuList}}" wx:key="id" class="sku-item">
          <view class="sku-info">
            <text class="sku-label">{{item.label}}</text>
            <text class="sku-total">订单 {{item.totalQuantity}} 件</text>
          </view>
          <view class="sku-qty-wrap">
            <input class="sku-qty-input" type="number"
                   value="{{item.inputQuantity}}"
                   data-index="{{index}}" bindinput="onSkuInput"
                   placeholder="数量" />
            <text class="sku-unit">件</text>
          </view>
        </view>
      </view>
    </view>

    <view class="summary-card">
      <view class="summary-row">
        <text class="summary-label">总数量</text>
        <text class="summary-value">{{summary.totalQuantity}} 件</text>
      </view>
      <view wx:if="{{summary.totalAmount > 0}}" class="summary-row">
        <text class="summary-label">预估工价</text>
        <text class="summary-value amount">¥{{summary.totalAmount}}</text>
      </view>
    </view>
  </block>

  <view class="footer-bar">
    <view class="btn-cancel" hover-class="footer-bar-hover" bindtap="goBack">取消</view>
    <view class="btn-submit {{loading ? 'btn-disabled' : ''}}" hover-class="footer-bar-hover" bindtap="confirmScan">
      {{loading ? '提交中...' : buttonText}}
    </view>
  </view>

</view>
