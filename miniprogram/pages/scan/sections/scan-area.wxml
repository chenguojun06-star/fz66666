  <!-- ④ 扫码区（一行：扫码主键） -->
  <view class="scan-area-big">
    <view class="scan-row">
      <view class="scan-btn-big {{loading ? 'off' : ''}}" hover-class="scan-btn-big-hover" hover-stay-time="100" bindtap="onScan">
        <view class="scan-btn-icon-svg">
          <image src="/assets/icons/scan-blue.svg" mode="aspectFit" class="scan-icon-img" />
        </view>
        <view class="scan-btn-text-group">
          <text class="scan-btn-main">{{loading ? '识别中...' : '扫码识别'}}</text>
          <text class="scan-btn-sub">{{lastUsedProcessName ? '上次：' + lastUsedProcessName : '自动匹配工序'}}</text>
        </view>
      </view>
    </view>
    <!-- 入库模式：仓库选择 -->
    <view wx:if="{{scanType === 'warehouse'}}" class="warehouse-section">
      <view class="warehouse-label">目标仓库（选填）：</view>
      <view class="warehouse-option-row">
        <view
          wx:for="{{warehouseOptions}}"
          wx:key="index"
          class="warehouse-chip {{warehouse === item ? 'warehouse-chip--active' : ''}}"
          bindtap="onWarehouseChipTap"
          data-value="{{item}}"
          hover-class="warehouse-chip-hover"
          hover-stay-time="100"
        >{{item}}</view>
        <view
          class="warehouse-chip warehouse-chip--clear {{warehouse ? '' : 'warehouse-chip--disabled'}}"
          bindtap="onWarehouseClear"
          hover-class="warehouse-chip-hover"
          hover-stay-time="100"
        >清除</view>
      </view>
      <input
        class="input-box"
        placeholder="或手动输入仓库编号"
        value="{{warehouse}}"
        bindinput="onWarehouseCodeInput"
      />

      <!-- 库位选择（仓库选择后出现） -->
      <view wx:if="{{warehouse && locationOptions.length > 0}}" class="warehouse-label warehouse-label--location">目标库位：</view>
      <view wx:if="{{warehouse && locationOptions.length > 0}}" class="warehouse-option-row">
        <view
          wx:for="{{locationOptions}}"
          wx:key="index"
          class="warehouse-chip {{warehouseLocationCode === item ? 'warehouse-chip--active' : ''}}"
          bindtap="onLocationChipTap"
          data-value="{{item}}"
          hover-class="warehouse-chip-hover"
          hover-stay-time="100"
        >{{item}}</view>
        <view
          class="warehouse-chip warehouse-chip--clear {{warehouseLocationCode ? '' : 'warehouse-chip--disabled'}}"
          bindtap="onLocationClear"
          hover-class="warehouse-chip-hover"
          hover-stay-time="100"
        >清除</view>
      </view>
      <input
        wx:if="{{warehouse}}"
        class="input-box"
        placeholder="或手动输入库位编号"
        value="{{warehouseLocationCode}}"
        bindinput="onLocationCodeInput"
      />
    </view>
    <view wx:if="{{currentUser && currentUser.factoryId}}" class="warehouse-input-row">
      <view class="factory-info-text">
        当前归属：{{currentUser.factoryName || '-'}}{{currentUser.orgPath ? ' · ' + currentUser.orgPath : ''}}{{currentUser.factoryType === 'INTERNAL' ? ' · 内部' : (currentUser.factoryType === 'EXTERNAL' ? ' · 外部' : '')}}
      </view>
    </view>
    <view class="scan-mode-tip">
      <text>说明：系统会按订单工序模板与历史扫码自动识别当前应执行工序，仅允许流转到未完成工序。</text>
    </view>
  </view>

