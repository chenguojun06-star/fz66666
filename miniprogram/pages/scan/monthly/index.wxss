/**
 * 当月记录页面样式 — 卡片式布局
 * 统一使用 design-tokens，card + shadow + radius
 */
@import '/styles/line-icons.wxss';

page {
  background: var(--color-bg-page);
  padding-bottom: env(safe-area-inset-bottom);
}

.container {
  padding: 10px;
}

/* ===== 月份选择器 ===== */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding: 14px;
  margin: 0 0 10px;
  background: var(--color-bg-card);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.04);
}
.month-arrow {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 700;
  color: var(--color-primary);
  background: rgba(var(--color-primary-rgb), 0.08);
  border-radius: 50%;
  transition: all 0.15s ease;
}
.month-arrow-hover {
  background: rgba(var(--color-primary-rgb), 0.15);
  transform: scale(0.92);
}
.month-text {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

/* ===== 筛选区域 ===== */
.filter-section {
  margin: 0 0 10px;
  padding: 10px 12px;
  background: var(--color-bg-card);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.04);
}

/* ===== 汇总统计卡片 ===== */
.summary-card {
  display: flex;
  margin: 0 0 10px;
  padding: 14px 4px;
  background: var(--color-bg-card);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.04);
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6px 4px;
  border-radius: var(--radius-md);
  transition: background 0.15s ease;
}
.summary-item + .summary-item {
  border-left: 1px solid var(--color-border-light);
}
.summary-item.summary-hl {
  background: transparent;
}
.summary-payable-active {
  background: rgba(var(--color-primary-rgb), 0.06);
  border-radius: var(--radius-md);
}
.summary-num {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.3;
}
.summary-item.summary-hl .summary-num {
  color: var(--color-primary);
  font-size: 20px;
  font-weight: 800;
}
.summary-item.summary-hl-hover {
  opacity: 0.8;
}
.summary-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4px;
}

/* ===== 表格 ===== */
.table-wrap {
  margin: 0;
  background: var(--color-bg-card);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.04);
}

/* ===== 空/加载状态 ===== */
.empty-state {
  padding: 48px 20px;
  margin: 0;
  background: transparent;
}
.empty-icon { font-size: 40px; opacity: 0.5; }
.empty-text { font-size: var(--font-size-base); color: var(--color-text-secondary); font-weight: 500; }
.empty-hint { margin-top: 6px; font-size: var(--font-size-xs); color: var(--color-text-disabled); }
.loading-row { text-align: center; padding: 16px; }
.loading-text { font-size: var(--font-size-sm); color: var(--color-text-disabled); }
.load-more {
  text-align: center;
  padding: 12px;
  margin: 0;
  background: transparent;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: 500;
}
.load-more-hover { opacity: 0.7; }
.no-more-row { background: transparent; }
.no-more-text { color: var(--color-text-disabled); font-weight: 400; }
