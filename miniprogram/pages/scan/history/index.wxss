/**
 * 历史记录页面样式 — 卡片式布局
 * 统一使用 design-tokens，card + shadow + radius
 */

page {
  background: var(--color-bg-page);
  padding-bottom: env(safe-area-inset-bottom);
}

.container {
  padding: 10px;
}

/* ===== 搜索栏（从 app.wxss 按需引入） ===== */
.search-row {
  display: flex;
  align-items: center;
  gap: 8px;
}
.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-sm);
}
.search-icon {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}
.search-input {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  width: 100%;
}
.search-btn {
  padding: 8px 16px;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  white-space: nowrap;
}
.search-btn-hover {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.clear-btn {
  padding: 8px 16px;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  border: none;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  white-space: nowrap;
}
.clear-btn-hover {
  background: var(--color-bg-hover);
}

/* ===== 模式切换 ===== */
.mode-tabs {
  display: flex;
  margin: 0 0 10px;
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1px solid var(--color-border-light);
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  transition: all 0.15s ease;
}
.mode-tab-active {
  color: var(--color-primary);
  font-weight: 600;
  background: var(--color-info-bg);
}

/* ===== 月份选择器 ===== */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding: 14px;
  margin: 0 0 10px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-md);
}
.month-arrow {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg-xl);
  font-weight: 700;
  color: var(--color-primary);
  background: var(--color-info-bg);
  border-radius: 50%;
}
.month-arrow-hover { opacity: 0.7; }
.month-text {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  min-width: 120px;
  text-align: center;
}

/* ===== 筛选区域 ===== */
.filter-section {
  margin: 0 0 10px;
  padding: 12px;
  background: var(--color-bg-card);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.04);
}
.date-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}
.date-col {
  flex: 1;
}
.date-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-bottom: 2px;
}
.date-separator {
  font-size: var(--font-size-sm);
  color: var(--color-text-disabled);
  flex-shrink: 0;
  padding: 0 2px;
}

/* ===== 汇总统计卡片 ===== */
.summary-card {
  display: flex;
  margin: 0 0 10px;
  padding: 14px 4px;
  background: var(--color-bg-card);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.04);
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6px 4px;
  border-radius: var(--radius-md);
  transition: background 0.15s ease;
}
.summary-item + .summary-item {
  border-left: 1px solid var(--color-border-light);
}
.summary-item.summary-hl {
  background: transparent;
}
.summary-item.summary-payable {
  transition: all 0.15s ease;
}
.summary-payable-hover {
  opacity: 0.8;
}
.summary-item.summary-payable-active {
  background: rgba(var(--color-primary-rgb), 0.06);
  border-radius: var(--radius-md);
}
.summary-num {
  font-size: var(--font-size-lg-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: var(--line-height-normal);
}
.summary-item.summary-hl .summary-num {
  color: var(--color-primary);
}
.summary-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4px;
}

/* ===== 表格 ===== */
.table-wrap {
  margin: 0;
  background: var(--color-bg-card);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
  border-radius: var(--radius-lg);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.04);
  max-height: calc(100vh - 340px);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ===== 空/加载状态 ===== */
.empty-state {
  padding: 48px 20px;
  margin: 0;
  background: transparent;
}
.empty-icon { font-size: var(--font-size-5xl); opacity: 0.5; }
.empty-text { font-size: var(--font-size-base); color: var(--color-text-secondary); font-weight: 500; }
.empty-hint { margin-top: 6px; font-size: var(--font-size-xs); color: var(--color-text-disabled); }
.loading-row { text-align: center; padding: 16px; }
.loading-text { font-size: var(--font-size-sm); color: var(--color-text-disabled); }
.load-more {
  text-align: center;
  padding: 12px;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: 500;
}
.load-more-hover { opacity: 0.7; }
.no-more-row { background: transparent; }
.no-more-text { color: var(--color-text-disabled); font-weight: 400; }
