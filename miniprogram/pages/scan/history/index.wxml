<view class="container">
  <!-- 头部筛选区域 -->
  <view class="filter-section">
    <view class="date-row">
      <view class="date-col">
        <text class="date-label">开始</text>
        <date-picker value="{{startDate}}" bindchange="onStartDateChange" />
      </view>
      <text class="date-separator">—</text>
      <view class="date-col">
        <text class="date-label">结束</text>
        <date-picker value="{{endDate}}" bindchange="onEndDateChange" />
      </view>
    </view>
    <view class="search-row">
      <view class="search-box">
        <view class="line-icon line-icon--sm icon-search search-icon"></view>
        <input class="search-input" placeholder="订单号 / 菲号 / 工序" value="{{searchKeyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="onSearch" />
      </view>
      <view class="search-btn" bindtap="onSearch" hover-class="search-btn-hover" hover-stay-time="50">搜索</view>
      <view class="clear-btn" wx:if="{{searchKeyword}}" bindtap="onClearSearch" hover-class="clear-btn-hover" hover-stay-time="50">重置</view>
    </view>
  </view>

  <!-- 汇总卡片 -->
  <view class="summary-card">
    <view class="summary-item">
      <text class="summary-num">{{summary.totalQuantity || 0}}</text>
      <text class="summary-label">总数量</text>
    </view>
    <view class="summary-item">
      <text class="summary-num">{{summary.recordCount || 0}}</text>
      <text class="summary-label">记录数（样衣{{summary.patternRecordCount || 0}}）</text>
    </view>
    <view class="summary-item summary-hl summary-payable {{showOnlyPayable ? 'summary-payable-active' : ''}}" bindtap="onTogglePayableFilter" hover-class="summary-payable-hover" hover-stay-time="50">
      <text class="summary-num">¥{{summary.totalWage || '0.00'}}</text>
      <text class="summary-label">工资汇总（{{summary.payableRecordCount || 0}}条）</text>
    </view>
  </view>

  <!-- 表格 -->
  <view class="table-wrap" wx:if="{{displayRecords.length > 0}}">
    <scan-record-table records="{{displayRecords}}" showAmount="{{true}}" />
  </view>

  <!-- 空状态 -->
  <empty-state wx:if="{{displayRecords.length === 0 && !loading}}" icon="icon-clipboard" text="{{emptyText}}" hint="{{emptyHint}}"></empty-state>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-row">
    <text class="loading-text">加载中...</text>
  </view>
  <load-more hasMore="{{hasMore}}" loading="{{loading}}" count="{{displayRecords.length}}" bind:loadmore="onLoadMore"></load-more>
</view>
