/**
 * 质检录入页面 — Apple Design 风格
 * 卡片：白底 + 1px divider 边框 + radius-xl + shadow-sm
 * 状态：pill 形 + 浅色背景 + 对应文字色
 * 数字：tabular-nums
 */

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--page-padding-x) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 140px);
}

/* ---- 订单信息卡片 ---- */
.info-card {
  background: var(--color-bg-card);
  
  
  margin-bottom: var(--card-gap);
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.card-header {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
}

.cover-wrap {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-page);
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  flex: 1;
  min-width: 0;
}

.style-no {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.sub-info {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-divider {
  height: 1px;
  background: var(--color-border);
  margin: var(--spacing-md) 0;
}

.kv-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

.kv-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-xs) 0;
}

.kv-item.kv-item-border {
  border-left: 1px solid var(--color-border);
  padding-left: var(--spacing-md);
}

.kv-item:nth-child(-n+2) {
  padding-bottom: var(--spacing-sm);
}

.kv-item:nth-child(n+3) {
  padding-top: var(--spacing-sm);
  border-top: 1px solid var(--color-border);
}

.kv-item.kv-item-border:nth-child(n+3) {
  border-left: 1px solid var(--color-border);
}

.kv-label {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.kv-value {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  text-align: right;
}

/* ---- AI 建议卡片 ---- */
.insight-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
  border-radius: var(--radius-2xl);
  padding: var(--spacing-lg);
  margin-bottom: var(--card-gap);
  background: var(--color-primary-bg);
  box-shadow: var(--shadow-sm);
  color: var(--color-primary);
  font-size: var(--font-size-xs);
  line-height: var(--line-height-relaxed);
}

.insight-icon {
  flex-shrink: 0;
  font-size: var(--font-size-base);
}

.insight-body {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  flex: 1;
}

.insight-text {
  font-size: var(--font-size-xs);
}

.insight-urgent {
  color: var(--color-danger);
  font-weight: var(--font-weight-medium);
}

.insight-label {
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-top: var(--spacing-xs);
}

.insight-checkpoint {
  font-size: var(--font-size-2xs);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

.insight-action {
  width: 100%;
  height: 40px;
  margin-top: var(--spacing-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-2xl);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
}

/* ---- 通用区块卡片 ---- */
.section-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}

/* ---- 分区组（对齐设计稿：标题在卡片外） ---- */
.section-group {
  margin-bottom: var(--card-gap);
}
.section-group-title {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-tertiary);
  padding: 0 8rpx;
  margin-bottom: 16rpx;
}
.group-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 0;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.section-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-tertiary);
  margin-bottom: var(--spacing-md);
  display: block;
}

/* ---- 质检结果选择 ---- */
.result-group {
  display: flex;
  gap: var(--spacing-sm);
}

.result-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  height: 56px;
  border-radius: var(--radius-2xl);
  background: var(--color-bg-card);
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  border: 2px solid var(--color-border);
  transition: all 0.2s ease;
}

.result-btn.active-pass {
  background: var(--color-success);
  color: var(--color-text-white);
  border-color: var(--color-success);
  font-weight: var(--font-weight-semibold);
}

.result-btn.active-fail {
  background: var(--color-danger);
  color: var(--color-text-white);
  border-color: var(--color-danger);
  font-weight: var(--font-weight-semibold);
}

.result-icon {
  font-size: var(--font-size-lg-xl);
}

.result-btn.active-pass .result-icon {
  color: var(--color-text-white);
}

.result-btn.active-fail .result-icon {
  color: var(--color-text-white);
}

/* ---- 表单行 ---- */
.group-field-list {
  padding: 0 32rpx;
}
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 0;
  border-bottom: 1px solid var(--color-border);
}

.form-row:last-child {
  border-bottom: none;
}

.form-row-col {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0;
}

.photo-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.photo-count-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.form-label {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.form-input {
  width: 130px;
  height: 36px;
  text-align: right;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 0 var(--spacing-sm);
  font-size: var(--font-size-md);
  background: var(--input-bg);
  font-variant-numeric: tabular-nums;
}

.form-picker {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.picker-arrow {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
}

/* ---- 照片网格 ---- */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--spacing-sm);
}

.photo-item {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-del {
  position: absolute;
  top: var(--spacing-xs);
  right: var(--spacing-xs);
  width: 20px;
  height: 20px;
  border-radius: var(--radius-full);
  background: var(--color-overlay);
  color: var(--color-text-white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-md);
  line-height: 1;
}

.photo-add {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: var(--radius-lg);
  border: 2px dashed var(--color-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  background: transparent;
}

.add-icon {
  font-size: var(--font-size-xl);
}

.add-text {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
}

/* ---- 备注 ---- */
.remark-area {
  width: 100%;
  min-height: 60px;
  padding: 24rpx 32rpx;
  font-size: var(--font-size-md);
  background: transparent;
  border: none;
  box-sizing: border-box;
}
