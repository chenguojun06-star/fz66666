
.container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb,37,99,235),0.06) 0%, transparent 60%),
              var(--page-bg);
  padding: var(--page-padding-x) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 160rpx);
}

/* ---- info-card ---- */
.info-card {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-header { display: flex; align-items: flex-start; gap: 24rpx; }
.cover-wrap {
  width: 140rpx; height: 140rpx;
  border-radius: 14rpx; overflow: hidden;
  flex-shrink: 0; background: var(--color-border-light);
}
.header-info { display: flex; flex-direction: column; gap: 8rpx; flex: 1; min-width: 0; }
.style-no { font-size: var(--font-size-md-lg); font-weight: 600; color: var(--color-text-primary); }
.sub-info { font-size: var(--font-size-xs); color: var(--color-text-tertiary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tag-process {
  display: inline-block; align-self: flex-start;
  background: rgba(var(--color-primary-rgb,37,99,235),0.08); color: var(--color-primary);
  font-size: var(--font-size-xxs); padding: 4rpx 14rpx; border-radius: 8rpx; margin-top: 4rpx;
}

/* ---- insight ---- */
.insight-card {
  display: flex; align-items: flex-start; gap: 12rpx;
  border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx;
  background: rgba(var(--color-primary-rgb,37,99,235),0.06); color: var(--color-primary);
  font-size: var(--font-size-xs); line-height: var(--line-height-relaxed);
}
.insight-icon { flex-shrink: 0; font-size: var(--font-size-base); }
.insight-body { display: flex; flex-direction: column; gap: 8rpx; flex: 1; }
.insight-text { font-size: var(--font-size-xs); }
.insight-urgent { color: var(--color-danger); font-weight: 500; }
.insight-label { font-size: var(--font-size-xxs); font-weight: 600; color: var(--color-text-primary); margin-top: 4rpx; }
.insight-checkpoint { font-size: var(--font-size-xxs); color: var(--color-text-secondary); line-height: var(--line-height-relaxed); }
.insight-action {
  align-self: flex-start; margin-top: 8rpx;
  font-size: var(--font-size-xs); font-weight: 600;
  color: var(--color-primary);
  padding: 6rpx 20rpx; border-radius: 8rpx;
  background: rgba(var(--color-primary-rgb,37,99,235),0.1);
}

/* ---- section ---- */
.section-card {
  background: var(--color-bg-card); border-radius: 20rpx;
  padding: 24rpx 28rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text-primary); margin-bottom: 16rpx; display: block; }

/* ---- quality result ---- */
.result-group { display: flex; gap: 20rpx; }
.result-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 10rpx;
  height: 100rpx; border-radius: 16rpx;
  background: var(--color-bg-light); font-size: var(--font-size-base); color: var(--color-text-secondary);
  border: 2rpx solid transparent; transition: all 0.2s;
}
.result-btn.active-pass {
  background: rgba(34,197,94,0.08); color: var(--color-success);
  border-color: var(--color-success); font-weight: 600;
}
.result-btn.active-fail {
  background: rgba(239,68,68,0.08); color: var(--color-danger);
  border-color: var(--color-danger); font-weight: 600;
}
.result-icon { font-size: var(--font-size-lg-xl); }

/* ---- form ---- */
.form-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 0; border-bottom: 1rpx solid var(--color-border-light);
}
.form-row:last-child { border-bottom: none; }
.form-row-col {
  display: flex; flex-direction: column; gap: 12rpx;
  padding: 16rpx 0;
}
.form-label { font-size: var(--font-size-sm); color: var(--color-text-primary); flex-shrink: 0; }
.form-input {
  width: 260rpx; height: 64rpx; text-align: right;
  border: 2rpx solid var(--color-border); border-radius: 10rpx;
  padding: 0 16rpx; font-size: var(--font-size-md);
}
.form-picker {
  display: flex; align-items: center; gap: 8rpx;
  font-size: var(--font-size-sm); color: var(--color-text-primary);
}
.picker-arrow { font-size: var(--font-size-2xs); color: var(--color-text-tertiary); }

/* ---- photo grid ---- */
.photo-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.photo-item { position: relative; width: 160rpx; height: 160rpx; border-radius: 12rpx; overflow: hidden; }
.photo-img { width: 100%; height: 100%; }
.photo-del {
  position: absolute; top: 4rpx; right: 4rpx;
  width: 40rpx; height: 40rpx; border-radius: 20rpx;
  background: rgba(0,0,0,0.55); color: var(--color-text-white);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-size-md); line-height: 1;
}
.photo-add {
  width: 160rpx; height: 160rpx; border-radius: 12rpx;
  border: 2rpx solid var(--color-border); display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8rpx;
  background: var(--color-bg-gray);
}
.add-icon { font-size: var(--font-size-xl); }
.add-text { font-size: var(--font-size-2xs); color: var(--color-text-tertiary); }

/* ---- remark ---- */
.remark-area {
  width: 100%; min-height: 120rpx;
  padding: 16rpx; font-size: var(--font-size-sm);
  border: 2rpx solid var(--color-border); border-radius: 12rpx;
  box-sizing: border-box;
}


