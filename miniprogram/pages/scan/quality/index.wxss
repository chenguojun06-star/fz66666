@import '/styles/design-tokens.wxss';

.container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb,37,99,235),0.06) 0%, transparent 60%),
              var(--page-bg, #f5f5f5);
  padding: 24rpx 24rpx calc(env(safe-area-inset-bottom) + 160rpx);
}

/* ---- info-card ---- */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-header { display: flex; align-items: flex-start; gap: 24rpx; }
.cover-wrap {
  width: 180rpx; height: 180rpx;
  border-radius: 20rpx; overflow: hidden;
  flex-shrink: 0; background: #f0f0f0;
}
.cover-img { width: 100%; height: 100%; }
.cover-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
}
.placeholder-icon { font-size: 48rpx; }
.header-info { display: flex; flex-direction: column; gap: 12rpx; flex: 1; min-width: 0; }
.style-no { font-size: 36rpx; font-weight: 700; color: #1a1a2e; }
.sub-info { font-size: 28rpx; color: #888; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tag-process {
  display: inline-block; align-self: flex-start;
  background: rgba(var(--color-primary-rgb,37,99,235),0.08); color: var(--primary-color, #2563eb);
  font-size: 26rpx; padding: 6rpx 16rpx; border-radius: 10rpx; margin-top: 4rpx;
}

/* ---- insight ---- */
.insight-card {
  display: flex; align-items: flex-start; gap: 12rpx;
  border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx;
  background: rgba(var(--color-primary-rgb,37,99,235),0.06); color: var(--primary-color, #2563eb);
  font-size: 24rpx; line-height: 1.6;
}
.insight-icon { flex-shrink: 0; font-size: 30rpx; }
.insight-body { display: flex; flex-direction: column; gap: 8rpx; flex: 1; }
.insight-text { font-size: 24rpx; }
.insight-action {
  align-self: flex-start; margin-top: 8rpx;
  font-size: 24rpx; font-weight: 600;
  color: var(--primary-color, #2563eb);
  padding: 6rpx 20rpx; border-radius: 8rpx;
  background: rgba(var(--color-primary-rgb,37,99,235),0.1);
}

/* ---- section ---- */
.section-card {
  background: #fff; border-radius: 20rpx;
  padding: 24rpx 28rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title { font-size: 26rpx; font-weight: 600; color: #1a1a2e; margin-bottom: 16rpx; display: block; }

/* ---- quality result ---- */
.result-group { display: flex; gap: 20rpx; }
.result-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: 10rpx;
  height: 100rpx; border-radius: 16rpx;
  background: #f8f9fb; font-size: 30rpx; color: #666;
  border: 2rpx solid transparent; transition: all 0.2s;
}
.result-btn.active-pass {
  background: rgba(34,197,94,0.08); color: #16a34a;
  border-color: #16a34a; font-weight: 600;
}
.result-btn.active-fail {
  background: rgba(239,68,68,0.08); color: #ef4444;
  border-color: #ef4444; font-weight: 600;
}
.result-icon { font-size: 36rpx; }

/* ---- form ---- */
.form-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.form-row:last-child { border-bottom: none; }
.form-row-col {
  display: flex; flex-direction: column; gap: 12rpx;
  padding: 16rpx 0;
}
.form-label { font-size: 26rpx; color: #333; flex-shrink: 0; }
.form-input {
  width: 260rpx; height: 64rpx; text-align: right;
  border: 2rpx solid #e0e0e0; border-radius: 10rpx;
  padding: 0 16rpx; font-size: 28rpx;
}
.form-picker {
  display: flex; align-items: center; gap: 8rpx;
  font-size: 26rpx; color: #333;
}
.picker-arrow { font-size: 20rpx; color: #999; }

/* ---- photo grid ---- */
.photo-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.photo-item { position: relative; width: 160rpx; height: 160rpx; border-radius: 12rpx; overflow: hidden; }
.photo-img { width: 100%; height: 100%; }
.photo-del {
  position: absolute; top: 4rpx; right: 4rpx;
  width: 40rpx; height: 40rpx; border-radius: 20rpx;
  background: rgba(0,0,0,0.55); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; line-height: 1;
}
.photo-add {
  width: 160rpx; height: 160rpx; border-radius: 12rpx;
  border: 2rpx dashed #ccc; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 8rpx;
  background: #fafafa;
}
.add-icon { font-size: 40rpx; }
.add-text { font-size: 20rpx; color: #999; }

/* ---- remark ---- */
.remark-area {
  width: 100%; min-height: 120rpx;
  padding: 16rpx; font-size: 26rpx;
  border: 2rpx solid #e0e0e0; border-radius: 12rpx;
  box-sizing: border-box;
}

/* ---- footer ---- */
.footer-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; gap: 20rpx;
  padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: #fff; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 99;
}
.btn-cancel, .btn-submit {
  flex: 1; height: 88rpx; border-radius: 44rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 30rpx; font-weight: 600;
}
.btn-cancel { background: #f3f4f6; color: #666; }
.btn-submit { background: var(--primary-color, #2563eb); color: #fff; }
.btn-submit.off { opacity: 0.5; }
.btn-hover { opacity: 0.8; }
