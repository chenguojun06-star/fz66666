/* ===== 扫码区（一行布局） ===== */
.scan-area-big {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 10px;
  margin-bottom: 8px;
  border: 1px solid var(--color-border);
}
.scan-row {
  display: flex;
  align-items: center;
  gap: 0;
  justify-content: center;
  margin-bottom: 8px;
}
.scan-btn-big {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  flex: 1;
  width: 100%;
  max-width: none;
  min-width: 0;
  padding: 0 12px;
  height: 52px;
  box-sizing: border-box;
  overflow: hidden;
  background: var(--gradient-action);
  color: var(--color-text-white);
  border-radius: var(--radius-full);
  font-size: var(--font-size-lg);
  font-weight: 700;
  border: none;
  box-shadow: 0 6px 20px rgba(37, 99, 235, 0.40);
}
.scan-btn-big.off {
  opacity: 0.4;
  pointer-events: none;
}
.scan-btn-big-hover {
  opacity: 0.88;
  transform: scale(0.97);
  box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35);
}
.scan-btn-icon {
  font-size: 20px;
}
.scan-btn-icon-svg {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.scan-btn-text-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.1;
}

.scan-btn-main {
  font-size: 18px;
  font-weight: 800;
  white-space: nowrap;
}

.scan-btn-sub {
  font-size: 13px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
  white-space: nowrap;
}

.warehouse-input-row {
  margin-bottom: 8px;
}

.warehouse-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary, var(--color-text-secondary));
  margin-bottom: 6px;
}

.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 8px;
}

.warehouse-chip {
  padding: 4px 14px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  border: 1px solid var(--color-border);
  background: var(--color-bg-light);
  color: var(--color-text-primary);
}

.warehouse-chip--active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

.warehouse-chip--clear {
  background: rgba(254, 226, 226, 0.6);
  border-color: rgba(252, 165, 165, 0.5);
  color: var(--color-danger, var(--color-error));
}

.warehouse-chip--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.warehouse-chip-hover {
  opacity: 0.75;
}

.warehouse-input-field {
  width: 100%;
  height: 40px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 12px;
  font-size: var(--font-size-sm);
  box-sizing: border-box;
}
.wh-box-inline {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
  padding: 6px 12px;
  background: var(--color-bg-light);
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
}
.wh-box-inline .wh-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}
.wh-box-inline .wh-input {
  flex: 1;
  font-size: var(--font-size-sm);
  height: 28px;
}

/* ===== 旧扫码区（兼容保留） ===== */
.scan-area {
  display: flex;
  gap: 8px;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 8px;
  padding-right: 50px;
  margin-bottom: 8px;
  border: 1px solid var(--color-border);
}

.scan-type-picker {
  flex: 0 0 112px;
  width: 112px;
  max-width: 112px;
  min-width: 112px;
  box-sizing: border-box;
  overflow: hidden;
}

.picker-display {
  display: flex;
  align-items: center;
  gap: 4px;
  background: var(--gradient-primary-solid);
  border-radius: var(--radius-full);
  width: 100%;
  padding: 0 12px;
  height: 40px;
  box-sizing: border-box;
  justify-content: center;
}

.picker-label {
  font-size: 13px;
  color: var(--color-primary);
  font-weight: 500;
}

.picker-arrow {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  margin-left: 2px;
}

.scan-input {
  flex: 0 0 44px;
  width: 44px;
  max-width: 44px;
  min-width: 44px;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 0;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(var(--color-primary-rgb), 0.1);
  box-sizing: border-box;
}
.scan-input input {
  width: 100%;
  height: 44px;
  font-size: var(--font-size-sm);
  text-align: center;
}
.scan-btn {
  display: flex;
  align-items: center;
  padding: 0 18px;
  height: 36px;
  background: rgba(255, 255, 255, 0.6);
  color: var(--color-text-primary);
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: var(--radius-full);
  font-size: var(--font-size-base);
  font-weight: 500;
  box-shadow: 0 2px 6px rgba(15, 23, 42, 0.06);
}
.scan-btn.off {
  opacity: 0.5;
}
.scan-btn-hover {
  background: var(--color-bg-light);
}
.scan-ico {
  width: 16px;
  height: 16px;
}

/* ===== 质检选项 ===== */
.qc-bar {
  display: flex;
  gap: 6px;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 8px;
  margin-bottom: 8px;
  border: 1px solid var(--color-border);
}
.qc-opt {
  flex: 1;
  text-align: center;
  padding: 6px 4px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
}
.qc-opt-hover {
  background: var(--color-bg-light);
}
.qc-opt.on.pass {
  background: var(--color-bg-light);
  color: var(--color-text-primary);
}
.qc-opt.on.fail {
  background: var(--color-bg-light);
  color: var(--color-text-primary);
}
.qc-opt.on.fix {
  background: var(--color-bg-light);
  color: var(--color-text-primary);
}

/* ===== 次品详情 ===== */
.defect-box {
  background: var(--color-warning-bg);
  border-radius: var(--radius-xl);
  padding: 10px;
  margin-bottom: 8px;
  border: 1px solid var(--color-warning-border);
}
.df-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid var(--color-border-light);
}
.df-row:last-child {
  border-bottom: none;
}
.df-label {
  width: 36px;
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}
.df-picker {
  flex: 1;
}
.df-val {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}
.df-photos {
  display: flex;
  gap: 6px;
  flex: 1;
}
.df-photo {
  position: relative;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.df-photo image {
  width: 100%;
  height: 100%;
}
.df-del {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 16px;
  height: 16px;
  background: rgba(15, 23, 42, 0.7);
  color: var(--color-text-white);
  font-size: var(--font-size-xs);
  text-align: center;
  line-height: 16px;
  border-radius: var(--radius-full);
}
.df-add {
  width: 40px;
  height: 40px;
  border: 1px dashed var(--color-border);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xl); /* 一级标题/图标 */
  color: var(--color-text-disabled);
}
.df-add.off {
  opacity: 0.4;
}

/* ===== 仓库输入 ===== */
.wh-box {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--color-bg-card);
  border-radius: var(--radius-full);
  padding: 8px 12px;
  margin-bottom: 8px;
  border: 1px solid var(--color-border);
}
.wh-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-disabled);
}
.wh-input {
  flex: 1;
  font-size: var(--font-size-sm);
}

