/* SKU列表 - 弹窗内 */
.purchase-modal-list {
  margin-top: 6px;
  max-height: 300px;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.purchase-modal-list--pattern {
  max-height: none;
}

.scan-section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 6px;
  margin-bottom: 5px;
}

.scan-section-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-text-primary);
}

.scan-section-desc {
  font-size: 11px;
  color: var(--color-text-disabled);
}

/* ✅ SKU统计摘要样式 */
.sku-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 6px 8px;
  background: linear-gradient(135deg, var(--color-info-bg) 0%, var(--color-info-bg) 100%);
  border-radius: var(--radius-sm);
  margin-bottom: 6px;
  border-left: 3px solid var(--color-primary);
}

.summary-stat {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 4px;
}

.summary-label {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: 500;
}

.summary-value {
  font-size: 13px;
  color: var(--color-text-primary);
  font-weight: 600;
}

.purchase-modal-item {
  background: var(--color-bg-card);
  border-radius: 7px;
  padding: 6px;
  margin-bottom: 4px;
  border: 1px solid rgba(var(--color-primary-rgb), 0.15);
  box-shadow: 0 3px 9px rgba(15, 23, 42, 0.04);
}

.purchase-modal-item--emphasis {
  background: linear-gradient(180deg, var(--color-bg-card) 0%, var(--color-bg-light) 100%);
}

.purchase-modal-item--form {
  background: var(--color-bg-card);
}

.purchase-modal-item:last-child {
  margin-bottom: 0;
}

.pmi-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 4px;
  margin-bottom: 4px;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--color-border);
}

.pmi-name {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
}

.pmi-label {
  width: 70px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.pmi-row {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.pmi-row:last-child {
  margin-bottom: 0;
}

/* 横向布局行 */
.pmi-row-inline {
  display: flex;
  gap: 5px;
  margin-bottom: 0;
}

.pmi-row-inline-spacious {
  align-items: stretch;
}

/* 横向布局列 */
.pmi-col {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 4px;
}

.pmi-col-card {
  align-items: flex-start;
  flex-direction: column;
  gap: 3px;
  padding: 6px;
  border-radius: 6px;
  background: var(--color-bg-light);
  border: 1px solid var(--color-border-light);
}

.pmi-label {
  width: 70px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.pmi-label-stack {
  width: auto;
}

/* 横向布局中的label自适应宽度 */
.pmi-col .pmi-label {
  width: auto;
  white-space: nowrap;
}

.pmi-value {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

.pmi-value.demand {
  color: var(--color-primary);
  font-weight: 600;
}

.pmi-input {
  flex: 1;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 5px;
  padding: 3px 5px;
  font-size: 12px;
  height: 30px;
  min-width: 60px;
}

.pmi-input-block {
  width: 100%;
  box-sizing: border-box;
}

.cf-item {
  display: flex;
  justify-content: space-between;
  padding: 3px 0;
  border-bottom: 1px solid var(--color-border-light);
}
.cf-item-card {
  width: calc(50% - 2px);
  box-sizing: border-box;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 3px;
  padding: 7px 8px;
  margin: 0;
  border: 1px solid var(--color-bg-light);
  border-radius: 6px;
  background: var(--color-bg-light);
}
.cf-item-wide {
  width: 100%;
}
.cf-item-stack .cf-v {
  max-width: none;
}
.cf-item:last-child {
  border-bottom: none;
}
.cf-k {
  font-size: 11px;
  color: var(--color-text-secondary);
}
.cf-v {
  font-size: 14px;
  color: var(--color-text-primary);
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 600;
}
.cf-item.compact .cf-k {
  font-size: var(--font-size-xs);
}
.cf-item.compact .cf-v {
  font-size: var(--font-size-xs);
  max-width: 220px;
}
.cf-v.wrap {
  white-space: normal;
  overflow: visible;
  text-overflow: unset;
}

.cf-v.mono {
  font-family: monospace;
  font-size: var(--font-size-xs);
}
.cf-v.hl {
  color: var(--color-text-secondary);
  font-weight: 500;
}
.modal-btns {
  display: flex;
  gap: 6px;
  padding: 10px 12px;
  border-top: 1px solid var(--color-border-light);
  flex-shrink: 0;
  background: var(--color-bg-card);
}
.mbtn {
  display: inline-flex;
  flex: 1;
  align-items: center;
  justify-content: center;
  padding: 0 8px;
  height: 36px;
  min-width: 0;
  border-radius: 8px;
  text-align: center;
  font-size: 13px;
  font-weight: 500;
  line-height: 1;
}
.mbtn-hover {
  opacity: 0.8;
  transform: scale(0.98);
}
.mbtn.cancel {
  background: rgba(255, 255, 255, 0.6);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
}
.mbtn.ok {
  background: var(--gradient-primary-alpha);
  color: var(--color-text-primary);
  border: 1px solid rgba(var(--color-primary-rgb), 0.2);
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
}
.mbtn.ok.off {
  opacity: 0.5;
}
