/* 🆕 扫码结果确认弹窗样式（2026-02-06 混合模式） */
.scan-result-modal .modal-box {
  width: 85%;
  max-width: 400px;
}

.scan-result-info {
  padding: 4px 0;
}

.result-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 36px;
  padding: 6px 10px;
  margin-bottom: 3px;
  background: #f8f9fa;
  border-radius: 6px;
  box-sizing: border-box;
}

.result-item-row {
  display: flex;
  gap: 4px;
  margin-bottom: 3px;
}

.result-item-half {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

/* === 工序滚动选择器（基于 inline-selector 通用样式 + 价格扩展） === */
.process-scroll-selector {
  margin-top: 6px;
}

.process-scroll-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px 4px;
}

.process-scroll-title {
  font-size: 11px;
  color: #64748b;
  font-weight: 600;
}

.process-scroll-hint {
  font-size: 10px;
  color: #94a3b8;
}

.process-scroll-list {
  max-height: 180px;
  padding: 0 6px 6px;
}

.process-selected-summary {
  margin: 0 8px 6px;
  padding: 8px 10px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
}

.process-selected-title {
  display: block;
  font-size: 11px;
  color: #475569;
  font-weight: 600;
  margin-bottom: 6px;
}

.process-selected-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.process-selected-tag {
  display: inline-flex;
  align-items: center;
  height: 24px;
  padding: 0 8px;
  border-radius: 999px;
  background: #eff6ff;
  color: #2563eb;
  font-size: 11px;
  font-weight: 600;
}

/* 价格标签（工序选择器专有） */
.process-item-price {
  font-size: 12px;
  color: #10b981;
  font-weight: 700;
}

.process-scroll-selector .inline-selector-label {
  font-size: 13px;
}

.inline-selector-item.active .process-item-price {
  color: #059669;
}

.item-label {
  font-size: 11px;
  color: #64748b;
  font-weight: 500;
}

.item-value {
  font-size: 13px;
  color: #1e293b;
  font-weight: 600;
}

.item-value.highlight {
  color: #2563eb;
}

.result-qty-input {
  width: 100px;
  height: 28px;
  padding: 0 8px;
  text-align: right;
  border: 1px solid var(--color-border);
  border-radius: 6px;
  background: #fff;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

/* 旧 picker 样式已移除，改用内联滚动选择器 */

.result-hint {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px;
  margin: 6px 0 0 0;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 6px;
  border-left: 4px solid #f59e0b;
}

.hint-icon {
  font-size: var(--font-size-lg);
}

.hint-text {
  flex: 1;
  font-size: var(--font-size-sm);
  color: #92400e;
  line-height: 1.5;
}

.modal-btn.ok {
  background: linear-gradient(135deg, #10b981 0%, var(--color-success) 100%);
  box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

.modal-btn.ok.loading {
  background: #9ca3af;
  pointer-events: none;
}

/* === 款式难度提示行 === */
.diff-hint-row {
  align-items: flex-start;
  background: #fff7ed;
  border: 1px solid #fed7aa;
}

.diff-hint-label {
  color: #c2410c;
  flex-shrink: 0;
  margin-top: 1px;
}

.diff-hint-text {
  font-size: 11px;
  color: #9a3412;
  font-weight: 500;
  line-height: 1.5;
  flex: 1;
  text-align: right;
  white-space: pre-wrap;
  word-break: break-all;
}
