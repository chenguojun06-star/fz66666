/* pages/payroll/payroll.wxss */
@import '../../styles/page-utils.wxss';

.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x);
}

/* ========== 汇总渐变卡片 (brand-50 -> brand-100) ========== */
.summary-card {
  margin-top: 12px;
  
  background: linear-gradient(135deg, var(--color-primary-bg) 0%, var(--color-primary-bg-dark) 100%);
  

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.summary-month {
  display: block;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.summary-amount {
  display: block;
  margin-top: 4px;
  font-size: var(--font-size-6xl);
  font-weight: var(--font-weight-bold);
  line-height: 1;
  letter-spacing: -0.03em;
  color: var(--color-primary);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

/* 环比指标 */
.summary-mom {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 8px;
}

.mom-arrow {
  width: 0;
  height: 0;
}

.mom-arrow.mom-up {
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-bottom: 6px solid var(--color-success);
}

.mom-arrow.mom-down {
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-top: 6px solid var(--color-danger);
}

.mom-text {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}

.mom-text.mom-up {
  color: var(--color-success);
}

.mom-text.mom-down {
  color: var(--color-danger);
}

.summary-stats {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 12px;
}

.summary-stat-item {
  flex: 1;
  min-width: 0;
}

.summary-stat-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.summary-stat-value {
  display: block;
  margin-top: 2px;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

.summary-stat-divider {
  width: 1px;
  height: 36px;
  background: var(--color-border);
  flex-shrink: 0;
}

/* ========== 日期选择栏 ========== */
.date-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 var(--page-padding-x) 12px;
}

.date-picker {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  padding: 0 12px;
  height: 36px;
  flex: 1;
  box-shadow: var(--shadow-sm);
}

.date-label {
  font-size: 12px;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.date-value {
  font-size: 13px;
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  font-variant-numeric: tabular-nums;
  flex: 1;
}

.date-sep {
  font-size: 14px;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

/* ========== 筛选标签 (Apple 风格下划线) ========== */
.filter-tabs {
  display: flex;
  align-items: center;
  margin-top: 12px;
  border-bottom: 1px solid var(--color-border);
}

.filter-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40px;
  padding: 0 12px;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  background: transparent;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  margin-bottom: -1px;
  transition: color 0.18s ease;
}

.filter-tab.active {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  border-bottom-color: var(--color-primary);
}

/* ========== 明细记录列表 ========== */
.detail-list {
  margin-top: 12px;
}

/* 工序记录卡片：border + rounded-lg(8px)，对齐设计稿 rounded-lg border border-[var(--background-300)] */
.record-item {
  background: var(--color-bg-card);
  
  
  
  margin-bottom: 10px;
  transition: background-color 0.18s ease;

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.record-item:active {
  background: var(--color-bg-muted);
}

.record-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.record-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.record-tag-line {
  display: flex;
  align-items: center;
  gap: 8px;
}

.process-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 2px 8px;
  border-radius: var(--radius-xs);
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  flex-shrink: 0;
}

.tag-piecework {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.tag-bonus {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.record-product {
  flex: 1;
  min-width: 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-sub {
  margin-top: 4px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-right {
  flex-shrink: 0;
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
}

.record-calc {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

.record-amount {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 0;
  gap: 12px;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

/* ========== 底部固定合计栏 ========== */
.bottom-bar-spacer {
  height: calc(56px + env(safe-area-inset-bottom));
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  background: var(--color-bg-card);
  border-top: 1px solid var(--color-border);
  padding-bottom: env(safe-area-inset-bottom);
}

.bottom-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  height: 56px;
}

.bottom-bar-label {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.bottom-bar-amount {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}
