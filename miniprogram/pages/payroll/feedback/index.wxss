.page {
  padding: 0 var(--page-padding-x);
  background: var(--color-bg-page);
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  margin-bottom: 0;
}
.title {
  font-size: 20px;
  font-weight: bold;
  color: var(--color-text-primary);
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-md);
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 40px;
  opacity: 0.4;
}
.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  margin-top: 20rpx;
}

.settlement-card {
  background: var(--color-bg-card);
  
  
  
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
.settlement-no {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.feedback-status {
  font-size: var(--font-size-xs);
  padding: 2px 8px;
  border-radius: 6px;
  font-weight: var(--font-weight-medium);
}
.status-none {
  background: var(--color-bg-page);
  color: var(--color-text-tertiary);
}
.status-PENDING {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}
.status-RESOLVED {
  background: var(--color-success-bg);
  color: var(--color-success);
}
.status-REJECTED {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.order-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.order-no {
  font-size: 12px;
  color: var(--color-text-tertiary);
}
.style-no {
  font-size: 15px;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.amount-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
  margin-top: 8px;
}
.amount {
  font-size: 24px;
  font-weight: bold;
  color: var(--color-text-primary);
  letter-spacing: -0.02em;
}
.quantity {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}
.time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.feedback-action {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* 页面内反馈表单 */
.inline-form-card {
  background: var(--color-bg-card);
  border-radius: 16px;
  border: 1px solid var(--color-border);
  padding: 16px;
  margin: 12px 0;
  box-shadow: var(--shadow-sm);
}
.inline-form-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}

.form-group {
  margin-bottom: 16px;
}
.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 6px;
}
.form-input {
  border: 1rpx solid var(--input-border);
  border-radius: var(--radius-xl);
  padding: 16rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: var(--input-bg);
  min-height: var(--input-height-sm);
  box-sizing: border-box;
}
.form-input-readonly {
  background: var(--color-bg-page);
  color: var(--color-text-tertiary);
}
.form-textarea {
  border: 1rpx solid var(--input-border);
  border-radius: var(--radius-xl);
  padding: 10px 12px;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: var(--input-bg);
  width: 100%;
  height: 100px;
  box-sizing: border-box;
}

.radio-group {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.radio-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 44px;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 12px 0;
  background: transparent;
}
.radio-item-active {
  border: 2px solid var(--color-primary);
  background: var(--color-primary-bg);
  color: var(--color-primary-dark);
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}
.btn-hover {
  opacity: 0.8;
}
