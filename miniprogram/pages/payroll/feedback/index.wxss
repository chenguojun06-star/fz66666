.page { padding: 24rpx; background: #f5f5f5; min-height: 100vh; }

.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.title { font-size: 36rpx; font-weight: bold; color: #333; }
.add-btn { background: #1677ff; color: #fff; padding: 12rpx 24rpx; border-radius: 8rpx; font-size: 26rpx; }
.add-btn-hover { opacity: 0.8; }

.filter-bar { margin-bottom: 24rpx; }
.filter-picker { display: inline-flex; align-items: center; background: #fff; padding: 12rpx 24rpx; border-radius: 8rpx; font-size: 26rpx; }
.arrow { margin-left: 8rpx; font-size: 20rpx; color: #999; }

.loading, .empty { text-align: center; padding: 80rpx 0; color: #999; font-size: 28rpx; }

.feedback-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.item-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.type-tag { padding: 4rpx 16rpx; border-radius: 6rpx; font-size: 24rpx; }
.status-tag { font-size: 24rpx; font-weight: 500; }
.item-body { margin-bottom: 12rpx; }
.settlement-id { font-size: 26rpx; color: #666; display: block; margin-bottom: 8rpx; }
.content { font-size: 28rpx; color: #333; display: block; line-height: 1.6; }

.resolve-info { background: #f6ffed; padding: 16rpx; border-radius: 8rpx; margin-bottom: 12rpx; }
.resolve-label { font-size: 24rpx; color: #52c41a; font-weight: 500; display: block; margin-bottom: 4rpx; }
.resolve-remark { font-size: 26rpx; color: #333; display: block; }
.resolver { font-size: 24rpx; color: #999; display: block; margin-top: 4rpx; }

.item-footer { display: flex; justify-content: flex-end; }
.time { font-size: 24rpx; color: #999; }

.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal-content { background: #fff; border-radius: 16rpx; padding: 40rpx; width: 85%; max-width: 600rpx; }
.modal-title { font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 32rpx; }

.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 28rpx; color: #333; display: block; margin-bottom: 8rpx; }
.form-input { border: 1rpx solid #ddd; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; }
.form-textarea { border: 1rpx solid #ddd; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; width: 100%; height: 200rpx; box-sizing: border-box; }

.radio-group { display: flex; gap: 32rpx; }
.radio-item { display: flex; align-items: center; gap: 8rpx; font-size: 28rpx; }

.form-actions { display: flex; gap: 24rpx; margin-top: 32rpx; }
.btn-cancel { flex: 1; text-align: center; padding: 20rpx; border: 1rpx solid #ddd; border-radius: 8rpx; font-size: 28rpx; color: #666; }
.btn-submit { flex: 1; text-align: center; padding: 20rpx; background: #1677ff; color: #fff; border-radius: 8rpx; font-size: 28rpx; }
.btn-hover { opacity: 0.8; }
