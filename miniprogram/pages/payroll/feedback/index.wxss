.page {
  padding: 12rpx var(--page-padding-x);
  background: var(--color-bg-page);
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-tertiary);
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  opacity: 0.4;
}
.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-top: 20rpx;
}

.settlement-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.settlement-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.feedback-status {
  font-size: var(--font-size-xs);
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-weight: var(--font-weight-medium);
}
.status-none {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}
.status-PENDING {
  background: var(--color-info-bg);
  color: var(--color-primary);
}
.status-RESOLVED {
  background: var(--color-success-bg);
  color: var(--color-success);
}
.status-REJECTED {
  background: var(--color-error-bg, rgba(255,77,79,0.1));
  color: var(--color-error, #ff4d4f);
}

.card-body {
  padding: 12rpx 0;
  border-top: 1rpx solid var(--color-border-light);
  border-bottom: 1rpx solid var(--color-border-light);
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 0;
}
.info-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.info-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}
.info-value.amount {
  color: var(--color-primary);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}
.time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.feedback-action {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-content {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 40rpx;
  width: 85%;
  max-width: 600rpx;
}
.modal-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  text-align: center;
  margin-bottom: 32rpx;
  color: var(--color-text-primary);
}

.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 8rpx;
}
.form-input {
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 16rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}
.form-input-readonly {
  background: var(--color-bg-gray);
  color: var(--color-text-tertiary);
}
.form-textarea {
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 16rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  width: 100%;
  height: 200rpx;
  box-sizing: border-box;
}

.radio-group {
  display: flex;
  gap: 32rpx;
}
.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.form-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}
.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}
.btn-submit {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
}
.btn-hover {
  opacity: 0.8;
}
