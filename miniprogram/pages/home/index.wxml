<view class="page" style="padding-top: {{statusBarHeight + 12}}px;">
  <!-- 顶部问候 -->
    <view class="header">
      <view class="greeting-name">{{userName}}，{{greeting}}</view>
      <view class="greeting-sub">欢迎使用衣智链</view>
    </view>

  <!-- 今日统计卡片 -->
  <view class="stats-row">
    <view class="stat-card {{item.cardClass}}" wx:for="{{statCards}}" wx:key="key">
      <view class="stat-icon-wrap {{item.iconWrapClass}}">
        <view class="line-icon line-icon--lg {{item.iconClass}}"></view>
      </view>
      <view class="stat-info">
        <view class="stat-value">{{item.key === 'todayProcessCount' ? todayProcessCount : todayWorkHours}}<text class="stat-unit">{{item.unit}}</text></view>
        <view class="stat-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <!-- 本月概览 -->
  <view class="monthly-section" wx:if="{{monthlyStats}}">
    <view class="section-header">
      <text class="section-title">本月概览</text>
    </view>
    <view class="monthly-grid">
      <view class="monthly-item">
        <text class="monthly-value">{{monthlyStats.totalScans || 0}}</text>
        <text class="monthly-label">扫码总数</text>
      </view>
      <view class="monthly-item">
        <text class="monthly-value">{{monthlyStats.totalQuantity || 0}}</text>
        <text class="monthly-label">完成件数</text>
      </view>
      <view class="monthly-item">
        <text class="monthly-value">{{monthlyStats.workDays || 0}}</text>
        <text class="monthly-label">出勤天数</text>
      </view>
    </view>
  </view>

  <!-- 全部菜单 -->
  <view class="menu-section">
    <view class="section-header">
      <text class="section-title">全部菜单</text>
    </view>
    <view class="menu-grid">
      <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="onMenuTap" data-index="{{index}}">
        <view class="menu-icon-circle {{item.circleClass}}">
          <view class="line-icon line-icon--lg {{item.iconClass}}"></view>
        </view>
        <text class="menu-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 最近扫码 -->
  <view class="recent-section" wx:if="{{recentScans.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近扫码</text>
      <text class="section-more" bindtap="onGoHistory">查看全部</text>
    </view>
    <view class="recent-list">
      <view class="recent-item" wx:for="{{recentScans}}" wx:key="id">
        <view class="recent-left">
          <text class="recent-stage">{{item.stageName}}</text>
          <text class="recent-order">{{item.orderNo}}</text>
        </view>
        <view class="recent-right">
          <text class="recent-qty">{{item.quantity}}件</text>
          <text class="recent-time">{{item.timeDisplay}}</text>
        </view>
      </view>
    </view>
  </view>

  <ai-assistant id="homeAiAssistant" notice-count="{{unreadNoticeCount}}" />
</view>
