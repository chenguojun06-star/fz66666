<view class="container">
  <!-- 通用悬浮铃铛组件 -->
  <floating-bell />

  <view class="card">
    <view class="title">首页</view>

    <global-search
      keyword="{{globalSearch.keyword}}"
      results="{{globalSearch.results}}"
      has-searched="{{globalSearch.hasSearched}}"
      bind:input="onGlobalSearchInput"
      bind:search="doGlobalSearch"
      bind:clear="clearGlobalSearch"
      bind:close="closeGlobalSearch"
      bind:itemtap="onResultItemTap"
    />

    <view wx:if="{{loading}}" class="hint">加载中...</view>
    <view wx:if="{{!loading && !statsLoaded}}" class="hint">暂无统计</view>
    <view class="home-section-title">数据概览</view>
    <view class="home-stats-row">
      <view class="home-stat-item">
        <view class="home-stat-left">
          <text class="home-stat-emoji">📋</text>
          <text class="home-stat-label">生产</text>
        </view>
        <text class="home-stat-value">{{stats.productionOrders}}</text>
      </view>
      <view class="home-stat-item">
        <view class="home-stat-left">
          <text class="home-stat-emoji">📥</text>
          <text class="home-stat-label">入库</text>
        </view>
        <text class="home-stat-value">{{stats.warehousingToday}}</text>
      </view>
    </view>
    <view class="home-stats-row">
      <view class="home-stat-item">
        <view class="home-stat-left">
          <text class="home-stat-emoji">🛒</text>
          <text class="home-stat-label">采购</text>
        </view>
        <text class="home-stat-value">{{stats.materialPurchase}}</text>
      </view>
      <view class="home-stat-item">
        <view class="home-stat-left">
          <text class="home-stat-emoji">⚠️</text>
          <text class="home-stat-label">次品</text>
        </view>
        <text class="home-stat-value">{{stats.defectCount}}</text>
      </view>
    </view>

    <view class="home-section-title">快捷入口</view>
    <view class="home-entries">
      <view class="home-entry" data-tab="orders_production" bindtap="goWork">生产</view>
      <view class="home-entry" data-tab="warehousing" bindtap="goWork">入库</view>
      <view class="home-entry" data-tab="exceptions" bindtap="goWork">异常</view>
      <view class="home-entry" bindtap="goScan">扫码</view>
      <view class="home-entry" bindtap="goAdmin">个人</view>
    </view>

    <view class="home-section-title">最近动态</view>
    <view wx:if="{{activities.length === 0}}" class="hint">暂无动态</view>
    <view wx:for="{{activities}}" wx:key="id" class="home-activity">
      <view class="home-activity-row">
        <view class="home-activity-content">{{item.content}}</view>
        <view class="home-activity-time">{{item.time}}</view>
      </view>
    </view>
  </view>
</view>
