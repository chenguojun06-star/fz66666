<view class="page">
  <custom-nav title="衣智链" />

  <view class="header">
    <view class="greeting-name">{{userName}}，{{greeting}}</view>
    <view class="greeting-sub">{{orgName ? orgName + '，欢迎使用衣智链' : '欢迎使用衣智链'}}</view>
  </view>

  <view class="weather-card">
    <view class="weather-top">
      <view class="weather-left">
        <view class="weather-temp-wrap">
          <text class="weather-temp">{{dateInfo.date}}</text>
          <text class="weather-desc">{{dateInfo.day}}</text>
        </view>
      </view>
      <text class="weather-season">{{dateInfo.season}}</text>
    </view>
    <view class="weather-tip">{{dateInfo.dailyTip}}</view>
  </view>

  <!-- 常用应用 -->
  <view class="menu-section">
    <view class="section-header">
      <text class="section-title">常用应用</text>
      <text class="section-more" bindtap="onMoreAppsTap">管理</text>
    </view>
    <view class="menu-grid">
      <view class="menu-item" wx:for="{{favoriteApps}}" wx:key="id" bindtap="onFavoriteTap" data-app="{{item}}" hover-class="menu-item-hover" hover-stay-time="100">
        <view class="menu-icon-circle {{item.circleClass}}">
          <view class="line-icon line-icon--lg {{item.iconClass}}"></view>
          <text wx:if="{{item.badge}}" class="menu-badge">{{item.badge}}</text>
        </view>
        <text class="menu-name">{{item.name}}</text>
      </view>
      <view class="menu-item" bindtap="onMoreAppsTap" hover-class="menu-item-hover" hover-stay-time="100">
        <view class="menu-icon-circle menu-icon-circle--gray">
          <view class="menu-more-icon">
            <text>·</text><text>·</text><text>·</text>
          </view>
        </view>
        <text class="menu-name">更多</text>
      </view>
    </view>
  </view>

  <!-- 全部菜单 -->
  <view class="menu-section">
    <view class="section-header">
      <text class="section-title">全部菜单</text>
    </view>
    <view class="menu-grid">
      <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="onMenuTap" data-index="{{index}}" hover-class="menu-item-hover" hover-stay-time="100">
        <view class="menu-icon-circle {{item.circleClass}}">
          <view class="line-icon line-icon--lg {{item.iconClass}}"></view>
          <text wx:if="{{item.badge}}" class="menu-badge">{{item.badge}}</text>
        </view>
        <text class="menu-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <ai-assistant id="homeAiAssistant" notice-count="{{unreadNoticeCount}}" />
</view>
