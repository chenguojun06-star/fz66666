<view class="page" style="padding-top: {{statusBarHeight + 12}}px;">
  <!-- 顶部问候 -->
  <view class="header">
    <view class="greeting-name">{{userName}}，{{greeting}} 👋</view>
    <view class="greeting-sub">欢迎使用云裳智立链</view>
  </view>

  <!-- 今日统计卡片 -->
  <view class="stats-row">
    <view class="stat-card stat-card--blue">
      <view class="stat-icon-wrap stat-icon-wrap--blue">
        <text class="stat-icon">📋</text>
      </view>
      <view class="stat-info">
        <view class="stat-value">{{todayProcessCount}}<text class="stat-unit">次</text></view>
        <view class="stat-label">今日完成工序</view>
      </view>
    </view>
    <view class="stat-card stat-card--green">
      <view class="stat-icon-wrap stat-icon-wrap--green">
        <text class="stat-icon">⏱</text>
      </view>
      <view class="stat-info">
        <view class="stat-value">{{todayWorkHours}}<text class="stat-unit">h</text></view>
        <view class="stat-label">今日工作时长</view>
      </view>
    </view>
  </view>

  <!-- 全部菜单 -->
  <view class="menu-section">
    <view class="menu-header">
      <text class="menu-title">全部菜单</text>
      <text class="menu-hint">长按可排序</text>
    </view>
    <view class="menu-grid">
      <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="onMenuTap" data-index="{{index}}">
        <view class="menu-icon-circle" style="background: {{item.bgColor}};">
          <text class="menu-emoji">{{item.icon}}</text>
        </view>
        <text class="menu-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <ai-assistant notice-count="{{unreadNoticeCount}}" />
</view>
