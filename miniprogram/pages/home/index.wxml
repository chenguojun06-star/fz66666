<view class="page">
  <view class="header">
    <view class="header-top">
      <view class="header-left">
        <view class="greeting-name">{{userName}}，{{greeting}}</view>
        <view class="greeting-sub">{{orgName || '衣智链'}}</view>
      </view>
      <view class="header-right">
        <view class="header-date">
          <text class="date-day">{{dateInfo.day}}</text>
          <text class="date-md">{{dateInfo.date}}</text>
        </view>
      </view>
    </view>
    <view class="header-tip" wx:if="{{dateInfo.dailyTip}}">
      <view class="tip-icon icon-lightbulb"></view>
      <text class="tip-text">{{dateInfo.dailyTip}}</text>
    </view>
  </view>

  <!-- 常用应用 -->
  <view class="menu-section">
    <view class="section-header">
      <text class="section-title">常用应用</text>
      <text class="section-more" bindtap="onMoreAppsTap">管理</text>
    </view>
    
    <view class="menu-grid">
      <view 
        class="menu-item {{draggingIndex === index ? 'menu-item--dragging' : ''}}" 
        wx:for="{{favoriteApps}}" 
        wx:key="id" 
        bindtap="onFavoriteTap" 
        data-index="{{index}}"
        data-app="{{item}}"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
        hover-class="menu-item-hover" 
        hover-stay-time="100"
      >
        <view class="menu-icon-circle {{item.circleClass}}">
          <view class="line-icon line-icon--lg {{item.iconClass}}"></view>
          <text wx:if="{{item.badge}}" class="menu-badge">{{item.badge}}</text>
        </view>
        <text class="menu-name">{{item.name}}</text>
      </view>
    </view>
    
    <view class="empty-hint" wx:if="{{favoriteApps.length === 0}}">
      <view class="empty-icon icon-mobile"></view>
      <text class="empty-text">还没有添加常用应用，点击「管理」添加吧</text>
    </view>
  </view>

  <ai-assistant id="homeAiAssistant" notice-count="{{unreadNoticeCount}}" />
</view>
