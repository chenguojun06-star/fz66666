<view class="page">
  <view class="header">
    <view class="greeting-name" style="height: 41rpx; display: block; box-sizing: border-box">{{userName}}，{{greeting}}</view>
    <view class="greeting-sub" style="height: 41rpx; display: block; box-sizing: border-box; position: relative; left: 0rpx; top: -8rpx">{{orgName ? orgName + '，欢迎使用衣智链' : '欢迎使用衣智链'}}</view>
  </view>

  <view class="weather-card">
    <view class="weather-top">
      <view class="weather-left">
        <view class="weather-temp-wrap">
          <text class="weather-temp">{{dateInfo.date}}</text>
          <text class="weather-desc">{{dateInfo.day}}</text>
        </view>
      </view>
      <text class="weather-season">{{dateInfo.season}}</text>
    </view>
    <view class="weather-tip">{{dateInfo.dailyTip}}</view>
  </view>

  <!-- 我的待办（按职务聚合） -->
  <view wx:if="{{myTodos.length > 0}}" class="todo-section">
    <view class="todo-header">
      <text class="todo-title">📋 我的待办</text>
    </view>
    <view class="todo-list">
      <view
        wx:for="{{myTodos}}"
        wx:key="key"
        class="todo-card"
        bindtap="onTodoTap"
        data-url="{{item.url}}"
      >
        <text class="todo-icon">{{item.icon}}</text>
        <view class="todo-info">
          <text class="todo-name">{{item.title}}</text>
        </view>
        <text class="todo-count">{{item.count}}</text>
        <text class="todo-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 常用应用 -->
  <view class="menu-section">
    <view class="section-header">
      <text class="section-title">常用应用</text>
      <text class="section-more" bindtap="onMoreAppsTap">管理</text>
    </view>
    
    <view class="menu-grid">
      <view 
        class="menu-item {{draggingIndex === index ? 'menu-item--dragging' : ''}}" 
        wx:for="{{favoriteApps}}" 
        wx:key="id" 
        bindtap="onFavoriteTap" 
        data-index="{{index}}"
        data-app="{{item}}"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
        hover-class="menu-item-hover" 
        hover-stay-time="100"
      >
        <view class="menu-icon-circle {{item.circleClass}}">
          <view class="line-icon line-icon--lg {{item.iconClass}}"></view>
          <text wx:if="{{item.badge}}" class="menu-badge">{{item.badge}}</text>
        </view>
        <text class="menu-name">{{item.name}}</text>
      </view>
    </view>
    
    <view class="empty-hint" wx:if="{{favoriteApps.length === 0}}">
      <text class="empty-icon">📱</text>
      <text class="empty-text">还没有添加常用应用，点击「管理」添加吧</text>
    </view>
  </view>

  <ai-assistant id="homeAiAssistant" notice-count="{{unreadNoticeCount}}" />
</view>
