<view class="container">
  <!-- 通用悬浮铃铛组件 -->

  <!-- 智能提醒角标（有未读通知时显示，非工厂账号或工厂账号均可见） -->
  <view wx:if="{{unreadNoticeCount > 0}}" class="home-notice-bar" bindtap="goInbox" hover-class="home-notice-bar-hover" hover-stay-time="100">
    <text class="home-notice-icon">🔔</text>
    <text class="home-notice-text">{{unreadNoticeCount}} 条智能提醒待处理</text>
    <text class="home-notice-arrow">›</text>
  </view>

  <view class="card">
    <view class="title">首页</view>

    <global-search
      keyword="{{globalSearch.keyword}}"
      results="{{globalSearch.results}}"
      has-searched="{{globalSearch.hasSearched}}"
      bind:input="onGlobalSearchInput"
      bind:search="doGlobalSearch"
      bind:clear="clearGlobalSearch"
      bind:close="closeGlobalSearch"
      bind:itemtap="onResultItemTap"
    />

    <view wx:if="{{loading}}" class="hint">加载中...</view>
    <view wx:if="{{!loading && !statsLoaded}}" class="hint">暂无统计</view>
    <!-- 数据概览：角色感知 -->
    <!-- 老板：完整4卡 -->
    <view wx:if="{{isTenantOwner}}">
      <view class="home-section-title">数据概览</view>
      <view class="home-stats-grid">
        <view class="home-stat-card stat-bulk">
          <view class="stat-head">
            <text class="stat-card-emoji">🛒</text>
            <text class="stat-card-label">大货下单</text>
            <text class="stat-total">{{topStats.bulkOrder.total}}</text>
          </view>
          <view class="stat-tags-row">
            <view class="stat-tag"><text class="tag-label">日</text><text class="tag-value">{{topStats.bulkOrder.day}}</text></view>
            <view class="stat-tag"><text class="tag-label">周</text><text class="tag-value">{{topStats.bulkOrder.week}}</text></view>
            <view class="stat-tag"><text class="tag-label">月</text><text class="tag-value">{{topStats.bulkOrder.month}}</text></view>
            <view class="stat-tag"><text class="tag-label">年</text><text class="tag-value">{{topStats.bulkOrder.year}}</text></view>
          </view>
        </view>
        <view class="home-stat-card stat-cutting">
          <view class="stat-head">
            <text class="stat-card-emoji">✂️</text>
            <text class="stat-card-label">裁剪数量</text>
            <text class="stat-total">{{topStats.cutting.total}}</text>
          </view>
          <view class="stat-tags-row">
            <view class="stat-tag"><text class="tag-label">日</text><text class="tag-value">{{topStats.cutting.day}}</text></view>
            <view class="stat-tag"><text class="tag-label">周</text><text class="tag-value">{{topStats.cutting.week}}</text></view>
            <view class="stat-tag"><text class="tag-label">月</text><text class="tag-value">{{topStats.cutting.month}}</text></view>
            <view class="stat-tag"><text class="tag-label">年</text><text class="tag-value">{{topStats.cutting.year}}</text></view>
          </view>
        </view>
      </view>
    </view>
    <!-- 跟单员：精简2卡（大货下单+裁剪） -->
    <view wx:elif="{{!isFactory}}">
      <view class="home-section-title">数据概览</view>
      <view class="home-stats-grid">
        <view class="home-stat-card stat-bulk">
          <view class="stat-head">
            <text class="stat-card-emoji">🛒</text>
            <text class="stat-card-label">大货下单</text>
            <text class="stat-total">{{topStats.bulkOrder.total}}</text>
          </view>
          <view class="stat-tags-row">
            <view class="stat-tag"><text class="tag-label">日</text><text class="tag-value">{{topStats.bulkOrder.day}}</text></view>
            <view class="stat-tag"><text class="tag-label">周</text><text class="tag-value">{{topStats.bulkOrder.week}}</text></view>
            <view class="stat-tag"><text class="tag-label">月</text><text class="tag-value">{{topStats.bulkOrder.month}}</text></view>
            <view class="stat-tag"><text class="tag-label">年</text><text class="tag-value">{{topStats.bulkOrder.year}}</text></view>
          </view>
        </view>
        <view class="home-stat-card stat-cutting">
          <view class="stat-head">
            <text class="stat-card-emoji">✂️</text>
            <text class="stat-card-label">裁剪数量</text>
            <text class="stat-total">{{topStats.cutting.total}}</text>
          </view>
          <view class="stat-tags-row">
            <view class="stat-tag"><text class="tag-label">日</text><text class="tag-value">{{topStats.cutting.day}}</text></view>
            <view class="stat-tag"><text class="tag-label">周</text><text class="tag-value">{{topStats.cutting.week}}</text></view>
            <view class="stat-tag"><text class="tag-label">月</text><text class="tag-value">{{topStats.cutting.month}}</text></view>
            <view class="stat-tag"><text class="tag-label">年</text><text class="tag-value">{{topStats.cutting.year}}</text></view>
          </view>
        </view>
      </view>
    </view>
    <!-- 工厂工人：无统计卡片 -->

    <!-- 快捷入口：角色感知 -->
    <!-- 老板：5个入口 -->
    <view wx:if="{{isTenantOwner}}">
      <view class="home-section-title">快捷入口</view>
      <view class="home-entries">
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" data-tab="orders_production" bindtap="goWork">生产</view>
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" bindtap="goScan">扫码</view>
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" bindtap="goAdmin">我的</view>
      </view>
    </view>
    <!-- 工厂工人：3个入口（扫码/工资/我的） -->
    <view wx:elif="{{isFactory}}">
      <view class="home-section-title">快捷入口</view>
      <view class="home-entries">
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" bindtap="goScan">扫码</view>
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" bindtap="goPayroll">工资</view>
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" bindtap="goAdmin">我的</view>
      </view>
    </view>
    <!-- 跟单员：3个入口（生产/扫码/我的） -->
    <view wx:else>
      <view class="home-section-title">快捷入口</view>
      <view class="home-entries">
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" data-tab="orders_production" bindtap="goWork">生产</view>
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" bindtap="goScan">扫码</view>
        <view class="home-entry" hover-class="home-entry-hover" hover-stay-time="100" bindtap="goAdmin">我的</view>
      </view>
    </view>

    <!-- 最近动态：仅对跟单员/老板显示，工厂工人不展示业务级动态 -->
    <block wx:if="{{!isFactory}}">
    <view class="home-section-title">最近动态</view>
    <view wx:if="{{activities.length === 0}}" class="hint">暂无动态</view>
    <view wx:for="{{activities}}" wx:key="id" class="home-activity">
      <view class="home-activity-row">
        <view class="home-activity-icon home-activity-icon--{{item.type}}">
          <text wx:if="{{item.type === 'style'}}">✂️</text>
          <text wx:elif="{{item.type === 'production'}}">📋</text>
          <text wx:elif="{{item.type === 'scan'}}">📱</text>
          <text wx:elif="{{item.type === 'material'}}">📦</text>
          <text wx:else>📌</text>
        </view>
        <view class="home-activity-content">{{item.content}}</view>
        <view class="home-activity-time">{{item.time}}</view>
      </view>
    </view>
    </block>
  </view>

  <!-- 智能小云 悬浮入口 -->
  <ai-assistant />
</view>
