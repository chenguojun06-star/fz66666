@import '/styles/line-icons.wxss';

/* ============ 首页 ============ */
page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* -- 顶部问候 -- */
.header {
  padding: 20px 20px 16px;
}

.greeting-name {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
}

.greeting-sub {
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* -- 统计卡片行 -- */
.stats-row {
  display: flex;
  gap: 12px;
  padding: 0 20px 16px;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding: 14px 12px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.8);
}

.stat-card--cool {
  background: rgba(255, 255, 255, 0.9);
}

.stat-card--warm {
  background: rgba(255, 255, 255, 0.9);
}

.stat-icon-wrap {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(var(--color-primary-rgb), 0.08);
}

.stat-icon-wrap--cool {
  background: rgba(var(--color-primary-rgb), 0.09);
}

.stat-icon-wrap--warm {
  background: rgba(var(--color-primary-rgb), 0.09);
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.1;
}

.stat-unit {
  font-size: var(--font-size-md);
  font-weight: 400;
  margin-left: 2px;
  color: var(--color-text-secondary);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 3px;
}

/* -- 全部菜单 -- */
.menu-section {
  padding: 16px 20px;
  border-top: 1px solid var(--color-divider);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  row-gap: 14px;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.menu-icon-circle {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
}

/* 菜单图标放大 */
.menu-icon-circle .line-icon--lg {
  width: 30px;
  height: 30px;
  background-size: 30px 30px;
}

.menu-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
}

/* ---- 本月概览 ---- */
.monthly-section {
  padding: 16px 20px;
  border-top: 1px solid var(--color-divider);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.section-more {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

.monthly-grid {
  display: flex;
  justify-content: space-around;
}

.monthly-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.monthly-value {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  line-height: 1.2;
}

.monthly-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xs);
}

/* ---- 最近扫码 ---- */
.recent-section {
  padding: 16px 20px;
  border-top: 1px solid var(--color-divider);
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 0;
  border-bottom: 1px solid var(--color-border);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.recent-stage {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-order {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: var(--spacing-sm);
}

.recent-qty {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.recent-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
  margin-top: 2px;
}
