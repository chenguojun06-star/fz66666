page {
  background: #f7f8fa;
}

/* 右上角提醒按钮 */
.reminder-btn {
  position: fixed;
  top: 20px;
  right: 20px;
  width: 40px;
  height: 40px;
  background: transparent;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.reminder-icon {
  width: 24px;
  height: 24px;
  opacity: 0.6;
}

.reminder-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 18px;
  height: 18px;
  background: #ff4757;
  color: #ffffff;
  border-radius: 9px;
  font-size: 10px; /* 极小字体 */
  line-height: 18px;
  text-align: center;
  padding: 0 4px;
  font-weight: 600;
  border: 2px solid #ffffff;
}

/* 提醒面板 */
.reminder-panel {
  position: fixed;
  top: 0;
  right: -320px;
  width: 320px;
  height: 100vh;
  background: #ffffff;
  box-shadow: -2px 0 8px rgba(0, 0, 0, 0.1);
  transition: right 0.3s ease;
  z-index: 1000;
  display: flex;
  flex-direction: column;
}

.reminder-panel.show {
  right: 0;
}

.reminder-panel-header {
  padding: 16px;
  border-bottom: 1px solid #e5e7eb;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.reminder-panel-title {
  font-size: 16px; /* 二级标题 */
  font-weight: 600;
  color: #1f2937;
}

.reminder-panel-close {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 18px; /* 一级标题/图标 */
}

.reminder-panel-content {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
}

.reminder-empty {
  text-align: center;
  color: #9ca3af;
  padding: 40px 20px;
  font-size: 14px; /* 正文字体 */
}

.reminder-item {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 10px;
}

.reminder-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.reminder-item-title {
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}

.reminder-item-time {
  font-size: 12px;
  color: #9ca3af;
}

.reminder-item-desc {
  font-size: 12px;
  color: #6b7280;
}

/* 遮罩层 */
.reminder-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(0, 0, 0, 0.3);
  z-index: 999;
}

.container .card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 12px;
}

.title {
  font-size: 16px; /* 二级标题 */
  font-weight: 600;
  margin-bottom: 10px;
  color: #1f2937;
}

.home-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-bottom: 8px;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.6);
  color: #1f2937;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
  text-align: center;
  font-size: 12px;
}

.home-section-title {
  margin-top: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}

.home-filter {
  margin-top: 8px;
  padding: 10px 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.filter-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.filter-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.filter-label {
  font-size: 12px;
  color: #6b7280;
}

.filter-input {
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 12px;
  color: #111827;
  background: #ffffff;
}

.filter-text {
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 12px;
  color: #111827;
  background: #ffffff;
}

.filter-actions {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}

.home-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 8px;
}

.home-stat {
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 10px 12px;
  background: #ffffff;
}

.home-stat-head {
  display: flex;
  align-items: center;
  gap: 8px;
}

.home-stat-icon-wrap {
  width: 24px;
  height: 24px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.home-stat-icon {
  width: 16px;
  height: 16px;
}

.icon-order {
  background: rgba(99, 102, 241, 0.12);
}

.icon-stock {
  background: rgba(16, 185, 129, 0.12);
}

.icon-purchase {
  background: rgba(249, 115, 22, 0.12);
}

.icon-defect {
  background: rgba(239, 68, 68, 0.12);
}

.home-stat-value {
  font-size: 14px;
  font-weight: 600;
  color: #111827;
}

.home-stat-label {
  font-size: 12px;
  color: #6b7280;
}

.home-entries {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 10px;
}

.home-entry {
  border: 1px solid #e5e7eb;
  background: #ffffff;
  color: #111827;
  border-radius: 999px;
  padding: 8px 8px;
  text-align: center;
  font-size: 12px;
}

.home-activity {
  padding: 10px 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  margin-top: 10px;
  background: #ffffff;
}

.home-activity-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}

.home-activity-content {
  flex: 1;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.home-activity-time {
  font-size: 12px;
  color: #8b8b94;
  white-space: nowrap;
}
