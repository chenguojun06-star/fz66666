@import '/styles/line-icons.wxss';

/* ============ 首页 ============ */
page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* -- 顶部问候 -- */
.header {
  padding: 20px 20px 16px;
}

.greeting-name {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
}

.greeting-sub {
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* -- 统计卡片行 -- */
.stats-row {
  display: flex;
  gap: 12px;
  padding: 0 20px 16px;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding: 14px 12px;
  border-radius: var(--radius-md);
  background: var(--color-bg-card);
}

.stat-card--cool {
  background: var(--color-bg-card);
}

.stat-card--warm {
  background: var(--color-bg-card);
}

.stat-icon-wrap {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(var(--color-primary-rgb), 0.08);
}

.stat-icon-wrap--cool {
  background: rgba(var(--color-primary-rgb), 0.09);
}

.stat-icon-wrap--warm {
  background: rgba(var(--color-primary-rgb), 0.09);
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.1;
}

.stat-unit {
  font-size: var(--font-size-md);
  font-weight: 400;
  margin-left: 2px;
  color: var(--color-text-secondary);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 3px;
}

/* -- 全部菜单 -- */
.menu-section {
  padding: 16px 20px;
  border-top: 1px solid var(--color-divider);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  row-gap: 20px;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.menu-icon-circle {
  width: 80px;
  height: 80px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
}

/* 菜单图标放大 */
.menu-icon-circle .line-icon--lg {
  width: 46px;
  height: 46px;
  background-size: 46px 46px;
}

.menu-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
}

/* ---- 本月概览 ---- */
.monthly-section {
  margin: 0 20px 16px;
  padding: 16px;
  background: #ffffff;
  border-radius: var(--radius-md);
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.section-more {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

.monthly-grid {
  display: flex;
  justify-content: space-around;
}

.monthly-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.monthly-value {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  line-height: 1.2;
}

.monthly-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xs);
}


