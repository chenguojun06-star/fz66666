page {
  background: #f7f8fa;
}

.container .card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 12px;
}

.title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 10px;
  color: #1f2937;
}

.home-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-bottom: 8px;
}

.btn-secondary {
  background: #eef2ff;
  color: #374151;
  border-radius: 999px;
  padding: 8px 12px;
  text-align: center;
  font-size: 12px;
}

.home-section-title {
  margin-top: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}

.home-filter {
  margin-top: 8px;
  padding: 10px 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.filter-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.filter-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.filter-label {
  font-size: 12px;
  color: #6b7280;
}

.filter-input {
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 12px;
  color: #111827;
  background: #ffffff;
}

.filter-text {
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 12px;
  color: #111827;
  background: #ffffff;
}

.filter-actions {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}

.home-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 8px;
}

.home-stat {
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 10px 12px;
  background: #ffffff;
}

.home-stat-head {
  display: flex;
  align-items: center;
  gap: 8px;
}

.home-stat-icon-wrap {
  width: 24px;
  height: 24px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
}

.home-stat-icon {
  width: 16px;
  height: 16px;
}

.icon-order {
  background: rgba(99, 102, 241, 0.12);
}

.icon-stock {
  background: rgba(16, 185, 129, 0.12);
}

.icon-purchase {
  background: rgba(249, 115, 22, 0.12);
}

.icon-defect {
  background: rgba(239, 68, 68, 0.12);
}

.home-stat-value {
  font-size: 14px;
  font-weight: 600;
  color: #111827;
}

.home-stat-label {
  font-size: 12px;
  color: #8e8e93;
}

.home-entries {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 10px;
}

.home-entry {
  border: 1px solid #e5e7eb;
  background: #ffffff;
  color: #111827;
  border-radius: 999px;
  padding: 8px 8px;
  text-align: center;
  font-size: 12px;
}

.home-activity {
  padding: 10px 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  margin-top: 10px;
  background: #ffffff;
}

.home-activity-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}

.home-activity-content {
  flex: 1;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.home-activity-time {
  font-size: 12px;
  color: #9ca3af;
  white-space: nowrap;
}
