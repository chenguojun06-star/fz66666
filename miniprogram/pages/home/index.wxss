/* ============ 首页 ============ */
page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* -- 顶部问候 -- */
.header {
  padding: var(--spacing-xl) var(--page-padding-x) var(--spacing-lg);
}

.greeting-name {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
}

.greeting-sub {
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* -- 日期卡片 -- */
.weather-card {
  display: flex;
  flex-direction: column;
  margin: 0 var(--page-padding-x) var(--spacing-lg);
  padding: 14rpx 16rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-card);
}

.weather-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.weather-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.weather-temp-wrap {
  display: flex;
  flex-direction: column;
}

.weather-temp {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: var(--line-height-tight);
}

.weather-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

.weather-season {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}

.weather-tip {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid var(--color-divider);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-medium);
}

/* -- 全部菜单 -- */
.menu-section {
  padding: var(--spacing-lg) var(--page-padding-x);
  border-top: 1px solid var(--color-divider);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  row-gap: var(--spacing-xl);
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
}

.menu-icon-circle {
  width: 53px;
  height: 53px;
  border-radius: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid rgba(var(--color-primary-rgb), 0.08);
}

/* 菜单图标缩小1/3 */
.menu-icon-circle .line-icon--lg {
  width: 31px;
  height: 31px;
  background-size: 31px 31px;
}

.menu-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
}

.menu-icon-circle--red {
  background: rgba(255, 77, 79, 0.08);
  border-color: rgba(255, 77, 79, 0.15);
}




