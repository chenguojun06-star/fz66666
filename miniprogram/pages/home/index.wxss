/* ============ 首页 ============ */
page {
  background: var(--color-bg-page, #f5f5f5);
}

.page {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* -- 顶部问候 -- */
.header {
  padding: 32rpx 32rpx 16rpx;
}

.greeting-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1a1a1a);
}

.greeting-sub {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary, #666);
}

/* -- 统计卡片行 -- */
.stats-row {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 32rpx 24rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: var(--radius-xl, 24rpx);
}

.stat-card--blue {
  background: rgba(59, 130, 246, 0.08);
}

.stat-card--green {
  background: rgba(16, 185, 129, 0.08);
}

.stat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stat-icon-wrap--blue {
  background: rgba(59, 130, 246, 0.15);
}

.stat-icon-wrap--green {
  background: rgba(16, 185, 129, 0.15);
}

.stat-icon {
  font-size: 36rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1a1a1a);
  line-height: 1.1;
}

.stat-unit {
  font-size: 28rpx;
  font-weight: 400;
  margin-left: 4rpx;
  color: var(--color-text-secondary, #666);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #666);
  margin-top: 6rpx;
}

/* -- 全部菜单 -- */
.menu-section {
  margin: 0 32rpx 32rpx;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 24rpx);
  padding: 28rpx 24rpx 16rpx;
}

.menu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 20rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1a1a1a);
}

.menu-hint {
  font-size: 22rpx;
  color: var(--color-text-placeholder, #bbb);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 28rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.menu-icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-emoji {
  font-size: 56rpx;
}

.menu-name {
  font-size: 26rpx;
  color: var(--color-text-primary, #1a1a1a);
  text-align: center;
}
