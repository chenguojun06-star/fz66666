@import '/styles/line-icons.wxss';

/* ============ 首页 ============ */
page {
  background:
    radial-gradient(circle at 12% 8%, rgba(109, 155, 239, 0.2), transparent 24%),
    radial-gradient(circle at 82% 14%, rgba(170, 194, 235, 0.18), transparent 22%),
    linear-gradient(135deg, var(--color-bg-gray) 0%, var(--color-bg-page) 42%, var(--color-bg-gray) 100%);
}

.page {
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* -- 顶部问候 -- */
.header {
  margin: 0 16px 8px;
  padding: 18px 16px;
  border-radius: 24px;
  background: linear-gradient(135deg, rgba(236, 242, 251, 0.96), rgba(255, 255, 255, 0.96));
  border: 1px solid rgba(31, 117, 234, 0.14);
  box-shadow: 0 12px 32px rgba(31, 117, 234, 0.08);
}

.header-copy {
  display: flex;
  flex-direction: column;
}

.greeting-name {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
}

.greeting-sub {
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

.header-hint {
  margin-top: 10px;
  display: inline-flex;
  align-self: flex-start;
  padding: 6px 10px;
  border-radius: 999px;
  font-size: var(--font-size-xs);
  color: #1f75ea;
  background: rgba(255, 255, 255, 0.74);
  border: 1px solid rgba(31, 117, 234, 0.18);
}

/* -- 统计卡片行 -- */
.stats-row {
  display: flex;
  gap: var(--spacing-md);
  padding: 8px 16px 12px;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding: 14px 12px;
  border-radius: var(--radius-xl);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.stat-card--cool {
  background: linear-gradient(180deg, rgba(240, 246, 255, 0.98), rgba(255, 255, 255, 0.98));
}

.stat-card--warm {
  background: linear-gradient(180deg, rgba(233, 242, 255, 0.98), rgba(255, 255, 255, 0.98));
}

.stat-icon-wrap {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(31, 117, 234, 0.08);
}

.stat-icon-wrap--cool {
  background: rgba(31, 117, 234, 0.12);
}

.stat-icon-wrap--warm {
  background: rgba(21, 98, 214, 0.12);
}

.stat-info {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.1;
}

.stat-unit {
  font-size: var(--font-size-md);
  font-weight: 400;
  margin-left: 2px;
  color: var(--color-text-secondary);
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 3px;
}

/* -- 全部菜单 -- */
.menu-section {
  margin: 0 16px 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 14px 12px 8px;
  border: 1px solid rgba(31, 117, 234, 0.12);
  box-shadow: 0 10px 28px rgba(31, 117, 234, 0.06);
}

.menu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4px 10px;
}

.menu-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
}

.menu-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  row-gap: 14px;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.menu-icon-circle {
  width: 52px;
  height: 52px;
  border-radius: 18px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
  background: rgba(245, 249, 255, 0.96);
  border: 1px solid rgba(31, 117, 234, 0.12);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
}

.menu-icon-circle--cool {
  background: linear-gradient(180deg, rgba(234, 243, 255, 0.98), rgba(245, 249, 255, 0.98));
  border-color: rgba(31, 117, 234, 0.16);
}

.menu-icon-circle--warm {
  background: linear-gradient(180deg, rgba(228, 239, 255, 0.98), rgba(242, 248, 255, 0.98));
  border-color: rgba(21, 98, 214, 0.16);
}

.menu-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
}

/* ---- 本月概览 ---- */
.monthly-section {
  margin: 0 var(--spacing-lg) var(--spacing-md);
  padding: var(--spacing-lg);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 249, 255, 0.98));
  border-radius: var(--radius-lg);
  border: 1px solid rgba(31, 117, 234, 0.1);
  box-shadow: 0 8px 24px rgba(31, 117, 234, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.section-more {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

.monthly-grid {
  display: flex;
  justify-content: space-around;
}

.monthly-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.monthly-value {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: #1562d6;
  line-height: 1.2;
}

.monthly-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xs);
}

/* ---- 最近扫码 ---- */
.recent-section {
  margin: 0 var(--spacing-lg) var(--spacing-md);
  padding: var(--spacing-lg);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 249, 255, 0.98));
  border-radius: var(--radius-lg);
  border: 1px solid rgba(31, 117, 234, 0.1);
  box-shadow: 0 8px 24px rgba(31, 117, 234, 0.05);
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 0;
  border-bottom: 1px solid var(--color-border);
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.recent-stage {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-order {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: var(--spacing-sm);
}

.recent-qty {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: #1562d6;
}

.recent-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
  margin-top: 2px;
}
