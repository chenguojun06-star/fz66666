@import '/styles/page-utils.wxss';
@import '/styles/modal-form.wxss';

.page-container,
.page {
  min-height: 100vh;
  padding: 0 var(--page-padding-x) calc(env(safe-area-inset-bottom) + 20px);
  background: var(--color-bg-page);
}

/* ---- 顶部 Tab Bar ---- */
.tab-bar {
  display: flex;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--spacing-lg) 0;
  font-size: var(--font-size-base);
  color: var(--color-text-tertiary);
  position: relative;
  font-weight: var(--font-weight-medium);
}
.tab-active {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: var(--radius-sm);
  background: var(--color-primary);
}

/* ---- 搜索栏 ---- */
.search-bar { padding: var(--spacing-md) 0; }
.search-box {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-sm) var(--spacing-md);
}
.search-emoji { font-size: var(--font-size-base); margin-right: var(--spacing-sm); }
.search-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  height: 24px;
}

.tab-content { padding: 0; }
.order-list { padding: 0; }

/* ---- 订单卡片 ---- */
.order-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--card-gap);
  overflow: hidden;
}
.order-card--overdue {
  border-left: 1rpx solid var(--color-danger);
}

.order-main {
  display: flex;
  padding: var(--spacing-lg);
  gap: var(--spacing-md);
}
.order-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}
.cover-pic {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-ph-text {
  font-size: var(--font-size-2xl);
}

.order-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* 顶部：订单号 + status tag */
.info-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}
.order-no {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

/* 规格信息行 - 标签+值（款号、工厂、交期等） */
.info-spec-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.info-spec-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.info-spec-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}
.info-remain {
  font-size: var(--font-size-xs);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-xs);
  font-weight: var(--font-weight-medium);
}
.days-safe    { background: var(--color-success-bg); color: var(--color-success); }
.days-warn    { background: var(--color-warning-bg); color: var(--color-warning); }
.days-urgent  { background: rgba(var(--color-primary-rgb), 0.1); color: var(--color-danger); }
.days-overdue { background: rgba(var(--color-primary-rgb), 0.12); color: var(--color-danger); font-weight: var(--font-weight-semibold); }
.days-done    { background: var(--color-success-bg); color: var(--color-success); }

.order-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  flex-shrink: 0;
}
.arrow-icon {
  font-size: var(--font-size-xl);
  color: var(--color-text-tertiary);
  transition: transform 0.2s;
  font-weight: var(--font-weight-light);
}
.arrow-icon--up {
  transform: rotate(90deg);
  color: var(--color-primary);
}

/* ---- 数量行 ---- */
.info-qty-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding-top: 2rpx;
}
.iq-num {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.iq-num--done {
  color: var(--color-success);
}
.iq-num--remain {
  color: var(--color-text-secondary);
}
.iq-lbl {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-right: var(--spacing-md);
}

/* ---- 迷你进度条 ---- */
.info-progress {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}
.ip-bar {
  flex: 1;
  height: 3px;
  background: var(--color-border-light);
  border-radius: var(--radius-xs);
  overflow: hidden;
}
.ip-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  transition: width 0.3s;
}
.ip-fill--overdue {
  background: var(--color-danger);
}
.ip-pct {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  min-width: 30px;
  text-align: right;
}

/* ---- 展开区 ---- */
.order-expand {
  border-top: 1rpx solid var(--color-border-light);
  padding: var(--spacing-lg);
}
.expand-section {
  margin-bottom: var(--spacing-lg);
}
.expand-section:last-child {
  margin-bottom: 0;
}
.expand-title {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

/* ---- 工序节点（展开区） ---- */
.process-node {
  margin-bottom: var(--spacing-md);
}
.process-node:last-child {
  margin-bottom: 0;
}
.node-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 3rpx;
}
.node-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.node-pct {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}
.node-pct--done {
  color: var(--color-success);
}
.node-bar-bg {
  height: 4px;
  background: var(--color-border-light);
  border-radius: var(--radius-xs);
  overflow: hidden;
  position: relative;
}
.node-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  transition: width 0.3s;
}
.node-bar-fill--done {
  background: var(--color-success);
}

/* ---- 展开区操作按钮 ---- */
.expand-actions {
  display: flex;
  gap: var(--spacing-md);
  padding-top: var(--spacing-lg);
  border-top: 1rpx solid var(--color-border-light);
  margin-top: 4rpx;
  flex-wrap: wrap;
}
.card-action-btn,
.act-btn {
  font-size: var(--font-size-xs);
  padding: 6rpx var(--spacing-md);
  border-radius: var(--radius-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
}
.act-btn--primary {
  color: var(--color-primary);
  background: var(--color-info-bg);
}
.act-btn--ship {
  color: var(--color-success);
  background: var(--color-success-bg);
}
.act-btn--remark {
  color: var(--color-primary);
  border-color: var(--color-primary-border);
}
.act-btn--detail {
  color: #7c5cfc;
  background: rgba(124, 92, 252, 0.1);
  font-weight: 600;
}

/* ---- 发货小卡片 ---- */
.shipment-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--card-gap);
}
.shipment-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}
.shipment-no {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.shipment-status {
  font-size: var(--font-size-xs);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-xs);
  font-weight: var(--font-weight-medium);
}


.shipment-info {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ---- 模态框样式 ---- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-content {
  width: 85vw;
  max-height: 80vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-2xl);
  border-bottom: 1rpx solid var(--color-border-light);
}
.modal-title { font-size: var(--font-size-lg); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
.modal-close { font-size: var(--font-size-xl); color: var(--color-text-tertiary); padding: 8rpx; }
.modal-body {
  flex: 1;
  padding: var(--spacing-lg) var(--spacing-2xl);
  max-height: 60vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.modal-footer {
  display: flex;
  gap: var(--spacing-lg);
  padding: var(--spacing-lg) var(--spacing-2xl);
  border-top: 1rpx solid var(--color-border-light);
}
.btn { flex: 1; text-align: center; padding: var(--spacing-lg) 0; border-radius: var(--radius-md); font-size: var(--font-size-base); font-weight: var(--font-weight-medium); }
.btn-primary { background: var(--color-primary); color: var(--color-text-white); }
.btn-cancel { background: var(--color-bg-gray); color: var(--color-text-secondary); }
.btn-danger { background: rgba(var(--color-primary-rgb), 0.08); color: var(--color-danger); }

/* ---- 发货表单内：剩余量提示 ---- */
.ship-remaining {
  padding: var(--spacing-md) var(--spacing-md);
  background: var(--color-success-bg);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-md);
  font-size: var(--font-size-xs);
  color: var(--color-success);
}

/* ---- 发货表格（SKU明细） ---- */
.ship-table-header {
  display: flex;
  padding: var(--spacing-md) 0;
  border-bottom: 2rpx solid var(--color-border-light);
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}
.ship-table-row {
  display: flex;
  padding: var(--spacing-lg) 0;
  border-bottom: 1rpx solid var(--color-border-light);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  align-items: center;
}
.st-col { flex: 1; text-align: center; }
.st-input {
  width: 80rpx;
  height: 60rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: var(--font-size-sm);
  background: var(--color-bg-card);
  box-sizing: border-box;
}

/* ---- 发货表单 ---- */
.ship-form { margin-top: var(--spacing-2xl); padding-top: var(--spacing-lg); border-top: 1rpx solid var(--color-border-light); }
.sf-row { display: flex; align-items: center; padding: var(--spacing-md) 0; }
.sf-label { font-size: var(--font-size-sm); color: var(--color-text-secondary); width: 140rpx; }
.sf-input { flex: 1; font-size: var(--font-size-sm); padding: var(--spacing-sm) var(--spacing-md); border: 1rpx solid var(--color-border); border-radius: var(--radius-sm); background: var(--color-bg-card); box-sizing: border-box; }
.sf-textarea { flex: 1; font-size: var(--font-size-sm); padding: var(--spacing-sm) var(--spacing-md); border: 1rpx solid var(--color-border); border-radius: var(--radius-sm); height: 120rpx; background: var(--color-bg-card); box-sizing: border-box; }
.radio-label { margin-right: var(--spacing-xl); font-size: var(--font-size-sm); }

/* ---- 订单详情信息区 ---- */
.detail-info { margin-bottom: var(--spacing-md); }
.di-row { display: flex; justify-content: space-between; padding: var(--spacing-md) 0; border-bottom: 1rpx solid var(--color-border-light); }
.di-label { font-size: var(--font-size-sm); color: var(--color-text-tertiary); }
.di-value { font-size: var(--font-size-sm); color: var(--color-text-primary); font-weight: var(--font-weight-medium); }
