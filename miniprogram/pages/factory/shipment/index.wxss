/**
 * 外发工厂页 · 对齐设计稿 factory-shipment.html
 * 全部颜色/圆角/间距使用 CSS 变量（design-tokens.wxss）
 */

/* ========== 页面 ========== */
.page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x) 20px;
  box-sizing: border-box;
}

/* ========== Sticky 头部 ========== */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
  background: var(--color-bg-page);
  padding: 8px 0 0;
}

/* ========== Tab 切换（segmented control） ========== */
.tab-bar {
  display: flex;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  padding: 3px;
  gap: 3px;
}
.tab-item {
  flex: 1;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
  border-radius: 6px;
  transition: all .2s;
}
.tab-active {
  background: var(--color-bg-card);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
  box-shadow: var(--shadow-sm);
}

/* ========== 工厂筛选卡 ========== */
.factory-scroll {
  white-space: nowrap;
  margin-top: 8px;
  width: 100%;
}
.factory-card {
  display: inline-block;
  vertical-align: top;
  width: 168px;
  padding: 12px;
  margin-right: 8px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  transition: all .2s;
}
.factory-card--active {
  border-color: var(--color-primary);
  border-width: 2px;
  padding: 11px;
}
.factory-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}
.factory-nums {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-top: 8px;
}
.fn-item {
  display: flex;
  align-items: baseline;
  gap: 2px;
}
.fn-val {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.2;
}
.fn-val--primary {
  color: var(--color-primary);
}
.fn-val--sm {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
}
.fn-lbl {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.factory-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: 8px;
}
.ftag {
  font-size: var(--font-size-xxs);
  padding: 1px 6px;
  border-radius: var(--radius-xs);
  font-weight: var(--font-weight-medium);
  line-height: 1.5;
}
.ftag--primary   { background: var(--color-primary-bg); color: var(--color-primary); }
.ftag--success   { background: var(--color-success-bg); color: var(--color-success); }
.ftag--danger    { background: var(--color-danger-bg); color: var(--color-danger); }
.ftag--warning   { background: var(--color-warning-bg); color: var(--color-warning); }

/* ========== 搜索栏 ========== */
.search-bar {
  padding: 8px 16px;
}
.search-row {
  display: flex;
  gap: 8px;
}
.search-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  height: 36px;
  padding: 0 12px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
}
.search-icon {
  flex-shrink: 0;
  opacity: .4;
}
.search-input {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  min-width: 0;
}
.scan-btn {
  flex-shrink: 0;
  width: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
  transition: transform 0.18s ease, background-color 0.18s ease;
}
.scan-btn:active {
  background: var(--color-bg-hover);
  transform: scale(0.95);
}
.scan-icon {
  color: var(--color-text-primary);
}

/* ========== 筛选 pill（生产中 / 已完成） ========== */
.filter-pills {
  display: flex;
  gap: 8px;
  padding: 0 16px;
}
.filter-pill {
  height: 32px;
  padding: 0 14px;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  background: var(--color-bg-card);
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}
.filter-pill--active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
}
.pill-count {
  font-size: var(--font-size-xxs);
  opacity: .8;
}

/* ========== 智能提示标签 ========== */
.hint-row {
  display: flex;
  gap: 8px;
  padding: 8px 16px 0;
}
.hint-tag {
  height: 24px;
  padding: 0 8px;
  display: inline-flex;
  align-items: center;
  gap: 3px;
  border-radius: var(--radius-xs);
  font-size: var(--font-size-xxs);
  font-weight: var(--font-weight-medium);
}
.hint-tag__icon {
  width: 12px;
  height: 12px;
  flex-shrink: 0;
}
.hint-tag__count {
  font-weight: var(--font-weight-bold);
  margin-left: 2px;
}
.hint-tag--danger {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}
.hint-tag--warning {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}
.hint-tag--active {
  opacity: .6;
}

/* ========== Tab 内容 ========== */
.tab-content {
  padding: 8px 0 0;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 0;
  gap: 12px;
}
.empty-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.line-icon--xl {
  width: 48px;
  height: 48px;
  background-size: 48px 48px;
}

/* ========== 订单列表 ========== */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 8px 0 0;
}

/* ========== 订单卡片 ========== */
/* ============ 订单卡片（与 dashboard 完全一致） ============ */
.order-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  padding: 12px;
  box-sizing: border-box;
  transition: transform 0.18s ease, background-color 0.18s ease;
}
.order-card--open {
  /* 展开时无特殊样式 */
}
.order-card--overdue {
  border-color: var(--color-danger-border);
}

/* — 主行：封面 + 信息 — */
.order-main {
  display: flex;
  gap: 12px;
}

/* 封面图 80x80 圆角 */
.order-cover {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
}
.cover-pic {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-ph-text {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 信息区 */
.order-info {
  flex: 1;
  min-width: 0;
}

/* 行1：订单号 + 状态标签 */
.info-line1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.order-no {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

/* 急标签 + 状态标签容器 */
.info-badges {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

/* 急标签（橙色实心，圆角） */
.urgent-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 20px;
  padding: 0 6px;
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-bold);
  border-radius: var(--radius-full);
  background: var(--color-warning);
  color: var(--color-text-white);
  line-height: 1;
  flex-shrink: 0;
}

/* 实心状态标签（h-5 实心背景 + 白字） */
.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 20px;
  padding: 0 8px;
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-full);
  color: var(--color-text-white);
  line-height: 1;
  flex-shrink: 0;
}
.status-badge--production { background: var(--color-primary); }
.status-badge--completed { background: var(--color-success); }
.status-badge--overdue { background: var(--color-danger); }
.status-badge--pending { background: var(--color-text-tertiary); }

/* 旧 badge 样式兼容 */
.badge { font-size: var(--font-size-2xs); padding: 1px 6px; font-weight: var(--font-weight-medium); line-height: 1.5; display: inline-block; }
.badge-urgent { background: var(--color-warning); color: #fff; border-radius: var(--radius-xs); }
.badge-status { border-radius: var(--radius-full); padding: 1px 10px; }

/* 行2：款名（单行，截断） */
.info-style {
  margin-top: 4px;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 旧 info-style-combined 兼容 */
.info-style-combined {
  margin-top: 4px;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 行3：客户名 */
.info-customer {
  margin-top: 2px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 行4：工厂名 */
.info-factory {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 旧 info-line3/info-line4/info-divider/info-delivery-badge 兼容 */
.info-line3, .info-line4 {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.info-divider {
  color: var(--color-text-quaternary);
  font-size: var(--font-size-xs);
}
.info-delivery-badge {
  font-size: var(--font-size-xs);
  padding: 1px 6px;
  border-radius: var(--radius-xs);
  font-weight: var(--font-weight-medium);
  background: var(--color-bg-page);
  color: var(--color-text-tertiary);
}
.info-delivery-badge--days-overdue {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}
.info-delivery-badge--days-urgent {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

/* ========== 数量 + 进度条 + 百分比 + 剩余（同一行） ========== */

.ip-bar {
  flex: 1;
  min-width: 0;
  height: 6px;
  background: var(--color-border);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.ip-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  transition: width 0.3s;
}
.ip-fill--overdue {
  background: var(--color-warning);
}
.ip-fill--done {
  background: var(--color-success);
}
.ip-pct {
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
  min-width: 32px;
  text-align: right;
}

/* 剩余天数标签（与 dashboard 一致） */
.ip-remain {
  display: inline-flex;
  align-items: center;
  height: 20px;
  padding: 0 8px;
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-full);
  line-height: 1;
  flex-shrink: 0;
  white-space: nowrap;
}
.ip-remain.days-safe    { background: var(--color-success-bg); color: var(--color-success); }
.ip-remain.days-warn    { background: var(--color-warning-bg); color: var(--color-warning); }
.ip-remain.days-urgent  { background: var(--color-danger-bg); color: var(--color-danger); }
.ip-remain.days-overdue { background: var(--color-danger-bg); color: var(--color-danger); font-weight: var(--font-weight-semibold); }
.ip-remain.days-done    { background: var(--color-success-bg); color: var(--color-success); }

/* ========== 展开区 ========== */

.act-btn {
  height: 32px;
  padding: 0 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-sm);
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  flex-shrink: 0;
  transition: all .15s;
}

/* ========== 展开/收起按钮（与 dashboard 一致） ========== */
.order-expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  border-top: 1px solid var(--color-border);
  margin-top: 12px;
  padding-top: 8px;
}
.expand-btn-text {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}
.expand-btn-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  transition: transform 0.2s;
}
.expand-btn-arrow--up {
  transform: rotate(180deg);
}

/* ========== 发货记录 ========== */
.shipment-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-shadow: var(--shadow-sm);
  margin-bottom: 12px;
}
.shipment-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.shipment-no {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.shipment-status {
  font-size: var(--font-size-xs);
  padding: 2px 10px;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
}
.shipment-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ========== 加载提示 ========== */
.load-tip {
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  padding: 16px 0;
}
.load-tip--end {
  color: var(--color-text-quaternary);
}

/* ============ 进度行（与 dashboard 一致） ============ */
.info-progress {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 12px;
}
.ip-left {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}
.ip-qty {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}
.ip-dot {
  font-size: var(--font-size-xs);
  color: var(--color-text-quaternary);
}
.ip-delivery {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* ============ 菲号明细表格 ============ */
.detail-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0 6px;
}
.detail-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.detail-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.detail-table {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.detail-row {
  display: flex;
  border-bottom: 1px solid var(--color-border-light);
}
.detail-row:last-child {
  border-bottom: none;
}
.detail-row--head {
  background: var(--color-bg-hover);
}
.detail-row--empty {
  justify-content: center;
}
.detail-cell {
  padding: 6px 8px;
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
}
.detail-cell--no {
  flex: none;
  width: 60px;
  font-weight: var(--font-weight-medium);
}
.detail-cell--proc {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 2px;
}
.proc-node {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.proc-sep {
  margin: 0 2px;
  color: var(--color-text-quaternary);
}
.detail-cell--qty {
  flex: none;
  width: 50px;
  text-align: right;
  font-variant-numeric: tabular-nums;
}
.detail-cell--empty {
  text-align: center;
  color: var(--color-text-tertiary);
  padding: 12px 8px;
}

/* ============ 展开区功能 ============ */
.expand-section {
  margin-bottom: var(--spacing-md);
}
.expand-section:last-child {
  margin-bottom: 0;
}
.expand-title {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}
/* 工序节点 */
.process-node {
  margin-bottom: var(--spacing-sm);
}
.process-node:last-child {
  margin-bottom: 0;
}
.node-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2px;
}
.node-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.node-pct {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}
.node-pct--done {
  color: var(--color-success);
}
.node-meta {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: 1.4;
}
.node-qty {
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}
.node-dot {
  margin: 0 6px;
  color: var(--color-text-tertiary);
}
.node-bundle-text {
  color: var(--color-text-tertiary);
}
.node-bar-bg {
  height: 4px;
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs);
  overflow: hidden;
  position: relative;
}
.node-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  transition: width 0.3s;
}
.node-bar-fill--done {
  background: var(--color-success);
}
/* 子工序列表 */
.node-sub-procs {
  margin-top: 6px;
  padding-left: 4px;
  border-left: 2px solid var(--color-border);
}
.sub-proc-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 3px 0;
}
.sp-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex: 1;
}
.sp-price {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  margin-left: var(--spacing-sm);
}
.sp-price--free {
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-normal);
}
/* SKU 表格 */
.sku-scroll {
  width: 100%;
}
.sku-table {
  min-width: 100%;
}
.sku-row {
  display: flex;
  border-bottom: 1px solid var(--color-border-light);
}
.sku-row--head {
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs) var(--radius-xs) 0 0;
}
.sku-cell {
  flex: 1;
  min-width: 36px;
  padding: 7px 2px;
  font-size: var(--font-size-xs);
  text-align: center;
  color: var(--color-text-primary);
}
.sku-cell--color {
  flex: none;
  width: 48px;
  text-align: left;
  padding-left: 8px;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.sku-cell--total {
  flex: none;
  width: 40px;
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}
/* 展开区容器 */
.order-expand {
  padding: 12px;
  border-top: 1px solid var(--color-border-light);
}
/* 快捷操作（与 dashboard 一致） */
.expand-actions {
  display: flex;
  gap: var(--spacing-md);
  padding-top: var(--spacing-lg);
  margin-top: 2px;
  flex-wrap: wrap;
}
.act-btn--detail {
  color: #7c5cfc;
  background: rgba(124, 92, 252, 0.1);
  font-weight: 600;
}
.act-btn--primary {
  color: var(--color-primary);
  background: var(--color-info-bg);
}
.act-btn--warn {
  color: var(--color-warning);
  background: var(--color-warning-bg);
}
.act-btn--remark {
  color: var(--color-primary);
  background: var(--color-primary-bg);
}

