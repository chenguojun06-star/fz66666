<!-- 质检详情页 · 六段式结构 -->

<view class="quality-page" wx:if="{{detail}}">

  <!-- ════════════ ① 基础信息卡 ════════════ -->
  <view class="top-card">
    <view class="top-left">
      <view class="cover-placeholder">
        <text class="cover-icon">✓</text>
        <text class="cover-label">质检</text>
      </view>
    </view>
    <view class="top-right">
      <view class="top-title">
        <text class="order-no">{{detail.orderNo || '-'}}</text>
        <text class="status-tag tag {{detail.qualityStatus === 'unqualified' ? 'tag-error' : 'tag-success'}}">{{detail.qualityStatusText || '-'}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.warehousingNo}}">
        <text class="info-label">入库号</text>
        <text class="info-value">{{detail.warehousingNo}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">款号</text>
        <text class="info-value">{{detail.styleNo || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">款名</text>
        <text class="info-value">{{detail.styleName || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">生产方</text>
        <text class="info-value">{{detail.factoryName || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">菲号</text>
        <text class="info-value">{{detail.bundleNo || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">颜色</text>
        <text class="info-value">{{detail.color || '-'}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">尺码</text>
        <text class="info-value">{{detail.size || '-'}}</text>
      </view>
    </view>
  </view>

  <!-- ════════════ ② 数量进度卡 ════════════ -->
  <view class="qty-card">
    <view class="qty-col">
      <text class="qty-num">{{detail.cuttingQuantity || 0}}</text>
      <text class="qty-label">裁剪</text>
    </view>
    <view class="qty-div"></view>
    <view class="qty-col">
      <text class="qty-num">{{detail.warehousingQuantity || 0}}</text>
      <text class="qty-label">质检</text>
    </view>
    <view class="qty-div"></view>
    <view class="qty-col">
      <text class="qty-num qty-success">{{detail.qualifiedQuantity || 0}}</text>
      <text class="qty-label">合格</text>
    </view>
    <view class="qty-div"></view>
    <view class="qty-col">
      <text class="qty-num qty-error">{{detail.unqualifiedQuantity || 0}}</text>
      <text class="qty-label">不合格</text>
    </view>
  </view>

  <!-- ════════════ ③ 操作区（无操作按钮，省略） ════════════ -->

  <!-- ════════════ ④ 执行进度区 · 质检信息 ════════════ -->
  <view class="section-card">
    <view class="section-hd">
      <text class="section-title">质检信息</text>
    </view>
    <view class="info-list">
      <view class="info-row" wx:if="{{detail.scanModeText}}">
        <text class="info-label">扫码方式</text>
        <text class="info-value">{{detail.scanModeText}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.qualityOperatorName}}">
        <text class="info-label">质检人</text>
        <text class="info-value">{{detail.qualityOperatorName}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.createTimeText}}">
        <text class="info-label">质检时间</text>
        <text class="info-value">{{detail.createTimeText}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.processName}}">
        <text class="info-label">工序</text>
        <text class="info-value">{{detail.processName}}</text>
      </view>
    </view>
  </view>

  <!-- ════════════ ⑤ 明细数据区 · 异常问题 + 不良品照片 ════════════ -->
  <view class="section-card" wx:if="{{detail.defectCategoryText || detail.defectRemark || detail.remark || detail.imageList.length > 0}}">
    <view class="section-hd">
      <text class="section-title">质检明细</text>
    </view>
    <view class="info-list" wx:if="{{detail.defectCategoryText || detail.defectRemark || detail.remark}}">
      <view class="info-row" wx:if="{{detail.defectCategoryText}}">
        <text class="info-label">缺陷类别</text>
        <text class="info-value text-error">{{detail.defectCategoryText}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.defectRemark}}">
        <text class="info-label">处理方式</text>
        <text class="info-value">{{detail.defectRemark}}</text>
      </view>
      <view class="info-row" wx:if="{{detail.remark}}">
        <text class="info-label">备注</text>
        <text class="info-value">{{detail.remark}}</text>
      </view>
    </view>

    <view class="photo-wrap" wx:if="{{detail.imageList.length > 0}}">
      <view class="photo-hd">
        <text class="photo-title">不良品照片</text>
        <text class="section-count">{{detail.imageList.length}}张</text>
      </view>
      <view class="photo-grid">
        <image
          wx:for="{{detail.imageList}}"
          wx:key="*this"
          class="defect-photo"
          src="{{item}}"
          mode="aspectFill"
          data-url="{{item}}"
          data-urls="{{detail.imageList}}"
          bindtap="onPreviewImage"
        />
      </view>
    </view>
  </view>

  <!-- ════════════ ⑥ 操作记录区（暂无，省略） ════════════ -->

  <view class="bottom-gap"></view>
</view>
