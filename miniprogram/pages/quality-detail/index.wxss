.quality-page {
  min-height: 100vh;
  padding: var(--spacing-xs) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 20px);
  background: var(--color-bg-page);
}

.top-card, .qty-card, .section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}

.top-card {
  padding: var(--spacing-lg);
  display: flex;
  gap: var(--spacing-lg);
  align-items: flex-start;
}

.top-left {
  width: 80px;
  height: 100px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-primary-bg);
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
}

.cover-icon {
  font-size: 28px;
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
  line-height: 1;
}

.cover-label {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

.top-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.top-title {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
  margin-bottom: 2px;
}

.order-no {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.info-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.info-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  min-width: 36px;
  flex-shrink: 0;
}

.info-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  word-break: break-all;
  flex: 1;
}

.text-error {
  color: var(--color-danger);
}

.qty-card {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
}

.qty-col {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
}

.qty-num {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1;
}

.qty-success {
  color: var(--color-success);
}

.qty-error {
  color: var(--color-danger);
}

.qty-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.qty-div {
  width: 1px;
  height: 30px;
  background: var(--color-border-light);
}

.section-card {
  padding: var(--spacing-lg);
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.section-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.info-list .info-row {
  padding: 3px 0;
}

.photo-wrap {
  margin-top: var(--spacing-sm);
}

.photo-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.photo-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.defect-photo {
  width: 100px;
  height: 100px;
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border-light);
  background: var(--color-bg-gray);
}

.bottom-gap {
  height: 20px;
}
