/* ========== 质检详情页 ========== */
/* 基于设计 Token（CSS 变量）实现，与列表页保持一致 */

.container {
  min-height: 100vh;
  background: var(--color-bg, #f5f6f8);
  padding: 0 var(--page-padding-x, 16px);
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 加载 / 空态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(0, 0, 0, 0.08);
  border-top-color: var(--color-primary, #165DFF);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--color-text-tertiary, #999);
}
.loading-inline {
  padding: 40rpx 0;
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 40rpx;
}
.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.empty-text {
  font-size: 32rpx;
  color: var(--color-text-primary, #1A1A1A);
  font-weight: 600;
}
.empty-hint {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-tertiary, #999);
}
.empty-inline {
  padding: 60rpx 0;
  text-align: center;
}
.empty-text-inline {
  font-size: 26rpx;
  color: var(--color-text-tertiary, #999);
}

/* 卡片基础 */
.detail-card {
  margin: 0 0 12px 0;
  padding: 12px;
  background: #fff;
  border: 1px solid var(--color-border, #e8e8e8);
  border-radius: var(--radius-xl);
  box-sizing: border-box;
  box-shadow: var(--shadow-sm, 0 1px 3px rgba(0, 0, 0, 0.04));
}
.detail-card.section-pending {
  border-top: 6rpx solid var(--color-primary, #165DFF);
}

/* 卡片标题行 */
.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.card-title-with-tag {
  display: flex;
  align-items: center;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
}
.card-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
  margin-bottom: 20rpx;
  display: block;
}
.card-title-hint {
  font-size: 24rpx;
  color: var(--color-text-tertiary, #999);
}
.card-badge {
  margin-left: 16rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  text-align: center;
  font-size: 22rpx;
  color: #fff;
  background: var(--color-text-tertiary, #999);
  border-radius: var(--radius-md);
}
.card-badge--primary {
  background: var(--color-primary, #165DFF);
}
.card-badge--ai {
  background: linear-gradient(135deg, #722ED1, #B37FEB);
}
.card-collapse-icon {
  font-size: 24rpx;
  color: var(--color-primary, #165DFF);
  padding: 8rpx 16rpx;
}

/* ========== 1. 基本信息卡 ========== */
.basic-header {
  display: flex;
  align-items: flex-start;
}
.basic-cover,
.basic-cover-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: #f0f1f3;
}
.basic-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary, #999);
}
.basic-header-info {
  margin-left: 24rpx;
  flex: 1;
  min-width: 0;
}
.basic-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.basic-order-no {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1A1A1A);
}
.status-pill {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-md);
  font-size: 22rpx;
  font-weight: 500;
}
.status-pill.status-success { background: rgba(82, 196, 26, 0.12); color: #52C41A; }
.status-pill.status-error { background: rgba(245, 63, 63, 0.12); color: #F53F3F; }
.status-pill.status-warning { background: rgba(255, 159, 0, 0.12); color: #FF9F00; }
.status-pill.status-info { background: rgba(22, 93, 255, 0.12); color: #165DFF; }
.basic-style-no {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary, #999);
  display: block;
}
.basic-info-rows {
  margin-top: 16rpx;
}
.basic-info-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--color-border-light, #f0f0f0);
  font-size: 26rpx;
}
.basic-info-row.last { border-bottom: none; }
.basic-info-label {
  width: 140rpx;
  color: var(--color-text-tertiary, #999);
  flex-shrink: 0;
}
.basic-info-value {
  flex: 1;
  color: var(--color-text-primary, #1A1A1A);
  word-break: break-all;
}
.remain-badge {
  margin-left: 16rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 600;
}
.remain-badge.remain-normal { background: rgba(82, 196, 26, 0.12); color: #52C41A; }
.remain-badge.remain-warn { background: rgba(255, 159, 0, 0.12); color: #FF9F00; }
.remain-badge.remain-danger { background: rgba(245, 63, 63, 0.12); color: #F53F3F; }

/* ========== 2. 数量进度卡 ========== */
.qty-progress-grid {
  display: flex;
  align-items: stretch;
}
.qty-progress-col {
  flex: 1;
  text-align: center;
  position: relative;
}
.qty-progress-col:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 10%;
  height: 80%;
  width: 1rpx;
  background: var(--color-border-light, #f0f0f0);
}
.qty-progress-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary, #999);
  display: block;
}
.qty-progress-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1A1A1A);
  margin-top: 8rpx;
  display: block;
}
.qty-progress-value.qty-success { color: #52C41A; }
.qty-progress-value.qty-error { color: #F53F3F; }

/* ========== 3/4. 信息行 / 质检明细 ========== */
.info-rows {
  margin-top: 4rpx;
}
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border-light, #f0f0f0);
  font-size: 28rpx;
}
.info-row.last { border-bottom: none; }
.info-row-label {
  width: 160rpx;
  color: var(--color-text-tertiary, #999);
  flex-shrink: 0;
}
.info-row-value {
  flex: 1;
  color: var(--color-text-primary, #1A1A1A);
  word-break: break-all;
}
.info-row-value--right { text-align: right; }
.info-row-value.defect-value { color: #F53F3F; font-weight: 500; }

.defect-photo-section {
  margin-top: 20rpx;
}
.defect-photo-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.defect-photo-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
}
.defect-photo-count {
  font-size: 24rpx;
  color: var(--color-text-tertiary, #999);
}
.photo-grid-3 {
  display: flex;
  flex-wrap: wrap;
}
.defect-photo-img {
  width: 200rpx;
  height: 200rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  border-radius: var(--radius-sm);
  background: #f0f1f3;
}

/* ========== 5. 质检概览 ========== */
.overview-grid {
  display: flex;
  margin: 20rpx 24rpx;
  gap: 16rpx;
}
.overview-card {
  flex: 1;
  background: #fff;
  
  
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.overview-card--primary { border-top: 6rpx solid var(--color-primary, #165DFF); }
.overview-card--warning { border-top: 6rpx solid #FF9F00; }
.overview-card--success { border-top: 6rpx solid #52C41A; }
.overview-card--active { box-shadow: 0 8rpx 32rpx rgba(22, 93, 255, 0.16); }
.overview-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1A1A1A);
  line-height: 1.1;
}
.overview-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-tertiary, #999);
}
.overview-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--color-primary, #165DFF);
}
.overview-hint--muted { color: var(--color-text-quaternary, #C0C0C0); }

/* ========== 6. 菲号多选列表（页面内操作，与 PC 端对齐） ========== */
.bundle-select-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid var(--color-border-light, #f0f0f0);
}
.bundle-select-actions {
  display: flex;
  align-items: center;
}
.bundle-select-action {
  font-size: 26rpx;
  color: var(--color-primary, #165DFF);
  padding: 8rpx 20rpx;
  border-right: 1rpx solid var(--color-border-light, #f0f0f0);
}
.bundle-select-action:last-child { border-right: none; }
.bundle-select-summary {
  font-size: 24rpx;
  color: var(--color-text-secondary, #666);
}

.bundle-select-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.bundle-select-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fafbfc;
  border-radius: var(--radius-sm);
  border: 2rpx solid transparent;
  transition: all 0.15s ease;
}
.bundle-select-item--active {
  background: rgba(22, 93, 255, 0.06);
  border-color: var(--color-primary, #165DFF);
}
.bundle-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: #fff;
  transition: all 0.15s ease;
}
.bundle-checkbox--checked {
  background: var(--color-primary, #165DFF);
  border-color: var(--color-primary, #165DFF);
}
.bundle-checkbox-icon {
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}
.bundle-select-info {
  flex: 1;
  min-width: 0;
}
.bundle-select-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}
.bundle-select-no {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
  word-break: break-all;
}
.bundle-select-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 6rpx;
}
.bundle-select-meta-item {
  font-size: 24rpx;
  color: var(--color-text-tertiary, #999);
  margin-right: 16rpx;
}
.bundle-select-meta-item:last-child { margin-right: 0; }

.tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-xs);
  font-size: 22rpx;
  line-height: 1.6;
}
.tag-info { background: rgba(22, 93, 255, 0.1); color: #165DFF; }
.tag-current { background: rgba(255, 159, 0, 0.12); color: #FF9F00; }

/* ========== 页面内质检表单（单选，原弹窗样式改为 .qc-form-*） ========== */
.qc-form {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-light, #f0f0f0);
}
.batch-unqual-form {
  background: rgba(245, 63, 63, 0.03);
  border-color: rgba(245, 63, 63, 0.2);
}
.qc-form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
  margin-bottom: 20rpx;
}
.qc-form-info-card,
.wh-form-info-card {
  background: #f7f8fa;
  
  
  margin-bottom: 20rpx;

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.qc-form-info-row,
.wh-form-info-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  font-size: 26rpx;
}
.qc-form-info-label,
.wh-form-info-label {
  width: 140rpx;
  color: var(--color-text-tertiary, #999);
  flex-shrink: 0;
}
.qc-form-info-value,
.wh-form-info-value {
  flex: 1;
  color: var(--color-text-primary, #1A1A1A);
  word-break: break-all;
}
.qc-form-info-strong,
.wh-form-info-strong {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary, #165DFF);
}

.qc-form-row,
.wh-form-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.qc-form-col,
.qc-form-col-full,
.wh-form-col-full {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.qc-form-label,
.wh-form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary, #666);
  margin-bottom: 12rpx;
}
.qc-form-input {
  height: 80rpx;
  background: #f7f8fa;
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 30rpx;
  color: var(--color-text-primary, #1A1A1A);
}
.qc-form-picker,
.wh-form-picker {
  background: #f7f8fa;
  border-radius: var(--radius-sm);
  height: 80rpx;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}
.qc-form-textarea {
  background: #f7f8fa;
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  min-height: 120rpx;
  font-size: 28rpx;
  color: var(--color-text-primary, #1A1A1A);
  width: 100%;
  box-sizing: border-box;
}
.qc-form-divider,
.wh-form-divider {
  height: 1rpx;
  background: var(--color-border-light, #f0f0f0);
  margin: 20rpx 0;
}
.qc-form-actions,
.wh-form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

/* 图片上传（质检表单复用） */
.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.upload-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.upload-img {
  width: 100%;
  height: 100%;
  background: #f0f1f3;
}
.upload-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 0 0 0 12rpx;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.upload-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafbfc;
}
.upload-add-icon {
  font-size: 48rpx;
  color: var(--color-text-tertiary, #999);
  line-height: 1;
}
.upload-add-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary, #999);
}

/* picker 通用值显示 */
.picker-value {
  font-size: 28rpx;
  color: var(--color-text-primary, #1A1A1A);
  width: 100%;
}
.picker-placeholder {
  color: var(--color-text-quaternary, #C0C0C0);
}

/* 批量操作按钮区 */
.batch-actions {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ========== 7. 质检记录列表 ========== */
.qc-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.qc-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}
.qc-card-highlighted {
  border-color: #FF9F00;
  background: rgba(255, 159, 0, 0.06);
}
.qc-card--actionable {
  border-left-color: var(--color-primary, #165DFF);
}
.qc-card--warning {
  border-left-color: #FF9F00;
}
.qc-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}
.qc-card-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.qc-wh-no {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
}
.qc-card-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.quality-status {
  font-size: 24rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-sm);
  font-weight: 500;
}
.quality-status.status-success { background: rgba(82, 196, 26, 0.12); color: #52C41A; }
.quality-status.status-error { background: rgba(245, 63, 63, 0.12); color: #F53F3F; }
.quality-status.status-warning { background: rgba(255, 159, 0, 0.12); color: #FF9F00; }
.quality-status.status-info { background: rgba(22, 93, 255, 0.12); color: #165DFF; }
.qc-card-body {
  font-size: 26rpx;
}
.qc-row {
  display: flex;
  padding: 8rpx 0;
}
.qc-label {
  width: 140rpx;
  color: var(--color-text-tertiary, #999);
  flex-shrink: 0;
}
.qc-value {
  flex: 1;
  color: var(--color-text-primary, #1A1A1A);
  word-break: break-all;
}
.qc-error-text { color: #F53F3F; }
.qc-qty-row {
  display: flex;
  margin: 12rpx 0;
  gap: 12rpx;
  flex-wrap: wrap;
}
.qc-qty-item {
  background: #fff;
  border-radius: var(--radius-xs);
  padding: 12rpx 16rpx;
  text-align: center;
}
.qc-qty-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #999);
  display: block;
}
.qc-qty-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
  display: block;
}
.qc-qty-value.qc-success { color: #52C41A; }
.qc-qty-value.qc-error { color: #F53F3F; }
.qc-qty-value.qc-info { color: #165DFF; }
.qc-photos {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-light, #f0f0f0);
}
.qc-photos-title {
  font-size: 24rpx;
  color: var(--color-text-secondary, #666);
  margin-bottom: 12rpx;
}

/* ========== 页面内入库表单（记录下方展开，原弹窗样式改为 .wh-form-*） ========== */
.wh-form {
  margin-top: 20rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border-light, #f0f0f0);
}
.wh-form-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
  margin-bottom: 20rpx;
}

/* ========== 8. AI 质检助手 ========== */
.ai-card { overflow: hidden; }
.ai-urgent-tip {
  display: flex;
  align-items: center;
  background: rgba(245, 63, 63, 0.06);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.urgent-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #F53F3F;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.urgent-text {
  flex: 1;
  font-size: 26rpx;
  color: #F53F3F;
  line-height: 1.5;
}
.ai-history-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.history-block {
  flex: 1;
  background: #f7f8fa;
  border-radius: var(--radius-sm);
  padding: 16rpx;
  text-align: center;
}
.history-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #999);
  display: block;
}
.history-value {
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 4rpx;
  display: block;
}
.history-value.verdict-good { color: #52C41A; }
.history-value.verdict-warn { color: #FF9F00; }
.history-value.verdict-critical { color: #F53F3F; }
.ai-section { margin-bottom: 20rpx; }
.ai-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
  margin-bottom: 12rpx;
}
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.tip-item {
  display: flex;
  align-items: flex-start;
  font-size: 26rpx;
  color: var(--color-text-secondary, #666);
  line-height: 1.6;
}
.tip-bullet {
  color: var(--color-primary, #165DFF);
  margin-right: 12rpx;
  font-weight: 700;
}
.defect-advice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.defect-advice-item {
  background: #f7f8fa;
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
}
.defect-advice-label {
  font-size: 24rpx;
  color: var(--color-primary, #165DFF);
  font-weight: 600;
  margin-bottom: 6rpx;
}
.defect-advice-text {
  font-size: 26rpx;
  color: var(--color-text-secondary, #666);
  line-height: 1.5;
}

/* ========== 9. BOM 物料 ========== */
.bom-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.bom-item {
  background: #f7f8fa;
  
  

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.bom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}
.bom-code {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1A1A1A);
}
.bom-type-tag {
  font-size: 20rpx;
  color: var(--color-primary, #165DFF);
  background: rgba(22, 93, 255, 0.1);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-xs);
}
.bom-name {
  font-size: 28rpx;
  color: var(--color-text-primary, #1A1A1A);
  display: block;
  margin-bottom: 6rpx;
}
.bom-meta {
  display: flex;
  flex-wrap: wrap;
}
.bom-meta-item {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #999);
  margin-right: 16rpx;
}

/* ========== 按钮通用样式 ========== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1;
  border: none;
  box-sizing: border-box;
}
.btn::after { border: none; }
.btn-sm {
  height: 56rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
}
.btn-block {
  display: flex;
  width: 100%;
  flex: 1;
}
.btn-primary-outline {
  background: #fff;
  color: var(--color-primary, #165DFF);
  border: 2rpx solid var(--color-primary, #165DFF);
}
.btn-primary-solid {
  background: var(--color-primary, #165DFF);
  color: #fff;
  border: 2rpx solid var(--color-primary, #165DFF);
}
.btn-default-outline {
  background: #fff;
  color: var(--color-text-secondary, #666);
  border: 2rpx solid #e5e6eb;
}
.btn-success-outline {
  background: #fff;
  color: #52C41A;
  border: 2rpx solid #52C41A;
}
.btn-warning-outline {
  background: #fff;
  color: #FF9F00;
  border: 2rpx solid #FF9F00;
}
.btn-danger-outline {
  background: #fff;
  color: #F53F3F;
  border: 2rpx solid #F53F3F;
}

/* 线性图标占位 */
.line-icon { display: inline-block; }
.line-icon--xl { width: 64rpx; height: 64rpx; }
.icon-alert::before { content: '!'; font-size: 48rpx; color: var(--color-text-tertiary, #999); }
.icon-shirt::before { content: '衫'; font-size: 40rpx; color: var(--color-text-tertiary, #999); }
