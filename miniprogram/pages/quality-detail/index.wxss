.quality-page {
  min-height: 100vh;
  padding: 12px var(--page-padding-x) calc(env(safe-area-inset-bottom) + 20px);
  background: var(--color-bg-page);
}

.top-card, .qty-card, .section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  margin-bottom: var(--card-gap);
  box-shadow: var(--shadow-card);
}

.top-card {
  padding: var(--spacing-lg);
  display: flex;
  gap: var(--spacing-md);
  align-items: flex-start;
}

.top-left {
  width: 72px;
  height: 90px;
  border-radius: var(--radius-card);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.cover-icon {
  width: 32px;
  height: 32px;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.cover-label {
  font-size: 11px;
  color: var(--color-primary);
  font-weight: 500;
}

.top-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.top-title {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 2px;
}

.order-no {
  font-size: var(--font-size-3xl);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.status-tag {
  font-size: var(--font-size-xs);
  padding: 2px 8px;
  border-radius: var(--radius-tag);
  font-weight: var(--font-weight-medium);
  line-height: 1.5;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.info-label {
  font-size: 12px;
  color: var(--color-text-tertiary);
  min-width: 42px;
  flex-shrink: 0;
}

.info-value {
  font-size: var(--font-size-lg);
  color: var(--color-text-primary);
  font-weight: 500;
  word-break: break-all;
  flex: 1;
  line-height: 1.4;
}

.text-error {
  color: var(--color-error);
}

.qty-card {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-md);
}

.qty-col {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.qty-num {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
}

.qty-success {
  color: var(--color-success);
}

.qty-error {
  color: var(--color-error);
}

.qty-label {
  font-size: 11px;
  color: var(--color-text-tertiary);
}

.qty-div {
  width: 1px;
  height: 28px;
  background: var(--color-border-light);
}

.section-card {
  padding: var(--spacing-lg);
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--card-gap);
}

.section-title {
  font-size: var(--font-size-2xl);
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 12px;
  color: var(--color-text-tertiary);
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.info-list .info-row {
  padding: 2px 0;
}

.photo-wrap {
  margin-top: var(--card-gap);
  padding-top: var(--card-gap);
  border-top: 1px solid var(--color-border-light);
}

.photo-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.photo-title {
  font-size: var(--font-size-lg);
  font-weight: 500;
  color: var(--color-text-secondary);
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.defect-photo {
  width: 100px;
  height: 100px;
  border-radius: 8px;
  background: var(--color-bg-gray);
}

.bottom-gap {
  height: 20px;
}
