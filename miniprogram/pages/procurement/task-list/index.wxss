@import '/styles/page-utils.wxss';

.page-container,
.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb), 0.06) 0%, transparent 60%),
    linear-gradient(180deg, rgba(var(--color-primary-rgb), 0.03) 0%, var(--color-bg-page) 30%);
  padding: 0 var(--page-padding-x) calc(40rpx + env(safe-area-inset-bottom));
}

/* ---- 跨岗位提示条 ---- */
.role-hint-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: var(--spacing-lg) 0 0;
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-warning-bg);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-warning-border);
}
.role-hint-icon { font-size: var(--font-size-sm); flex-shrink: 0; }
.role-hint-text { font-size: var(--font-size-xs); color: var(--color-warning); line-height: 1.5; }

/* ---- 筛选 Tab ---- */
.filter-tabs {
  display: flex;
  padding: var(--spacing-lg) 0;
  gap: var(--spacing-lg);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.filter-tab {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: var(--spacing-sm) var(--spacing-xl);
  border-radius: var(--radius-xl);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}
.filter-tab.active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}
.tab-badge {
  font-size: var(--font-size-xs);
  background: rgba(var(--color-primary-rgb), 0.3);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-xl);
}
.filter-tab.active .tab-badge {
  background: rgba(255, 255, 255, 0.35);
}

/* ---- 搜索框（对齐裁剪明细页面） ---- */
.order-search-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--color-primary-border);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}
.order-search-input {
  flex: 1;
  height: 80rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
}
.order-search-icon {
  font-size: 36rpx;
  color: var(--color-text-tertiary);
  opacity: 0.6;
}

/* ---- 加载状态 ---- */
.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-secondary);
  font-size: var(--font-size-md);
}

/* ---- 订单卡片列表（对齐裁剪明细页面 order-sel-card 紧凑样式） ---- */
.order-list {
  padding: 0;
}

.order-sel-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-lg);
  padding: var(--spacing-lg) var(--spacing-2xl);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid var(--color-border-light);
  position: relative;
}
.task-card-hover {
  transform: scale(0.99);
  box-shadow: var(--shadow-md);
}

.sel-cover-box {
  width: 120rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}
.sel-cover-img {
  width: 100%;
  height: 100%;
}
.sel-cover-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-tertiary);
}
.cover-abbr {
  font-size: 48rpx;
  color: var(--color-text-tertiary);
}

.sel-card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

/* 顶部：订单号 + 状态标签 */
.info-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 4rpx;
}
.order-no {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* 状态标签 */
.status-tag.tag {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  background: var(--color-primary-bg);
  color: var(--color-primary);
}
.status-tag.tag-warning { background: rgba(250, 157, 59, 0.12); color: var(--color-warning); }
.status-tag.tag-success { background: rgba(7, 193, 96, 0.1); color: var(--color-success); }
.status-tag.tag-danger  { background: rgba(250, 81, 81, 0.12); color: var(--color-danger); }
.status-tag.tag-processing { background: var(--color-primary-bg); color: var(--color-primary); }

/* info-row：双行信息（label + value） */
.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.info-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  min-width: 56rpx;
}
.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}
.info-value.highlight {
  color: var(--color-primary);
  font-weight: 600;
}
.info-value.success {
  color: var(--color-success);
}
.info-value.pending {
  color: var(--color-warning);
}

/* 右侧箭头 */
.card-arrow {
  position: absolute;
  right: var(--spacing-2xl);
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-tertiary);
  font-size: var(--font-size-lg);
  flex-shrink: 0;
}

/* ---- 底部提示 ---- */
.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-xs);
}
