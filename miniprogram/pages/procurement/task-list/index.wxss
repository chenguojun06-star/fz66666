@import '/styles/page-utils.wxss';

.page-container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 50% 0%, rgba(var(--color-primary-rgb, 37,99,235), 0.06) 0%, transparent 60%);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ── Filter Bar ── */
.filter-bar {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(12px);
}
.filter-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(0,0,0,0.04);
  transition: all 0.25s;
}
.filter-tab.active {
  background: var(--color-primary, #2563eb);
  color: #fff;
}
.tab-label {
  font-size: 26rpx;
  font-weight: 500;
}
.tab-count {
  font-size: 22rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  background: rgba(0,0,0,0.08);
  padding: 0 8rpx;
}
.filter-tab.active .tab-count {
  background: rgba(255,255,255,0.3);
  color: #fff;
}

/* ── Loading ── */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(0,0,0,0.1);
  border-top-color: var(--color-primary, #2563eb);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-tertiary, #9ca3af);
}

/* ── Task Cards ── */
.task-list {
  padding: 16rpx 24rpx;
}
.task-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 20rpx);
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 12rpx;
}
.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}
.order-no {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1f2937);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}
.tag-orange {
  background: rgba(245, 158, 11, 0.12);
  color: var(--color-warning, #d97706);
}
.tag-blue {
  background: rgba(var(--color-primary-rgb, 37, 99, 235), 0.10);
  color: var(--color-primary, #2563eb);
}
.tag-green {
  background: rgba(34, 197, 94, 0.12);
  color: var(--color-success, #16a34a);
}
.arrow-icon {
  font-size: 36rpx;
  color: var(--color-text-tertiary, #94a3b8);
  margin-left: 8rpx;
}

.card-body {
  padding: 8rpx 28rpx 20rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
}
.info-label {
  font-size: 26rpx;
  color: var(--color-text-tertiary, #9ca3af);
}
.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary, #1f2937);
  font-weight: 500;
}
.info-value.highlight {
  color: var(--color-warning, #d97706);
}

/* ── Card Footer ── */
.card-footer {
  display: flex;
  padding: 16rpx 28rpx 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid var(--color-border-light, #f0f0f0);
}
.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.btn-primary {
  background: var(--color-primary, #2563eb);
  color: #fff;
}
.btn-primary:active {
  opacity: 0.85;
}
