<view class="container">
  <!-- 吸顶区：搜索 + 扫码 + 筛选器（与 dashboard 一致的通用组件） -->
  <sticky-search-bar
    placeholder="搜索物料/订单号"
    value="{{keyword}}"
    show-scan="{{true}}"
    show-filter="{{true}}"
    bind:input="onSearchInput"
    bind:scan="onScanTap"
  >
    <view slot="filter">
      <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{statusTabs}}"
          wx:key="key"
          class="filter-pill {{activeFilter === item.key ? 'filter-pill--on' : ''}} {{item.pillClass}}"
          data-key="{{item.key}}"
          bindtap="onFilterTap"
        >
          <text class="filter-text">{{item.label}}</text>
          <text wx:if="{{item.count > 0}}" class="filter-num">{{item.count}}</text>
        </view>
      </scroll-view>
    </view>
  </sticky-search-bar>

  <!-- 加载中 -->
  <view wx:if="{{loading && !filteredItems.length}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载采购任务中…</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{filteredItems.length === 0}}" class="empty-state">
    <view class="empty-icon line-icon icon-package"></view>
    <text class="empty-text">暂无采购任务</text>
    <text class="empty-hint">当有物料需要采购时，任务将出现在这里</text>
  </view>

  <!-- 任务列表（物料级别卡片） -->
  <block wx:else>
    <view
      wx:for="{{filteredItems}}"
      wx:key="id"
      class="task-card"
    >
      <!-- 头部：款式图 + 物料信息 + 状态标签 -->
      <view class="card-header">
        <view class="card-media">
          <image
            wx:if="{{item.styleCoverUrl}}"
            class="media-img"
            src="{{item.styleCoverUrl}}"
            mode="aspectFill"
            lazy-load="true"
          />
          <view wx:else class="media-placeholder line-icon icon-package"></view>
        </view>
        <view class="card-title-area">
          <text class="material-name">{{item.materialName || '未知物料'}}</text>
          <text class="material-code" wx:if="{{item.materialCode}}">{{item.materialCode}}</text>
        </view>
        <text class="tag {{item.statusTagClass}}">{{item.statusLabel}}</text>
      </view>

      <!-- 详情行：2 列网格，订单号跨两列 -->
      <view class="card-body">
        <view class="info-row info-row-full">
          <text class="info-label">订单号</text>
          <text class="info-value">{{item.orderNo || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">数量</text>
          <text class="info-value">{{item.quantityText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">供应商</text>
          <text class="info-value">{{item.supplierText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">{{item.dateLabel}}</text>
          <text class="info-value">{{item.dateText || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">采购员</text>
          <text class="info-value">{{item.buyerText}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="card-footer">
        <view
          wx:if="{{item.isPending}}"
          class="btn-claim"
          data-id="{{item.id}}"
          bindtap="onClaimPurchase"
          hover-class="btn-claim-hover"
          hover-stay-time="100"
        >
          <text>领取采购</text>
          <view class="line-icon icon-arrow-right-sm claim-arrow"></view>
        </view>
        <view
          wx:else
          class="btn-detail"
          data-order-no="{{item.orderNo}}"
          data-style-no="{{item.styleNo}}"
          bindtap="onViewDetail"
          hover-class="btn-detail-hover"
          hover-stay-time="100"
        >
          查看详情
        </view>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="no-more">已显示全部任务</view>
  </block>
  <ai-assistant />
</view>
