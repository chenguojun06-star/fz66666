<view class="container">
  <!-- 跨岗位提示条 -->
  <view wx:if="{{roleHint}}" class="role-hint-bar">
    <text class="role-hint-icon">⚠️</text>
    <text class="role-hint-text">{{roleHint}}</text>
  </view>

  <!-- 状态筛选 Tab -->
  <view class="filter-tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="key"
      class="filter-tab {{activeFilter === item.key ? 'active' : ''}}"
      bindtap="onFilterTap"
      data-key="{{item.key}}"
    >
      <text>{{item.label}}</text>
      <text wx:if="{{item.count > 0}}" class="tab-badge">{{item.count}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading && !filteredGroups.length}}" class="loading-state">
    <text>加载采购任务中…</text>
  </view>

  <!-- 空状态 -->
  <empty-state wx:elif="{{filteredGroups.length === 0}}" iconEmoji="📦" text="暂无数据" hint="下拉刷新试试" card="{{true}}"></empty-state>

  <!-- 任务列表 -->
  <block wx:else>
    <view
      wx:for="{{filteredGroups}}"
      wx:key="orderNo"
      class="task-card"
      data-group="{{item}}"
      bindtap="onGroupTap"
      hover-class="task-card-hover"
    >
      <!-- 主区域：图片 + 规格信息右栏（与样衣开发风格一致） -->
      <view class="card-main">
        <view class="card-cover" catchtap="onCoverPreview" data-url="{{item.styleCoverUrl}}">
          <image wx:if="{{item.styleCoverUrl}}" class="card-cover-img" src="{{item.styleCoverUrl}}" mode="aspectFill" lazy-load="{{true}}" />
          <view wx:else class="card-cover-empty">
            <text class="cover-abbr">📦</text>
          </view>
        </view>

        <view class="card-info">
          <!-- 顶部：订单号 + 状态标签 -->
          <view class="info-top">
            <text class="order-no">{{item.orderNo}}</text>
            <text class="status-tag tag tag-{{item.statusColor}}">{{item.statusText}}</text>
          </view>

          <!-- 规格信息行：款号 + 物料 -->
          <view class="info-spec-row">
            <text class="info-spec-label" wx:if="{{item.styleNo}}">款号</text>
            <text class="info-spec-value" wx:if="{{item.styleNo}}">{{item.styleNo}}</text>
            <text class="info-spec-label">物料</text>
            <text class="info-spec-value highlight">{{item.totalCount}} 项</text>
          </view>

          <!-- 规格信息行：到货率 + 待采购/采购中 -->
          <view class="info-spec-row">
            <text class="info-spec-label">到货率</text>
            <text class="info-spec-value {{item.arrivalRate >= 100 ? 'success' : ''}}">{{item.arrivalRate}}%</text>
            <text class="info-spec-label" wx:if="{{item.pendingCount > 0}}">待采购</text>
            <text class="info-spec-value pending" wx:if="{{item.pendingCount > 0}}">{{item.pendingCount}} 项</text>
            <text class="info-spec-label" wx:if="{{item.receivedCount > 0 && item.pendingCount === 0}}">采购中</text>
            <text class="info-spec-value" wx:if="{{item.receivedCount > 0 && item.pendingCount === 0}}">{{item.receivedCount}} 项</text>
          </view>
        </view>
      </view>

      <!-- 进度条 -->
      <view class="progress-wrapper">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.arrivalRate > 100 ? 100 : item.arrivalRate}}%"></view>
        </view>
      </view>

      <!-- 底部操作 -->
      <view class="card-footer">
        <view wx:if="{{item.canReceive}}" class="btn-action btn-primary" hover-class="btn-primary-hover" hover-stay-time="100" catchtap="onReceive" data-group="{{item}}">
          领取任务
        </view>
        <view wx:elif="{{item.canOperate}}" class="btn-action btn-primary" hover-class="btn-primary-hover" hover-stay-time="100" catchtap="onGroupTap" data-group="{{item}}">
          采购执行
        </view>
        <view wx:else class="btn-action btn-disabled">
          {{item.statusText}}
        </view>
        <view class="btn-action btn-outline" hover-class="btn-outline-hover" hover-stay-time="100" catchtap="onGroupTap" data-group="{{item}}">
          查看详情
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="no-more">已显示全部任务</view>
  </block>
</view>
