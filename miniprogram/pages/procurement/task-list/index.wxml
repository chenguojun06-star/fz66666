<view class="container">
  <!-- 跨岗位提示条 -->
  <view wx:if="{{roleHint}}" class="role-hint-bar">
    <text class="role-hint-icon">⚠️</text>
    <text class="role-hint-text">{{roleHint}}</text>
  </view>

  <!-- 状态筛选 Tab -->
  <view class="filter-tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="key"
      class="filter-tab {{activeStatus === item.key ? 'active' : ''}}"
      bindtap="onTabChange"
      data-key="{{item.key}}"
    >
      <text>{{item.label}}</text>
      <text wx:if="{{item.count > 0}}" class="tab-badge">{{item.count}}</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-box">
      <view class="line-icon line-icon--sm icon-search search-icon"></view>
      <input
        class="search-input"
        placeholder="搜索物料/订单号"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
      />
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading && !filteredGroups.length}}" class="loading-state">
    <text>加载采购页面中…</text>
  </view>

  <!-- 空状态 -->
  <empty-state wx:elif="{{filteredGroups.length === 0}}" icon="icon-box" text="暂无采购任务" hint="当有新的订单分配时，采购任务将出现在这里" card="{{true}}"></empty-state>

  <!-- 订单卡片列表 -->
  <block wx:else>
    <view class="order-list">
      <view
        wx:for="{{filteredGroups}}"
        wx:key="groupKey"
        class="proc-card"
        data-group="{{item}}"
        bindtap="onGroupTap"
        hover-class="proc-card-hover"
      >
        <!-- 顶部：款式图片 + 订单信息 -->
        <view class="proc-card-top">
          <view class="proc-cover" catchtap="onCoverPreview" data-url="{{item.styleCoverUrl}}" data-group="{{item}}">
            <image wx:if="{{item.styleCoverUrl}}" class="proc-cover-img" src="{{item.styleCoverUrl}}" mode="aspectFill" lazy-load="{{true}}" />
          </view>
          <view class="proc-info">
            <view class="proc-info-head">
              <text class="proc-order-no {{item.isSample ? 'proc-sample-no' : ''}}">{{item.displayOrderNo}}</text>
              <text class="status-tag tag tag-{{item.statusColor}}">{{item.statusText}}</text>
            </view>
            <text wx:if="{{item.styleNo}}" class="proc-style-no">{{item.styleNo}}</text>
          </view>
        </view>
        <!-- 详情行 -->
        <view class="proc-details">
          <view class="proc-detail-row">
            <text class="proc-detail-label">物料</text>
            <text class="proc-detail-value highlight">{{item.totalCount}}项</text>
          </view>
          <view class="proc-detail-row">
            <text class="proc-detail-label">到货率</text>
            <text class="proc-detail-value {{item.arrivalRate >= 100 ? 'success' : ''}}">{{item.arrivalRate}}%</text>
          </view>
          <view class="proc-detail-row" wx:if="{{item.pendingCount > 0}}">
            <text class="proc-detail-label">待采购</text>
            <text class="proc-detail-value pending">{{item.pendingCount}}项</text>
          </view>
          <view class="proc-detail-row" wx:if="{{item.receiverName}}">
            <text class="proc-detail-label">领取人</text>
            <text class="proc-detail-value">{{item.receiverName}}</text>
          </view>
        </view>
        <!-- 底部操作按钮 -->
        <view class="proc-action" wx:if="{{item.canReceive}}">
          <view class="proc-btn proc-btn-primary" catchtap="onReceive" data-group="{{item}}">
            <text>领取采购</text>
          </view>
        </view>
        <view class="proc-action proc-action--end" wx:else>
          <view class="proc-btn proc-btn-outline">
            <text>查看详情</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="no-more">已显示全部任务</view>
  </block>
</view>
