<view class="container">
  <!-- 跨岗位提示条 -->
  <view wx:if="{{roleHint}}" class="role-hint-bar">
    <text class="role-hint-icon">⚠️</text>
    <text class="role-hint-text">{{roleHint}}</text>
  </view>

  <!-- 状态筛选 Tab -->
  <view class="filter-tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="key"
      class="filter-tab {{activeStatus === item.key ? 'active' : ''}}"
      bindtap="onTabChange"
      data-key="{{item.key}}"
    >
      <text>{{item.label}}</text>
      <text wx:if="{{item.count > 0}}" class="tab-badge">{{item.count}}</text>
    </view>
  </view>

  <!-- 搜索框（对齐裁剪明细页面 order-list） -->
  <view class="order-search-bar">
    <input
      class="order-search-input"
      placeholder="搜索订单号 / 款号"
      value="{{searchKeyword}}"
      bindinput="onSearchInput"
      confirm-type="search"
      bindconfirm="onSearchConfirm"
    />
    <view class="order-search-icon">
      <text class="icon-search">S</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading && !filteredGroups.length}}" class="loading-state">
    <text>加载采购页面中…</text>
  </view>

  <!-- 空状态 -->
  <empty-state wx:elif="{{filteredGroups.length === 0}}" iconEmoji="📦" text="暂无采购任务" hint="当有新的订单分配时，采购任务将出现在这里" card="{{true}}"></empty-state>

  <!-- 订单卡片列表（对齐裁剪明细页面 order-list 紧凑样式） -->
  <block wx:else>
    <view class="order-list">
      <view
        wx:for="{{filteredGroups}}"
        wx:key="orderNo"
        class="order-sel-card"
        data-group="{{item}}"
        bindtap="onGroupTap"
        hover-class="task-card-hover"
      >
        <!-- 左侧款式缩略图 -->
        <view class="sel-cover-box" catchtap="onCoverPreview" data-url="{{item.styleCoverUrl}}">
          <image wx:if="{{item.styleCoverUrl}}" class="sel-cover-img" src="{{item.styleCoverUrl}}" mode="aspectFill" lazy-load="{{true}}" />
          <view wx:else class="sel-cover-empty">
            <text class="cover-abbr">📦</text>
          </view>
        </view>
        <!-- 右侧双行信息 -->
        <view class="sel-card-info">
          <!-- 顶部：订单号 + 状态标签 -->
          <view class="info-top">
            <text class="order-no">{{item.orderNo}}</text>
            <text class="status-tag tag tag-{{item.statusColor}}">{{item.statusText}}</text>
          </view>
          <!-- 规格行：款号 + 物料 + 到货率 -->
          <view class="info-row">
            <text class="info-label" wx:if="{{item.styleNo}}">款号</text>
            <text class="info-value" wx:if="{{item.styleNo}}">{{item.styleNo}}</text>
            <text class="info-label">物料</text>
            <text class="info-value highlight">{{item.totalCount}}项</text>
          </view>
          <view class="info-row">
            <text class="info-label">到货率</text>
            <text class="info-value {{item.arrivalRate >= 100 ? 'success' : ''}}">{{item.arrivalRate}}%</text>
            <text class="info-label" wx:if="{{item.pendingCount > 0}}">待采购</text>
            <text class="info-value pending" wx:if="{{item.pendingCount > 0}}">{{item.pendingCount}}项</text>
            <text class="info-label" wx:if="{{item.receiverName}}">领取</text>
            <text class="info-value" wx:if="{{item.receiverName}}">{{item.receiverName}}</text>
          </view>
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="no-more">已显示全部任务</view>
  </block>
</view>
