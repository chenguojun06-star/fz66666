<custom-nav title="采购到货" />

<view class="page-container">
  <!-- 订单头 -->
  <view class="order-header">
    <view class="header-row">
      <text class="header-label">订单号</text>
      <text class="header-value">{{orderNo}}</text>
    </view>
    <view class="header-row">
      <text class="header-label">款号</text>
      <text class="header-value">{{styleNo}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrapper" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{materialPurchases.length === 0}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无采购物料</text>
  </view>

  <!-- 物料列表 -->
  <view class="material-list" wx:else>
    <text class="list-title">物料明细（{{materialPurchases.length}}项）</text>

    <view class="material-row {{item.isComplete ? 'row-done' : ''}}"
      wx:for="{{materialPurchases}}" wx:key="id">

      <!-- 主行：名称 + 状态 + 到货/采购 -->
      <view class="row-main">
        <text class="mat-name">{{item.materialName}}</text>
        <text class="status-badge badge-{{item.statusColor}}">{{item.statusText}}</text>
        <text class="mat-qty">{{item.arrivedQuantity}}/{{item.purchaseQuantity}}</text>
      </view>

      <!-- 规格行 -->
      <view class="row-spec" wx:if="{{item.color || item.size || item.specification}}">
        <text class="spec-text" wx:if="{{item.color}}">{{item.color}}</text>
        <text class="spec-sep" wx:if="{{item.color && item.size}}">·</text>
        <text class="spec-text" wx:if="{{item.size}}">{{item.size}}</text>
        <text class="spec-sep" wx:if="{{(item.color || item.size) && item.specification}}">·</text>
        <text class="spec-text" wx:if="{{item.specification}}">{{item.specification}}</text>
      </view>

      <!-- 输入行 -->
      <view class="row-input" wx:if="{{item.isActionable}}">
        <text class="input-label">到货数量</text>
        <input class="input-field" type="digit" placeholder="输入数量"
          data-id="{{item.id || item.purchaseId}}"
          bindinput="onMaterialInput" value="{{item.inputQuantity}}" />
      </view>

      <!-- 待领取提示 -->
      <view class="receive-hint" wx:if="{{item.needsReceive}}">
        <text class="hint-text">⚠ 领取后可登记到货</text>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="remark-section" wx:if="{{materialPurchases.length > 0 && !loading}}">
    <text class="remark-label">备注（到货率＜70%时必填）</text>
    <textarea class="remark-input" placeholder="请输入备注"
      bindinput="onRemarkInput" value="{{remark}}" maxlength="200" />
  </view>
</view>

<!-- 底部操作栏 -->
<view class="bottom-bar" wx:if="{{materialPurchases.length > 0 && !loading}}">
  <view class="btn-receive" bindtap="onReceiveAll">一键领取</view>
  <view class="btn-submit {{(!hasInput || submitting) ? 'btn-disabled' : ''}}"
    bindtap="onSubmit">提交到货</view>
</view>
