/* =====================================================
 * 采购详情页 — 对照设计稿 procurement-detail.html
 * 全部使用 design-tokens CSS 变量，禁止硬编码颜色 / 渐变
 * 卡片：box-shadow + var(--radius-card)，不使用 border
 * ===================================================== */

/* ================ 页面容器 ================ */
.page-container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x) 80px;
}

/* ================ 卡片容器（多卡片布局） ================ */
.detail-body {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding-top: 12px;
}

/* ================ 通用卡片（Apple 风格白卡） ================ */
.detail-card {
  background: var(--color-bg-card);
  
  box-shadow: var(--shadow-card);
  overflow: hidden;
  

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

/* ================ 区块标题 ================ */
.section-title {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ================ 订单头部卡片 ================ */
.header-top {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.order-media {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  overflow: hidden;
  background: var(--color-bg-page);
}

.media-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: var(--color-text-tertiary);
}

.header-title {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-top: 2px;
}

.order-no {
  font-size: var(--font-size-lg-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.style-no {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}

/* 头部状态标签（.tag 全局定义） */
.header-top .tag {
  flex-shrink: 0;
  align-self: flex-start;
}

/* ---- 头部统计摘要 ---- */
.header-summary {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}

.summary-item {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.summary-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.summary-value {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

.summary-primary {
  color: var(--color-primary);
}

.summary-divider {
  width: 1px;
  height: 12px;
  background: var(--color-border);
}

/* ================ 统计概览卡片 ================ */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.stat-item {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.stat-label {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  white-space: nowrap;
}

.stat-value {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

.stat-value-text {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  white-space: nowrap;
}

.stat-primary { color: var(--color-primary); }
.stat-success { color: var(--color-success); }
.stat-warning { color: var(--color-warning); }
.stat-danger  { color: var(--color-danger); }

/* ---- 总进度条 ---- */
.overall-progress {
  margin-top: 12px;
}

.overall-progress-track {
  height: 8px;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.overall-progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

/* ================ 物料到货进度卡片 ================ */
.material-list {
  padding: 16px;
}

.material-item {
  padding: 12px 0;
  border-top: 1px solid var(--color-border);
}

.material-item:first-of-type {
  border-top: none;
  padding-top: 12px;
}

.material-list .section-head {
  margin-bottom: 4px;
}

/* ---- 物料信息行 ---- */
.mat-info {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}

.mat-info-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.mat-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mat-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mat-tags {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 6px;
}

/* ---- 数量统计 4 列 ---- */
.qty-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-top: 12px;
}

.qty-item {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.qty-lbl {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
}

.qty-val {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.qty-pending { color: var(--color-text-secondary); }
.qty-primary { color: var(--color-primary); }

/* ---- 创建/领取/回料信息 ---- */
.mat-meta {
  display: block;
  margin-top: 8px;
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---- 物料进度条 ---- */
.progress-bar {
  margin-top: 8px;
  height: 6px;
  background: var(--color-bg-subtle);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.fill-success {
  background: var(--color-success);
}

/* ---- 到货数量输入 + 确认回料 ---- */
.item-input-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 12px;
}

.input-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  height: 36px;
  padding: 0 12px;
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
}

.input-wrap:focus-within {
  border-color: var(--color-primary);
}

.input-icon {
  font-size: 14px;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: 1.4;
}

.input-placeholder {
  color: var(--color-text-placeholder);
  font-size: var(--font-size-sm);
}

/* 确认回料 — 镂空描边按钮 */
.btn-return-confirm {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 36px;
  padding: 0 12px;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  background: transparent;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  white-space: nowrap;
  flex-shrink: 0;
}

.btn-hover {
  opacity: 0.7;
}

/* ---- 需采购提示 ---- */
.receive-hint {
  margin-top: 8px;
}

.receive-hint text {
  font-size: var(--font-size-2xs);
  color: var(--color-warning);
}

/* ================ 备注卡片 ================ */
.remark-section {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.remark-wrap {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  transition: border-color 0.2s ease;
}

.remark-wrap:focus-within {
  border-color: var(--color-primary);
}

.remark-input {
  width: 100%;
  min-height: 72px;
  padding: 10px 12px;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.remark-placeholder {
  color: var(--color-text-placeholder);
  font-size: var(--font-size-sm);
}

/* ================ 加载状态 ================ */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 0;
}

.loading-spinner {
  width: 28px;
  height: 28px;
  border: 3px solid var(--color-bg-subtle);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 12px;
}

.empty-icon {
  font-size: 32px;
  color: var(--color-text-quaternary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-top: 12px;
}

/* ================ 底部操作栏（3 按钮） ================ */
/* 覆盖全局 .footer-bar 的按钮样式：两枚镂空 + 一枚主色填充 */
.footer-bar {
  display: flex;
  gap: 8px;
}

.footer-bar .btn-outline,
.footer-bar .btn-primary {
  flex: 1;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-sm);
  white-space: nowrap;
}

.footer-bar .btn-outline {
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
}

.footer-bar .btn-primary {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-white);
  background: var(--color-primary);
  border: none;
}

.footer-bar .btn-disabled {
  opacity: 0.4;
  pointer-events: none;
}

.footer-bar-hover {
  opacity: 0.75;
}
