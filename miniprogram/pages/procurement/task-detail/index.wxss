@import '/styles/page-utils.wxss';

.page-container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 30% 0%, rgba(var(--color-primary-rgb, 37,99,235), 0.06), transparent 50%),
              var(--color-bg-base, #f3f4f6);
  padding: 0 24rpx;
  padding-top: 24rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 订单头 */
.order-header {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.order-no-row,
.style-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.style-row { margin-top: 12rpx; }
.order-label {
  font-size: 26rpx;
  color: var(--color-text-tertiary, #9ca3af);
  flex-shrink: 0;
}
.order-value {
  font-size: 28rpx;
  color: var(--color-text-primary, #1f2937);
  font-weight: 600;
}

/* 汇总统计 */
.summary-bar {
  display: flex;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.summary-num {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1f2937);
}
.summary-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #9ca3af);
}
.rate-ok { color: var(--color-success, #22c55e); }
.rate-warn { color: var(--color-warning, #f59e0b); }

/* 加载 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 20rpx;
}
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-border, #e5e7eb);
  border-top-color: var(--color-primary, #2563eb);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary, #9ca3af);
}

/* 物料卡片 */
.material-list { margin-bottom: 20rpx; }
.material-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1rpx solid #e5e7eb;
  transition: opacity 0.2s;
}
.card-done {
  opacity: 0.65;
}

/* 物料卡片内容 */
.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
  display: block;
}
.card-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 12rpx 0;
}
.info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}
.info-label {
  font-size: 28rpx;
  color: #888;
}
.info-value {
  font-size: 28rpx;
  color: #222;
  font-weight: 500;
}

/* 到货输入 */
.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--color-bg-secondary, #f9fafb);
  border-radius: var(--radius-md, 12rpx);
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}
.input-label {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6b7280);
  flex-shrink: 0;
}
.input-field {
  flex: 1;
  height: 64rpx;
  background: var(--color-bg-card, #fff);
  border: 2rpx solid var(--color-border, #e5e7eb);
  border-radius: var(--radius-sm, 8rpx);
  padding: 0 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #1f2937);
  text-align: center;
}
.input-unit {
  font-size: 24rpx;
  color: var(--color-text-tertiary, #9ca3af);
  flex-shrink: 0;
}

/* 领取提示 */
.receive-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(245,158,11,0.08);
  border-radius: var(--radius-sm, 8rpx);
}
.hint-icon { font-size: 28rpx; }
.hint-text {
  font-size: 24rpx;
  color: var(--color-warning, #d97706);
}

/* 备注区 */
.remark-section {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.remark-label {
  font-size: 26rpx;
  color: var(--color-text-secondary, #6b7280);
  margin-bottom: 16rpx;
  display: block;
}
.remark-input {
  width: 100%;
  min-height: 140rpx;
  background: var(--color-bg-secondary, #f9fafb);
  border: 2rpx solid var(--color-border, #e5e7eb);
  border-radius: var(--radius-md, 12rpx);
  padding: 20rpx;
  font-size: 28rpx;
  color: var(--color-text-primary, #1f2937);
  box-sizing: border-box;
}

/* 底部按钮栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card, #fff);
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.btn-receive {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--radius-md, 12rpx);
  font-size: 30rpx;
  font-weight: 600;
  background: var(--color-bg-card, #fff);
  color: var(--color-primary, #2563eb);
  border: 2rpx solid var(--color-primary, #2563eb);
}
.btn-submit {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--radius-md, 12rpx);
  font-size: 30rpx;
  font-weight: 600;
  background: var(--color-primary, #2563eb);
  color: #fff;
  border: none;
}
.btn-disabled {
  opacity: 0.5;
}

/* ── Card header ── */
.card-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.card-title-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
  margin-right: 16rpx;
}

/* ── Status badge ── */
.status-badge {
  font-size: 24rpx;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  font-weight: 500;
  flex-shrink: 0;
}
.badge-orange { background: rgba(245,158,11,0.12); color: #d97706; }
.badge-blue   { background: rgba(59,130,246,0.12);  color: #2563eb; }
.badge-green  { background: rgba(16,185,129,0.12);  color: #059669; }
.badge-gray   { background: #f3f4f6;                color: #6b7280; }

/* ── SKU tag row ── */
.sku-tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.sku-tag {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #f3f4f6;
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
}
.sku-tag-label {
  font-size: 24rpx;
  color: #9ca3af;
  margin-right: 6rpx;
}
.sku-tag-value {
  font-size: 24rpx;
  color: #1f2937;
  font-weight: 600;
}

/* ── Quantity strip ── */
.qty-strip {
  display: flex;
  flex-direction: row;
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx 0;
  margin-bottom: 4rpx;
}
.qty-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.qty-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}
.qty-value-done {
  color: #059669;
}
.qty-label {
  font-size: 22rpx;
  color: #9ca3af;
}
.qty-divider {
  width: 1rpx;
  background: #e5e7eb;
  align-self: stretch;
  margin: 4rpx 0;
}
