/* ===== 采购详情页 · 六段式样式 ===== */

.detail-page {
  min-height: 100vh;
  padding: 8px var(--page-padding-x) calc(env(safe-area-inset-bottom) + 60px);
  background: var(--color-bg-page);
}

/* ===== 加载 / 空状态 ===== */
.loading-wrapper,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.loading-spinner {
  width: 24px;
  height: 24px;
  border: 2px solid var(--color-border-light);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 10px;
}
.empty-icon { font-size: var(--font-size-5xl); opacity: 0.4; }
.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-top: 10px;
}

/* ===== 通用卡片 ===== */
.section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}
.section-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.section-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ===== ① 基础信息卡 ===== */
.header-card { padding-bottom: var(--spacing-md); }
.header-top {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-md);
}
.order-no {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.style-no {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.header-summary {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-top: var(--spacing-xs);
}
.summary-count {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.summary-rate {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ===== ② 数量进度卡 ===== */
.qty-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}
.qty-col {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
}
.qty-num {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1;
}
.qty-done   { color: var(--color-success); }
.qty-remain { color: var(--color-text-secondary); }
.qty-pct    { color: var(--color-primary); }
.qty-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.qty-div {
  width: 1px;
  height: 30px;
  background: var(--color-border-light);
}

.overall-progress-wrap { margin-bottom: var(--spacing-md); }
.overall-progress-bar {
  height: 6px;
  background: var(--color-border-light);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.overall-progress-fill {
  height: 100%;
  background: var(--gradient-progress);
  border-radius: var(--radius-full);
  transition: width 0.3s;
}

/* ===== ③ 操作区 ===== */
.action-section {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  display: flex;
  justify-content: center;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}
.btn-confirm-procurement {
  padding: var(--spacing-sm) var(--spacing-xl);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-white);
  background: var(--color-success);
  border-radius: var(--radius-lg);
  border: none;
}

/* ===== ④ 执行进度区 · 物料列表 ===== */
.material-list {
  display: flex;
  flex-direction: column;
}
.material-item {
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--color-border-light);
}
.material-item:last-child { border-bottom: none; }
.material-item.item-done { opacity: 0.6; }
.material-item.item-confirmed {
  border-color: var(--color-success-border);
  background: var(--color-success-bg);
  border-radius: var(--radius-sm);
  padding-left: var(--spacing-md);
  padding-right: var(--spacing-md);
  margin-top: 3px;
}

.mat-head { margin-bottom: 3px; }
.mat-title {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 5px;
}
.mat-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.mat-meta-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--spacing-md);
  margin-top: 2px;
}
.mat-meta {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.mat-qty-row {
  display: flex;
  align-items: center;
  margin-top: var(--spacing-sm);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) 0;
}
.qty-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  border-left: 1px solid var(--color-border-light);
}
.qty-cell:first-child { border-left: none; }
.qty-lbl {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.qty-val {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.qty-val.arrived { color: var(--color-success); }
.qty-val.pending { color: var(--color-warning); }

.mat-sub-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 3px;
  margin-top: 5px;
}
.mat-sub {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.mat-progress { margin-top: 5px; }
.mat-progress-bar {
  height: 4px;
  background: var(--color-border-light);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.mat-progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}
.mat-progress-fill.fill-confirmed {
  background: var(--color-success);
}

.mat-input-row {
  margin-top: 7px;
}
.mat-input {
  width: 100%;
  height: 36px;
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  border-radius: var(--input-radius);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.mat-action-row {
  margin-top: 6px;
  display: flex;
  justify-content: flex-start;
}
.btn-return-confirm {
  display: inline-block;
  padding: 5px 14px;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-info);
  background: var(--color-info-bg);
  border: 1px solid var(--color-info-border);
  border-radius: var(--radius-sm);
}

.mat-hint { margin-top: 5px; }
.hint-text {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
}

/* ===== ⑤ 备注区 ===== */
.remark-card .remark-input {
  width: 100%;
  min-height: 60px;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm);
  box-sizing: border-box;
}

/* ===== 底部操作栏 ===== */
.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: var(--spacing-xs) var(--page-padding-x) calc(var(--spacing-xs) + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1px solid var(--color-border-light);
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.04);
  z-index: var(--z-dropdown);
}
.footer-bar .btn-secondary,
.footer-bar .btn-submit {
  flex: 1;
  height: var(--btn-height-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  border: none;
}
.footer-bar .btn-secondary {
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  border: 1px solid var(--color-border-light);
}
.footer-bar .btn-submit {
  color: var(--color-text-white);
  background: var(--color-primary);
}
.footer-bar-hover { opacity: 0.85; }
.btn-disabled {
  opacity: 0.45;
  pointer-events: none;
}
