@import '/styles/page-utils.wxss';

.page-container {
  min-height: 100vh;
  background: #f5f6fa;
  padding-bottom: 140rpx;
}

/* ===== 订单头 ===== */
.order-header {
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}
.header-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.header-row:last-child { margin-bottom: 0; }
.header-label {
  font-size: 26rpx;
  color: #999;
  width: 120rpx;
}
.header-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* ===== 加载状态 ===== */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: var(--primary-color, #4285f4);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; }
.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* ===== 物料列表 ===== */
.material-list {
  padding: 24rpx 24rpx 0;
}
.list-title {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 16rpx;
  display: block;
}

/* ===== 物料行 ===== */
.material-row {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
}
.row-done { opacity: 0.55; }

/* 主行：名称 + 状态 + 数量 */
.row-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.mat-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mat-qty {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

/* 状态徽章 */
.status-badge {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  line-height: 1.5;
}
.badge-orange { background: #fff7e6; color: #fa8c16; }
.badge-blue   { background: #e6f7ff; color: #1890ff; }
.badge-green  { background: #f6ffed; color: #52c41a; }
.badge-gray   { background: #f5f5f5; color: #999;    }

/* 规格行 */
.row-spec {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  flex-wrap: wrap;
}
.spec-text {
  font-size: 24rpx;
  color: #999;
}
.spec-sep {
  font-size: 20rpx;
  color: #ccc;
  margin: 0 8rpx;
}

/* 输入行 */
.row-input {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 16rpx;
}
.input-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}
.input-field {
  flex: 1;
  height: 64rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #333;
}

/* 领取提示 */
.receive-hint {
  margin-top: 12rpx;
}
.hint-text {
  font-size: 24rpx;
  color: #fa8c16;
}

/* ===== 备注区 ===== */
.remark-section {
  margin: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}
.remark-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}
.remark-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}
.btn-receive {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  color: var(--primary-color, #4285f4);
  background: #e6f0ff;
  border-radius: 12rpx;
}
.btn-submit {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  background: var(--primary-color, #4285f4);
  border-radius: 12rpx;
}
.btn-disabled {
  opacity: 0.45;
  pointer-events: none;
}
