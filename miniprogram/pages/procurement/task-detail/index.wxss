
.page-container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 160rpx;
}

/* ===== 订单头 ===== */
.order-header {
  background: var(--color-bg-card);
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}
.header-main {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}
.order-no {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.style-no {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.header-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}
.summary-count {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.summary-rate {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}
.header-actions {
  margin-top: 16rpx;
}
.btn-confirm-procurement {
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-white);
  background: var(--color-success);
  border-radius: var(--radius-sm);
}

/* ===== 加载状态 ===== */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-border-light);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 20rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}
.empty-icon { font-size: 80rpx; opacity: 0.4; }
.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-top: 20rpx;
}

/* ===== 物料列表 ===== */
.material-list {
  padding: 16rpx 24rpx 0;
}
.material-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 20rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--color-border-light);
}
.item-done { opacity: 0.5; }
.item-confirmed { border-color: var(--color-success-border); }

.mat-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}
.mat-row + .mat-row {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-border-light);
}
.mat-tag {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: var(--color-info-bg);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-xs);
}
.mat-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.mat-row-qty {
  gap: 0;
}
.qty-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}
.qty-item + .qty-item {
  border-left: 1rpx solid var(--color-border-light);
  padding-left: 16rpx;
}
.qty-val {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.qty-val.arrived { color: var(--color-success); }
.qty-val.pending { color: var(--color-warning); }
.qty-lbl {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

/* 状态标签 */
.status-tag {
  font-size: var(--font-size-xs);
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  line-height: 1.6;
  font-weight: var(--font-weight-medium);
}
.tag-orange { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-blue   { background: var(--color-info-bg); color: var(--color-primary); }
.tag-green  { background: var(--color-success-bg); color: var(--color-success); }
.tag-gray   { background: var(--color-bg-gray); color: var(--color-text-tertiary); }

.confirm-badge {
  font-size: var(--font-size-xs);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  background: var(--color-success-bg);
  color: var(--color-success);
  flex-shrink: 0;
  font-weight: var(--font-weight-medium);
}

/* 进度条 */
.progress-bar {
  margin-top: 10rpx;
  height: 4rpx;
  background: var(--color-border-light);
  border-radius: 4rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}
.fill-confirmed {
  background: var(--color-success);
}

/* 回料确认信息 */
.confirm-info {
  margin-top: 8rpx;
}
.confirm-detail {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* 输入行 */
.item-input {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--color-border-light);
}
.input-field {
  width: 100%;
  height: 64rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  box-sizing: border-box;
}

/* 回料确认按钮 */
.item-confirm-row {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-border-light);
}
.btn-return-confirm {
  display: inline-block;
  padding: 8rpx 24rpx;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: var(--color-info-bg);
  border: 1rpx solid var(--color-info-border);
  border-radius: var(--radius-sm);
}

/* 领取提示 */
.receive-hint {
  margin-top: 10rpx;
}
.receive-hint text {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
}

/* ===== 备注区 ===== */
.remark-section {
  margin: 16rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 20rpx;
  border: 1rpx solid var(--color-border-light);
}
.remark-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 12rpx;
}
.remark-input {
  width: 100%;
  min-height: 100rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  border-radius: var(--radius-sm);
  padding: 16rpx;
  box-sizing: border-box;
}


