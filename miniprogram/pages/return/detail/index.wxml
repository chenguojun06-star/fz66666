<view class="page-bg">
  <block wx:if="{{loading}}">
    <view class="loading-wrap">加载中...</view>
  </block>

  <block wx:elif="{{detail}}">
    <view class="status-card">
      <view class="status-row">
        <text class="status-label">状态</text>
        <text class="status-value" style="color:{{statusColor}};">{{statusLabel}}</text>
      </view>
      <view class="status-row">
        <text class="status-label">退货单号</text>
        <text class="status-value no">{{detail.returnNo}}</text>
      </view>
      <view class="status-row">
        <text class="status-label">退货金额</text>
        <text class="status-value amount">¥{{detail.totalAmount}}</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">基本信息</view>
      <view class="info-card">
        <view class="info-row">
          <text class="info-label">原单号</text>
          <text class="info-value">{{detail.originalNo}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">{{partyLabel}}</text>
          <text class="info-value">{{detail.partyName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">退货类型</text>
          <text class="info-value">{{detail.returnType}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">退货原因</text>
          <text class="info-value">{{detail.returnReason}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">操作人</text>
          <text class="info-value">{{detail.operatorName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">创建时间</text>
          <text class="info-value">{{detail.createTime}}</text>
        </view>
        <view class="info-row" wx:if="{{detail.approveUserName}}">
          <text class="info-label">审核人</text>
          <text class="info-value">{{detail.approveUserName}}</text>
        </view>
        <view class="info-row" wx:if="{{detail.approveTime}}">
          <text class="info-label">审核时间</text>
          <text class="info-value">{{detail.approveTime}}</text>
        </view>
        <view class="info-row" wx:if="{{detail.returnTime}}">
          <text class="info-label">退货时间</text>
          <text class="info-value">{{detail.returnTime}}</text>
        </view>
        <view class="info-row" wx:if="{{detail.refundTime}}">
          <text class="info-label">退款时间</text>
          <text class="info-value">{{detail.refundTime}}</text>
        </view>
        <view class="info-row" wx:if="{{detail.refundAmount}}">
          <text class="info-label">退款金额</text>
          <text class="info-value refund">¥{{detail.refundAmount}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">备注</text>
          <text class="info-value">{{detail.remark}}</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">退货明细（{{items.length}}）</view>
      <view class="items-card">
        <block wx:for="{{items}}" wx:key="idx">
          <view class="item-row">
            <view class="item-header">
              <text class="item-idx">{{item.idx}}</text>
              <text class="item-name">{{item.name}}</text>
            </view>
            <view class="item-meta">
              <text wx:if="{{item.code}}" class="item-code">{{item.code}}</text>
              <text wx:if="{{item.color}}" class="item-tag">{{item.color}}</text>
              <text wx:if="{{item.size}}" class="item-tag">{{item.size}}</text>
            </view>
            <view class="item-qty-row">
              <text class="item-qty">数量: {{item.quantity}}{{item.unit}}</text>
              <text class="item-price">单价: ¥{{item.unitPrice}}</text>
              <text class="item-amount">小计: ¥{{item.amount}}</text>
            </view>
            <view class="item-reason" wx:if="{{item.returnReason}}">原因: {{item.returnReason}}</view>
          </view>
        </block>
      </view>
    </view>

    <view class="action-bar" wx:if="{{canApprove || canComplete || canReject}}">
      <button wx:if="{{canApprove}}" class="btn btn-primary" bindtap="onApprove">审核通过</button>
      <button wx:if="{{canReject}}" class="btn btn-danger" bindtap="onReject">拒绝</button>
      <button wx:if="{{canComplete}}" class="btn btn-primary" bindtap="onComplete">完成退货</button>
    </view>
    <view class="action-bar" wx:elif="{{type === 'sales' && detail.returnStatus === 'APPROVED'}}">
      <button class="btn btn-primary" bindtap="onRefund">标记退款完成</button>
    </view>
  </block>
</view>
