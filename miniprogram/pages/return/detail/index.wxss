.page-bg {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 80px;
}

.loading-wrap {
  text-align: center;
  padding: 60px 0;
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

.status-card {
  background: var(--color-bg-card);
  margin: 12px;
  padding: 16px 14px;
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
}

.status-label {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

.status-value {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
  font-variant-numeric: tabular-nums;
}

.status-value.no {
  font-weight: var(--font-weight-semibold);
}

.status-value.amount {
  color: var(--color-danger);
  font-size: var(--font-size-lg);
}

.section {
  margin: 0 12px 12px;
}

.section-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: 4px 4px 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.info-card,
.items-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 12px 14px;
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.info-row {
  display: flex;
  padding: 7px 0;
  border-bottom: 1px solid var(--color-border-light);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 80px;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  word-break: break-all;
}

.info-value.refund {
  color: var(--color-danger);
  font-weight: var(--font-weight-semibold);
}

.item-row {
  padding: 10px 0;
  border-bottom: 1px solid var(--color-border-light);
}

.item-row:last-child {
  border-bottom: none;
}

.item-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.item-idx {
  width: 20px;
  height: 20px;
  line-height: 20px;
  text-align: center;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-xs);
  border-radius: 50%;
  flex-shrink: 0;
}

.item-name {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  flex: 1;
}

.item-meta {
  display: flex;
  gap: 6px;
  margin-bottom: 6px;
  padding-left: 28px;
}

.item-code {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

.item-tag {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  padding: 2px 7px;
  border-radius: var(--radius-sm);
}

.item-qty-row {
  display: flex;
  justify-content: space-between;
  padding-left: 28px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}

.item-amount {
  color: var(--color-danger);
  font-weight: var(--font-weight-semibold);
}

.item-reason {
  margin-top: 6px;
  padding-left: 28px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 8px;
  padding: 10px 12px calc(10px + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1px solid var(--color-border-light);
  z-index: var(--z-dropdown);
}

.action-bar .btn {
  flex: 1;
  margin: 0;
  padding: 0;
}

.action-bar .btn::after {
  border: none;
}

.action-bar .btn-primary {
  height: var(--btn-height-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
}

.action-bar .btn-danger {
  height: var(--btn-height-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  background: var(--color-danger);
  color: var(--color-text-white);
  border: none;
}

.action-bar .btn-primary[disabled] {
  opacity: 0.5;
}
