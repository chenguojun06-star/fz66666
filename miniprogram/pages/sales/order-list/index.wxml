<!-- 平台订单列表 -->

<view class="page">
  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-box">
      <view class="line-icon line-icon--sm icon-search search-icon"></view>
      <input class="search-input" placeholder="输入订单号/买家名后按搜索" value="{{keyword}}"
             confirm-type="search" bindinput="onSearchInput" bindconfirm="onSearchConfirm" />
      <view wx:if="{{keyword}}" class="search-clear" bindtap="onClearKeyword">
        <view class="icon-close"></view>
      </view>
    </view>
  </view>

  <!-- 平台筛选 Tab（横向滚动） -->
  <scroll-view class="tab-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tab-pill {{activePlatform === item.key ? 'tab-pill--on' : ''}}"
          wx:for="{{platformTabs}}" wx:key="key"
          data-key="{{item.key}}" bindtap="onPlatformTap">
      <text>{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 状态筛选 -->
  <scroll-view class="tab-scroll status-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="status-pill {{activeStatus === item.key ? 'status-pill--on' : ''}}"
          wx:for="{{statusTabs}}" wx:key="key"
          data-key="{{item.key}}" bindtap="onStatusTap">
      <text>{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{list.length > 0}}">
    <view class="order-card" wx:for="{{list}}" wx:key="id" data-idx="{{index}}" bindtap="onOrderTap">
      <!-- 第一行：平台 + 状态 -->
      <view class="oc-head">
        <view class="oc-head-left">
          <text class="oc-platform">{{item.platformName}}</text>
          <text class="oc-prod-no" wx:if="{{item.productionOrderNo}}">已排产</text>
        </view>
        <text class="oc-status {{item.statusCls}}">{{item.status}}</text>
      </view>
      <!-- 平台单号（优先显示） -->
      <view class="oc-no" wx:if="{{item.platformOrderNo}}" data-no="{{item.platformOrderNo}}" catchtap="onCopyOrderNo">
        <text class="oc-no-label">平台单号</text>
        <text class="oc-no-val">{{item.platformOrderNo}}</text>
        <text class="oc-copy">复制</text>
      </view>
      <!-- 内部单号 -->
      <view class="oc-no oc-no--sub" wx:if="{{item.orderNo}}" data-no="{{item.orderNo}}" catchtap="onCopyOrderNo">
        <text class="oc-no-label">内部单号</text>
        <text class="oc-no-val">{{item.orderNo}}</text>
        <text class="oc-copy">复制</text>
      </view>
      <!-- 商品信息 -->
      <view class="oc-row" wx:if="{{item.productText}}">
        <text class="oc-label">商品</text>
        <text class="oc-val oc-product">{{item.productText}}</text>
      </view>
      <!-- 买家 -->
      <view class="oc-row">
        <text class="oc-label">买家</text>
        <text class="oc-val">{{item.buyerName}}</text>
      </view>
      <!-- 金额 -->
      <view class="oc-row">
        <text class="oc-label">实付</text>
        <text class="oc-val oc-amount">¥{{item.amount}}</text>
      </view>
      <!-- 物流 -->
      <view class="oc-row" wx:if="{{item.trackingNo}}">
        <text class="oc-label">物流</text>
        <text class="oc-val">{{item.expressCompany}} {{item.trackingNo}}</text>
      </view>
      <!-- 下单时间 -->
      <view class="oc-row" wx:if="{{item.orderTime}}">
        <text class="oc-label">下单</text>
        <text class="oc-val oc-time">{{item.orderTime}}</text>
      </view>
    </view>
  </view>

  <!-- 加载更多 / 没有更多 -->
  <view wx:if="{{list.length > 0 && hasMore}}" class="load-more">
    <text>{{loadingMore ? '加载中...' : '上拉加载更多'}}</text>
  </view>
  <view wx:if="{{list.length > 0 && !hasMore}}" class="no-more">
    <text>没有更多了</text>
  </view>

  <!-- 骨架屏（首次加载） -->
  <view wx:if="{{loading && list.length === 0}}" class="skeleton-list">
    <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="skeleton-line skeleton-line--short"></view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line skeleton-line--long"></view>
    </view>
  </view>

  <!-- 空状态（区分加载失败） -->
  <view class="empty-state" wx:if="{{!loading && list.length === 0 && !loadError}}">
    <text class="empty-icon icon-order"></text>
    <text class="empty-text">暂无订单</text>
    <text class="empty-hint">切换平台或状态试试</text>
  </view>
  <view class="empty-state" wx:if="{{!loading && list.length === 0 && loadError}}">
    <text class="empty-icon">⚠️</text>
    <text class="empty-text">加载失败</text>
    <text class="empty-hint" bindtap="onRetry">点击重试</text>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
