@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  padding: 0 var(--page-padding-x, 12px) calc(env(safe-area-inset-bottom) + 20px);
  background: var(--color-bg-page);
}

/* ============ 搜索框 + 筛选区（sticky 吸顶，与设计稿对齐） ============ */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 20;
  background: var(--color-bg-page);
  padding: 8px 0 8px;
}

/* ============ 搜索框 ============ */
.search-bar {
  padding: 0;
  margin-bottom: 8px;
}
.search-box {
  height: 36px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  padding: 0 12px;
}
.search-box:focus-within {
  border-color: var(--color-primary);
}
.search-input {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}
.search-icon {
  color: var(--color-text-tertiary);
  margin-right: 8px;
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}
.search-clear {
  color: var(--color-text-tertiary);
  padding: 0 4px;
  display: flex;
  align-items: center;
}
.search-btn-inline {
  color: var(--color-primary);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  padding-left: 12px;
  flex-shrink: 0;
}

/* ============ 平台筛选 Tab ============ */
.tab-scroll {
  white-space: nowrap;
  padding: 0;
  margin-bottom: 8px;
}
.tab-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 0 12px;
  height: 32px;
  line-height: 1;
  margin-right: 8px;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  border: none;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.tab-pill--on {
  background: var(--color-primary);
  color: var(--color-text-white);
  font-weight: var(--font-weight-semibold);
}
.tab-pill-count {
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

/* ============ 状态筛选 ============ */
.status-scroll {
  margin-bottom: 0;
}
.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 0 12px;
  height: 32px;
  line-height: 1;
  margin-right: 8px;
  border-radius: var(--radius-full);
  background: var(--color-bg-muted);
  border: none;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.status-pill--on {
  background: var(--color-primary);
  color: var(--color-text-white);
  font-weight: var(--font-weight-semibold);
}
.status-pill-count {
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

/* ============ 订单卡片 ============ */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 8px 0 0;
}
.order-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
  box-shadow: var(--shadow-sm);
  transition: transform 0.18s ease, background-color 0.18s ease;
}
.order-card:active {
  transform: scale(0.99);
  transition: transform 0.15s ease;
}

/* ============ 卡片头部 ============ */
.oc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.oc-head-left {
  display: flex;
  align-items: center;
  gap: 6px;
}
.oc-platform {
  display: inline-flex;
  align-items: center;
  height: 20px;
  padding: 0 6px;
  border-radius: var(--radius-xs);
  background: var(--color-bg-page);
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  white-space: nowrap;
}
.oc-prod-no {
  display: inline-flex;
  align-items: center;
  height: 20px;
  padding: 0 6px;
  border-radius: var(--radius-xs);
  background: var(--color-primary-bg);
  color: var(--color-primary-dark);
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}
.oc-time {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

/* ============ 单号行 ============ */
.oc-no {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 10px;
  padding: 0;
}
.oc-no-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}
.oc-no-val {
  flex: 1;
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.oc-copy-icon {
  width: 12px;
  height: 12px;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

/* ============ 分隔线 ============ */
.oc-divider {
  height: 1px;
  background: var(--color-border);
  margin: 10px 0;
}

/* ============ 商品信息 ============ */
.oc-product {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* ============ 底部行 ============ */
.oc-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-top: 8px;
}
.oc-buyer {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.oc-amount {
  color: var(--color-primary-dark);
  font-weight: var(--font-weight-semibold);
  font-size: var(--font-size-lg);
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
}

/* ============ 物流行 ============ */
.oc-logistics {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 8px;
}
.oc-logistics-icon {
  width: 14px;
  height: 14px;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}
.oc-logistics-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

/* ============ 加载更多 / 没有更多 ============ */
.load-more {
  text-align: center;
  padding: 16px 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.no-more {
  text-align: center;
  padding: 24px 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ============ 空状态 ============ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 0;
  gap: 8px;
}
.empty-icon {
  width: 48px;
  height: 48px;
  color: var(--color-text-tertiary);
  opacity: 0.3;
}
.empty-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.empty-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ============ 加载态 ============ */
.loading-state {
  text-align: center;
  padding: 24px 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

/* ============ 骨架屏 ============ */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 0;
}
.skeleton-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--card-padding);
  border: 1px solid var(--color-border);
}
.skeleton-line {
  height: 12px;
  background: linear-gradient(90deg, var(--color-bg-page) 25%, var(--color-border) 50%, var(--color-bg-page) 75%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.4s ease infinite;
  border-radius: var(--radius-xs);
  margin-bottom: 8px;
}
.skeleton-line--short { width: 30%; }
.skeleton-line--long  { width: 90%; }
@keyframes skeleton-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
