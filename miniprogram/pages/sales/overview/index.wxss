@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  padding: 0 var(--page-padding-x, 12px) calc(env(safe-area-inset-bottom) + 20px);
  background: var(--color-bg-page);
}

/* ============ 日期范围筛选条 ============ */
.range-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 0;
  white-space: nowrap;
  width: 100%;
}
.range-pill {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 0 16px;
  height: 36px;
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  border: none;
  flex-shrink: 0;
  white-space: nowrap;
}
.range-pill--on {
  background: var(--color-primary);
  color: var(--color-text-white);
  font-weight: 600;
}
.range-date {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  padding: 2px 4px 8px;
  font-variant-numeric: tabular-nums;
}

/* ============ 汇总卡片网格 ============ */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  padding-bottom: 16px;
}
.sum-card {
  background: var(--color-bg-card);
  
  
  box-shadow: var(--shadow-sm);
  border-left: 4px solid var(--color-primary);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.sum-val {
  display: block;
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  line-height: 1.2;
  color: var(--color-text-primary);
  margin-top: 6px;
  font-variant-numeric: tabular-nums;
}
.sum-lbl {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.sum-card--blue   { border-left-color: var(--color-primary); }
.sum-card--green  { border-left-color: var(--color-success); }
.sum-card--orange { border-left-color: var(--color-warning); }
.sum-card--purple { border-left-color: var(--color-purple); }

/* ============ 分区标题 ============ */
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 2px 12px;
}
.section-title {
  font-size: var(--font-size-lg-xl);
  font-weight: 600;
  color: var(--color-text-primary);
}
.section-action {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  display: flex;
  align-items: center;
  gap: 4px;
}

/* ============ 平台卡片 ============ */
.platform-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.platform-card {
  background: var(--color-bg-card);
  
  
  box-shadow: var(--shadow-sm);
  

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.pc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.pc-name {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.pc-count {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}
.pc-divider {
  height: 1px;
  background: var(--color-bg-page);
  margin: var(--spacing-md) 0;
}
.pc-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
}
.pc-col {
  flex: 1;
  min-width: 0;
}
.pc-num {
  display: block;
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  line-height: 1.2;
  margin-top: 2px;
  font-variant-numeric: tabular-nums;
}
.pc-num--blue  { color: var(--color-primary); }
.pc-lbl {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ============ 空状态 / 加载态 ============ */
.loading-state {
  text-align: center;
  padding: 24px 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
