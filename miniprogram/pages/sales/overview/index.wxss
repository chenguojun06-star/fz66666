@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  padding: 0 var(--page-padding-x, 12px) calc(env(safe-area-inset-bottom) + 20px);
  background: var(--color-bg-page);
}

/* ============ 日期范围筛选条 ============ */
.range-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 0;
  flex-wrap: wrap;
}
.range-pill {
  padding: 6px 16px;
  border-radius: var(--radius-full);
  background: var(--color-bg-card);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  border: none;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
}
.range-pill--on {
  background: var(--color-primary);
  color: var(--color-text-white);
  font-weight: 600;
  box-shadow: 0 2px 6px rgba(37, 99, 235, 0.2);
}
.range-date {
  width: 100%;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  padding: 2px 4px;
}

/* ============ 汇总卡片网格 ============ */
.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding-bottom: 16px;
}
.sum-card {
  background: var(--color-bg-card);
  border-radius: 16px;
  padding: 18px 14px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.03);
  border: none;
}
.sum-val {
  display: block;
  font-size: var(--font-size-lg);
  font-weight: 700;
  line-height: 1.2;
  color: var(--color-text-primary);
}
.sum-lbl {
  display: block;
  font-size: 11px;
  color: var(--color-text-secondary);
  margin-top: 5px;
}
.sum-card--blue   .sum-val { color: var(--color-primary); }
.sum-card--green  .sum-val { color: var(--color-success); }
.sum-card--orange .sum-val { color: var(--color-warning); }
.sum-card--purple .sum-val { color: #7c5cfc; }

/* ============ 分区标题 ============ */
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 2px 12px;
}
.section-title {
  font-size: var(--font-size-3xl);
  font-weight: 600;
  color: var(--color-text-primary);
}
.section-action {
  font-size: var(--font-size-lg);
  color: var(--color-primary);
  padding: 4px 12px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-primary);
  background: transparent;
}

/* ============ 平台卡片 ============ */
.platform-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.platform-card {
  background: var(--color-bg-card);
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.03);
  border: none;
}
.pc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 12px;
}
.pc-name {
  font-size: var(--font-size-3xl);
  font-weight: 600;
  color: var(--color-text-primary);
}
.pc-arrow {
  font-size: var(--font-size-4xl);
  color: var(--color-text-tertiary);
}
.pc-body {
  display: flex;
  padding-top: 12px;
  background: var(--color-bg-gray);
  margin: 0 -16px -16px;
  padding: 14px 16px;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
}
.pc-col {
  flex: 1;
  text-align: center;
}
.pc-num {
  display: block;
  font-size: var(--font-size-3xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}
.pc-num--blue  { color: var(--color-primary); }
.pc-num--green { color: var(--color-success); }
.pc-lbl {
  display: block;
  font-size: 11px;
  color: var(--color-text-tertiary);
  margin-top: 4px;
}

/* ============ 空状态 / 加载态 ============ */
.loading-state {
  text-align: center;
  padding: 24px 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
