<!-- 扫码测试页面 - 使用新架构 -->
<view class="scan-test-page">
  <!-- 测试版本标识 -->
  <view class="test-banner">
    <text class="test-icon">🧪</text>
    <text class="test-text">测试版本 {{testVersion}}</text>
    <button class="compare-btn" size="mini" bindtap="onGoToOldVersion">对比旧版</button>
  </view>

  <!-- 工厂信息 -->
  <view class="factory-info" wx:if="{{currentFactory}}">
    <text class="factory-name">{{currentFactory.name}}</text>
    <text class="user-name">{{currentUser.name || '未登录'}}</text>
  </view>

  <!-- 扫码按钮 -->
  <view class="scan-section">
    <button 
      class="scan-button {{scanEnabled ? '' : 'disabled'}}" 
      bindtap="onScanTap"
      disabled="{{!scanEnabled}}"
    >
      <text class="scan-icon">📷</text>
      <text class="scan-text">开始扫码</text>
    </button>

    <!-- 调试按钮 -->
    <button 
      wx:if="{{debugMode}}"
      class="debug-button" 
      bindtap="onDebugScan"
      size="mini"
    >
      🔧 模拟扫码测试
    </button>
  </view>

  <!-- 扫码结果 -->
  <view class="result-section" wx:if="{{lastResult.message}}">
    <view class="result-card {{lastResult.success ? 'success' : 'error'}}">
      <view class="result-header">
        <text class="result-icon">{{lastResult.success ? '✅' : '❌'}}</text>
        <text class="result-message">{{lastResult.message}}</text>
      </view>
      
      <view class="result-details" wx:if="{{lastResult.success}}">
        <view class="detail-item">
          <text class="detail-label">订单号:</text>
          <text class="detail-value">{{lastResult.orderNo}}</text>
        </view>
        <view class="detail-item" wx:if="{{lastResult.styleNo}}">
          <text class="detail-label">款号:</text>
          <text class="detail-value">{{lastResult.styleNo}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">工序:</text>
          <text class="detail-value">{{lastResult.processName}}</text>
        </view>
        <view class="detail-item" wx:if="{{lastResult.quantity}}">
          <text class="detail-label">数量:</text>
          <text class="detail-value">{{lastResult.quantity}}件</text>
        </view>
      </view>

      <!-- 撤销按钮 -->
      <view class="undo-section" wx:if="{{undo.canUndo}}">
        <button 
          class="undo-button {{undo.loading ? 'loading' : ''}}" 
          bindtap="onUndo"
          disabled="{{undo.loading}}"
          size="mini"
        >
          <text wx:if="{{!undo.loading}}">撤销 ({{undo.countdown}}s)</text>
          <text wx:else>撤销中...</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 我的面板 -->
  <view class="my-panel">
    <view class="panel-header">
      <text class="panel-title">今日数据</text>
      <text class="refresh-btn" bindtap="onRefreshMyPanel">🔄</text>
    </view>

    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{myPanel.todayScans}}</text>
        <text class="stat-label">扫码次数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{myPanel.todayQuantity}}</text>
        <text class="stat-label">扫码数量</text>
      </view>
    </view>

    <view class="recent-records" wx:if="{{myPanel.recentRecords.length > 0}}">
      <text class="records-title">最近记录</text>
      <view class="record-item" wx:for="{{myPanel.recentRecords}}" wx:key="index">
        <text class="record-process">{{item.processName}}</text>
        <text class="record-quantity">{{item.quantity}}件</text>
        <text class="record-time">{{item.scanTime}}</text>
      </view>
    </view>
  </view>

  <!-- 提醒列表 -->
  <view class="reminders-section" wx:if="{{reminderCount > 0}}">
    <view class="reminders-header">
      <text class="reminders-title">待处理提醒 ({{reminderCount}})</text>
    </view>
    <view class="reminder-item" 
      wx:for="{{reminders}}" 
      wx:key="id"
      data-index="{{index}}"
      bindtap="onReminderTap"
    >
      <text class="reminder-icon">🔔</text>
      <view class="reminder-content">
        <text class="reminder-order">{{item.orderNo}}</text>
        <text class="reminder-message">{{item.message}}</text>
      </view>
    </view>
  </view>

  <!-- 架构说明 -->
  <view class="architecture-info">
    <text class="arch-title">🏗️ 新架构说明</text>
    <text class="arch-desc">采用三层架构：Page → Handler → Service</text>
    <view class="arch-layers">
      <text class="layer-item">• QRCodeParser: 4种格式解析</text>
      <text class="layer-item">• StageDetector: 智能工序识别</text>
      <text class="layer-item">• ScanHandler: 业务流程编排</text>
    </view>
  </view>
</view>
