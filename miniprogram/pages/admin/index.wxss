page {
  background: var(--color-bg-page);
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

.container {
  min-height: 100vh;
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
}

.user-profile-card {
  margin: 0 0 var(--card-gap-y);
  padding: 14px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(var(--color-primary-rgb), 0.12);
  box-shadow: 0 10px 24px rgba(var(--color-primary-rgb), 0.06);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 12px;
}

.profile-avatar {
  width: 48px;
  height: 48px;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  border: 2px solid rgba(var(--color-primary-rgb), 0.14);
  flex-shrink: 0;
  overflow: hidden;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.profile-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.profile-name {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.logout-btn {
  padding: 4px 12px;
  background: var(--color-error-bg);
  border-radius: var(--radius-md);
}

.logout-btn-hover {
  background: var(--color-error-border);
}

.logout-text {
  font-size: var(--font-size-sm);
  color: var(--color-error);
}

.profile-role {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: 2px 8px;
  background: rgba(245, 247, 250, 0.9);
  border: 1px solid rgba(var(--color-primary-rgb), 0.12);
  border-radius: var(--radius-md);
  align-self: flex-start;
}

.profile-online {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.online-icon {
  opacity: 0.8;
}

/* 功能菜单列表 */
.menu-list {
  margin: 0 0 var(--card-gap-y);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(var(--color-primary-rgb), 0.1);
  box-shadow: 0 10px 24px rgba(var(--color-primary-rgb), 0.05);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--color-border-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background: var(--color-bg-light);
}

.menu-icon-wrap {
  width: 34px;
  height: 34px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.98);
  border: 1px solid rgba(var(--color-primary-rgb), 0.14);
  box-shadow: 0 4px 10px rgba(var(--color-primary-rgb), 0.08);
  margin-right: 12px;
  flex-shrink: 0;
}

.menu-label {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.menu-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-right: 4px;
}

.menu-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-disabled);
  flex-shrink: 0;
}

/* ===== 菜单管理弹窗 ===== */
.mm-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.mm-panel {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: 16px 16px 0 0;
  padding: 20px 16px calc(20px + env(safe-area-inset-bottom));
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.mm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.mm-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.mm-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-light);
}

.mm-close-hover {
  background: var(--color-border-light);
}

.mm-close-text {
  font-size: 16px;
  color: var(--color-text-secondary);
}

.mm-desc {
  font-size: 13px;
  color: var(--color-text-secondary);
  margin-bottom: 16px;
  line-height: 1.5;
}

.mm-list {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.mm-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0;
  border-bottom: 1px solid var(--color-border-light);
}

.mm-item:last-child {
  border-bottom: none;
}

.mm-item-label {
  font-size: 15px;
  color: var(--color-text-primary);
  font-weight: 500;
}

.mm-switch {
  width: 48px;
  height: 28px;
  border-radius: 14px;
  position: relative;
  transition: background 0.2s;
  flex-shrink: 0;
}

.mm-switch-on {
  background: var(--color-primary, #1677ff);
}

.mm-switch-off {
  background: var(--color-border, #d9d9d9);
}

.mm-switch-dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: #ffffff;
  position: absolute;
  top: 3px;
  transition: left 0.2s;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
}

.mm-switch-on .mm-switch-dot {
  left: 23px;
}

.mm-switch-off .mm-switch-dot {
  left: 3px;
}

.mm-footer {
  display: flex;
  gap: 12px;
  margin-top: 20px;
}

.mm-btn {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 500;
}

.mm-btn-hover {
  opacity: 0.8;
}

.mm-btn-cancel {
  background: var(--color-bg-light);
  color: var(--color-text-secondary);
}

.mm-btn-save {
  background: var(--color-primary, #1677ff);
  color: #ffffff;
}

.mm-btn-disabled {
  opacity: 0.5;
}
