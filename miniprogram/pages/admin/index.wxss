page {
  background: var(--color-bg-page);
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

.nav-logout {
  padding: 6px 12px;
  background: var(--color-bg-gray);
  border-radius: 16px;
}

.nav-logout-text {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.title-left-group {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logout-btn {
  padding: 6px 12px;
  background: var(--color-bg-gray);
  border-radius: 16px;
}

.logout-btn-hover {
  background: var(--color-border);
}

.logout-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.title-right-group {
  display: flex;
  align-items: center;
  gap: 8px;
}

/* 通知铃铛 - 与首页保持一致 */
.notification-bell {
  position: relative;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border-radius: 50%;
}

.notification-bell-hover {
  background: var(--color-bg-light);
}

.bell-icon {
  width: 24px;
  height: 24px;
  opacity: 0.6;
}

.bell-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 18px;
  height: 18px;
  padding: 0 4px;
  background: var(--color-error);
  color: var(--color-text-white);
  font-size: var(--font-size-xs);
  font-weight: 600;
  line-height: 18px;
  border-radius: 9px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--color-bg-card);
}

/* 用户信息卡片 - 淡蓝色简洁风格 */
.user-profile-card {
  margin-bottom: 16px;
  padding: 12px 14px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-md);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 12px;
}

.profile-avatar {
  width: 48px;
  height: 48px;
  background: var(--color-bg-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 600;
  color: var(--color-text-primary);
  border: 2px solid var(--color-border);
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.profile-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.profile-name {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.logout-btn {
  padding: 4px 12px;
  background: #fee2e2;
  border-radius: 12px;
}

.logout-btn-hover {
  background: #fecaca;
}

.logout-text {
  font-size: 13px;
  color: var(--color-error);
}

.profile-role {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: 2px 8px;
  background: var(--color-bg-light);
  border-radius: var(--radius-md);
  align-self: flex-start;
}

.profile-online {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.online-icon {
  font-size: var(--font-size-base);
}

.user-info-item {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  background: var(--color-bg-light);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

.user-info-item-hover {
  background: var(--color-bg-light);
}

.user-info-item.disabled {
  opacity: 0.5;
}

.user-info-icon {
  font-size: var(--font-size-base);
  opacity: 0.8;
}

.user-info-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-right: 2px;
}

.user-info-text {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--color-text-primary);
}

/* 功能导航行 */
.nav-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  padding: 8px 12px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.nav-row .user-info-item {
  flex: 1;
  justify-content: center;
}

.system-info {
  margin-bottom: 16px;
  padding: 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
}

.info-label {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.info-value {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}

.permissions-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}

.permission-item {
  padding: 4px 12px;
  background: var(--color-bg-gray);
  border-radius: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
}

.admin-section {
  margin-top: 16px;
}

.admin-card {
  display: flex;
  align-items: center;
  padding: 14px;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-purple) 100%);
  border-radius: var(--radius-sm);
  margin-bottom: 12px;
  position: relative;
  overflow: hidden;
}

.admin-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
}

.admin-card-content {
  flex: 1;
  position: relative;
  z-index: 1;
}

.admin-card-label {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-white);
  margin-bottom: 4px;
}

.admin-card-desc {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.85);
}

.admin-card-badge {
  padding: 2px 8px;
  background: var(--color-error);
  color: var(--color-text-white);
  font-size: var(--font-size-sm);
  font-weight: 600;
  border-radius: 10px;
  margin-right: 8px;
  position: relative;
  z-index: 1;
}

.admin-card-arrow {
  font-size: var(--font-size-xl);
  color: rgba(255, 255, 255, 0.9);
  position: relative;
  z-index: 1;
}

.actions {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
}

.actions .btn-secondary,
.actions .btn-primary {
  border-radius: var(--radius-full);
  padding: 10px 18px;
  text-align: center;
  font-size: var(--font-size-base);
  min-height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  margin-top: 10px;
  font-size: var(--font-size-lg); /* 二级标题 */
  font-weight: 600;
  color: var(--color-text-primary);
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-top: 8px;
}

.stat-card {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 12px 8px;
  background: var(--color-bg-card);
  text-align: center;
  box-shadow: var(--shadow-md);
  transition: background 0.15s;
}

.stat-card-hover {
  background: var(--color-bg-light);
  transform: scale(0.97);
}

.stat-value {
  font-size: var(--font-size-2xl); /* 正文字体 */
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 4px;
}

.stat-label {
  font-size: var(--font-size-xs); /* 辅助字体 */
  color: var(--color-text-secondary);
  font-weight: 500;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: var(--font-size-base); /* 正文字体 */
  font-weight: 600;
}

.item-sub {
  display: block;
  width: 100%;
  margin-top: 6px;
  font-size: var(--font-size-sm); /* 辅助字体 */
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.item-fields {
  -webkit-overflow-scrolling: touch;
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 6px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  white-space: nowrap;
  overflow-x: auto;
}

.item-field {
  flex-shrink: 0;
}

.salary-card {
  margin-top: 10px;
  padding: 12px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  background: var(--color-bg-card);
}

.salary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.salary-label {
  font-size: var(--font-size-sm); /* 辅助字体 */
  color: var(--color-text-secondary);
}

.salary-value {
  font-size: var(--font-size-base); /* 正文字体 */
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ========== 修改密码 ========== */
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  cursor: pointer;
}

.action-row-label {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.action-row-arrow {
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

/* ========== 双列操作卡片 ========== */
.action-row-pair {
  display: flex;
  gap: 12rpx;
  margin: 10rpx 0 6rpx;
}

.action-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx 12rpx;
  background: var(--color-bg-card);
  border-radius: 12rpx;
  border: 1rpx solid var(--color-border);
  gap: 4rpx;
}

.action-card--active {
  background: rgba(37, 99, 235, 0.06);
  border-color: rgba(37, 99, 235, 0.3);
}

.action-card-emoji {
  font-size: 30rpx;
  line-height: 1;
}

.action-card-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: 500;
}

.action-card-arrow {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.change-pwd-panel {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-top: 16rpx;
  border: 1rpx solid var(--color-border);
}

.change-pwd-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.change-pwd-field {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.field-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.field-input {
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.change-pwd-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.pwd-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 10rpx;
  background: var(--color-bg-page);
  border: 1rpx solid var(--color-border);
  color: var(--color-text-secondary);
  font-size: var(--font-size-base);
}

.pwd-btn-confirm {
  flex: 2;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 10rpx;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-base);
  font-weight: 600;
}

.pwd-btn-confirm.disabled {
  opacity: 0.5;
}
/* ========== 邀请员工卡片 ========== */
.invite-card {
  margin: 16rpx 0;
  padding: 28rpx 24rpx;
  background: var(--color-bg-card, #f8f9ff);
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
}

.invite-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.invite-icon {
  font-size: 34rpx;
}

.invite-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary, #888);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.invite-code-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.invite-code {
  flex: 1;
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  color: var(--color-primary);
  background: var(--color-bg-light);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  text-align: center;
}

.invite-copy-btn {
  padding: 16rpx 24rpx;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.invite-link-row {
  padding: 14rpx 16rpx;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 10rpx;
  text-align: center;
}

.invite-link-text {
  font-size: 24rpx;
  color: var(--color-primary);
}

/* ========== 问题反馈 ========== */
.field-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 12rpx 16rpx;
  background: var(--color-bg-gray, #f5f5f5);
  border-radius: 8rpx;
  font-size: var(--font-size-base, 28rpx);
  color: var(--color-text-primary, #1f2937);
  line-height: 1.6;
  box-sizing: border-box;
}

.picker-value {
  color: var(--color-text-primary, #1f2937);
  font-size: var(--font-size-base, 28rpx);
  line-height: 2;
}

.feedback-list {
  padding: 0 4rpx;
  margin-bottom: 16rpx;
}

.feedback-item {
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  background: var(--color-bg-gray, #f5f5f5);
  border-radius: var(--radius-base, 12rpx);
}

.feedback-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.feedback-item-title {
  font-size: var(--font-size-base, 28rpx);
  font-weight: 600;
  color: var(--color-text-primary, #1f2937);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.feedback-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.feedback-status-PENDING {
  background: #fff7ed;
  color: #ea580c;
}

.feedback-status-PROCESSING {
  background: var(--color-bg-light);
  color: var(--color-primary);
}

.feedback-status-RESOLVED {
  background: #f0fdf4;
  color: #16a34a;
}

.feedback-status-CLOSED {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.feedback-item-content {
  font-size: 24rpx;
  color: var(--color-text-secondary, #6b7280);
  line-height: 1.5;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feedback-item-reply {
  font-size: 24rpx;
  color: var(--color-primary);
  background: var(--color-bg-light);
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.reply-label {
  font-weight: 600;
}

.feedback-item-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary, #9ca3af);
}
