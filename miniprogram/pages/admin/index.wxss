page {
  background: #f7f8fa;
}

.container .card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 12px;
}

.btn-primary {
  border-radius: 999px;
  padding: 10px 14px;
  font-size: 14px; /* 按钮字体 */
}

.section-title {
  margin-top: 10px;
  font-size: 14px; /* 三级标题 */
  font-weight: 600;
  color: #1f2937;
}

.actions {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.6);
  color: #1f2937;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
  text-align: center;
  font-size: 14px; /* 按钮字体 */
}

.my-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: 10px;
}

.my-stat {
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 10px 12px;
  background: #ffffff;
}

.my-stat-value {
  font-size: 14px; /* 正文字体 */
  font-weight: 600;
  color: #111827;
}

.my-stat-label {
  font-size: 12px; /* 辅助字体 */
  color: #6b7280;
}

.list-item {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
  margin-top: 10px;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: 14px; /* 正文字体 */
  font-weight: 600;
}

.item-sub {
  display: block;
  width: 100%;
  margin-top: 6px;
  font-size: 12px; /* 辅助字体 */
  color: #374151;
  line-height: 1.5;
}

.salary-card {
  margin-top: 10px;
  padding: 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
}

.salary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.salary-label {
  font-size: 12px; /* 辅助字体 */
  color: #6b7280;
}

.salary-value {
  font-size: 14px; /* 正文字体 */
  font-weight: 600;
  color: #111827;
}

.hint {
  font-size: 11px; /* 备注字体 */
  color: #8b8b94;
}
