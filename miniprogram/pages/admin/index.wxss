page {
  background: var(--color-bg-page);
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

.container {
  min-height: 100vh;
  padding-top: env(safe-area-inset-top);
}

/* 用户信息卡片 */
.user-profile-card {
  margin: 16px;
  padding: 14px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(var(--color-primary-rgb), 0.12);
  box-shadow: 0 10px 24px rgba(var(--color-primary-rgb), 0.06);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 12px;
}

.profile-avatar {
  width: 48px;
  height: 48px;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  border: 2px solid rgba(var(--color-primary-rgb), 0.14);
  flex-shrink: 0;
  overflow: hidden;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.profile-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.profile-name {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.logout-btn {
  padding: 4px 12px;
  background: var(--color-error-bg);
  border-radius: var(--radius-md);
}

.logout-btn-hover {
  background: var(--color-error-border);
}

.logout-text {
  font-size: var(--font-size-sm);
  color: var(--color-error);
}

.profile-role {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: 2px 8px;
  background: rgba(245, 247, 250, 0.9);
  border: 1px solid rgba(var(--color-primary-rgb), 0.12);
  border-radius: var(--radius-md);
  align-self: flex-start;
}

.profile-online {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.online-icon {
  opacity: 0.8;
}

/* 功能菜单列表 */
.menu-list {
  margin: 0 16px 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid rgba(var(--color-primary-rgb), 0.1);
  box-shadow: 0 10px 24px rgba(var(--color-primary-rgb), 0.05);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--color-border-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background: var(--color-bg-light);
}

.menu-icon-wrap {
  width: 34px;
  height: 34px;
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.98);
  border: 1px solid rgba(var(--color-primary-rgb), 0.14);
  box-shadow: 0 4px 10px rgba(var(--color-primary-rgb), 0.08);
  margin-right: 12px;
  flex-shrink: 0;
}

.menu-label {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.menu-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-right: 4px;
}

.menu-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: #ff3b30;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-disabled);
  flex-shrink: 0;
}

