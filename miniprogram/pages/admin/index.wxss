page {
  background: var(--color-bg-page);
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

.container {
  min-height: 100vh;
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
}

.user-profile-card {
  margin: 0 0 var(--card-gap);
  padding: var(--spacing-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-primary-border);
  box-shadow: 0 10px 24px rgba(var(--color-primary-rgb), 0.06);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.profile-avatar {
  width: 48px;
  height: 48px;
  background: rgba(255, 255, 255, 0.98);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  border: 2px solid var(--color-primary-border);
  flex-shrink: 0;
  overflow: hidden;
}

.profile-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.profile-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
}

.profile-name {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.logout-btn {
  padding: 8px 14px;
  min-height: 32px;
  background: rgba(239, 68, 68, 0.08);
  border-radius: var(--radius-full);
  border: 1px solid rgba(239, 68, 68, 0.2);
  transition: all 0.2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn-hover {
  background: rgba(239, 68, 68, 0.15);
  border-color: rgba(239, 68, 68, 0.3);
}

.logout-text {
  font-size: var(--font-size-sm);
  color: var(--color-danger);
}

.profile-role {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  padding: 2px var(--spacing-sm);
  background: var(--color-bg-light);
  border: 1px solid var(--color-primary-border);
  border-radius: var(--radius-md);
  align-self: flex-start;
}

.profile-online {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.online-icon {
  opacity: 0.8;
}

.menu-list {
  margin: 0 0 var(--card-gap);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-primary-border);
  box-shadow: 0 10px 24px rgba(var(--color-primary-rgb), 0.05);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-lg);
  border-bottom: 1px solid var(--color-border-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background: var(--color-bg-light);
}

.menu-icon-wrap {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary-bg), rgba(255, 255, 255, 0.98));
  border: 1px solid var(--color-primary-border);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.1);
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.menu-label {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.menu-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-right: var(--spacing-xs);
}

.menu-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-disabled);
  flex-shrink: 0;
  font-weight: 300;
}

.mm-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-overlay);
  z-index: var(--z-notification);
}

.mm-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: var(--spacing-lg) var(--page-padding-x) calc(var(--spacing-lg) + env(safe-area-inset-bottom));
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  z-index: var(--z-notification);
}

.mm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.mm-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.mm-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--color-bg-light);
}

.mm-close-hover {
  background: var(--color-border-light);
}

.mm-close-text {
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
}

.mm-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
  line-height: var(--line-height-medium);
}

.mm-scroll {
  flex: 1;
  max-height: 55vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.mm-role-group {
  margin-bottom: var(--spacing-md);
}

.mm-role-header {
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-light);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-xs);
}

.mm-role-label {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.mm-list {
  overflow-y: auto;
}

.mm-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--color-border-light);
}

.mm-item:last-child {
  border-bottom: none;
}

.mm-item-label {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.mm-switch {
  width: 48px;
  height: 28px;
  border-radius: var(--radius-full);
  position: relative;
  transition: background 0.2s;
  flex-shrink: 0;
}

.mm-switch-on {
  background: var(--color-primary);
}

.mm-switch-off {
  background: var(--color-border);
}

.mm-switch-dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--color-bg-card);
  position: absolute;
  top: 3px;
  transition: left 0.2s;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15);
}

.mm-switch-on .mm-switch-dot {
  left: 23px;
}

.mm-switch-off .mm-switch-dot {
  left: 3px;
}

.mm-footer {
  display: flex;
  gap: var(--spacing-md);
  margin-top: var(--spacing-lg);
}

.mm-btn {
  flex: 1;
  height: var(--btn-height-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
}

.mm-btn-hover {
  opacity: 0.8;
}

.mm-btn-cancel {
  background: var(--color-bg-light);
  color: var(--color-text-secondary);
}

.mm-btn-save {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

.mm-btn-disabled {
  opacity: 0.5;
}
