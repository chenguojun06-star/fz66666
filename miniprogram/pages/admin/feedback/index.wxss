@import '/styles/design-tokens.wxss';
@import '/styles/modal-form.wxss';

.container {
  min-height: 100vh;
  background: var(--bg-page);
  padding-top: env(safe-area-inset-top);
}

.tab-bar {
  display: flex;
  margin: 12px 16px 0;
  background: var(--bg-card);
  border-radius: var(--radius-sm);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.tab-item {
  flex: 1;
  text-align: center;
  height: 40px;
  line-height: 40px;
  font-size: var(--font-md);
  color: var(--text-secondary);
  font-weight: var(--weight-medium);
  transition: all 0.2s;
}

.tab-item.active {
  color: var(--text-white);
  background: var(--primary);
  font-weight: var(--weight-semibold);
}

.form-card {
  margin: 12px 16px;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 20px 16px;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: var(--weight-medium);
}

.form-input {
  height: 44px;
  line-height: 44px;
  padding: 0 12px;
  background: var(--bg-light);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-base);
  font-size: var(--font-base);
  color: var(--text-primary);
}

.form-textarea {
  min-height: 100px;
  padding: 10px 12px;
  background: var(--bg-light);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-base);
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.6;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 12px;
  background: var(--bg-light);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-base);
}

.picker-text {
  font-size: var(--font-base);
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 18px;
  color: var(--text-disabled);
}

.form-actions {
  margin-top: 8px;
}

.btn-submit {
  width: 100%;
  height: 44px;
  line-height: 44px;
  text-align: center;
  background: var(--primary);
  color: var(--text-white);
  font-size: var(--font-base);
  font-weight: var(--weight-semibold);
  border-radius: var(--radius-sm);
  transition: opacity 0.2s;
}

.btn-submit:active {
  opacity: 0.85;
}

.btn-submit.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.feedback-list {
  padding: 12px 16px;
}

.feedback-item {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 14px;
  margin-bottom: 10px;
  box-shadow: var(--shadow-sm);
}

.feedback-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.feedback-title {
  font-size: var(--font-base);
  font-weight: var(--weight-semibold);
  color: var(--text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feedback-status {
  font-size: var(--font-xs);
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-weight: var(--weight-medium);
  flex-shrink: 0;
  margin-left: 8px;
}

.status-PENDING {
  background: #fef3c7;
  color: #92400e;
}

.status-PROCESSING {
  background: #dbeafe;
  color: #1e40af;
}

.status-RESOLVED {
  background: #d1fae5;
  color: #065f46;
}

.status-CLOSED {
  background: var(--bg-gray);
  color: var(--text-secondary);
}

.feedback-content {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feedback-reply {
  background: var(--bg-light);
  border-radius: var(--radius-sm);
  padding: 8px 10px;
  margin-bottom: 8px;
}

.reply-label {
  font-size: var(--font-xs);
  color: var(--primary);
  font-weight: var(--weight-semibold);
}

.reply-content {
  font-size: var(--font-xs);
  color: var(--text-primary);
  line-height: 1.5;
}

.feedback-time {
  font-size: var(--font-xs);
  color: var(--text-disabled);
}
