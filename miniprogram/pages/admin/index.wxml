<view class="container">
  <custom-nav title="我的" show-search="{{false}}" />

  <!-- 用户信息卡 -->
  <view wx:if="{{userInfo}}" class="user-profile-card">
    <view class="profile-header">
      <view class="profile-avatar">
        <image wx:if="{{avatarImgUrl}}" src="{{avatarImgUrl}}" mode="aspectFill" style="width:100%;height:100%;border-radius:50%;display:block;" binderror="onAvatarError" />
        <text wx:else>{{avatarLetter}}</text>
      </view>
      <view class="profile-info">
        <view class="profile-name-row">
          <text class="profile-name">{{userInfo.name || userInfo.username || '未知用户'}}</text>
          <view class="logout-btn" hover-class="logout-btn-hover" hover-stay-time="100" bindtap="onLogout">
            <text class="logout-text">退出</text>
          </view>
        </view>
        <view class="profile-role">{{roleDisplayName || '普通用户'}}</view>
        <view wx:if="{{showApprovalEntry}}" class="profile-online">
          <text class="online-icon">👥</text>
          <text>{{onlineCount}}人</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" hover-class="menu-item-hover" data-url="/pages/admin/change-password/index" bindtap="onNavTo">
      <text class="menu-icon">🔒</text>
      <text class="menu-label">修改密码</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" hover-class="menu-item-hover" data-url="/pages/payroll/payroll" bindtap="onNavTo">
      <text class="menu-icon">💰</text>
      <text class="menu-label">工资查询</text>
      <text class="menu-arrow">›</text>
    </view>
    <view wx:if="{{showInviteSection}}" class="menu-item" hover-class="menu-item-hover" data-url="/pages/admin/invite/index" bindtap="onNavTo">
      <text class="menu-icon">👥</text>
      <text class="menu-label">邀请员工</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" hover-class="menu-item-hover" data-url="/pages/admin/feedback/index" bindtap="onNavTo">
      <text class="menu-icon">📝</text>
      <text class="menu-label">问题反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view wx:if="{{showApprovalEntry}}" class="menu-item" hover-class="menu-item-hover" data-url="/pkg-admin-notification/pages/index/index" bindtap="onNavTo">
      <text class="menu-icon">🔔</text>
      <text class="menu-label">消息通知</text>
      <text class="menu-arrow">›</text>
    </view>
    <view wx:if="{{showApprovalEntry}}" class="menu-item" hover-class="menu-item-hover" data-url="/pkg-admin-approval/pages/index/index" bindtap="onNavTo">
      <text class="menu-icon">✅</text>
      <text class="menu-label">用户审批</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" hover-class="menu-item-hover" bindtap="onLanguageSwitchTap">
      <text class="menu-icon">🌐</text>
      <text class="menu-label">切换语言</text>
      <text class="menu-value">{{currentLanguageName || '中文'}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>云裳智立链 v2.0</text>
  </view>
</view>

<!-- 小云 AI 助手（全页面悬浮） -->
<ai-assistant />
