@import '../../../styles/inline-selector.wxss';
@import '../../../styles/page-utils.wxss';
@import '../../../styles/modal-form.wxss';

.container {
  min-height: 100vh;
  background: var(--color-bg-light);
  padding: 10px;
}

.notification-header {
  display: flex;
  align-items: center;
  padding: 15px 10px;
  background: var(--color-bg-card);
  border-radius: 8px;
  margin-bottom: 10px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
}

.notification-icon {
  font-size: 24px;
  margin-right: 10px;
}

.notification-title {
  flex: 1;
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.notification-count {
  background: var(--color-error);
  color: var(--color-text-white);
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
}

.loading,
.empty {
  text-align: center;
  padding: 50px 10px;
  color: var(--color-text-disabled);
  font-size: 14px;
}

/* empty-icon / empty-text → page-utils.wxss */

.user-list {
  padding-bottom: 10px;
}

.user-card {
  background: var(--color-bg-card);
  border-radius: 8px;
  margin-bottom: 10px;
  padding: 12px;
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
}

.user-header {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.user-avatar {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-purple) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  margin-right: 10px;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4px;
}

.user-meta {
  font-size: 12px;
  color: var(--color-text-disabled);
}

.user-badge {
  background: var(--color-primary);
  color: var(--color-text-white);
  padding: 3px 8px;
  border-radius: 3px;
  font-size: 11px;
}

.user-details {
  border-top: 1px solid var(--color-bg-light);
  padding-top: 10px;
  margin-bottom: 10px;
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 6px 0;
}

.detail-label {
  width: 70px;
  color: var(--color-text-secondary);
  font-size: 13px;
}

.detail-value {
  flex: 1;
  color: var(--color-text-primary);
  font-size: 13px;
}

.user-actions {
  display: flex;
  gap: 10px;
  border-top: 1px solid var(--color-bg-light);
  padding-top: 10px;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 10px;
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
}

.reject-btn {
  background: var(--color-bg-card);
  color: var(--color-error);
  border: 1px solid var(--color-error);
}

.approve-btn {
  background: var(--color-success);
  color: var(--color-text-white);
}

/* .load-more / .load-more.disabled → page-utils.wxss */

/* 弹窗页面专用样式 */
.modal-text {
  font-size: 14px;
  color: var(--color-text-primary);
  margin-bottom: 4px;
}

.highlight {
  color: var(--color-primary);
  font-weight: 600;
}

.modal-hint {
  font-size: 12px;
  color: var(--color-text-disabled);
  margin-bottom: 6px;
}

.modal-hint.danger {
  color: var(--color-error);
}

.required {
  color: var(--color-error);
}
