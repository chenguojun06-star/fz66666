@import '/styles/modal-form.wxss';

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
}

.tab-bar {
  display: flex;
  margin: var(--card-gap-y) 0 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.tab-item {
  flex: 1;
  text-align: center;
  height: 40px;
  line-height: 40px;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
  transition: all 0.2s;
}

.tab-item.active {
  color: var(--color-text-white);
  background: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

.form-card {
  margin: var(--card-gap-y) 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 20px 16px;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.form-input {
  height: 44px;
  line-height: 44px;
  padding: 0 12px;
  background: var(--color-bg-light);
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.form-textarea {
  min-height: 100px;
  padding: 10px 12px;
  background: var(--color-bg-light);
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 12px;
  background: var(--color-bg-light);
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
}

.picker-text {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.picker-arrow {
  font-size: var(--font-size-lg-xl);
  color: var(--color-text-disabled);
}

.form-actions {
  margin-top: 8px;
}

.btn-submit {
  width: 100%;
  height: 44px;
  line-height: 44px;
  text-align: center;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-sm);
  transition: opacity 0.2s;
}

.btn-submit-hover {
  opacity: 0.85;
}

.btn-submit.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.feedback-list {
  padding: var(--card-gap-y) 0;
}

.feedback-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 14px;
  margin-bottom: 10px;
  box-shadow: var(--shadow-sm);
}

.feedback-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.feedback-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feedback-status {
  font-size: var(--font-size-xs);
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
  margin-left: 8px;
}

.feedback-content {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feedback-reply {
  background: var(--color-bg-light);
  border-radius: var(--radius-sm);
  padding: 8px 10px;
  margin-bottom: 8px;
}

.reply-label {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

.reply-content {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  line-height: var(--line-height-medium);
}

.feedback-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}
