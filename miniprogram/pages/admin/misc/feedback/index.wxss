@import '/styles/modal-form.wxss';

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
}

.tab-bar {
  display: flex;
  gap: 4px;
  margin: var(--card-gap-y) 0 0;
  background: var(--color-border);
  border-radius: var(--radius-2xl);
  padding: 4px;
}

.tab-item {
  flex: 1;
  text-align: center;
  height: 36px;
  line-height: 36px;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-xl);
  transition: all 0.2s;
}

.tab-item.active {
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  font-weight: var(--font-weight-semibold);
}

.form-card {
  margin: var(--card-gap-y) 0 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.form-row {
  padding: 14px 16px;
}

.form-row-inner {
  display: flex;
  align-items: center;
  gap: 12px;
}

.form-row-label {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  white-space: nowrap;
}

.form-row-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.form-row-value {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-left: auto;
}

.form-row-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

.form-row-block {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.form-row-block .form-row-label {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.form-row-textarea {
  width: 100%;
  min-height: 80px;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
}

.form-char-count {
  text-align: right;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.form-divider {
  height: 1px;
  background: var(--color-border);
  margin-left: 16px;
}

.picker-arrow {
  font-size: var(--font-size-lg-xl);
  color: var(--color-text-disabled);
}

.form-actions {
  margin-top: 16px;
}

.btn-submit {
  width: 100%;
  text-align: center;
  padding: 14px 0;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
}

.btn-submit-hover {
  opacity: 0.85;
}

.btn-submit.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.feedback-list {
  padding: var(--card-gap-y) 0;
}

.feedback-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}

.feedback-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.feedback-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feedback-status {
  font-size: var(--font-size-2xs);
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
  margin-left: 8px;
  color: var(--color-text-white);
}
.feedback-status.status-PENDING {
  background: var(--color-warning);
}
.feedback-status.status-REPLIED {
  background: var(--color-success);
}
.feedback-status.status-RESOLVED {
  background: var(--color-success);
}
.feedback-status.status-REJECTED {
  background: var(--color-danger);
}

.feedback-content {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feedback-reply {
    background: var(--color-primary-bg);
    border-radius: var(--radius-lg);
    padding: 10px;
    margin-bottom: 8px;
}

.reply-label {
  font-size: var(--font-size-xs);
  color: var(--color-primary-dark);
  font-weight: var(--font-weight-semibold);
}

.reply-content {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: var(--line-height-medium);
}

.feedback-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
