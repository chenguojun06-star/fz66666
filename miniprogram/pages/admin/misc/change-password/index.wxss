/* 修改密码页：仅使用本地 .form-* / .btn-submit 样式，未引用 mf-* 弹窗样式，
   故无需 @import '/styles/modal-form.wxss'（约 7KB 未使用样式）。 */

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--page-padding-x) var(--page-padding-x) 0;
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
}

.card {
  margin: 0 0 var(--card-gap-y);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 20px 16px;
}

.form-section {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}

.form-input {
  height: 44px;
  line-height: 44px;
  padding: 0 12px;
  background: var(--color-bg-light);
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.form-actions {
  margin-top: 24px;
}

.btn-submit {
  width: 100%;
  height: 44px;
  line-height: 44px;
  text-align: center;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-sm);
  transition: opacity 0.2s;
}

.btn-submit-hover {
  opacity: 0.85;
}

.btn-submit.disabled {
  opacity: 0.5;
  pointer-events: none;
}
