
.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
  padding-bottom: calc(env(safe-area-inset-bottom) + 16px);
}

.qr-section {
  text-align: center;
  padding: 32rpx 0 0;
}

.qr-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 40rpx 32rpx 32rpx;
  box-shadow: var(--shadow-md);
}

.qr-image {
  width: 360rpx;
  display: block;
  margin: 0 auto 24rpx;
  border-radius: var(--radius-md);
}

.qr-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
}

.qr-card-fail {
  padding: 80rpx 32rpx;
}

.qr-fail-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: 24rpx;
}

.retry-btn {
  display: inline-block;
  padding: 10px 28px;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
}

.retry-btn-hover {
  opacity: 0.85;
}

.qr-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.qr-loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--color-border-light);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: qr-spin 0.8s linear infinite;
}

@keyframes qr-spin {
  to { transform: rotate(360deg); }
}

.qr-loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.invite-card {
  margin: 16rpx 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 24px 16px;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 12px;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.code-display {
  flex: 1;
  text-align: center;
  background: var(--color-bg-light);
  border-radius: var(--radius-md);
  padding: 14px;
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  letter-spacing: 4px;
}

.copy-btn {
  height: 44px;
  line-height: 44px;
  text-align: center;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-md);
  padding: 0 20px;
}

.code-row .copy-btn {
  flex-shrink: 0;
}

.copy-btn-hover {
  opacity: 0.85;
}

.copy-link {
  width: 100%;
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

.divider {
  height: 1px;
  background: var(--color-border-light);
  margin: 20px 0;
}

.hint-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 12px;
}

.steps-card {
  margin: 0 0 16rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 16px;
  box-shadow: var(--shadow-sm);
}

.steps-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 14px;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 14px;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-num {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(var(--color-primary-rgb), 0.1);
  color: var(--color-primary);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  padding-top: 2px;
}

.step-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

.share-btn {
  margin: 0 0 16rpx;
  height: 44px;
  line-height: 44px;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-md);
  border: none;
}

.share-btn::after {
  border: none;
}

.button-hover {
  opacity: 0.85;
}
