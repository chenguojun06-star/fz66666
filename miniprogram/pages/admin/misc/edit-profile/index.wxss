page {
  background: var(--color-bg-page);
}

.container {
  min-height: 100vh;
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 40vh;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 12px;
  font-size: 14px;
  color: var(--color-text-tertiary);
}

.content {
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
}

/* ===== 头像区域 ===== */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0 16px;
}

.avatar-wrap {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-wrap-hover {
  opacity: 0.85;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.avatar-letter {
  font-size: 32px;
  font-weight: 700;
  color: #fff;
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--color-bg-card);
  border: 2px solid var(--color-border-lighter);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-icon {
  font-size: 14px;
  color: var(--color-primary);
  line-height: 1;
}

.avatar-tip {
  margin-top: 8px;
  font-size: 12px;
  color: var(--color-text-tertiary);
}

/* ===== 表单卡片 ===== */
.form-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 0 16px;
  box-shadow: var(--shadow-sm);
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 52px;
  padding: 8px 0;
}

.form-row + .form-row {
  border-top: 1px solid var(--color-border-lighter);
}

.form-label {
  font-size: 14px;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  width: 72px;
}

.form-value {
  font-size: 14px;
  color: var(--color-text-primary);
  text-align: right;
  flex: 1;
}

.form-value--readonly {
  color: var(--color-text-tertiary);
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 14px;
  color: var(--color-text-primary);
  height: 40px;
}

/* ===== 提示 ===== */
.hint-card {
  padding: 12px 4px;
}

.hint-text {
  font-size: 12px;
  color: var(--color-text-quaternary);
}

/* ===== 保存按钮 ===== */
.btn-section {
  margin-top: 24px;
  padding: 0 16px;
}

.save-btn {
  background: var(--color-primary);
  border-radius: var(--radius-2xl);
  padding: 14px;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.save-btn-hover {
  opacity: 0.9;
}

.save-btn--disabled {
  opacity: 0.5;
}

.save-btn-text {
  font-size: 16px;
  font-weight: 500;
  color: #fff;
}
