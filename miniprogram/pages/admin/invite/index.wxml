<view class="container">
  <custom-nav title="邀请员工" />

  <view class="invite-card">
    <view class="section-title">工厂邀请码</view>
    <view class="code-display">{{tenantCode || '--'}}</view>
    <view class="copy-btn" bindtap="onCopyTenantCode">复制工厂码</view>

    <view class="divider"></view>

    <view class="section-title">PC端注册链接</view>
    <view class="hint-text">员工可通过此链接在电脑端注册账号</view>
    <view class="copy-btn copy-link" bindtap="onCopyInviteUrl">复制注册链接</view>
  </view>

  <view class="tips-card">
    <view class="tips-title">使用说明</view>
    <view class="tips-item">1. 将工厂邀请码发送给新员工</view>
    <view class="tips-item">2. 新员工在注册时输入邀请码即可加入</view>
    <view class="tips-item">3. 管理员可在用户审批中查看待审核成员</view>
  </view>
</view>
