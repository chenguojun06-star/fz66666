<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <icon type="search" size="14" color="#999" />
      <input
        class="search-input"
        placeholder="搜索款号/款名"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        bindconfirm="onSearch"
      />
    </view>
  </view>

  <view class="filter-row">
    <picker mode="selector" range="{{departmentOptions}}" range-key="label" value="{{selectedDepartmentIndex}}" bindchange="onDepartmentFilterChange">
      <view class="filter-pill">
        <text class="filter-pill-label">部门</text>
        <text class="filter-pill-value">{{departmentOptions[selectedDepartmentIndex].label}}</text>
      </view>
    </picker>
    <picker mode="selector" range="{{factoryTypeOptions}}" range-key="label" value="{{selectedFactoryTypeIndex}}" bindchange="onFactoryTypeFilterChange">
      <view class="filter-pill">
        <text class="filter-pill-label">标签</text>
        <text class="filter-pill-value">{{factoryTypeOptions[selectedFactoryTypeIndex].label}}</text>
      </view>
    </picker>
  </view>

  <!-- 统计栏 -->
  <view class="summary-filter-bar">
    <view class="summary-pill summary-pill-active">
      <text class="summary-label">成品总数</text>
      <text class="summary-value">{{stats.totalQty}}</text>
    </view>
    <view class="summary-pill">
      <text class="summary-label">可用库存</text>
      <text class="summary-value green">{{stats.availableQty}}</text>
    </view>
    <view class="summary-pill">
      <text class="summary-label">次品</text>
      <text class="summary-value {{stats.defectQty > 0 ? 'red' : ''}}">{{stats.defectQty}}</text>
    </view>
  </view>

  <!-- 列表内容 -->
  <scroll-view
    scroll-y
    class="list-container"
    bindscrolltolower="onLoadMore"
    refresher-enabled
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <block wx:if="{{list.length > 0}}">
      <view class="wc-card" wx:for="{{list}}" wx:key="id">
        <!-- 图片 -->
        <image wx:if="{{item.imageUrl}}" class="wc-img" src="{{item.imageUrl}}" mode="aspectFill" data-index="{{index}}" binderror="onImageError" />
        <view wx:else class="wc-img-placeholder">
          <text>暂无图片</text>
        </view>

        <!-- 信息区 -->
        <view class="wc-content">
          <view class="wc-head">
            <text class="wc-title" user-select>{{item.styleNo}}</text>
            <view class="wc-op-row">
              <view class="wc-op-btn wc-op-btn-primary" bindtap="openOutstockModal" data-index="{{index}}">出库</view>
            </view>
          </view>
          <text class="wc-subtitle" user-select>{{item.styleName || '未命名款式'}}</text>
          <view wx:if="{{item.factoryName || item.orgPath || item.factoryType}}" class="wc-meta-row">
            <text class="wc-meta-text">{{item.factoryName || '-'}}</text>
            <text wx:if="{{item.orgPath}}" class="wc-meta-text">{{item.orgPath}}</text>
            <text wx:if="{{item.factoryType === 'INTERNAL'}}" class="wc-meta-tag wc-meta-tag-internal">内部</text>
            <text wx:if="{{item.factoryType === 'EXTERNAL'}}" class="wc-meta-tag wc-meta-tag-external">外部</text>
          </view>
          <view class="wc-tags-row">
            <text class="wc-tag wc-tag-color" wx:for="{{item.colors}}" wx:key="*this" wx:for-item="c">{{c}}</text>
          </view>
          <view class="wc-tags-row" wx:if="{{item.sizes.length > 0}}">
            <text class="wc-tag wc-tag-size" wx:for="{{item.sizes}}" wx:key="*this" wx:for-item="s">{{s}}</text>
          </view>
          <view class="wc-stock">
            <view class="wc-stock-item">
              <text class="wc-stock-label">可用</text>
              <text class="wc-stock-val green">{{item.availableQty}}</text>
              <text class="wc-stock-unit">件</text>
            </view>
            <view class="wc-stock-item">
              <text class="wc-stock-label">锁定</text>
              <text class="wc-stock-val orange">{{item.lockedQty}}</text>
              <text class="wc-stock-unit">件</text>
            </view>
            <view class="wc-stock-item">
              <text class="wc-stock-label">次品</text>
              <text class="wc-stock-val red">{{item.defectQty}}</text>
              <text class="wc-stock-unit">件</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:elif="{{!loading}}" class="empty-state">
      <image src="/assets/icons/empty.svg" mode="widthFix" class="empty-img" />
      <text>暂无成品库存数据</text>
    </view>

    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>

  <!-- 出库弹窗 —— mp-modal 通用组件 -->
  <mp-modal
    visible="{{modal.visible}}"
    title="成品出库 - 多尺码明细"
    show-close="{{false}}"
  >
    <view class="mf-body" slot="body">
      <!-- 基础信息 -->
      <view class="mf-kv-list">
        <view class="mf-kv"><text class="mf-kv-key">款号</text><text class="mf-kv-val">{{modal.order.styleNo || '-'}}</text></view>
        <view class="mf-kv"><text class="mf-kv-key">款式名称</text><text class="mf-kv-val">{{modal.order.styleName || '-'}}</text></view>
        <view class="mf-kv"><text class="mf-kv-key">可用库存</text><text class="mf-kv-val">{{modal.order.availableQty || 0}} 件</text></view>
      </view>

      <view class="scan-toolbar">
        <view class="scan-btn" bindtap="onScanSkuQr">微信扫码定位SKU</view>
        <text class="scan-tip">扫 U 编码后自动定位颜色/码数，并默认加 1 件</text>
      </view>

      <view wx:if="{{modal.lastScannedSku}}" class="scan-result-card">
        <view class="scan-result-title">最近扫码</view>
        <view class="scan-result-row">
          <text class="scan-result-main">{{modal.lastScannedSku.color}} / {{modal.lastScannedSku.size}}</text>
          <text class="scan-result-stock">库存 {{modal.lastScannedSku.availableQty}}</text>
          <text class="scan-result-stock">出库 {{modal.lastScannedSku.outboundQty}}</text>
        </view>
        <view class="scan-result-code">{{modal.lastScannedQrCode}}</view>
      </view>

      <!-- SKU列表 -->
      <view class="sku-section">
        <view class="section-title">📋 请选择需要出库的颜色和尺码：</view>

        <view wx:if="{{modal.loadingSkus}}" class="loading-skus">
          <text>加载SKU信息中...</text>
        </view>

        <view wx:elif="{{modal.skuList.length > 0}}" class="sku-list">
          <view class="sku-item {{modal.scannedSkuKey === item.sku ? 'sku-item-active' : ''}}" wx:for="{{modal.skuList}}" wx:key="sku">
            <view class="sku-info">
              <view class="sku-header">
                <text class="sku-color">{{item.color}}</text>
                <text class="sku-size">{{item.size}}</text>
              </view>
              <view class="sku-stock">
                <text class="stock-label">可用:</text>
                <text class="stock-value">{{item.availableQty}}</text>
              </view>
            </view>
            <view class="sku-qty-input">
              <input
                class="qty-input"
                type="number"
                placeholder="0"
                value="{{item.outboundQty}}"
                data-index="{{index}}"
                bindinput="onSkuQtyInput"
              />
              <view class="max-btn" data-index="{{index}}" bindtap="onFillMaxQty">MAX</view>
            </view>
          </view>
        </view>

        <view wx:else class="empty-skus">
          <text>该款式暂无可用库存</text>
        </view>
      </view>

      <!-- 汇总信息 -->
      <view class="summary-section">
        <view class="summary-row">
          <text class="summary-label">总出库数量</text>
          <text class="summary-value">{{modal.totalOutbound}} 件</text>
        </view>
      </view>

      <!-- 备注 -->
      <view class="mf-item">
        <text class="mf-label">备注</text>
        <textarea class="mf-textarea" placeholder="选填" value="{{modal.remark}}" bindinput="onModalRemarkInput" />
      </view>
    </view>
    <view class="mf-actions" slot="actions">
      <view class="mf-btn cancel" bindtap="closeOutstockModal">取消</view>
      <view class="mf-btn ok {{modal.submitting || modal.totalOutbound === 0 ? 'disabled' : ''}}" bindtap="onConfirmOutstock">
        {{modal.submitting ? '提交中...' : '确认出库'}}
      </view>
    </view>
  </mp-modal>
</view>
