@import '../../../../styles/modal-form.wxss';
@import '../../../../styles/page-utils.wxss';
@import '../../../../styles/wh-card.wxss';

.container {
  height: 100vh;
  background-color: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 10px;
  background-color: var(--color-bg-card);
}

.filter-row {
  display: flex;
  gap: 8px;
  padding: 0 10px 10px;
  background-color: var(--color-bg-card);
}

.filter-pill {
  min-width: 90px;
  padding: 5px 9px;
  border-radius: var(--radius-full);
  background: var(--color-bg-gray);
  border: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  gap: 5px;
}

.filter-pill-label {
  font-size: 11px;
  color: var(--color-text-disabled);
}

.filter-pill-value {
  font-size: 12px;
  color: var(--color-text-primary);
  font-weight: 600;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-gray);
  border-radius: var(--radius-full);
  padding: 5px 10px;
}

.search-input {
  flex: 1;
  margin-left: 5px;
  font-size: 14px;
}

.summary-filter-bar {
  display: flex;
  padding: 8px 10px;
  gap: 8px;
  background-color: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border-light);
}

.summary-pill {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6px 0;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-gray);
}

.summary-pill-active {
  background-color: var(--color-blue-light);
}

.summary-label {
  font-size: 11px;
  color: var(--color-text-disabled);
}

.summary-value {
  font-size: 16px;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-top: 2px;
}

.wc-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-top: 4px;
}

.wc-meta-text {
  font-size: 11px;
  color: var(--color-text-secondary);
}

.wc-meta-tag {
  padding: 1px 5px;
  border-radius: 500px;
  font-size: 10px;
  font-weight: 600;
}

.wc-meta-tag-internal {
  background: rgba(217, 119, 6, 0.1);
  color: var(--color-warning);
}

.wc-meta-tag-external {
  background: rgba(114, 46, 209, 0.08);
  color: var(--color-purple);
}

.summary-value.green {
  color: var(--color-success);
}

.summary-value.red {
  color: var(--color-error);
}

.list-container {
  flex: 1;
  padding: 10px;
  box-sizing: border-box;
}

/* 旧卡片类名已迁移至 /styles/wh-card.wxss（wc-* 前缀） */

/* empty-state / empty-img / loading-more / no-more → page-utils.wxss */

/* SKU列表样式（页面专用） */
.sku-section {
  margin: 10px 0;
  padding: 8px;
  background-color: var(--color-bg-gray);
  border-radius: 6px;
}

.section-title {
  font-size: 13px;
  color: var(--color-text-primary);
  font-weight: 600;
  margin-bottom: 8px;
}

.loading-skus, .empty-skus {
  text-align: center;
  padding: 20px 0;
  color: var(--color-text-disabled);
  font-size: 12px;
}

.sku-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.scan-toolbar {
  margin: 10px 0 8px;
  padding: 8px;
  border-radius: var(--radius-sm);
  background: rgba(45, 127, 249, 0.08);
  border: 1px solid rgba(45, 127, 249, 0.18);
}

.scan-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 110px;
  height: 30px;
  padding: 0 10px;
  border-radius: 6px;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: 12px;
  font-weight: 600;
}

.scan-tip {
  display: block;
  margin-top: 5px;
  font-size: 11px;
  color: var(--color-text-secondary);
}

.scan-result-card {
  margin-bottom: 8px;
  padding: 8px;
  border-radius: 6px;
  background: rgba(5, 150, 105, 0.08);
  border: 1px solid rgba(5, 150, 105, 0.18);
}

.scan-result-title {
  font-size: 11px;
  color: var(--color-text-secondary);
}

.scan-result-row {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-top: 4px;
  align-items: center;
}

.scan-result-main {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-text-primary);
}

.scan-result-stock {
  font-size: 11px;
  color: var(--color-success);
}

.scan-result-code {
  margin-top: 4px;
  font-size: 10px;
  color: var(--color-text-secondary);
  word-break: break-all;
}

.sku-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-bg-card);
  padding: 6px 8px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
}

.sku-item-active {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 1px rgba(45, 127, 249, 0.12);
}

.sku-info {
  flex: 1;
}

.sku-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 3px;
}

.sku-color {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-primary);
  background-color: var(--color-blue-light);
  padding: 1px 6px;
  border-radius: 2px;
}

.sku-size {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-success);
  background-color: rgba(5, 150, 105, 0.08);
  padding: 1px 6px;
  border-radius: 2px;
}

.sku-stock {
  display: flex;
  align-items: center;
  gap: 4px;
}

.stock-label {
  font-size: 11px;
  color: var(--color-text-disabled);
}

.stock-value {
  font-size: 12px;
  font-weight: 700;
  color: var(--color-success);
}

.sku-qty-input {
  display: flex;
  align-items: center;
  gap: 4px;
}

.qty-input {
  width: 50px;
  height: 28px;
  text-align: center;
  font-size: 13px;
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-sm);
  background-color: var(--color-bg-card);
  font-weight: 600;
  color: var(--color-text-primary);
}

.max-btn {
  min-width: 32px;
  height: 28px;
  line-height: 28px;
  text-align: center;
  border-radius: var(--radius-sm);
  background-color: var(--color-primary);
  color: var(--color-text-white);
  font-size: 10px;
  font-weight: 600;
}

/* 汇总信息 */
.summary-section {
  margin: 10px 0;
  padding: 8px;
  background-color: var(--color-blue-light);
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border-blue);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-label {
  font-size: 13px;
  color: var(--color-text-disabled);
}

.summary-value {
  font-size: 16px;
  font-weight: 700;
  color: var(--color-primary);
}
