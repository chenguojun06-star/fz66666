@import '../../../../styles/modal-form.wxss';
@import '../../../../styles/page-utils.wxss';
@import '../../../../styles/wh-card.wxss';

.container {
  height: 100vh;
  background-color: var(--color-bg-page);
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 20rpx;
  background-color: var(--color-bg-card);
}

.filter-row {
  display: flex;
  gap: 16rpx;
  padding: 0 20rpx 20rpx;
  background-color: var(--color-bg-card);
}

.filter-pill {
  min-width: 180rpx;
  padding: 10rpx 18rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-gray);
  border: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.filter-pill-label {
  font-size: 22rpx;
  color: var(--color-text-disabled);
}

.filter-pill-value {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-gray);
  border-radius: var(--radius-full);
  padding: 10rpx 20rpx;
}

.search-input {
  flex: 1;
  margin-left: 10rpx;
  font-size: 28rpx;
}

.summary-filter-bar {
  display: flex;
  padding: 16rpx 20rpx;
  gap: 16rpx;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border-light);
}

.summary-pill {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: var(--radius-md);
  background-color: var(--color-bg-gray);
}

.summary-pill-active {
  background-color: var(--color-blue-light);
}

.summary-label {
  font-size: 22rpx;
  color: var(--color-text-disabled);
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-top: 4rpx;
}

.wc-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.wc-meta-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.wc-meta-tag {
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.wc-meta-tag-internal {
  background: rgba(217, 119, 6, 0.1);
  color: var(--color-warning);
}

.wc-meta-tag-external {
  background: rgba(114, 46, 209, 0.08);
  color: var(--color-purple);
}

.summary-value.green {
  color: var(--color-success);
}

.summary-value.red {
  color: var(--color-error);
}

.list-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 旧卡片类名已迁移至 /styles/wh-card.wxss（wc-* 前缀） */

/* empty-state / empty-img / loading-more / no-more → page-utils.wxss */

/* SKU列表样式（页面专用） */
.sku-section {
  margin: 20rpx 0;
  padding: 16rpx;
  background-color: var(--color-bg-gray);
  border-radius: 12rpx;
}

.section-title {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  margin-bottom: 16rpx;
}

.loading-skus, .empty-skus {
  text-align: center;
  padding: 40rpx 0;
  color: var(--color-text-disabled);
  font-size: 24rpx;
}

.sku-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sku-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: var(--color-bg-card);
  padding: 12rpx 16rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border);
}

.sku-info {
  flex: 1;
}

.sku-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.sku-color {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
  background-color: var(--color-blue-light);
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.sku-size {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-success);
  background-color: rgba(5, 150, 105, 0.08);
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.sku-stock {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stock-label {
  font-size: 22rpx;
  color: var(--color-text-disabled);
}

.stock-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-success);
}

.sku-qty-input {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-input {
  width: 100rpx;
  height: 56rpx;
  text-align: center;
  font-size: 26rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-sm);
  background-color: var(--color-bg-card);
  font-weight: 600;
  color: var(--color-text-primary);
}

.max-btn {
  min-width: 64rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  background-color: var(--color-primary);
  color: var(--color-text-white);
  font-size: 20rpx;
  font-weight: 600;
}

/* 汇总信息 */
.summary-section {
  margin: 20rpx 0;
  padding: 16rpx;
  background-color: var(--color-blue-light);
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-border-blue);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-label {
  font-size: 26rpx;
  color: var(--color-text-disabled);
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
}
