@import '../../../../styles/modal-form.wxss';
@import '../../../../styles/page-utils.wxss';
@import '../../../../styles/wh-card.wxss';

.container {
  height: 100vh;
  background-color: #f5f6f8;
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 20rpx;
  background-color: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-gray, #f5f5f5);
  border-radius: 36rpx;
  padding: 10rpx 20rpx;
}

.search-input {
  flex: 1;
  margin-left: 10rpx;
  font-size: 28rpx;
}

.summary-filter-bar {
  display: flex;
  padding: 16rpx 20rpx;
  gap: 16rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.summary-pill {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
  background-color: #f8f9fa;
}

.summary-pill-active {
  background-color: #e8f4fd;
}

.summary-label {
  font-size: 22rpx;
  color: #999;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-top: 4rpx;
}

.summary-value.green {
  color: #52c41a;
}

.summary-value.red {
  color: #ff4d4f;
}

.list-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 旧卡片类名已迁移至 /styles/wh-card.wxss（wc-* 前缀） */

/* empty-state / empty-img / loading-more / no-more → page-utils.wxss */

/* SKU列表样式（页面专用） */
.sku-section {
  margin: 20rpx 0;
  padding: 16rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
}

.section-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.loading-skus, .empty-skus {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 24rpx;
}

.sku-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sku-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e5e7eb;
}

.sku-info {
  flex: 1;
}

.sku-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.sku-color {
  font-size: 26rpx;
  font-weight: 600;
  color: #1890ff;
  background-color: #e6f7ff;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.sku-size {
  font-size: 26rpx;
  font-weight: 600;
  color: #52c41a;
  background-color: #f6ffed;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.sku-stock {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stock-label {
  font-size: 22rpx;
  color: #ccc;
}

.stock-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #52c41a;
}

.sku-qty-input {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.qty-input {
  width: 100rpx;
  height: 56rpx;
  text-align: center;
  font-size: 26rpx;
  border: 2rpx solid #1890ff;
  border-radius: 8rpx;
  background-color: #fff;
  font-weight: 600;
  color: #333;
}

.max-btn {
  min-width: 64rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 8rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
}

/* 汇总信息 */
.summary-section {
  margin: 20rpx 0;
  padding: 16rpx;
  background-color: #e6f7ff;
  border-radius: 8rpx;
  border: 1rpx solid #91d5ff;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-label {
  font-size: 26rpx;
  color: #999;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1890ff;
}
