.container {
  height: 100vh;
  background-color: #f5f6f8;
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 20rpx;
  background-color: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 10rpx 20rpx;
}

.search-input {
  flex: 1;
  margin-left: 10rpx;
  font-size: 28rpx;
}

.summary-filter-bar {
  display: flex;
  padding: 16rpx 20rpx;
  gap: 16rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.summary-pill {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
  background-color: #f8f9fa;
}

.summary-pill-active {
  background-color: #e8f4fd;
}

.summary-label {
  font-size: 22rpx;
  color: #999;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-top: 4rpx;
}

.summary-value.green {
  color: #52c41a;
}

.summary-value.red {
  color: #ff4d4f;
}

.list-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.list-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
}

.item-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-img-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #ccc;
}

.item-content {
  flex: 1;
  min-width: 0;
  position: relative;
}

.item-op-row {
  position: absolute;
  right: 0;
  top: 0;
}

.item-op-btn {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.item-op-btn-primary {
  background-color: #1890ff;
  color: #fff;
}

.item-header {
  display: flex;
  align-items: center;
  padding-right: 100rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.item-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.item-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
}

.tag-color {
  background-color: #e8f4fd;
  color: #1890ff;
}

.tag-size {
  background-color: #f0f0f0;
  color: #666;
}

.item-stock {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
}

.stock-info {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.stock-info .label {
  font-size: 22rpx;
  color: #999;
}

.stock-info .value {
  font-size: 28rpx;
  font-weight: 700;
}

.stock-info .value.green {
  color: #52c41a;
}

.stock-info .value.orange {
  color: #faad14;
}

.stock-info .value.red {
  color: #ff4d4f;
}

.stock-info .unit {
  font-size: 20rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  color: #999;
}

.empty-img {
  width: 200rpx;
  margin-bottom: 20rpx;
}

.loading-more, .no-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999;
}
