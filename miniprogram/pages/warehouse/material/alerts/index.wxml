<view class="container">
  <view class="header">
    <text class="title">面辅料需求排行</text>
    <text class="subtitle">按近{{days}}天出库频率计算</text>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:if="{{!loading && list.length === 0}}" class="empty">
    <image class="empty-img" src="/assets/icons/empty.svg" mode="widthFix" />
    <text>暂无库存预警</text>
  </view>

  <view class="ranking-grid">
    <view
      wx:for="{{list}}"
      wx:key="stockId"
      class="ranking-item"
      bindtap="onItemTap"
      data-item="{{item}}"
    >
      <view class="rank-badge">{{index + 1}}</view>
      <view class="rank-info">
        <text class="rank-title">{{item.materialCode || item.materialName || '物料'}}</text>
        <text class="rank-sub">库存 {{item.quantity || 0}} / 水位 {{item.suggestedSafetyStock || item.safetyStock || 0}}</text>
      </view>
      <view class="rank-count">缺 {{(item.suggestedSafetyStock || item.safetyStock || 0) - (item.quantity || 0) > 0 ? (item.suggestedSafetyStock || item.safetyStock || 0) - (item.quantity || 0) : 0}}</view>
    </view>
  </view>

  <view class="btn" bindtap="goScan">去扫码</view>

  <view wx:if="{{orderModal.visible}}" class="modal">
    <view class="modal-box">
      <view class="modal-head">下发采购指令</view>
      <view class="modal-body">
        <view class="modal-info">
          <text class="modal-title">{{orderModal.item.materialName || orderModal.item.materialCode}}</text>
          <text class="modal-sub">编码：{{orderModal.item.materialCode || '-'}}</text>
          <text class="modal-sub">单件用量：{{orderModal.item.perPieceUsage || '-'}}</text>
          <text class="modal-sub">最少可生产：{{orderModal.item.minProductionQty || '-'}} / 最大可生产：{{orderModal.item.maxProductionQty || '-'}}</text>
        </view>
        <view class="modal-field">
          <text class="field-label">采购数量</text>
          <input class="field-input" type="number" value="{{orderModal.quantity}}" bindinput="onQtyInput" />
        </view>
        <view class="modal-field">
          <text class="field-label">备注</text>
          <textarea class="field-textarea" value="{{orderModal.remark}}" bindinput="onRemarkInput" placeholder="可选" />
        </view>
      </view>
      <view class="modal-actions">
        <view class="btn-secondary" bindtap="onCancelOrder">取消</view>
        <view class="btn-primary" bindtap="onConfirmOrder">
          {{orderModal.submitting ? '提交中...' : '下发'}}
        </view>
      </view>
    </view>
  </view>
</view>
