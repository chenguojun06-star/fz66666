@import '../../../../styles/modal-form.wxss';
@import '../../../../styles/wh-card.wxss';

.container {
  padding: var(--spacing-lg);
}

.header {
  margin-bottom: var(--spacing-lg);
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.days-tabs {
  display: flex;
  gap: var(--spacing-xs);
}

.tab {
  padding: 8rpx 18rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-light);
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}

.tab.active {
  color: var(--color-primary);
  background: var(--color-blue-light);
}

.need-switch {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-light);
}

.need-switch.on {
  color: var(--color-primary);
  background: var(--color-blue-light);
}

.title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
}

.subtitle {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xs);
}

.loading {
  text-align: center;
  color: var(--color-text-secondary);
}

.empty {
  text-align: center;
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xl);
}

.empty-img {
  width: 120px;
  margin-bottom: var(--spacing-sm);
}

.ranking-list {
  display: flex;
  flex-direction: column;
}

/* ---- 面辅料排行卡片本地覆盖 ---- */

/* 标题行内的排名小圆圈 */
.ri-rank-circle {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-blue-light, #e3f2fd);
  color: var(--color-primary, #1890ff);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 40rpx;
}

/* 充足 / 缺料 状态按钮 — 外圈与字体等大，居中 */
.ri-btn-ok,
.ri-btn-warn {
  padding: 2rpx 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 20rpx;
  line-height: 32rpx;
  text-align: center;
  white-space: nowrap;
}

.ri-btn-ok {
  background: rgba(209, 250, 229, 0.9);
  color: #059669;
  border-color: #a7f3d0;
}

.ri-btn-warn {
  background: rgba(254, 243, 199, 0.9);
  color: #d97706;
  border-color: #fde68a;
}

/* 底部操作行：左右两按钮并列 */
.ri-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
}

.btn {
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-sm);
}

/* 采购数量选择器（弹窗专用） */
.qty-input {
  width: 140rpx;
  text-align: center;
  background: var(--color-bg-light);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm);
  font-size: var(--font-size-sm);
}

.qty-picker {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border-light);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.qty-shortage {
  padding: 10rpx 14rpx;
  border-radius: var(--radius-sm);
  background: var(--color-blue-light);
  color: var(--color-primary);
  font-size: var(--font-size-xs);
}
