@import '../../../../styles/modal-form.wxss';
@import '../../../../styles/wh-card.wxss';

.container {
  padding: var(--spacing-lg);
}

.header {
  margin-bottom: var(--spacing-lg);
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.days-tabs {
  display: flex;
  gap: var(--spacing-xs);
}

.tab {
  padding: 4px 9px;
  border-radius: var(--radius-sm);
  background: var(--color-bg-light);
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}

.tab.active {
  color: var(--color-primary);
  background: var(--color-blue-light);
}

.need-switch {
  padding: 4px 8px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-light);
}

.need-switch.on {
  color: var(--color-primary);
  background: var(--color-blue-light);
}

.title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
}

.subtitle {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xs);
}

.loading {
  text-align: center;
  color: var(--color-text-secondary);
}

.empty {
  text-align: center;
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xl);
}

.empty-img {
  width: 120px;
  margin-bottom: var(--spacing-sm);
}

.ranking-list {
  display: flex;
  flex-direction: column;
}

/* ---- 面辅料排行卡片本地覆盖 ---- */

/* 标题行内的排名小圆圈 */
.ri-rank-circle {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--color-blue-light, var(--color-info-bg));
  color: var(--color-primary, var(--color-primary));
  font-size: 11px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 20px;
}

/* 充足 / 缺料 状态按钮 — 椭圆药丸形，居中 */
.ri-btn-ok,
.ri-btn-warn {
  padding: 2px 8px;
  font-size: 10px;
  font-weight: 700;
  border-radius: 500px;
  line-height: 14px;
  text-align: center;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.ri-btn-ok {
  background: rgba(209, 250, 229, 0.9);
  color: var(--color-success);
  border: 1px solid var(--color-success-border);
}

.ri-btn-warn {
  background: rgba(254, 243, 199, 0.9);
  color: var(--color-warning);
  border: 1px solid var(--color-warning-border);
}

/* 底部操作行：左右两按钮并列 */
.ri-actions {
  display: flex;
  justify-content: flex-end;
  gap: 5px;
}

.btn {
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-sm);
}

/* 采购数量选择器（弹窗专用） */
.qty-input {
  width: 70px;
  text-align: center;
  background: var(--color-bg-light);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: var(--spacing-sm);
  font-size: var(--font-size-sm);
}

.qty-picker {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.qty-btn {
  width: 26px;
  height: 26px;
  line-height: 26px;
  text-align: center;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border-light);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.qty-shortage {
  padding: 5px 7px;
  border-radius: var(--radius-sm);
  background: var(--color-blue-light);
  color: var(--color-primary);
  font-size: var(--font-size-xs);
}
