.container {
  padding: var(--spacing-md);
  background: var(--color-bg-page, var(--color-bg-light));
  min-height: 100vh;
  box-sizing: border-box;
}

.summary-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  border: 1px solid var(--color-border-light);
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.title {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
}

.code {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5px 7px;
}

.metric {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}

.value {
  color: var(--color-text-primary);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.section {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border-light);
  padding: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.section-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
}

.section-sub,
.refresh {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}

.loading,
.empty {
  text-align: center;
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
  padding: var(--spacing-md) 0;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 7px 0;
  border-bottom: 1px solid var(--color-border-light);
}

.row:last-child {
  border-bottom: none;
}

.row-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.row-title {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

.row-sub {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.row-sub-line {
  display: flex;
  align-items: center;
  gap: 5px;
}

.status-tag {
  display: inline-block;
  padding: 1px 5px;
  border-radius: 500px;
  font-size: var(--font-size-xs);
  line-height: 1.4;
}

.status-tag.default {
  color: var(--color-text-secondary);
  background: var(--color-bg-light);
}

.status-tag.warning {
  color: var(--color-warning, var(--color-warning));
  background: var(--color-warning-light, var(--color-warning-bg));
}

.status-tag.success {
  color: var(--color-success, var(--color-success));
  background: var(--color-success-light, var(--color-success-bg));
}

.status-tag.error {
  color: var(--color-danger, var(--color-error));
  background: var(--color-danger-light, var(--color-error-bg));
}

.row-qty {
  min-width: 40px;
  text-align: right;
  color: var(--color-primary);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
}

.footer-btn {
  text-align: center;
  padding: 9px 0;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
}
