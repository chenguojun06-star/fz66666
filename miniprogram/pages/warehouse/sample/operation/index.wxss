.container {
  padding: 30rpx;
  background-color: var(--color-bg-gray);
  min-height: 100vh;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.form-item {
  background-color: var(--color-bg-card);
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
  display: block;
}

input, textarea, .picker {
  font-size: 30rpx;
  color: var(--color-text-primary);
  width: 100%;
}

.input-wrap {
  display: flex;
  align-items: center;
}

.scan-btn {
  padding: 10rpx;
  margin-left: 20rpx;
}

.scan-btn image {
  width: 40rpx;
  height: 40rpx;
}

.form-row {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.ml-20 {
  margin-left: 20rpx;
}

.submit-btn {
  margin-top: 60rpx;
  background-color: var(--color-primary);
}

/* 库存选择相关样式 */
.stock-selection {
  margin-bottom: 20rpx;
}

.section-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.stock-item {
  background-color: var(--color-bg-card);
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stock-item.active {
  border-color: var(--color-primary);
  background-color: #e6f7ff;
}

.stock-spec {
  font-weight: bold;
  font-size: 30rpx;
  margin-right: 16rpx;
}

.stock-type {
  font-size: 24rpx;
  color: var(--color-text-disabled);
  background-color: var(--color-bg-gray);
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
}

.stock-qty {
  font-size: 28rpx;
  color: var(--color-success);
  font-weight: 500;
}

.loading-stock {
  text-align: center;
  color: var(--color-text-disabled);
  font-size: 24rpx;
  padding: 10rpx;
}
