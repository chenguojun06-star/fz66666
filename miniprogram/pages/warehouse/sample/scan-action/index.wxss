/* 样衣扫码动作页 — 遵循 material/scan 设计规范 */

.container {
  padding: 12rpx var(--page-padding-x);
  background: var(--color-bg-page, var(--color-bg-light));
  min-height: 100vh;
}

/* 头部 */
.header { margin-bottom: 12px; }
.header-title { font-size: var(--font-size-lg-xl); font-weight: bold; color: var(--color-text); display: block; }
.header-sub { font-size: var(--font-size-sm); color: var(--color-text-secondary); margin-top: 4px; display: block; }

/* 加载 */
.loading-wrap { display: flex; justify-content: center; align-items: center; padding: 60px 0; }
.loading-text { font-size: var(--font-size-md); color: var(--color-text-secondary); }

/* 错误 */
.error-card {
  background: var(--color-error-bg);
  border: 1px solid var(--color-error);
  border-radius: var(--radius-md);
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.error-icon { font-size: var(--font-size-4xl); margin-bottom: 8px; }
.error-msg { font-size: var(--font-size-md); color: var(--color-error); text-align: center; margin-bottom: 12px; }
.btn-retry {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: 6px 20px;
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-xs);
}

/* 成功 */
.success-banner {
  background: var(--color-success-bg);
  border: 1px solid var(--color-success);
  border-radius: var(--radius-md);
  padding: 10px 14px;
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}
.success-icon { font-size: var(--font-size-lg-xl); margin-right: 8px; }
.success-text { font-size: var(--font-size-md); color: var(--color-success); }

/* 信息卡片 */
.info-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 12px 14px;
  margin-bottom: 10px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.info-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid var(--color-border-light);
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: var(--font-size-sm); color: var(--color-text-secondary); width: 60px; flex-shrink: 0; }
.info-value { font-size: var(--font-size-md); color: var(--color-text); flex: 1; }
.info-value.bold,
.bold { font-weight: bold; font-size: var(--font-size-md-lg); color: var(--color-primary); }

/* 状态标签 */
.status-tag { padding: 2px 8px; border-radius: 10px; font-size: var(--font-size-xs); }
.tag-green { background: var(--color-success-bg); color: var(--color-success); }
.tag-orange { background: var(--color-warning-bg); color: var(--color-warning); }

/* 借调记录 */
.loan-item { margin-top: 4px; padding-top: 4px; border-top: 1px dashed var(--color-border-light); }

/* 操作按钮 */
.action-area { margin-bottom: 10px; }

.btn-inbound {
  background: var(--color-primary);
  color: var(--color-text-white);
  text-align: center;
  border-radius: var(--radius-md);
  padding: 14px 0;
  font-size: var(--font-size-md-lg);
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(24,144,255,0.25);
  margin-bottom: 8px;
}

.btn-loan {
  background: var(--color-primary);
  color: var(--color-text-white);
  text-align: center;
  border-radius: var(--radius-md);
  padding: 14px 0;
  font-size: var(--font-size-md-lg);
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(24,144,255,0.25);
  margin-bottom: 8px;
}

.btn-return {
  background: var(--color-warning);
  color: var(--color-text-white);
  text-align: center;
  border-radius: var(--radius-md);
  padding: 14px 0;
  font-size: var(--font-size-md-lg);
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(250,173,20,0.25);
  margin-bottom: 8px;
}

.btn-disabled { opacity: 0.6; pointer-events: none; }

.btn-next {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  color: var(--color-text-secondary);
  text-align: center;
  border-radius: var(--radius-md);
  padding: 12px 0;
  font-size: var(--font-size-md);
  margin-top: 6px;
}
