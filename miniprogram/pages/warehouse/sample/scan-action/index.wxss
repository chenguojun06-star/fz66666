/* 样衣扫码动作页 — 遵循 material/scan 设计规范 */
@import '/styles/line-icons.wxss';

.container {
  padding: 12px;
  background: var(--color-bg-page, var(--color-bg-light));
  min-height: 100vh;
}

/* 头部 */
.header { margin-bottom: 12px; }
.header-title { font-size: 18px; font-weight: bold; color: var(--color-text); display: block; }
.header-sub { font-size: 13px; color: var(--color-text-secondary); margin-top: 4px; display: block; }

/* 加载 */
.loading-wrap { display: flex; justify-content: center; align-items: center; padding: 60px 0; }
.loading-text { font-size: 14px; color: var(--color-text-secondary); }

/* 错误 */
.error-card {
  background: var(--color-error-bg, #fff2f0);
  border: 1px solid var(--color-error, #ff4d4f);
  border-radius: 8px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.error-icon { font-size: 32px; margin-bottom: 8px; }
.error-msg { font-size: 14px; color: var(--color-error, #ff4d4f); text-align: center; margin-bottom: 12px; }
.btn-retry {
  font-size: 14px;
  color: var(--color-primary);
  padding: 6px 20px;
  border: 1px solid var(--color-primary);
  border-radius: 6px;
}

/* 成功 */
.success-banner {
  background: var(--color-success-bg, #f6ffed);
  border: 1px solid var(--color-success, #52c41a);
  border-radius: 8px;
  padding: 10px 14px;
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}
.success-icon { font-size: 18px; margin-right: 8px; }
.success-text { font-size: 14px; color: var(--color-success, #52c41a); }

/* 信息卡片 */
.info-card {
  background: var(--color-bg-card, #fff);
  border-radius: 8px;
  padding: 12px 14px;
  margin-bottom: 10px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}
.info-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid var(--color-border-light, #f0f0f0);
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 13px; color: var(--color-text-secondary); width: 60px; flex-shrink: 0; }
.info-value { font-size: 14px; color: var(--color-text); flex: 1; }
.info-value.bold,
.bold { font-weight: bold; font-size: 16px; color: var(--color-primary); }

/* 状态标签 */
.status-tag { padding: 2px 8px; border-radius: 10px; font-size: 12px; }
.tag-green { background: var(--color-success-bg, #f6ffed); color: var(--color-success, #52c41a); }
.tag-orange { background: var(--color-warning-bg, #fff7e6); color: var(--color-warning, #faad14); }

/* 借调记录 */
.loan-item { margin-top: 4px; padding-top: 4px; border-top: 1px dashed var(--color-border-light, #f0f0f0); }

/* 操作按钮 */
.action-area { margin-bottom: 10px; }

.btn-inbound {
  background: var(--color-primary);
  color: #fff;
  text-align: center;
  border-radius: 8px;
  padding: 14px 0;
  font-size: 16px;
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(24,144,255,0.25);
  margin-bottom: 8px;
}

.btn-loan {
  background: var(--color-primary);
  color: #fff;
  text-align: center;
  border-radius: 8px;
  padding: 14px 0;
  font-size: 16px;
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(24,144,255,0.25);
  margin-bottom: 8px;
}

.btn-return {
  background: var(--color-warning, #faad14);
  color: #fff;
  text-align: center;
  border-radius: 8px;
  padding: 14px 0;
  font-size: 16px;
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(250,173,20,0.25);
  margin-bottom: 8px;
}

.btn-disabled { opacity: 0.6; pointer-events: none; }

.btn-next {
  background: #fff;
  border: 1px solid var(--color-border);
  color: var(--color-text-secondary);
  text-align: center;
  border-radius: 8px;
  padding: 12px 0;
  font-size: 14px;
  margin-top: 6px;
}
