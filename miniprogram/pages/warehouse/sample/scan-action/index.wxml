<!-- 样衣仓库管理页 -->
<view class="container">
  
  <!-- ==================== 列表视图 ==================== -->
  <view wx:if="{{viewMode === 'list'}}">
    <!-- 搜索栏 -->
    <view class="search-bar">
      <view class="search-box">
        <text class="search-icon">🔍</text>
        <input 
          class="search-input" 
          placeholder="搜索款号/颜色/尺码" 
          value="{{searchKeyword}}" 
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
        />
        <text class="search-clear" wx:if="{{searchKeyword}}" catchtap="onSearchInput" data-clear="true">✕</text>
      </view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="action-bar">
      <view class="btn-scan" bindtap="onScanCode">
        <text class="btn-icon">📷</text>
        <text class="btn-text">扫码</text>
      </view>
    </view>
    
    <!-- 列表 -->
    <view class="stock-list">
      <view wx:if="{{stockListLoading && stockList.length === 0}}" class="loading-wrap">
        <text class="loading-text">加载中...</text>
      </view>
      
      <view wx:elif="{{stockListError}}" class="error-card">
        <text class="error-icon">⚠️</text>
        <text class="error-msg">{{stockListError}}</text>
        <view class="btn-retry" bindtap="loadStockList" data-refresh="true">重试</view>
      </view>
      
      <view wx:elif="{{stockList.length === 0}}" class="empty-wrap">
        <text class="empty-icon">👕</text>
        <text class="empty-text">暂无样衣库存</text>
      </view>
      
      <block wx:else>
      <view 
        class="stock-item" 
        wx:for="{{stockList}}" 
        wx:key="id"
        bindtap="onStockItemTap"
        data-stock="{{item}}"
      >
        <image wx:if="{{item._imageUrl}}" class="stock-thumb" src="{{item._imageUrl}}" lazy-load mode="aspectFill" catchtap="onPreviewImage" data-src="{{item._imageUrl}}" />
        <view wx:else class="stock-thumb-placeholder">
          <text>👕</text>
        </view>
        <view class="stock-info">
          <view class="stock-row">
            <text class="stock-label">款号</text>
            <text class="stock-value">{{item.styleNo || '-'}}</text>
          </view>
          <view class="stock-row">
            <text class="stock-label">颜色</text>
            <text class="stock-value">{{item.color || '-'}}</text>
          </view>
          <view class="stock-row">
            <text class="stock-label">尺码</text>
            <text class="stock-value">{{item.size || '-'}}</text>
          </view>
          <view class="stock-row" wx:if="{{item._sampleTypeLabel}}">
            <text class="stock-label">类型</text>
            <text class="stock-value">{{item._sampleTypeLabel}}</text>
          </view>
        </view>
        <view class="stock-status">
          <view class="stock-quantity">
            <text class="qty-num">{{item.quantity || 0}}</text>
            <text class="qty-unit">件</text>
          </view>
          <text class="stock-loan" wx:if="{{item.loanedQuantity > 0}}">借出 {{item.loanedQuantity}}</text>
          <text class="stock-arrow">›</text>
        </view>
      </view>
      </block>
      
      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{stockList.length > 0}}">
        <text wx:if="{{stockListLoading}}" class="load-text">加载中...</text>
        <text wx:elif="{{hasMore}}" class="load-text" bindtap="loadStockList">加载更多</text>
        <text wx:else class="load-text">— 没有更多了 —</text>
      </view>
    </view>
  </view>
  
  <!-- ==================== 详情视图 ==================== -->
  <view wx:if="{{viewMode === 'detail'}}">
    <!-- 头部 -->
    <view class="header">
      <view class="header-back" bindtap="onBackToList">‹ 返回列表</view>
      <text class="header-title">样衣详情</text>
      <view class="header-scan" bindtap="onScanCode">📷 扫码</view>
    </view>
    
    <view class="header-info">
      <text class="header-sub">{{styleNo}} · {{color}} · {{size}}</text>
    </view>
    
    <!-- 加载中 -->
    <view class="loading-wrap" wx:if="{{loading}}">
      <text class="loading-text">查询中...</text>
    </view>
    
    <!-- 错误提示 -->
    <view class="error-card" wx:elif="{{errorMsg}}">
      <text class="error-icon">⚠️</text>
      <text class="error-msg">{{errorMsg}}</text>
      <view class="btn-retry" bindtap="onRetry">重试</view>
    </view>
    
    <!-- 成功提示 -->
    <view class="success-banner" wx:if="{{successMsg}}">
      <text class="success-icon">✅</text>
      <text class="success-text">{{successMsg}}</text>
    </view>
    
    <!-- 库存信息卡片 -->
    <block wx:if="{{stockInfo && !loading}}">
      <!-- 未找到库存记录 -->
      <view class="info-card" wx:if="{{!stockInfo.found}}">
        <view class="info-row">
          <text class="info-label">状态</text>
          <text class="info-value">
            <text class="status-tag tag tag-warning">未入库</text>
          </text>
        </view>
        <view class="info-row">
          <text class="info-label">款号</text>
          <text class="info-value bold">{{styleNo}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">颜色</text>
          <text class="info-value">{{color}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">尺码</text>
          <text class="info-value">{{size}}</text>
        </view>
      </view>
      
      <!-- 已有库存记录 -->
      <view class="info-card" wx:if="{{stockInfo.found && stockInfo.stock}}">
        <view class="detail-header">
          <view class="detail-info">
            <view class="info-row">
              <text class="info-label">状态</text>
              <text class="info-value">
                <text class="status-tag tag tag-success" wx:if="{{stockInfo.availableQuantity > 0}}">在库</text>
                <text class="status-tag tag tag-warning" wx:else>全部借出</text>
              </text>
            </view>
            <view class="info-row">
              <text class="info-label">款号</text>
              <text class="info-value bold">{{stockInfo.stock.styleNo}}</text>
            </view>
            <view class="info-row" wx:if="{{stockInfo.stock.styleName}}">
              <text class="info-label">款名</text>
              <text class="info-value">{{stockInfo.stock.styleName}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">颜色</text>
              <text class="info-value">{{stockInfo.stock.color}}</text>
            </view>
            <view class="info-row">
              <text class="info-label">尺码</text>
              <text class="info-value">{{stockInfo.stock.size}}</text>
            </view>
            <view class="info-row" wx:if="{{stockInfo.stock.sampleType}}">
              <text class="info-label">类型</text>
              <text class="info-value">{{stockInfo.stock._sampleTypeLabel || stockInfo.stock.sampleType}}</text>
            </view>
          </view>
          <image wx:if="{{stockInfo.stock._imageUrl}}" class="detail-thumb" src="{{stockInfo.stock._imageUrl}}" lazy-load mode="aspectFill" bindtap="onPreviewImage" data-src="{{stockInfo.stock._imageUrl}}" />
        </view>
        <view class="info-row" wx:if="{{stockInfo.stock.location}}">
          <text class="info-label">仓位</text>
          <text class="info-value">{{stockInfo.stock.location}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">库存</text>
          <text class="info-value bold">{{stockInfo.stock.quantity}} 件</text>
        </view>
        <view class="info-row">
          <text class="info-label">可用</text>
          <text class="info-value bold">{{stockInfo.availableQuantity}} 件</text>
        </view>
        <view class="info-row" wx:if="{{stockInfo.stock.loanedQuantity > 0}}">
          <text class="info-label">借出</text>
          <text class="info-value">{{stockInfo.stock.loanedQuantity}} 件</text>
        </view>
      </view>
      
      <!-- 借调记录 -->
      <view class="info-card" wx:if="{{stockInfo.activeLoans && stockInfo.activeLoans.length > 0}}">
        <view class="info-row">
          <text class="info-label info-label--wide">当前借调记录</text>
        </view>
        <view class="loan-item" wx:for="{{stockInfo.activeLoans}}" wx:key="id">
          <view class="info-row">
            <text class="info-label">借出人</text>
            <text class="info-value">{{item.borrower}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">借给谁</text>
            <text class="info-value">{{item.lendToFactoryName || item.lendTo || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">数量</text>
            <text class="info-value">{{item.quantity}} 件</text>
          </view>
          <view class="info-row">
            <text class="info-label">剩余未还</text>
            <text class="info-value">{{item.remainingQuantity || item.quantity}} 件</text>
          </view>
          <view class="info-row">
            <text class="info-label">时间</text>
            <text class="info-value">{{item.loanDate || item.createTime}}</text>
          </view>
          <view class="info-row" wx:if="{{item.transferFromLoanId}}">
            <text class="info-label">来源</text>
            <text class="info-value transfer-tag">转借</text>
          </view>
          <view class="loan-actions" wx:if="{{item.status === 'borrowed'}}">
            <view class="btn-transfer-sm" bindtap="onTransfer" data-id="{{item.id}}">转借</view>
          </view>
        </view>
      </view>
      
      <!-- 操作按钮区域 -->
      <view class="action-area" wx:if="{{!successMsg}}">
        <!-- 仓库区域选择（入库时显示） -->
        <view wx:if="{{_showInbound}}" class="warehouse-section">
          <view class="warehouse-label">入库仓库：</view>
          <view class="warehouse-option-row">
            <view
              wx:for="{{warehouseOptions}}"
              wx:key="index"
              class="warehouse-chip {{warehouse === item ? 'warehouse-chip--active' : ''}}"
              bindtap="onWarehouseChipTap"
              data-value="{{item}}"
              hover-class="warehouse-chip-hover"
            >{{item}}</view>
            <view
              class="warehouse-chip warehouse-chip--clear {{warehouse ? '' : 'warehouse-chip--disabled'}}"
              bindtap="onWarehouseClear"
              hover-class="warehouse-chip-hover"
            >清除</view>
          </view>
          <input
            class="input-box"
            placeholder="或手动输入仓库编号"
            value="{{warehouse}}"
            bindinput="onWarehouseCodeInput"
          />
          
          <!-- 库位选择 -->
          <view wx:if="{{warehouse && locationOptions.length > 0}}" class="warehouse-label warehouse-label--mt">入库库位：</view>
          <view wx:if="{{warehouse && locationOptions.length > 0}}" class="warehouse-option-row">
            <view
              wx:for="{{locationOptions}}"
              wx:key="index"
              class="warehouse-chip {{warehouseLocationCode === item ? 'warehouse-chip--active' : ''}}"
              bindtap="onLocationChipTap"
              data-value="{{item}}"
              hover-class="warehouse-chip-hover"
            >{{item}}</view>
            <view
              class="warehouse-chip warehouse-chip--clear {{warehouseLocationCode ? '' : 'warehouse-chip--disabled'}}"
              bindtap="onLocationClear"
              hover-class="warehouse-chip-hover"
            >清除</view>
          </view>
          <input
            wx:if="{{warehouse}}"
            class="input-box"
            placeholder="或手动输入库位编号"
            value="{{warehouseLocationCode}}"
            bindinput="onLocationCodeInput"
          />
        </view>
        
        <view
          class="btn-inbound {{submitting ? 'btn-disabled' : ''}}"
          wx:if="{{_showInbound}}"
          bindtap="onInbound"
        >
          入库
        </view>
        <!-- 借调内联表单（替代弹窗，点击"借调"按钮展开/收起） -->
        <view class="loan-inline" wx:if="{{showLoanForm}}">
          <view class="loan-inline-row">
            <text class="loan-inline-label">借给谁</text>
            <radio-group class="loan-inline-radios" bindchange="onLoanLendToTypeChange">
              <label class="radio-item"><radio value="person" checked="{{loanLendToType==='person'}}" /> 个人</label>
              <label class="radio-item"><radio value="factory" checked="{{loanLendToType==='factory'}}" /> 工厂</label>
            </radio-group>
          </view>
          <!-- 个人：搜索租户人员 -->
          <block wx:if="{{loanLendToType === 'person'}}">
            <view class="loan-inline-row">
              <text class="loan-inline-label">姓名</text>
              <input class="loan-inline-input" placeholder="搜索人员姓名" value="{{loanUserSearch}}" bindinput="onLoanUserSearch" />
            </view>
            <!-- 已选中显示 -->
            <view class="loan-inline-selected" wx:if="{{loanLendTo}}">已选: {{loanLendTo}}</view>
            <!-- 搜索结果列表 -->
            <view class="loan-inline-list" wx:if="{{_filteredLoanUsers.length > 0}}">
              <view class="loan-inline-option" wx:for="{{_filteredLoanUsers}}" wx:key="id"
                bindtap="onLoanUserSelect" data-idx="{{index}}">
                {{item.name || item.username}}
              </view>
            </view>
          </block>
          <!-- 工厂：搜索外发工厂 -->
          <block wx:if="{{loanLendToType === 'factory'}}">
            <view class="loan-inline-row">
              <text class="loan-inline-label">工厂</text>
              <input class="loan-inline-input" placeholder="搜索工厂名称" value="{{loanFactorySearch}}" bindinput="onLoanFactorySearch" />
            </view>
            <!-- 已选中显示 -->
            <view class="loan-inline-selected" wx:if="{{loanLendToFactoryName}}">已选: {{loanLendToFactoryName}}</view>
            <!-- 搜索结果列表 -->
            <view class="loan-inline-list" wx:if="{{_filteredLoanFactories.length > 0}}">
              <view class="loan-inline-option" wx:for="{{_filteredLoanFactories}}" wx:key="id"
                bindtap="onLoanFactorySelect" data-idx="{{index}}">
                {{item.factoryName || item.name}}
              </view>
            </view>
          </block>
          <view class="loan-inline-row">
            <text class="loan-inline-label">备注</text>
            <input class="loan-inline-input" placeholder="选填" value="{{loanRemark}}" bindinput="onLoanRemarkInput" />
          </view>
          <view class="loan-inline-actions">
            <view class="loan-inline-btn loan-inline-btn--cancel" bindtap="onLoanFormCancel">取消</view>
            <view class="loan-inline-btn loan-inline-btn--confirm" bindtap="onLoanFormConfirm">确认借调</view>
          </view>
        </view>

        <view
          class="btn-loan {{submitting ? 'btn-disabled' : ''}}"
          wx:if="{{_showLoan && !successMsg}}"
          bindtap="onLoan"
        >
          {{showLoanForm ? '收起' : '借调'}}
        </view>
        <view
          class="btn-return {{submitting ? 'btn-disabled' : ''}}"
          wx:if="{{_showReturn}}"
          bindtap="onReturn"
        >
          归还
        </view>
      </view>
    </block>
  </view>
  
  <!-- 归还选择弹窗 -->
  <view class="modal-mask" wx:if="{{showReturnPicker}}" bindtap="onReturnPickerCancel">
    <view class="modal-content" catchtap="">
      <view class="modal-title">选择归还记录</view>
      <view class="modal-body">
        <view class="return-pick-item {{selectedLoanId === item.id ? 'return-pick-item--active' : ''}}"
          wx:for="{{stockInfo.activeLoans}}" wx:key="id"
          bindtap="onReturnLoanSelect" data-id="{{item.id}}">
          <text>{{item.lendToFactoryName || item.lendTo || item.borrower || '未知'}}</text>
          <text>剩余 {{item.remainingQuantity || item.quantity}} 件</text>
        </view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn-cancel" bindtap="onReturnPickerCancel">取消</view>
        <view class="modal-btn-confirm" bindtap="onReturnPickerConfirm">确认归还</view>
      </view>
    </view>
  </view>

  <!-- 转借表单弹窗 -->
  <view class="modal-mask" wx:if="{{showTransferForm}}" bindtap="onTransferFormCancel">
    <view class="modal-content" catchtap="">
      <view class="modal-title">转借样衣</view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">转借入人姓名</text>
          <input class="form-input" placeholder="转借给谁" value="{{transferLendTo}}" bindinput="onTransferLendToInput" />
        </view>
        <view class="form-item">
          <text class="form-label">转借入工厂名称</text>
          <input class="form-input" placeholder="工厂名称（选填）" value="{{transferLendToFactoryName}}" bindinput="onTransferFactoryInput" />
        </view>
        <view class="form-item">
          <text class="form-label">备注</text>
          <input class="form-input" placeholder="转借原因（选填）" value="{{transferRemark}}" bindinput="onTransferRemarkInput" />
        </view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn-cancel" bindtap="onTransferFormCancel">取消</view>
        <view class="modal-btn-confirm" bindtap="onTransferFormConfirm">确认转借</view>
      </view>
    </view>
  </view>

  <!-- 隐私协议 -->
  <privacy-dialog
    wx:if="{{showPrivacy}}"
    bind:agree="onPrivacyAgree"
    bind:disagree="onPrivacyDisagree"
  />
</view>
