@import '../../../../styles/inline-selector.wxss';
@import '../../../../styles/page-utils.wxss';
@import '../../../../styles/modal-form.wxss';
@import '../../../../styles/wh-card.wxss';

.container {
  height: 100vh;
  background-color: var(--color-bg-gray);
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 10px;
  background-color: var(--color-bg-card);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-gray);
  border-radius: 18px;
  padding: 5px 10px;
}

.search-input {
  flex: 1;
  margin-left: 5px;
  font-size: 14px;
}

.scan-icon {
  padding: 5px;
}

.summary-filter-bar {
  display: flex;
  gap: 10px;
  padding: 0 10px 10px;
  background-color: var(--color-bg-card);
  margin-bottom: 10px;
}

.summary-pill {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  border: 1px solid var(--color-border-light);
  border-radius: 6px;
  padding: 9px 10px;
  background-color: var(--color-bg-card);
}

.summary-pill-active {
  border-color: var(--color-primary);
  background-color: var(--color-primary-light);
}

.summary-label {
  font-size: 13px;
  color: var(--color-text-secondary);
}

.summary-value {
  font-size: 17px;
  font-weight: 600;
  color: var(--color-primary);
}

.list-container {
  flex: 1;
  padding: 10px;
  box-sizing: border-box;
}

/* 旧卡片类名已迁移至 /styles/wh-card.wxss（wc-* 前缀） */

/* empty-state / empty-img / loading-more / no-more → page-utils.wxss */

/* 弹窗表单 — 已迁移至 /styles/modal-form.wxss（mf-* 类名） */
/* 页面专用覆盖 */
.stock-selection {
  margin-bottom: 8px;
}

.stock-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.stock-spec {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: 600;
}

.stock-type {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.stock-qty {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}

/* 借出记录列表 */
.loan-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.loan-item {
  padding: 8px 10px;
  background: var(--color-bg-light, var(--color-bg-light));
  border-radius: 6px;
  border: 1px solid var(--color-border);
}

.loan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}

.loan-borrower {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
}

.loan-status {
  font-size: var(--font-size-xs);
  padding: 1px 6px;
  border-radius: 4px;
}

.loan-status.ongoing {
  background-color: var(--color-warning-bg);
  color: var(--color-warning);
}

.loan-status.returned {
  background-color: var(--color-success-bg);
  color: var(--color-success);
}

.loan-status.lost {
  background-color: var(--color-error-bg);
  color: var(--color-danger);
}
