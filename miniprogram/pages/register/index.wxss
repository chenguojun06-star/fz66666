page {
  background: var(--color-bg-page);
}

.register-card {
  margin-top: 10px;
  border-radius: var(--radius-2xl);
  border: none;
  padding: 20px;
  box-shadow: var(--shadow-sm);
}

.title {
  font-size: var(--font-size-3xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  text-align: left;
  margin-bottom: 4px;
}

.subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  text-align: left;
  margin-bottom: 20px;
}

.required {
  color: var(--color-danger);
  margin-left: 2px;
}

.field + .field {
  margin-top: 14px;
}

.label {
  display: flex;
  align-items: center;
  gap: 2px;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  margin-bottom: 8px;
}

.input {
  height: 52px;
  background: var(--color-bg-page);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
  padding: 0 16px;
  font-size: var(--font-size-base);
}

.input-row {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--color-bg-page);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
  padding: 0 16px;
  height: 52px;
}

.input-row .input {
  flex: 1;
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 0;
}

.input-icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  color: var(--color-text-tertiary);
}

.scan-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-border);
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.scan-icon {
  font-size: var(--font-size-lg-xl);
}

.scan-icon-svg {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tenant-info {
  margin-top: 4px;
}

.tenant-tag {
  font-size: var(--font-size-xs);
  color: var(--color-success);
  padding: 2px 6px;
  background: var(--color-success-bg);
  border-radius: var(--radius-sm);
}

.agreement-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 20px;
}

.ios-toggle {
  width: 51px;
  height: 31px;
  border-radius: var(--radius-full);
  background: var(--color-bg-page);
  position: relative;
  transition: background-color 0.2s ease;
  flex-shrink: 0;
}

.ios-toggle.on {
  background: var(--color-primary);
}

.ios-toggle-handle {
  position: absolute;
  top: 2px;
  left: 2px;
  width: 27px;
  height: 27px;
  border-radius: 50%;
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease;
}

.ios-toggle.on .ios-toggle-handle {
  transform: translateX(20px);
}

.agreement-text-wrap {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 4px;
}

.agreement-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.agreement-link {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

.back-link {
  text-align: center;
  margin-top: 20px;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}
.back-link-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}
.back-link-action {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}

/* Submit button override — design: h-52, rounded-2xl, font-16, shadow-sm */
.register-card .btn {
  margin-top: 20px;
}
.register-card .btn-primary {
  height: 52px;
  flex: 1;
  width: 100%;
  border-radius: var(--radius-2xl);
  font-size: var(--font-size-lg);
  box-shadow: var(--shadow-sm);
}

.factory-field {
  position: relative;
  z-index: 10;
}

.factory-dropdown {
  margin-top: 4px;
  border-radius: var(--radius-2xl);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-md);
  max-height: 160px;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.factory-dropdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-bottom: 1px solid var(--color-border);
}

.factory-dropdown-item:last-child {
  border-bottom: none;
}

.factory-dropdown-item-hover {
  background: var(--color-bg-page);
}

.factory-dropdown-name {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.factory-dropdown-code {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.factory-dropdown-empty {
  padding: 12px 14px;
  color: var(--color-text-disabled);
  font-size: var(--font-size-xs);
  text-align: center;
}
