page {
  background: var(--color-bg-page);
}

.register-card {
  margin-top: 10px;
}

.title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 4px;
}

.subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 20px;
}

.required {
  color: var(--color-danger);
  margin-left: 2px;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.input-row .input {
  flex: 1;
}

.scan-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.scan-icon {
  font-size: var(--font-size-lg-xl);
}

.scan-icon-svg {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tenant-info {
  margin-top: 4px;
}

.tenant-tag {
  font-size: var(--font-size-xs);
  color: var(--color-success, var(--color-success));
  padding: 2px 6px;
  background: rgba(34, 197, 94, 0.08);
  border-radius: var(--radius-sm);
}

.back-link {
  text-align: center;
  color: var(--color-primary, var(--color-primary));
  font-size: var(--font-size-md);
  padding: 12px 0 0;
}
