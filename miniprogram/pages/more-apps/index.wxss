/* ============ 更多应用页面 ============ */
page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* -- 搜索栏（基础样式走 app.wxss 全局 .search-bar / .search-box；本页 sticky 用 --sticky 修饰类） -- */

.edit-btn {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: 8px 12px;
  min-height: 32px;
  border-radius: var(--radius-full);
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-btn-active {
  background: var(--color-primary);
  color: var(--color-text-white);
}

/* -- 内容区域 -- */
.fav-section,
.all-apps-section {
  background: var(--color-bg-card);
  margin-top: var(--spacing-md);
  padding: var(--spacing-lg) var(--page-padding-x);
}

.fav-section {
  background: linear-gradient(135deg, var(--color-warning-bg) 0%, var(--color-bg-card) 100%);
  border: 1px solid var(--color-warning-border);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  letter-spacing: 0.5px;
}

.section-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  padding: 2px 8px;
  border-radius: var(--radius-full);
}

.clear-btn {
  font-size: var(--font-size-sm);
  color: var(--color-danger);
}

/* -- 应用网格 -- */
.app-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  row-gap: var(--spacing-xl);
}

.app-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
  position: relative;
}

.menu-icon-circle {
  width: 56px;
  height: 56px;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  position: relative;
}

.menu-icon-circle .line-icon--lg {
  width: 30px;
  height: 30px;
  background-size: 30px 30px;
}

.menu-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--color-danger);
  color: var(--color-text-white);
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 10px;
  line-height: 1.2;
  font-weight: var(--font-weight-semibold);
}

.fav-star {
  position: absolute;
  top: -6px;
  right: -6px;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  opacity: 0.6;
  z-index: 2;
}

.fav-star-active {
  opacity: 1;
}

.app-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
  line-height: var(--line-height-tight);
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: var(--font-weight-medium);
}

.remove-btn {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 20px;
  height: 20px;
  padding: 6px;
  background: var(--color-danger);
  color: var(--color-text-white);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

/* -- 应用分组 -- */
.app-group {
  margin-bottom: var(--spacing-xxl);
}

.app-group:last-child {
  margin-bottom: 0;
}

.group-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-sm);
  border-bottom: 2px solid var(--color-primary-border);
}

.group-count {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-normal);
  color: var(--color-text-secondary);
}

/* -- 空状态 -- */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-xxl) 0;
}

.empty-icon {
  font-size: 24px;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* -- 图标颜色（Apple 风格：淡背景） -- */
.menu-icon-circle--purple {
  background: var(--icon-bg-purple);
}

.menu-icon-circle--blue {
  background: var(--icon-bg-blue);
}

.menu-icon-circle--teal {
  background: var(--icon-bg-teal);
}

.menu-icon-circle--amber {
  background: var(--icon-bg-amber);
}

.menu-icon-circle--green {
  background: var(--icon-bg-green);
}

.menu-icon-circle--orange {
  background: var(--icon-bg-orange);
}

.menu-icon-circle--rose {
  background: var(--icon-bg-rose);
}

.menu-icon-circle--indigo {
  background: var(--icon-bg-indigo);
}

.menu-icon-circle--cyan {
  background: var(--icon-bg-cyan);
}

.menu-icon-circle--gray {
  background: var(--icon-bg-gray);
}
