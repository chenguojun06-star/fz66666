@import '/styles/page-utils.wxss';
@import '/styles/modal-form.wxss';

.page {
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--color-bg-page);
  min-height: 100vh;
}

.stats-bar {
  display: flex;
  gap: 8px;
  padding: 12px;
  background: var(--color-bg-card);
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 10px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
}

.stat-value {
  display: block;
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: 2px;
}

.tab-bar {
  display: flex;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border-light);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  position: relative;
}

.tab-active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 3px;
  background: var(--color-primary);
  border-radius: 2px;
}

.payable-card, .payment-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 12px;
  margin: 8px 12px;
  box-shadow: var(--shadow-sm);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.payee-name {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-text-primary);
}

.card-body {
  display: flex;
  flex-wrap: wrap;
  gap: 4px 16px;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: var(--font-size-sm);
}

.info-label {
  color: var(--color-text-tertiary);
}

.info-value {
  color: var(--color-text-primary);
}

.info-value.amount {
  color: var(--color-primary);
  font-weight: 600;
}

.info-value.paid {
  color: var(--color-success);
}

.info-value.remaining {
  color: var(--color-danger);
  font-weight: 600;
}

.info-value.desc {
  color: var(--color-text-secondary);
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-actions {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid var(--color-border-light);
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  padding: 6px 16px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  font-weight: 500;
}

.pay-btn {
  background: var(--color-primary);
  color: #fff;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: var(--z-modal);
}

.modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: calc(var(--z-modal) + 1);
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--color-border-light);
}

.modal-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
}

.modal-close {
  font-size: 20px;
  color: var(--color-text-tertiary);
  padding: 4px;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 16px;
}

.modal-footer {
  display: flex;
  gap: 12px;
  padding: 12px 16px;
  border-top: 1px solid var(--color-border-light);
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  font-weight: 500;
}

.modal-btn.cancel {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.modal-btn.confirm {
  background: var(--color-primary);
  color: #fff;
}

.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
}

.picker-box .arrow {
  color: var(--color-text-tertiary);
}

.radio-label {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  margin-right: 12px;
  margin-bottom: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}

/* 确认/取消/重新支付按钮 */
.confirm-btn {
  background: var(--color-success);
  color: #fff;
}

.cancel-btn {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
  margin-right: 8px;
}

/* 支付弹窗内的子操作按钮 */
.modal-sub-actions {
  display: flex;
  gap: 8px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border-light);
}

.sub-action-btn {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  background: var(--color-bg-gray);
}

/* 搜索收款人 */
.search-btn {
  text-align: center;
  padding: 8px 0;
  margin-top: 8px;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
}

.payee-result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--color-border-light);
}

.payee-result-name {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.payee-result-type {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.empty-hint {
  text-align: center;
  padding: 20px 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
}
