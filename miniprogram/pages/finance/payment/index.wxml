<view class="page">
  <!-- Stats bar -->
  <view class="stats-bar" wx:if="{{stats}}">
    <view class="stat-card">
      <text class="stat-label">待付款</text>
      <text class="stat-value stat-warning">¥{{stats.totalPendingAmount || '0.00'}}</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">已付款</text>
      <text class="stat-value stat-success">¥{{stats.totalPaidAmount || '0.00'}}</text>
    </view>
  </view>

  <!-- Tab bar -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'tab-active' : ''}}" data-tab="0" bindtap="switchTab">待付款</view>
    <view class="tab-item {{activeTab === 1 ? 'tab-active' : ''}}" data-tab="1" bindtap="switchTab">收支记录</view>
  </view>

  <!-- Tab 1: 待付款 -->
  <view wx:if="{{activeTab === 0}}" class="tab-panel">
    <empty-state wx:if="{{!loading && pendingList.length === 0}}" text="暂无待付款项" />
    <view class="payable-card" wx:for="{{pendingList}}" wx:key="bizId">
      <view class="card-header">
        <text class="card-tag {{item.bizTypeCls}}">{{item.bizTypeText}}</text>
        <text class="card-biz-no">{{item.bizNo || '—'}}</text>
      </view>
      <text class="payee-name">{{item.payeeName || '—'}}</text>
      <text class="card-order-no" wx:if="{{item.orderNo}}">关联订单 {{item.orderNo}}</text>
      <view class="amount-row">
        <view class="amount-col">
          <text class="amount-label">应付金额</text>
          <text class="amount-val-main">¥{{item.amount || 0}}</text>
        </view>
        <block wx:if="{{item.paidAmount > 0}}">
          <view class="amount-divider"></view>
          <view class="amount-col amount-col-padded">
            <text class="amount-label">已付金额</text>
            <text class="amount-val-paid">¥{{item.paidAmount}}</text>
          </view>
        </block>
        <view class="amount-divider"></view>
        <view class="amount-col amount-col-padded">
          <text class="amount-label">待付金额</text>
          <text class="amount-val-remaining">¥{{item.remainingAmount || item.amount || 0}}</text>
        </view>
      </view>
      <view class="card-footer" wx:if="{{canPay}}">
        <text class="card-desc">{{item.description || '—'}}</text>
        <view class="pay-btn" data-index="{{index}}" bindtap="onOpenPayModal">付款</view>
      </view>
    </view>
    <view class="load-more {{!pendingHasMore ? 'disabled' : ''}}" wx:if="{{loading || !pendingHasMore}}">
      <text>{{loading ? '加载中...' : '没有更多了'}}</text>
    </view>
  </view>

  <!-- Tab 2: 收支记录 -->
  <view wx:if="{{activeTab === 1}}" class="tab-panel">
    <empty-state wx:if="{{!loading && paymentList.length === 0}}" text="暂无收支记录" />
    <view class="payment-card" wx:for="{{paymentList}}" wx:key="id">
      <view class="card-header">
        <text class="card-tag {{item.statusCls}}">{{item.statusText}}</text>
        <text class="card-time">{{item.createTime || '—'}}</text>
      </view>
      <text class="payee-name">{{item.payeeName || '—'}}</text>
      <view class="card-footer-row {{canPay && item.status === 'processing' ? 'footer-justify-between' : ''}}">
        <view class="record-amount-wrap">
          <text class="amount-val">¥{{item.amount || 0}}</text>
          <text class="method-val">{{item.paymentMethodText || '—'}}</text>
        </view>
        <view class="record-actions" wx:if="{{canPay && item.status === 'processing'}}">
          <view class="record-btn record-btn-cancel" data-id="{{item.id}}" bindtap="onCancelRecord">取消</view>
          <view class="record-btn record-btn-confirm" data-id="{{item.id}}" bindtap="onConfirmRecord">确认</view>
        </view>
      </view>
    </view>
    <view class="load-more {{!paymentHasMore ? 'disabled' : ''}}" wx:if="{{loading || !paymentHasMore}}">
      <text>{{loading ? '加载中...' : '没有更多了'}}</text>
    </view>
  </view>

  <!-- Payment inline form -->
  <view wx:if="{{showPayModal}}" class="inline-form-card">

    <!-- ===== Form view ===== -->
    <block wx:if="{{modalView === 'form'}}">
      <!-- Header -->
      <view class="inline-form-title">
        <text class="modal-title">发起支付</text>
        <view class="modal-close icon-close" bindtap="onCancelPay"></view>
      </view>
      <!-- KV list -->
      <view class="modal-kv-list" wx:if="{{currentPayable}}">
        <view class="modal-kv">
          <text class="modal-kv-key">收款方</text>
          <text class="modal-kv-val">{{currentPayable.payeeName}}</text>
        </view>
        <view class="modal-kv">
          <text class="modal-kv-key">业务类型</text>
          <text class="modal-kv-val">{{currentPayable.bizTypeText}}</text>
        </view>
        <view class="modal-kv">
          <text class="modal-kv-key">待付金额</text>
          <text class="modal-kv-val modal-kv-amount">¥{{currentPayable.remainingAmount || currentPayable.amount || 0}}</text>
        </view>
      </view>
      <!-- Form fields -->
      <view class="modal-form-area">
        <view class="mf-item">
          <text class="mf-label mf-required">支付金额</text>
          <view class="amount-input-wrap">
            <text class="amount-input-prefix">¥</text>
            <input class="amount-input" type="digit" placeholder="请输入支付金额" value="{{payForm.amount}}" bindinput="onPayAmountInput" />
          </view>
        </view>
        <view class="mf-item">
          <text class="mf-label">支付方式</text>
          <view class="method-grid">
            <view class="method-btn {{payForm.paymentMethod === item.value ? 'method-active' : ''}}" wx:for="{{paymentMethods}}" wx:key="value" data-value="{{item.value}}" bindtap="onPayMethodSelect">
              <view class="method-check" wx:if="{{payForm.paymentMethod === item.value}}"></view>
              <text>{{item.label}}</text>
            </view>
          </view>
        </view>
        <view class="mf-item">
          <text class="mf-label">收款账户</text>
          <block wx:if="{{payeeAccounts.length > 0}}">
            <picker mode="selector" range="{{payeeAccounts}}" range-key="accountName" bindchange="onSelectAccount">
              <view class="picker-box">
                <text class="picker-text {{selectedAccountId ? '' : 'placeholder'}}">{{selectedAccountId ? selectedAccountName : '选择收款账户'}}</text>
                <view class="arrow icon-arrow-right-sm"></view>
              </view>
            </picker>
          </block>
          <view class="picker-box" wx:else bindtap="onAddAccount">
            <text class="picker-text placeholder">选择收款账户</text>
            <view class="arrow icon-arrow-right-sm"></view>
          </view>
        </view>
        <view class="mf-item">
          <text class="mf-label">备注</text>
          <input class="mf-input" placeholder="选填" value="{{payForm.remark}}" bindinput="onPayRemarkInput" />
        </view>
      </view>
      <!-- Sub actions -->
      <view class="modal-sub-actions">
        <view class="sub-action-btn" bindtap="onSearchPayee">
          <view class="line-icon line-icon--sm icon-search"></view>
          <text>搜索收款人</text>
        </view>
        <view class="sub-action-divider"></view>
        <view class="sub-action-btn" bindtap="onAddAccount">
          <view class="icon-plus-sm"></view>
          <text>新增收款账户</text>
        </view>
      </view>
      <!-- Footer -->
      <view class="inline-form-actions">
        <view class="modal-btn cancel" bindtap="onCancelPay">取消</view>
        <view class="modal-btn confirm" bindtap="onSubmitPay">确认支付</view>
      </view>
    </block>

    <!-- ===== Search payee view ===== -->
    <block wx:if="{{modalView === 'search'}}">
      <view class="inline-form-title">
        <text class="modal-title">搜索收款人</text>
        <view class="modal-close icon-close" bindtap="onBackToForm"></view>
      </view>
      <view class="search-panel">
        <view class="search-input-wrap">
          <view class="search-input-icon"></view>
          <input class="search-input" placeholder="输入收款人名称" value="{{searchKeyword}}" bindinput="onPayeeSearchInput" confirm-type="search" bindconfirm="onPayeeSearch" />
          <view class="search-btn" bindtap="onPayeeSearch">搜索</view>
        </view>
        <view class="search-results">
          <view class="search-result-item" wx:for="{{searchResults}}" wx:key="index" data-index="{{index}}" bindtap="onSelectPayee">
            <text class="search-result-name">{{item.payeeName || item.name}}</text>
            <text class="search-result-type">{{item.payeeType || item.type || ''}}</text>
          </view>
          <view class="search-empty" wx:if="{{!searching && searchResults.length === 0 && searchKeyword}}">
            <text>未找到匹配的收款人</text>
          </view>
          <view class="search-empty" wx:if="{{searching}}">
            <text>搜索中...</text>
          </view>
        </view>
      </view>
    </block>

    <!-- ===== Add account view ===== -->
    <block wx:if="{{modalView === 'addAccount'}}">
      <view class="inline-form-title">
        <text class="modal-title">新增收款账户</text>
        <view class="modal-close icon-close" bindtap="onBackToForm"></view>
      </view>
      <view class="modal-form-area">
        <view class="mf-item">
          <text class="mf-label mf-required">账户名称</text>
          <input class="mf-input" placeholder="如：绍兴面料厂尾款账户" value="{{newAccountForm.accountName}}" bindinput="onAccountInput" data-field="accountName" />
        </view>
        <view class="mf-item">
          <text class="mf-label mf-required">账号</text>
          <input class="mf-input" placeholder="请输入账号" value="{{newAccountForm.accountNumber}}" bindinput="onAccountInput" data-field="accountNumber" />
        </view>
        <view class="mf-item">
          <text class="mf-label">开户行</text>
          <input class="mf-input" placeholder="请输入开户行" value="{{newAccountForm.bankName}}" bindinput="onAccountInput" data-field="bankName" />
        </view>
      </view>
      <view class="inline-form-actions">
        <view class="modal-btn cancel" bindtap="onBackToForm">取消</view>
        <view class="modal-btn confirm" bindtap="onSaveAccount">保存</view>
      </view>
    </block>

  </view>
  <ai-assistant />
</view>
