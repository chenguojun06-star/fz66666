/* =========================================
   订单详情页 · 完整版样式
   ========================================= */
@import '/styles/page-utils.wxss';

.detail-page {
  min-height: 100vh;
  padding: 8px var(--page-padding-x) calc(env(safe-area-inset-bottom) + 60px);
  background: var(--color-bg-page);
}

/* ============ 加载骨架 ============ */
.skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.skel-top {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 12px;
  display: flex;
  gap: 12px;
}
.skel-cover {
  width: 100px;
  height: 130px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  flex-shrink: 0;
}
.skel-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding-top: 4px;
}
.skel-line {
  height: 18px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-sm);
}
.skel-line--lg { height: 24px; width: 60%; }
.skel-line--sm { height: 14px; width: 40%; }
.skel-block {
  height: 100px;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
}
.skel-block--sm { height: 60px; }

/* ============ 通用卡片 ============ */
.top-card, .qty-card, .section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
  /* Apple: removed hard border, use shadow */
}

/* ============ 顶部信息卡 ============ */
.top-card {
  padding: var(--spacing-lg);
  display: flex;
  gap: var(--spacing-lg);
  align-items: flex-start;
}
.top-left {
  width: 100px;
  height: 130px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
  position: relative;
}
.top-left--carousel {
  cursor: pointer;
}
.img-swiper {
  width: 100%;
  height: 100%;
}
.img-swiper image {
  width: 100%;
  height: 100%;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-icon {
  font-size: 16px;
  opacity: 0.3;
}

/* 图片左右切换箭头 */
.img-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 22px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
  border-radius: var(--radius-sm);
  z-index: 2;
  color: var(--color-text-white);
  font-size: 12px;
  line-height: 1;
}
.img-nav:active {
  background: rgba(0, 0, 0, 0.55);
}
.img-nav--prev { left: 3px; }
.img-nav--next { right: 3px; }

/* 图片索引指示器 */
.img-indicator {
  position: absolute;
  bottom: 4px;
  right: 4px;
  background: rgba(0, 0, 0, 0.45);
  border-radius: var(--radius-sm);
  padding: 2px 6px;
  z-index: 2;
}
.img-indicator-text {
  font-size: 11px;
  color: var(--color-text-white);
  font-weight: var(--font-weight-medium);
  line-height: 1;
}

/* 图片类型标签 */
.img-type-tag {
  position: absolute;
  top: 4px;
  left: 4px;
  background: rgba(0, 0, 0, 0.45);
  border-radius: var(--radius-sm);
  padding: 2px 5px;
  z-index: 2;
}
.img-type-tag text {
  font-size: 11px;
  color: var(--color-text-white);
  font-weight: var(--font-weight-medium);
  line-height: 1;
}
.top-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.top-title {
  display: flex;
  align-items: center;
  gap: 5px;
  flex-wrap: wrap;
  margin-bottom: 3px;
}
.order-no {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}
.info-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.info-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  min-width: 28px;
}
.info-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}
.info-value--strong {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.remain-badge {
  font-size: var(--font-size-xs);
  padding: 2px 7px;
  border-radius: var(--radius-sm);
  font-weight: var(--font-weight-medium);
  margin-left: auto;
}
.days-safe    { background: var(--color-success-bg); color: var(--color-success); }
.days-warn    { background: var(--color-warning-bg); color: var(--color-warning); }
.days-urgent  { background: var(--color-danger-bg); color: var(--color-danger); }
.days-overdue { background: var(--color-danger-bg); color: var(--color-danger); font-weight: var(--font-weight-semibold); }

/* ============ 备注卡（紧跟顶部信息卡） ============ */
.remark-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 10px var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  display: flex;
  gap: 8px;
  font-size: var(--font-size-sm);
  box-shadow: var(--shadow-card);
  /* Apple: removed hard border, use shadow */
}
.remark-card .dc-label {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
  min-width: 32px;
}
.remark-card .dc-value {
  flex: 1;
  color: var(--color-text-primary);
  line-height: 1.5;
}

/* ============ 数量进度卡 ============ */
.qty-card {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  background: var(--color-primary-bg);
  position: relative;
  overflow: hidden;
}
.qty-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--color-primary);
}
.qty-col {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.qty-num {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  line-height: 1;
}
.qty-done { color: var(--color-success); }
.qty-remain { color: var(--color-text-secondary); }
.qty-pct { color: var(--color-primary); }
.qty-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}
.qty-div {
  width: 1px;
  height: 36px;
  background: var(--color-border-light);
}

/* 总进度条 */
.progress-bar-wrap {
  margin: -5px 0 5px;
}
.progress-bar {
  height: 6px;
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs);
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  transition: width 0.3s;
}
.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 6px;
}
.progress-qty {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.progress-pct {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

/* ============ 下单矩阵表格 ============ */
.matrix-table {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.matrix-thead, .matrix-tbody {
  min-width: 100%;
}
.matrix-tr {
  display: flex;
  align-items: center;
}
.matrix-tr--head {
  border-bottom: 1px solid var(--color-border-light);
  padding-bottom: 5px;
  margin-bottom: 2px;
}
.matrix-th, .matrix-td {
  flex-shrink: 0;
  min-width: 36px;
  text-align: center;
  font-size: var(--font-size-xs);
  padding: 4px 2px;
  box-sizing: border-box;
}
.matrix-th--color {
  min-width: 50px;
  text-align: left;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.matrix-td--color {
  min-width: 50px;
  text-align: left;
  color: var(--color-text-primary);
  font-size: var(--font-size-xs);
}
.matrix-th--total, .matrix-td--total {
  min-width: 40px;
  text-align: center;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
}
.matrix-td {
  color: var(--color-text-primary);
}
.matrix-tr:not(.matrix-tr--head):not(:last-child) {
  border-bottom: 1px solid var(--color-border-light);
  padding-bottom: 2px;
}
.matrix-tr--total {
  border-top: 2px solid var(--color-primary);
  margin-top: 2px;
  padding-top: 5px;
  font-weight: var(--font-weight-bold);
}
.matrix-tr--total .matrix-td {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

/* ============ 裁剪明细列表 ============ */
.cut-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* ============ 物料采购 ============ */
.mat-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.mat-item {
  padding: 8px 9px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.mat-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.mat-info {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}
.mat-actions {
  display: flex;
  align-items: center;
  gap: 5px;
  flex-shrink: 0;
}
.mat-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.mat-code {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.mat-detail-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.mat-detail-cell {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.mat-detail-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.mat-detail-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}
.mat-detail-value--highlight { color: var(--color-success); font-weight: var(--font-weight-semibold); }
.mat-detail-value--gray { color: var(--color-text-tertiary); }
.mat-receiver {
  padding-top: 2px;
}
.mat-receiver-text {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}
.claim-btn-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 3px 10px;
  border-radius: var(--radius-md);
  border: 1px solid var(--color-primary);
  background: transparent;
  color: var(--color-primary);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  line-height: 1;
}
.claim-btn-inline:active {
  background: var(--color-primary-bg);
}

/* ============ 裁剪明细扩展 ============ */
.cut-item {
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: 8px 10px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.cut-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.cut-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.cut-left {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 1;
  min-width: 0;
}
.cut-no {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
  min-width: 30px;
}
.cut-color, .cut-size {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  padding: 2px 6px;
  border-radius: var(--radius-sm);
}
.cut-right {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}
.cut-qty {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.cut-detail-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.cut-detail-cell {
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.cut-detail-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.cut-detail-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}
.cut-receiver {
  padding-top: 2px;
}
.cut-receiver-text {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}
.cut-scanned {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  background: var(--color-bg-gray);
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  /* Apple: removed hard border, use shadow */
}
.cut-scanned--done {
  background: var(--color-success-bg);
  color: var(--color-success);
  border-color: var(--color-success-border);
}
.see-all-link {
  text-align: center;
  padding-top: 8px;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

/* ============ 区块通用 ============ */
.section-card {
  padding: var(--spacing-lg);
}
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
  position: relative;
  padding-left: 10px;
}
.section-hd::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 14px;
  background: var(--color-primary);
  border-radius: 2px;
}
.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.section-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  padding: 2px 8px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-sm);
  font-weight: var(--font-weight-medium);
}

/* ============ 工序阶段 ============ */
.stage-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.stage-item {
  padding: 9px 10px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
}
.stage-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px;
}
.stage-left {
  display: flex;
  align-items: center;
  gap: 6px;
}
.stage-dot {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
}
.stage-done { 
  background: var(--color-success); 
  color: var(--color-text-white);
}
.stage-doing { 
  background: var(--color-primary); 
  color: var(--color-text-white);
}
.stage-pending { 
  background: var(--color-bg-hover); 
  border: 2px solid var(--color-border);
}

.stage-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.stage-status {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  padding: 2px 7px;
  border-radius: var(--radius-sm);
}
.stage-done.stage-status  { background: var(--color-success-bg); color: var(--color-success); }
.stage-doing.stage-status { background: var(--color-info-bg); color: var(--color-info); }
.stage-pending.stage-status { background: var(--color-bg-hover); color: var(--color-text-secondary); }

.stage-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 2px;
  margin-bottom: 3px;
}
.meta-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.stage-progress {
  display: flex;
  align-items: center;
  gap: 6px;
}
.sp-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  min-width: 40px;
  text-align: right;
}
.sp-bar {
  flex: 1;
  height: 4px;
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs);
  overflow: hidden;
}
.sp-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  transition: width 0.3s;
}
.sp-fill--done { background: var(--color-success); }

/* ============ 扫码记录 ============ */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 10px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
}
.record-left {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 1;
  min-width: 0;
}
.record-scan-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  white-space: nowrap;
}
.record-type {
  font-size: var(--font-size-xs);
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}
.record-type-scan-cutting { background: rgba(124,92,252,0.1); color: var(--color-purple-light); }
.record-type-scan-quality { background: var(--color-warning-bg); color: var(--color-warning); }
.record-type-scan-warehouse { background: var(--color-success-bg); color: var(--color-success); }
.record-type-scan-default { background: var(--color-info-bg); color: var(--color-info); }
.record-type-scan-sewing { background: rgba(236,72,153,0.1); color: #ec4899; }
.record-type-scan-secondary { background: rgba(249,115,22,0.1); color: #f97316; }

.record-proc {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.record-right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.record-operator {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.record-qty {
  font-size: var(--font-size-sm);
  color: var(--color-success);
  font-weight: var(--font-weight-semibold);
}

/* ============ BOM 列表 ============ */
.bom-group {
  margin-bottom: 5px;
}
.bom-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 10px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  margin-bottom: 4px;
}
.bom-left {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 1;
  min-width: 0;
}
.bom-type {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  min-width: 40px;
}
.bom-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.bom-right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.bom-qty {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.bom-price {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
}

/* ============ 裁剪分扎摘要 ============ */
.bundle-summary {
  display: flex;
  align-items: center;
  gap: 8px;
}
.bs-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.bs-scanned { color: var(--color-success); }

/* ============ 款式报价 ============ */
.quotation-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 16px;
}
.qt-cell {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.qt-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.qt-value {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.qt-price {
  color: var(--color-primary);
  font-size: var(--font-size-lg);
}

/* ============ 订单信息扩展 ============ */
.detail-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 12px;
}
.detail-cell {
  width: calc(50% - 6px);
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.detail-cell--full { width: 100%; }
.dc-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.dc-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  word-break: break-all;
}
.dc-value--wrap { line-height: 1.5; }

/* ============ 操作按钮区（横向镂空文字按钮） ============ */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card);
  padding: 10px var(--page-padding-x) calc(env(safe-area-inset-bottom) + 10px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  z-index: var(--z-dropdown);
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
}
.action-btn {
  flex: 1;
  height: var(--btn-height-md);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 var(--spacing-sm);
  border-radius: var(--radius-button);
  background: var(--color-bg-card);
  color: var(--color-primary);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  text-align: center;
  line-height: 1;
  transition: all 0.15s ease;
  box-sizing: border-box;
  box-shadow: var(--shadow-card);
}
.action-btn:active {
  opacity: 0.7;
  transform: scale(0.96);
}

/* 终端状态（已完成/已作废/已关闭）：按钮变灰 + 禁止点击 */
.action-bar--disabled .action-btn {
  opacity: 0.4;
  pointer-events: none;
  border-color: var(--color-border-light);
  color: var(--color-text-tertiary);
}

/* ============ 底部间距 ============ */
.bottom-gap { height: 20px; }

/* ============ 加载失败/空数据兜底 ============ */
.detail-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 20px;
}
.detail-empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
}
.detail-empty-retry {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  padding: 6px 20px;
  border-radius: var(--radius-full);
  background: var(--color-primary-bg);
}
