/* ========================================
   生产管理 · 美团风格订单卡片
   一张订单一张卡片，层次分明
   ======================================== */
@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  padding: 0 var(--page-padding-x) calc(env(safe-area-inset-bottom) + 20px);
  background: var(--color-bg-page);
}

/* ============ 今日概览条 ============ */
.today-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}
.today-left {
  display: flex;
  align-items: baseline;
  gap: 8px;
}
.today-label {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-primary);
}
.today-date {
  font-size: 12px;
  color: var(--color-text-tertiary);
}
.today-scan {
  font-size: 11px;
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.04);
  padding: 3px 10px;
  border-radius: 20px;
}

/* ============ 4 摘要卡片 ============ */
.stats-row {
  display: flex;
  gap: 8rpx;
  padding: 0 0 12rpx;
}
.stat-card {
  flex: 1;
  text-align: center;
  padding: 12rpx 4rpx;
  border-radius: 10px;
  background: var(--color-bg-card);
}
.stat-val {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.1;
}
.stat-lbl {
  display: block;
  font-size: 11px;
  color: var(--color-text-tertiary);
  margin-top: 4px;
}
.stat-card--purple .stat-val { color: #7c5cfc; }
.stat-card--blue   .stat-val { color: var(--color-primary); }
.stat-card--green  .stat-val { color: var(--color-success); }
.stat-card--orange .stat-val { color: var(--color-warning); }

/* 骨架 */
.skeleton-row { padding-bottom: 12px; }
.stat-card--skeleton {
  padding: 14px 4px;
}
.skel-line {
  background: rgba(0, 0, 0, 0.05);
  border-radius: 4px;
  margin: 0 auto;
}
.skel-line--short { width: 60%; height: 20px; margin-bottom: 6px; }
.skel-line--long  { width: 70%; height: 10px; }

/* ============ 搜索栏 ============ */
.search-bar { padding: 0 0 12rpx; }
.search-box {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: 22px;
  padding: 9px 14px;
}
.search-emoji { font-size: 14px; margin-right: 6px; }
.search-input {
  flex: 1;
  font-size: 14px;
  color: var(--color-text-primary);
  height: 24px;
}
.search-clear {
  font-size: 15px;
  color: var(--color-text-tertiary);
  padding: 0 4px;
}

.filter-scroll {
  white-space: nowrap;
  padding: 0 0 12rpx;
}
.filter-pill {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 7px 14px;
  border-radius: 8px;
  background: var(--color-bg-card);
  margin-right: 8px;
  min-width: 52px;
}
.filter-pill--on {
  background: var(--color-primary);
}
.filter-num {
  font-size: 17px;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.1;
}
.filter-text {
  font-size: 11px;
  color: var(--color-text-tertiary);
  margin-top: 2px;
}
.filter-pill--on .filter-num,
.filter-pill--on .filter-text {
  color: #fff;
}

/* 延期 */
.filter-pill--danger .filter-num { color: var(--color-danger); }
.filter-pill--danger.filter-pill--on { background: var(--color-danger); }
.filter-pill--danger.filter-pill--on .filter-num { color: #fff; }

/* 已完成 */
.filter-pill--done .filter-num { color: var(--color-success); }
.filter-pill--done.filter-pill--on { background: var(--color-success); }
.filter-pill--done.filter-pill--on .filter-num { color: #fff; }

/* ============ 订单列表 ============ */
.order-list { padding: 0; }

/* ============ 订单卡片 ============ */
.order-card {
  background: var(--color-bg-card);
  border-radius: 12px;
  margin-bottom: 12px;
  overflow: hidden;
}
.order-card--overdue {
  border-left: 1px solid var(--color-danger);
}

/* — 主行：封面 + 信息 — */
.order-main {
  display: flex;
  padding: 14px;
  gap: 10px;
}

/* 封面图 */
.order-cover {
  width: 90px;
  height: 120px;
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
}
.cover-pic {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  background: var(--color-bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-ph-text {
  font-size: 28px;
}

/* 信息区 */
.order-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.info-line1 {
  display: flex;
  align-items: center;
  gap: 6px;
}
.order-no {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 标签 */
.badge {
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 4px;
  font-weight: 500;
  line-height: 16px;
}
.badge-urgent {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-danger);
}
.badge-gray {
  background: rgba(120, 120, 128, 0.1);
  color: var(--color-text-tertiary);
}
.badge-blue {
  background: rgba(59, 130, 246, 0.1);
  color: var(--color-primary);
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 4px;
  font-weight: 500;
  line-height: 16px;
}

.info-line2 {
  display: flex;
  align-items: center;
  gap: 6px;
}
.info-style {
  font-size: 13px;
  color: var(--color-text-secondary);
}
.info-divider {
  font-size: 12px;
  color: var(--color-border-light);
}
.info-factory {
  font-size: 12px;
  color: var(--color-text-tertiary);
}

.info-line3 {
  display: flex;
  align-items: center;
  gap: 8px;
}
.info-delivery {
  font-size: 12px;
  color: var(--color-text-secondary);
}
.info-remain {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: 500;
}
/* 剩余天数颜色 */
.days-safe    { background: rgba(34, 197, 94, 0.08); color: var(--color-success); }
.days-warn    { background: rgba(245, 158, 11, 0.08); color: var(--color-warning); }
.days-urgent  { background: rgba(239, 68, 68, 0.08); color: var(--color-danger); }
.days-overdue { background: rgba(239, 68, 68, 0.12); color: var(--color-danger); font-weight: 600; }
.days-done    { background: rgba(34, 197, 94, 0.08); color: var(--color-success); }

/* 折叠箭头 */
.order-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  flex-shrink: 0;
}
.arrow-icon {
  font-size: 20px;
  color: var(--color-text-tertiary);
  transition: transform 0.2s;
  font-weight: 300;
}
.arrow-icon--up {
  transform: rotate(90deg);
  color: var(--color-primary);
}

/* — 数量行（交期下方） — */
.info-qty-row {
  display: flex;
  align-items: baseline;
  gap: 4px;
  padding-top: 2px;
}
.iq-num {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-primary);
}
.iq-num--done {
  color: var(--color-success);
}
.iq-num--remain {
  color: var(--color-text-secondary);
}
.iq-lbl {
  font-size: 10px;
  color: var(--color-text-tertiary);
  margin-right: 8px;
}

/* — 进度条（交期下方） — */
.info-progress {
  display: flex;
  align-items: center;
  gap: 8px;
}
.ip-bar {
  flex: 1;
  height: 3px;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 2px;
  overflow: hidden;
}
.ip-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 2px;
  transition: width 0.3s;
}
.ip-fill--overdue {
  background: var(--color-danger);
}
.ip-pct {
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-secondary);
  min-width: 30px;
  text-align: right;
}

/* — 展开区域 — */
.order-expand {
  border-top: 1px solid rgba(0, 0, 0, 0.04);
  padding: 14px;
}

.expand-section {
  margin-bottom: 14px;
}
.expand-section:last-child {
  margin-bottom: 0;
}
.expand-title {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8px;
}

/* 工序节点 */
.process-node {
  margin-bottom: 8px;
}
.process-node:last-child {
  margin-bottom: 0;
}
.node-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 3px;
}
.node-name {
  font-size: 12px;
  color: var(--color-text-secondary);
}
.node-pct {
  font-size: 11px;
  color: var(--color-text-tertiary);
  font-weight: 500;
}
.node-pct--done {
  color: var(--color-success);
}
.node-bar-bg {
  height: 4px;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 2px;
  overflow: hidden;
  position: relative;
}
.node-bundle {
  position: absolute;
  top: -15px;
  right: 0;
  font-size: 9px;
  color: var(--color-text-tertiary);
}
.node-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 2px;
  transition: width 0.3s;
}
.node-bar-fill--done {
  background: var(--color-success);
}

/* 子工序列表 */
.node-sub-procs {
  margin-top: 6px;
  padding-left: 4px;
  border-left: 2px solid var(--color-border);
}
.sub-proc-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 3px 0;
}
.sp-name {
  font-size: 11px;
  color: var(--color-text-secondary);
  flex: 1;
}
.sp-price {
  font-size: 11px;
  color: var(--color-primary);
  font-weight: 500;
  margin-left: 8px;
}
.sp-price--free {
  color: var(--color-text-tertiary);
  font-weight: 400;
}

/* SKU 表格 */
.sku-scroll {
  width: 100%;
}
.sku-table {
  min-width: 100%;
}
.sku-row {
  display: flex;
  border-bottom: 1px solid rgba(0, 0, 0, 0.04);
}
.sku-row--head {
  background: rgba(0, 0, 0, 0.02);
  border-radius: 4px 4px 0 0;
}
.sku-cell {
  flex: 1;
  min-width: 36px;
  padding: 7px 2px;
  font-size: 11px;
  text-align: center;
  color: var(--color-text-primary);
}
.sku-cell--color {
  flex: none;
  width: 48px;
  text-align: left;
  padding-left: 8px;
  font-weight: 500;
  color: var(--color-text-secondary);
}
.sku-cell--total {
  flex: none;
  width: 40px;
  font-weight: 600;
  color: var(--color-primary);
}

/* 快捷操作 */
.expand-actions {
  display: flex;
  gap: 8px;
  padding-top: 12px;
  border-top: 1px solid rgba(0, 0, 0, 0.04);
  margin-top: 4px;
}
.act-btn {
  font-size: 11px;
  padding: 6px 12px;
  border-radius: 6px;
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.04);
}
.act-btn--primary {
  color: var(--color-primary);
  background: rgba(var(--color-primary-rgb), 0.08);
}
.act-btn--warn {
  color: #d48806;
  background: rgba(250, 173, 20, 0.12);
}

/* ============ 加载 / 空状态 ============ */
.load-tip {
  text-align: center;
  padding: 16px 0 24px;
  font-size: 13px;
  color: var(--color-text-tertiary);
}
.load-tip--end {
  font-size: 11px;
}
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.empty-icon {
  font-size: 40px;
  margin-bottom: 10px;
}
.empty-text {
  font-size: 14px;
  color: var(--color-text-tertiary);
}
