/* 进度看板 · 4 张指标摘要卡片 */
@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  padding: 12px 16px calc(env(safe-area-inset-bottom) + 16px);
  background: var(--color-bg-page, #f5f6fa);
  box-sizing: border-box;
}

/* ===== 日期栏 ===== */
.date-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.date-text {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-primary, #1a1a2e);
}
.scan-badge {
  font-size: 11px;
  color: var(--color-text-secondary, #8c8c8c);
  background: rgba(0, 0, 0, 0.04);
  padding: 3px 10px;
  border-radius: 20px;
}

/* ===== 2×2 卡片网格 ===== */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

/* ===== 摘要卡片 ===== */
.summary-card {
  width: calc(50% - 6px);
  background: var(--color-bg-card, #ffffff);
  border-radius: var(--radius-md, 12px);
  padding: 16px;
  box-sizing: border-box;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

/* 卡片左侧色条装饰 */
.summary-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12px;
  bottom: 12px;
  width: 3px;
  border-radius: 2px;
}
.card--purple::before { background: #7c5cfc; }
.card--blue::before   { background: #3b82f6; }
.card--green::before  { background: #22c55e; }
.card--orange::before { background: #f59e0b; }

/* ===== 卡片头部 ===== */
.card-hd {
  display: flex;
  align-items: center;
  margin-bottom: 14px;
}
.card-icon {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  margin-right: 8px;
  flex-shrink: 0;
}
.icon--purple { background: rgba(124, 92, 252, 0.1); }
.icon--blue   { background: rgba(59, 130, 246, 0.1); }
.icon--green  { background: rgba(34, 197, 94, 0.1); }
.icon--orange { background: rgba(245, 158, 11, 0.1); }

.card-title {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-text-secondary, #8c8c8c);
}

/* ===== 指标体 ===== */
.card-bd {
  display: flex;
  align-items: flex-end;
  gap: 0;
}
.metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.metric-divider {
  width: 1px;
  height: 28px;
  background: rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}
.metric-val {
  font-size: 28px;
  font-weight: 700;
  color: var(--color-text-primary, #1a1a2e);
  line-height: 1.1;
}
.metric-lbl {
  font-size: 11px;
  color: var(--color-text-secondary, #8c8c8c);
  margin-top: 4px;
}

/* 数值变体 */
.val--muted {
  color: var(--color-text-secondary, #8c8c8c);
  font-size: 22px;
  font-weight: 600;
}
.val--danger {
  color: #ef4444;
}

/* ===== 骨架屏 ===== */
.skeleton {
  animation: pulse 1.5s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%      { opacity: 0.4; }
}
.skel-line {
  background: rgba(0, 0, 0, 0.06);
  border-radius: 4px;
}
.skel-title {
  width: 60%;
  height: 16px;
  margin-bottom: 16px;
}
.skel-num {
  width: 40%;
  height: 32px;
  margin-bottom: 8px;
}
.skel-label {
  width: 50%;
  height: 12px;
}
