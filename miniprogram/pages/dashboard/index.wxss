/* 进度看板 — 样式 */
@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  background: var(--color-bg-page, #f5f7fa);
  padding: 12px;
  padding-top: calc(env(safe-area-inset-top) + 100rpx);
  box-sizing: border-box;
}

/* ======== 统计条 ======== */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 10px 8px;
  margin-bottom: 12px;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-xl, 16px);
  box-shadow: 0 4px 14px rgba(var(--color-primary-rgb, 59,130,246), 0.06);
}

.stat-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6px 10px;
  border-radius: var(--radius-full, 999px);
  transition: background 0.2s;
}

.stat-pill--active {
  background: rgba(var(--color-primary-rgb, 59,130,246), 0.1);
}

.stat-val {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text-primary, #1a1a2e);
}

.stat-pill--active .stat-val {
  color: var(--color-primary, #3b82f6);
}

.stat-label {
  font-size: 11px;
  color: var(--color-text-secondary, #8c8c8c);
  margin-top: 2px;
}

.stat-pill--active .stat-label {
  color: var(--color-primary, #3b82f6);
}

/* ======== 订单卡片 ======== */
.order-list {
  padding-bottom: 20px;
}

.order-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 12px);
  border: 1px solid rgba(var(--color-primary-rgb, 59,130,246), 0.1);
  margin-bottom: 10px;
  padding: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  transition: box-shadow 0.2s;
}

.order-card--closed {
  opacity: 0.6;
}

.order-card--overdue {
  border-color: var(--color-error, #ff4d4f);
  border-width: 1.5px;
}

/* ======== 卡片头部 ======== */
.order-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.cover-box {
  width: 200rpx;
  height: 200rpx;
  min-width: 200rpx;
  border-radius: var(--radius-md, 8px);
  overflow: hidden;
  background: #f0f2f5;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  background: linear-gradient(135deg, #e8ecf1, #f0f2f5);
}

.header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.order-no {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-text-primary, #1a1a2e);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 180px;
}

.tag {
  font-size: 10px;
  padding: 1px 6px;
  border-radius: var(--radius-full, 999px);
  white-space: nowrap;
}

.tag-urgent {
  color: var(--color-error, #ff4d4f);
  background: rgba(255, 77, 79, 0.1);
}

.tag-plate {
  color: var(--color-primary, #3b82f6);
  background: rgba(var(--color-primary-rgb, 59,130,246), 0.1);
}

.header-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--color-text-secondary, #8c8c8c);
}

.style-no {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 120px;
}

.meta-sep {
  color: var(--color-border, #e5e7eb);
}

.meta-factory {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100px;
}

.header-delivery {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
}

.delivery-date {
  color: var(--color-text-secondary, #8c8c8c);
}

.remain-days {
  font-weight: 600;
  padding: 0 6px;
  border-radius: var(--radius-full, 999px);
  font-size: 10px;
  line-height: 18px;
}

.days-safe {
  color: var(--color-success, #52c41a);
  background: rgba(82, 196, 26, 0.1);
}

.days-warn {
  color: #f7a600;
  background: rgba(247, 166, 0, 0.1);
}

.days-urgent {
  color: var(--color-error, #ff4d4f);
  background: rgba(255, 77, 79, 0.1);
}

.days-overdue {
  color: #fff;
  background: var(--color-error, #ff4d4f);
}

.days-done {
  color: var(--color-text-secondary, #8c8c8c);
  background: rgba(140, 140, 140, 0.1);
}

/* 总进度条 */
.progress-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 2px;
}

.progress-bar {
  flex: 1;
  height: 6px;
  background: var(--color-border-light, #f0f0f0);
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 3px;
  background: linear-gradient(90deg, var(--color-primary, #3b82f6), #60a5fa);
  transition: width 0.3s ease;
}

.progress-pct {
  font-size: 12px;
  font-weight: 700;
  color: var(--color-primary, #3b82f6);
  min-width: 36px;
  text-align: right;
}

/* 折叠箭头 */
.collapse-arrow {
  font-size: 14px;
  color: var(--color-text-secondary, #8c8c8c);
  transition: transform 0.25s ease;
  padding-top: 2px;
}

.collapse-arrow--open {
  transform: rotate(180deg);
}

/* ======== 展开区域 ======== */
.order-body {
  border-top: 1px solid var(--color-border-light, #f0f0f0);
  margin-top: 10px;
  padding-top: 10px;
}

/* 数量统计行 */
.body-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 12px;
}

.body-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.body-stat-val {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text-primary, #1a1a2e);
}

.body-stat-label {
  font-size: 11px;
  color: var(--color-text-secondary, #8c8c8c);
  margin-top: 2px;
}

/* 工序进度列表 */
.process-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.process-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.process-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.process-name {
  font-size: 12px;
  color: var(--color-text-primary, #1a1a2e);
}

.process-pct {
  font-size: 12px;
  font-weight: 600;
  color: var(--color-text-secondary, #8c8c8c);
}

.process-done {
  color: var(--color-success, #52c41a);
}

.process-bar {
  height: 4px;
  background: var(--color-border-light, #f0f0f0);
  border-radius: 2px;
  overflow: hidden;
}

.process-bar-fill {
  height: 100%;
  border-radius: 2px;
  background: var(--color-primary, #3b82f6);
  transition: width 0.3s ease;
}

.process-bar-fill--done {
  background: var(--color-success, #52c41a);
}

/* ======== 颜色尺码矩阵 ======== */
.sku-section {
  margin-top: 12px;
}

.sku-title {
  font-size: 12px;
  font-weight: 600;
  color: var(--color-text-secondary, #8c8c8c);
  margin-bottom: 6px;
}

.sku-table {
  border: 1px solid var(--color-border-light, #f0f0f0);
  border-radius: var(--radius-md, 8px);
  overflow: hidden;
  font-size: 11px;
}

.sku-row {
  display: flex;
  align-items: center;
}

.sku-row--header {
  background: #f8f9fa;
  font-weight: 600;
  color: var(--color-text-secondary, #8c8c8c);
}

.sku-row:not(:last-child) {
  border-bottom: 1px solid var(--color-border-light, #f0f0f0);
}

.sku-cell {
  flex: 1;
  text-align: center;
  padding: 5px 2px;
  color: var(--color-text-primary, #1a1a2e);
  min-width: 32px;
}

.sku-cell--color {
  flex: 1.3;
  text-align: left;
  padding-left: 8px;
  font-weight: 600;
}

.sku-cell--total {
  font-weight: 600;
  color: var(--color-primary, #3b82f6);
}

/* ======== 加载状态 ======== */
.loading-more {
  text-align: center;
  padding: 16px;
  font-size: 13px;
  color: var(--color-text-secondary, #8c8c8c);
}

.no-more {
  text-align: center;
  padding: 16px;
  font-size: 12px;
  color: var(--color-text-secondary, #8c8c8c);
}
