/* ========================================
   生产管理 · 美团风格订单卡片
   一张订单一张卡片，层次分明
   ======================================== */
@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  padding: 0 var(--page-padding-x) calc(env(safe-area-inset-bottom) + 10px);
  background: var(--color-bg-page);
}

/* ============ 今日概览条 ============ */
.today-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-xs) 0;
}
.today-left {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-xs);
}
.today-label {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.today-date {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.today-scan {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-hover);
  padding: 2px 10px;
  border-radius: var(--radius-full);
}

/* ============ 4 摘要卡片 ============ */
.stats-row {
  display: flex;
  gap: 8px;
  padding: 0 0 12px;
}
.stat-card {
  flex: 1;
  text-align: center;
  padding: 12px 4px;
  border-radius: var(--radius-card);
  background: var(--color-bg-card);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.03);
}
.stat-val {
  display: block;
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.1;
}
.stat-lbl {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: var(--spacing-xs);
}
.stat-card--purple .stat-val { color: var(--color-purple-light); }
.stat-card--blue   .stat-val { color: var(--color-primary); }
.stat-card--green  .stat-val { color: var(--color-success); }
.stat-card--orange .stat-val { color: var(--color-warning); }

/* 骨架 */
.skeleton-row { padding-bottom: var(--spacing-sm); }
.stat-card--skeleton {
  padding: var(--spacing-sm) 2px;
}
.skel-line {
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs);
  margin: 0 auto;
}
.skel-line--short { width: 60%; height: 20px; margin-bottom: 6px; }
.skel-line--long  { width: 70%; height: 10px; }

.filter-scroll {
  white-space: nowrap;
  padding: 0 0 var(--spacing-xs);
}

.filter-pill {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 7px 14px;
  border-radius: var(--radius-card);
  background: var(--color-bg-card);
  margin-right: 8px;
  min-width: 52px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.03);
}
.filter-pill--on {
  background: var(--color-primary);
}
.filter-num {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.1;
}
.filter-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 2px;
}
.filter-pill--on .filter-num,
.filter-pill--on .filter-text {
  color: var(--color-text-white);
}

/* 延期 */
.filter-pill--danger .filter-num { color: var(--color-danger); }
.filter-pill--danger.filter-pill--on { background: var(--color-danger); }
.filter-pill--danger.filter-pill--on .filter-num { color: var(--color-text-white); }

/* 临近交期 */
.filter-pill--warning .filter-num { color: var(--color-warning); }
.filter-pill--warning.filter-pill--on { background: var(--color-warning); }
.filter-pill--warning.filter-pill--on .filter-num { color: var(--color-text-white); }

/* 已完成 */
.filter-pill--done .filter-num { color: var(--color-success); }
.filter-pill--done.filter-pill--on { background: var(--color-success); }
.filter-pill--done.filter-pill--on .filter-num { color: var(--color-text-white); }

/* ============ 订单列表 ============ */
.order-list { padding: 0; }

/* ============ 订单卡片 ============ */
.order-card {
  background: var(--color-bg-card);
  border-radius: 16px;
  margin-bottom: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.03);
}
.order-card--overdue {
  box-shadow: 0 2px 8px rgba(255, 77, 79, 0.08), 0 1px 2px rgba(255, 77, 79, 0.06);
}

/* — 主行：封面 + 信息 — */
.order-main {
  display: flex;
  padding: var(--spacing-md);
  gap: var(--spacing-sm);
}

/* 封面图 - 长方形，与样衣开发一致 */
.order-cover {
  width: 60px;
  height: 80px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}
.cover-pic {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-ph-text {
  font-size: var(--font-size-2xl);
}

/* 信息区 */
.order-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

/* 顶部：订单号 + status tag */
.info-top {
  display: flex;
  align-items: center;
  gap: 5px;
  flex-wrap: wrap;
}
.order-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

/* 规格信息行 - 标签+值（款号、工厂、交期等） */
.info-spec-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.info-spec-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.info-spec-value {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.info-remain {
  font-size: var(--font-size-sm);
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  font-weight: var(--font-weight-medium);
}

/* 剩余天数颜色 */
.days-safe    { background: var(--color-success-bg); color: var(--color-success); }
.days-warn    { background: var(--color-warning-bg); color: var(--color-warning); }
.days-urgent  { background: var(--color-danger-bg); color: var(--color-danger); }
.days-overdue { background: var(--color-danger-bg); color: var(--color-danger); font-weight: var(--font-weight-semibold); }
.days-done    { background: var(--color-success-bg); color: var(--color-success); }

/* 折叠箭头 */
.order-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  flex-shrink: 0;
}
.arrow-icon {
  font-size: 14px;
  color: var(--color-text-tertiary);
  transition: transform 0.2s;
  font-weight: 300;
}
.arrow-icon--up {
  transform: rotate(90deg);
  color: var(--color-primary);
}

/* — 数量行（交期下方） — */
.info-qty-row {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding-top: 3px;
}
.iq-main {
  display: flex;
  align-items: baseline;
  gap: 2px;
}
.iq-num {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.iq-unit {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.iq-sub {
  display: flex;
  align-items: center;
  gap: 3px;
}
.iq-num--done {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-success);
}
.iq-num--remain {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.iq-lbl {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.iq-divider {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
}

/* — 进度条（交期下方） — */
.info-progress {
  display: flex;
  align-items: center;
  gap: 8px;
}
.ip-bar {
  flex: 1;
  height: 3px;
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs);
  overflow: hidden;
}
.ip-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  transition: width 0.3s;
}
.ip-fill--overdue {
  background: var(--color-danger);
}
.ip-pct {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  min-width: 30px;
  text-align: right;
}

/* — 展开区域 — */
.order-expand {
  border-top: 1px solid var(--color-border-light);
  padding: var(--spacing-md);
}

.expand-section {
  margin-bottom: var(--spacing-md);
}
.expand-section:last-child {
  margin-bottom: 0;
}
.expand-title {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

/* 工序节点 */
.process-node {
  margin-bottom: var(--spacing-sm);
}
.process-node:last-child {
  margin-bottom: 0;
}
.node-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2px;
}
.node-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.node-pct {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}
.node-pct--done {
  color: var(--color-success);
}
.node-meta {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: 1.4;
}
.node-qty {
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}
.node-dot {
  margin: 0 6px;
  color: var(--color-text-tertiary);
}
.node-bundle-text {
  color: var(--color-text-tertiary);
}
.node-bar-bg {
  height: 4px;
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs);
  overflow: hidden;
  position: relative;
}
.node-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  transition: width 0.3s;
}
.node-bar-fill--done {
  background: var(--color-success);
}

/* 子工序列表 */
.node-sub-procs {
  margin-top: 6px;
  padding-left: 4px;
  border-left: 2px solid var(--color-border);
}
.sub-proc-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 3px 0;
}
.sp-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex: 1;
}
.sp-price {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  margin-left: var(--spacing-sm);
}
.sp-price--free {
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-normal);
}

/* SKU 表格 */
.sku-scroll {
  width: 100%;
}
.sku-table {
  min-width: 100%;
}
.sku-row {
  display: flex;
  border-bottom: 1px solid var(--color-border-light);
}
.sku-row--head {
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs) var(--radius-xs) 0 0;
}
.sku-cell {
  flex: 1;
  min-width: 36px;
  padding: 7px 2px;
  font-size: var(--font-size-xs);
  text-align: center;
  color: var(--color-text-primary);
}
.sku-cell--color {
  flex: none;
  width: 48px;
  text-align: left;
  padding-left: 8px;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.sku-cell--total {
  flex: none;
  width: 40px;
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

/* 快捷操作 - 填充风格按钮（与外发工厂页面统一） */
.expand-actions {
  display: flex;
  gap: var(--spacing-md);
  padding-top: var(--spacing-lg);
  margin-top: 2px;
  flex-wrap: wrap;
}
.card-action-btn,
.act-btn {
  font-size: var(--font-size-xs);
  padding: 3px var(--spacing-md);
  border-radius: var(--radius-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  border: none;
  line-height: 1.4;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
}
.act-btn--primary {
  color: var(--color-primary);
  background: var(--color-info-bg);
}
.act-btn--warn {
  color: var(--color-warning);
  background: var(--color-warning-bg);
}
.act-btn--detail {
  color: var(--color-purple-light);
  background: rgba(124, 92, 252, 0.1);
  font-weight: 600;
}
.act-btn--remark {
  color: var(--color-primary);
  background: var(--color-primary-bg);
}

/* ============ 加载 / 空状态 ============ */
.load-tip {
  text-align: center;
  padding: 16px 0 24px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.load-tip--end {
  font-size: var(--font-size-xs);
}
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.empty-icon {
  font-size: 16px;
  margin-bottom: var(--spacing-sm);
}
.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}
