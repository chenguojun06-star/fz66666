<!-- 生产管理 · 美团风格订单卡片 -->
<custom-nav title="生产管理" show-back="{{true}}" />

<view class="page">
  <!-- 今日概览 · 紧凑横条 -->
  <view class="today-bar">
    <view class="today-left">
      <text class="today-label">今日概览</text>
      <text class="today-date">{{todayStr}}</text>
    </view>
    <text class="today-scan" wx:if="{{todayScanCount > 0}}">{{todayScanCount}} 次扫码</text>
  </view>

  <!-- 4 张摘要卡片 · 横向等分 -->
  <view class="stats-row" wx:if="{{!loading}}">
    <view class="stat-card stat-card--purple" wx:if="{{cards.sample.developing > 0 || cards.sample.completed > 0}}">
      <text class="stat-val">{{cards.sample.developing}}</text>
      <text class="stat-lbl">样衣开发</text>
    </view>
    <view class="stat-card stat-card--blue">
      <text class="stat-val">{{cards.production.total}}</text>
      <text class="stat-lbl">生产订单</text>
    </view>
    <view class="stat-card stat-card--green">
      <text class="stat-val">{{cards.inbound.today}}</text>
      <text class="stat-lbl">今日入库</text>
    </view>
    <view class="stat-card stat-card--orange">
      <text class="stat-val">{{cards.outbound.today}}</text>
      <text class="stat-lbl">今日出库</text>
    </view>
  </view>
  <view class="stats-row skeleton-row" wx:else>
    <view class="stat-card stat-card--skeleton" wx:for="{{4}}" wx:key="index">
      <view class="skel-line skel-line--short"></view>
      <view class="skel-line skel-line--long"></view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-emoji">🔍</text>
      <input class="search-input" placeholder="搜索订单号 / 款号" value="{{searchKey}}" bindinput="onSearchInput" confirm-type="search" />
      <text class="search-clear" wx:if="{{searchKey}}" catchtap="onSearchClear">✕</text>
    </view>
  </view>

  <!-- 状态过滤条 -->
  <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-pill {{activeFilter === item.key ? 'filter-pill--on' : ''}} {{item.key === 'overdue' ? 'filter-pill--danger' : ''}} {{item.key === 'completed' ? 'filter-pill--done' : ''}}"
          wx:for="{{statFilters}}" wx:key="key"
          data-key="{{item.key}}" bindtap="onStatTap">
      <text class="filter-num">{{statCounts[item.key] || 0}}</text>
      <text class="filter-text">{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- ===== 订单列表 · 美团风格 ===== -->
  <view class="order-list" wx:if="{{orders.list.length > 0}}">
    <view class="order-card {{item.expanded ? 'order-card--open' : ''}} {{item.remainDaysClass === 'days-overdue' ? 'order-card--overdue' : ''}}"
          wx:for="{{orders.list}}" wx:key="id">

      <!-- 主行：封面图 + 全部信息 -->
      <view class="order-main" data-index="{{index}}" bindtap="onCardToggle">
        <view class="order-cover" catchtap="onCoverPreview" data-url="{{item.styleCoverUrl}}">
          <image wx:if="{{item.styleCoverUrl}}" class="cover-pic" src="{{item.styleCoverUrl}}" mode="aspectFill" lazy-load />
          <view wx:else class="cover-placeholder">
            <text class="cover-ph-text">📦</text>
          </view>
        </view>

        <view class="order-info">
          <view class="info-line1">
            <text class="order-no">{{item.orderNo}}</text>
            <text wx:if="{{item.urgencyTagText === '急'}}" class="badge badge-urgent">急</text>
            <text wx:if="{{item.plateTypeTagText}}" class="badge badge-blue">{{item.plateTypeTagText}}</text>
          </view>
          <view class="info-line2">
            <text class="info-style">{{item.styleNo || '暂无款号'}}</text>
            <text class="info-divider" wx:if="{{item.factoryName}}">|</text>
            <text class="info-factory" wx:if="{{item.factoryName}}">{{item.factoryName}}</text>
          </view>
          <view class="info-line3" wx:if="{{item.deliveryDateStr}}">
            <text class="info-delivery">交期 {{item.deliveryDateStr}}</text>
            <text class="info-remain {{item.remainDaysClass}}" wx:if="{{item.remainDaysText}}">{{item.remainDaysText}}</text>
          </view>
          <!-- 数量 + 进度 -->
          <view class="info-qty-row">
            <text class="iq-num">{{item.cuttingQty || item.totalQuantity || item.orderQuantity || 0}}</text>
            <text class="iq-lbl">总数</text>
            <text class="iq-num iq-num--done">{{item.completedQuantity || 0}}</text>
            <text class="iq-lbl">已完成</text>
            <text class="iq-num iq-num--remain">{{item.remainQuantity || 0}}</text>
            <text class="iq-lbl">剩余</text>
          </view>
          <view class="info-progress">
            <view class="ip-bar">
              <view class="ip-fill {{item.remainDaysClass === 'days-overdue' ? 'ip-fill--overdue' : ''}}" style="width:{{item.calculatedProgress > 100 ? 100 : item.calculatedProgress}}%"></view>
            </view>
            <text class="ip-pct">{{item.calculatedProgress || 0}}%</text>
          </view>
        </view>

        <view class="order-arrow">
          <text class="arrow-icon {{item.expanded ? 'arrow-icon--up' : ''}}">›</text>
        </view>
      </view>

      <!-- 展开区域 -->
      <view class="order-expand" wx:if="{{item.expanded}}" catchtap="">
        <!-- 工序进度明细 -->
        <view class="expand-section" wx:if="{{item.processNodes.length > 0}}">
          <text class="expand-title">工序进度</text>
          <view class="process-node" wx:for="{{item.processNodes}}" wx:for-item="node" wx:key="name">
            <view class="node-hd">
              <text class="node-name">{{node.name}}</text>
              <text class="node-pct {{node.percent >= 100 ? 'node-pct--done' : ''}}">{{node.percent}}%</text>
            </view>
            <view class="node-bar-bg">
              <text class="node-bundle" wx:if="{{node.bundleInfo}}">{{node.bundleInfo.scanned}}/{{node.bundleInfo.total}}菲</text>
              <view class="node-bar-fill {{node.percent >= 100 ? 'node-bar-fill--done' : ''}}" style="width:{{node.percent}}%"></view>
            </view>
            <!-- 子工序列表 -->
            <view class="node-sub-procs" wx:if="{{node.children && node.children.length > 0}}">
              <view class="sub-proc-item" wx:for="{{node.children}}" wx:for-item="sp" wx:key="name">
                <text class="sp-name">{{sp.name}}</text>
                <text class="sp-price" wx:if="{{sp.unitPrice > 0}}">¥{{sp.unitPrice}}</text>
                <text class="sp-price sp-price--free" wx:else>待定价</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 颜色尺码矩阵 -->
        <view class="expand-section" wx:if="{{item.colorGroups && item.colorGroups.length > 0}}">
          <text class="expand-title">颜色尺码</text>
          <scroll-view scroll-x class="sku-scroll" enhanced show-scrollbar="{{false}}">
            <view class="sku-table">
              <view class="sku-row sku-row--head">
                <text class="sku-cell sku-cell--color">颜色</text>
                <text class="sku-cell" wx:for="{{item.allSizes}}" wx:for-item="sz" wx:key="*this">{{sz}}</text>
                <text class="sku-cell sku-cell--total">合计</text>
              </view>
              <view class="sku-row" wx:for="{{item.colorGroups}}" wx:for-item="cg" wx:key="color">
                <text class="sku-cell sku-cell--color">{{cg.color}}</text>
                <text class="sku-cell" wx:for="{{item.allSizes}}" wx:for-item="sz" wx:key="*this">{{cg.sizeMap[sz] || '-'}}</text>
                <text class="sku-cell sku-cell--total">{{cg.total}}</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- 快捷操作 -->
        <view class="expand-actions">
          <view class="act-btn" catchtap="onCopyOrderNo" data-order-no="{{item.orderNo}}">复制单号</view>
          <view class="act-btn act-btn--primary" catchtap="onViewCuttingBundles" data-order-no="{{item.orderNo}}">查看裁剪</view>
          <view class="act-btn act-btn--primary" catchtap="onEditProcess" data-order-id="{{item.id}}" data-order-no="{{item.orderNo}}" data-status="{{item.status}}" wx:if="{{item.status === 'production'}}">编辑工序</view>
          <view class="act-btn act-btn--warn" catchtap="onTransferOrder" data-order-id="{{item.id}}" data-order-no="{{item.orderNo}}">转单</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-tip" wx:if="{{orders.loading}}">加载中…</view>
  <view class="load-tip load-tip--end" wx:if="{{!orders.loading && !orders.hasMore && orders.list.length > 0}}">— 没有更多了 —</view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !orders.loading && orders.list.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单数据</text>
  </view>

  <!-- 小云 AI 助手 -->
  <ai-assistant id="dashboardAiAssistant" notice-count="{{unreadNoticeCount}}" />
</view>
