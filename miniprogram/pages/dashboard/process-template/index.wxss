/* 工序模板配置页 - 苹果 Grouped List 风格 */
@import '/styles/page-utils.wxss';

.page-bg {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 60px;
}

/* 顶部款式信息卡 */
.status-card {
  margin: 12px 16px;
  
  background: var(--color-primary-bg);
  
  box-shadow: var(--shadow-sm);
  
  backdrop-filter: none;
  -webkit-backdrop-filter: none;

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.status-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}
.status-card-row {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
  flex: 1;
}
.status-card-icon {
  flex-shrink: 0;
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 2px;
}
.status-card-icon svg {
  width: 24px;
  height: 24px;
}
.status-card-title {
  font-size: 20px;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.02em;
}
.status-card-sub {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}
.status-card-meta {
  display: flex;
  gap: 6px;
  margin-top: 6px;
}
.meta-chip {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: var(--color-bg-card);
  padding: 0 10px;
  height: 28px;
  line-height: 28px;
  border-radius: var(--radius-sm);
  font-variant-numeric: tabular-nums;
  font-weight: var(--font-weight-medium);
}
.meta-chip--price {
  color: var(--color-primary);
  background: var(--color-bg-card);
  font-variant-numeric: tabular-nums;
}

/* 加载 */
.loading-wrap {
  padding: 40px 0;
  text-align: center;
}
.loading-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

/* 阶段分组列表 */
.group-list {
  padding: 12px 16px;
}
.group {
  margin-bottom: 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

/* 组头 */
.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 12px;
}
.group-header-left {
  display: flex;
  align-items: center;
  gap: 6px;
}
.group-header-name {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.group-header-count {
  font-size: var(--font-size-2xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-page);
  padding: 1px 6px;
  border-radius: var(--radius-sm);
  min-width: 16px;
  text-align: center;
}
.group-header-right {
  display: flex;
  align-items: center;
  gap: 10px;
}
.group-header-add {
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2px;
}
.group-header-add svg {
  width: 18px;
  height: 18px;
}
.group-header-arrow {
  color: var(--color-text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2px;
  transition: transform 0.2s;
  transform: rotate(-90deg);
}
.group-header-arrow svg {
  width: 16px;
  height: 16px;
}
.group-header-arrow.arrow-down {
  transform: rotate(0deg);
}

/* 工序列表 */
.cell-list {
  padding: 0;
}
.cell-empty {
  padding: 12px;
  text-align: center;
}
.cell-empty-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.cell {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 10px 12px;
  border-top: 1px solid var(--color-border);
}
.cell:first-child {
  border-top: none;
}
.cell-main {
  flex: 1;
  min-width: 0;
}
.cell-title-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
}
.cell-title {
  font-size: 15px;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.cell-code {
  font-size: var(--font-size-xxs);
  color: var(--color-text-secondary);
  background: var(--color-bg-page);
  padding: 1px 6px;
  border-radius: var(--radius-xs);
}
.cell-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.cell-meta {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.cell-meta--price {
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  font-variant-numeric: tabular-nums;
}
.cell-diff-badge {
  font-size: var(--font-size-xxs);
  padding: 1px 4px;
  border-radius: var(--radius-xs);
  font-weight: var(--font-weight-medium);
}
.cell-diff-badge--easy {
  color: var(--color-success);
  background: var(--color-success-bg);
}
.cell-diff-badge--medium {
  color: var(--color-warning);
  background: var(--color-warning-bg);
}
.cell-diff-badge--hard {
  color: var(--color-danger);
  background: var(--color-danger-bg);
}
.cell-desc {
  display: block;
  margin-top: 4px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cell-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 2px;
  padding-left: 8px;
  flex-shrink: 0;
}
.cell-action {
  width: 32px;
  height: 32px;
  padding: 4px;
  border-radius: var(--radius-sm);
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cell-action svg {
  width: 14px;
  height: 14px;
}
.cell-action--edit {
  color: var(--color-text-tertiary);
}
.cell-action--del {
  color: var(--color-text-tertiary);
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 1px solid var(--color-border);
  z-index: var(--z-dropdown);
}
.action-btn {
  flex: 1;
  height: var(--btn-height-md);
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  border: none;
  line-height: var(--btn-height-md);
}
.action-btn--secondary {
  background: var(--color-bg-card);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
}
.action-btn--primary {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.action-btn--primary[loading]::before {
  display: none;
}

/* 内联表单 */
.inline-form-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 16px;
  margin: 12px 16px;
  box-shadow: var(--shadow-sm);
}
.inline-form-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}
.modal-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.modal-close {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
  padding: 0 4px;
}
.modal-body {
  padding: 8px 12px;
}
.form-item {
  margin-bottom: 10px;
}
.form-label {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 4px;
}
.form-input {
  width: 100%;
  height: var(--input-height);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  /* Apple: removed hard border, use shadow */
}
.form-textarea {
  width: 100%;
  min-height: 60px;
  padding: 8px var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  /* Apple: removed hard border, use shadow */
}
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: var(--input-height);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  /* Apple: removed hard border, use shadow */
}
.form-picker-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
  transform: rotate(90deg);
}
.inline-form-actions {
  display: flex;
  gap: 8px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}
.modal-btn {
  flex: 1;
  height: var(--btn-height-md);
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: 600;
  border: none;
  line-height: var(--btn-height-md);
}
.modal-btn--cancel {
  background: var(--color-bg-page);
  color: var(--color-text-primary);
  /* Apple: removed hard border, use shadow */
}
.modal-btn--confirm {
  background: var(--color-primary);
  color: var(--color-text-white);
}
