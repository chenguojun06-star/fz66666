/* 工序模板配置页 - 苹果 Grouped List 风格 */
@import '/styles/page-utils.wxss';

.page-bg {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: 60px;
}

/* 顶部款式信息卡 */
.status-card {
  margin: 8px 12px 0;
  padding: 10px 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}
.status-card-row {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.status-card-title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.status-card-sub {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.status-card-meta {
  display: flex;
  gap: 6px;
  margin-top: 6px;
}
.meta-chip {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  padding: 2px 8px;
  border-radius: var(--radius-full);
}
.meta-chip--price {
  color: var(--color-primary);
  background: var(--color-primary-bg);
  font-variant-numeric: tabular-nums;
}

/* 加载 */
.loading-wrap {
  padding: 40px 0;
  text-align: center;
}
.loading-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

/* 阶段分组列表 */
.group-list {
  padding: 8px 12px;
}
.group {
  margin-bottom: 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}

/* 组头 */
.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  border-bottom: 1px solid var(--color-border-light);
}
.group-header-left {
  display: flex;
  align-items: center;
  gap: 6px;
}
.group-header-name {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.group-header-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  padding: 1px 6px;
  border-radius: var(--radius-full);
  min-width: 16px;
  text-align: center;
}
.group-header-right {
  display: flex;
  align-items: center;
  gap: 10px;
}
.group-header-add {
  font-size: 18px;
  color: var(--color-primary);
  line-height: 1;
  padding: 0 4px;
}
.group-header-arrow {
  font-size: 16px;
  color: var(--color-text-tertiary);
  transform: rotate(90deg);
  transition: transform 0.2s;
}
.group-header-arrow.arrow-down {
  transform: rotate(270deg);
}

/* 工序列表 */
.cell-list {
  padding: 0;
}
.cell-empty {
  padding: 12px;
  text-align: center;
}
.cell-empty-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.cell {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 10px 12px;
  border-bottom: 1px solid var(--color-border-light);
}
.cell:last-child {
  border-bottom: none;
}
.cell-main {
  flex: 1;
  min-width: 0;
}
.cell-title-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 4px;
}
.cell-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.cell-code {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  padding: 1px 4px;
  border-radius: var(--radius-xs);
}
.cell-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.cell-meta {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.cell-meta--price {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  font-variant-numeric: tabular-nums;
}
.cell-desc {
  display: block;
  margin-top: 4px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cell-actions {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-left: 8px;
}
.cell-action {
  font-size: var(--font-size-xs);
  padding: 2px 6px;
  border-radius: var(--radius-xs);
  text-align: center;
}
.cell-action--edit {
  color: var(--color-primary);
}
.cell-action--del {
  color: var(--color-danger);
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 8px;
  padding: 8px 12px;
  padding-bottom: calc(8px + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 1px solid var(--color-border-light);
  z-index: var(--z-dropdown);
}
.action-btn {
  flex: 1;
  height: var(--btn-height-md);
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  border: none;
  line-height: var(--btn-height-md);
}
.action-btn--secondary {
  background: var(--color-bg-gray);
  color: var(--color-primary);
  border: 1px solid var(--color-border);
}
.action-btn--primary {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.action-btn--primary[loading]::before {
  display: none;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-overlay);
  z-index: var(--z-modal);
}
.modal-panel {
  position: fixed;
  left: 12px;
  right: 12px;
  top: 50%;
  transform: translateY(-50%);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  z-index: calc(var(--z-modal) + 1);
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: var(--shadow-modal);
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px;
  border-bottom: 1px solid var(--color-border-light);
}
.modal-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.modal-close {
  font-size: 18px;
  color: var(--color-text-tertiary);
  padding: 0 4px;
}
.modal-body {
  padding: 8px 12px;
}
.form-item {
  margin-bottom: 10px;
}
.form-label {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 4px;
}
.form-input {
  width: 100%;
  height: var(--input-height);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  border: 1px solid var(--color-border-light);
}
.form-textarea {
  width: 100%;
  min-height: 60px;
  padding: 8px var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  border: 1px solid var(--color-border-light);
}
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: var(--input-height);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border-light);
}
.form-picker-arrow {
  font-size: 16px;
  color: var(--color-text-tertiary);
  transform: rotate(90deg);
}
.modal-footer {
  display: flex;
  gap: 8px;
  padding: 8px 12px 12px;
}
.modal-btn {
  flex: 1;
  height: var(--btn-height-md);
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  border: none;
  line-height: var(--btn-height-md);
}
.modal-btn--cancel {
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
}
.modal-btn--confirm {
  background: var(--color-primary);
  color: var(--color-text-white);
}
