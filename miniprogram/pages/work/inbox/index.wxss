@import '/styles/page-utils.wxss';

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 20rpx 24rpx 100rpx;
  box-sizing: border-box;
}

/* 顶部统计条 */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 16rpx;
}
.stats-total {
  font-size: 26rpx;
  color: var(--color-text-disabled);
}
.stats-unread {
  font-size: 26rpx;
  color: var(--color-warning);
  font-weight: 600;
}
.stats-read-all {
  font-size: 26rpx;
  color: var(--color-success);
}

/* 加载中 */
.loading-box {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-disabled);
  font-size: 28rpx;
}

/* 通知列表 */
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 通知卡片 */
.notice-card {
  position: relative;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 28rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.notice-unread {
  border-left: 6rpx solid var(--color-warning);
}

.notice-read {
  border-left: 6rpx solid var(--color-border-light);
  opacity: 0.85;
}

/* 未读红点 */
.unread-dot {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-error);
}

/* 通知标题行 */
.notice-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.notice-icon {
  font-size: 34rpx;
  line-height: 1;
}
.notice-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  flex: 1;
  line-height: 1.4;
}

/* 通知内容 */
.notice-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
}

/* 底部元数据 */
.notice-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.meta-order {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}
.meta-time {
  font-size: 24rpx;
  color: var(--color-text-disabled);
}

/* 全部标为已读按钮 */
.mark-all-btn {
  margin-top: 28rpx;
  text-align: center;
  padding: 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* ─────────── 催单回复编辑表单 ─────────── */
.edit-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.edit-card {
  width: 100%;
  background: var(--color-bg-card, #fff);
  border-radius: 24rpx 24rpx 0 0;
  padding: 36rpx 32rpx 60rpx;
  box-sizing: border-box;
}
.edit-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary, #1a1a2e);
  display: block;
  margin-bottom: 6rpx;
}
.edit-card-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary, #666);
  display: block;
  margin-bottom: 28rpx;
}
.edit-field {
  margin-bottom: 24rpx;
}
.edit-label {
  font-size: 26rpx;
  color: var(--color-text-secondary, #555);
  display: block;
  margin-bottom: 8rpx;
}
.edit-input {
  width: 100%;
  background: var(--color-bg-page, #f5f7fa);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: var(--color-text-primary, #1a1a2e);
}
.edit-textarea {
  width: 100%;
  background: var(--color-bg-page, #f5f7fa);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: var(--color-text-primary, #1a1a2e);
  min-height: 120rpx;
}
.edit-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}
.edit-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  background: var(--color-bg-page, #f0f0f0);
  color: var(--color-text-secondary, #666);
}
.edit-btn-submit {
  flex: 2;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: var(--color-primary, #5B6AF0);
  color: #fff;
}
.edit-btn-disabled {
  opacity: 0.5;
}
