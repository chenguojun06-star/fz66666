@import '/styles/page-utils.wxss';

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 10px 12px 50px;
  box-sizing: border-box;
}

/* ==================== 顶部统计条 ==================== */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px 0 8px;
}
.stats-total {
  font-size: var(--font-size-sm);
  color: var(--color-text-disabled);
}
.stats-unread {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}
.stats-read-all {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ==================== 加载中 ==================== */
.loading-box {
  text-align: center;
  padding: 40px 0;
  color: var(--color-text-disabled);
  font-size: var(--font-size-md);
}

/* ==================== 通知列表 ==================== */
.notice-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ==================== 通知卡片 ==================== */
.notice-card {
  position: relative;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 14px 14px 10px;
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(var(--color-primary-rgb), 0.1);
}

.notice-unread {
  border-left: 3px solid rgba(var(--color-primary-rgb), 0.38);
}

.notice-read {
  border-left: 3px solid rgba(15, 23, 42, 0.06);
}

.notice-read .notice-title {
  color: var(--color-text-secondary);
}

.notice-read .notice-content {
  color: var(--color-text-tertiary);
}

/* 未读红点 */
.unread-dot {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-error);
}

/* 通知标题行 */
.notice-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.notice-icon-wrap {
  width: 28px;
  height: 28px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-page);
  border: 1px solid rgba(var(--color-primary-rgb), 0.14);
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.04);
  flex-shrink: 0;
}
.notice-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  flex: 1;
  line-height: 1.4;
}

/* 通知内容 */
.notice-content {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.7;
  display: block;
  margin-bottom: 8px;
}

/* 底部元数据 */
.notice-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.meta-order {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}
.meta-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}

/* ==================== 全部标为已读 ==================== */
.mark-all-btn {
  margin-top: 14px;
  text-align: center;
  padding: 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-md);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}

.empty-icon-wrap {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12px;
  background: var(--color-bg-page);
  border: 1px solid rgba(var(--color-primary-rgb), 0.14);
  box-shadow: 0 6px 14px rgba(0, 0, 0, 0.04);
}

/* ==================== 催单回复编辑表单 ==================== */
.edit-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
}
.edit-card {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 18px 16px 30px;
  box-sizing: border-box;
}

.edit-card-title-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 3px;
}

.edit-card-title {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  display: block;
}
.edit-card-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 14px;
}
.edit-field {
  margin-bottom: 12px;
}
.edit-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 4px;
}
.edit-input {
  width: 100%;
  background: var(--color-bg-page);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 10px 12px;
  font-size: var(--font-size-md);
  box-sizing: border-box;
  color: var(--color-text-primary);
}
.edit-textarea {
  width: 100%;
  background: var(--color-bg-page);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 10px 12px;
  font-size: var(--font-size-md);
  box-sizing: border-box;
  color: var(--color-text-primary);
  min-height: 60px;
}
.edit-btns {
  display: flex;
  gap: 10px;
  margin-top: 14px;
}
.edit-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  border-radius: 7px;
  font-size: var(--font-size-md);
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}
.edit-btn-submit {
  flex: 2;
  text-align: center;
  padding: 12px 0;
  border-radius: 7px;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  background: var(--color-primary);
  color: var(--color-text-white);
}
.edit-btn-disabled {
  opacity: 0.5;
}
