<view class="container">
  <!-- 顶部统计条 -->
  <view class="stats-bar">
    <text class="stats-total">共 {{notices.length}} 条</text>
    <text wx:if="{{unreadCount > 0}}" class="stats-unread">{{unreadCount}} 条未读</text>
    <text wx:else class="stats-read-all">全部已读 ✓</text>
  </view>

  <!-- 空状态 -->
  <empty-state wx:if="{{!loading && notices.length === 0}}" icon="icon-bell" text="暂无智能提醒" hint="系统检测到异常会第一时间通知你" card="{{true}}"></empty-state>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-box">
    <text>加载中...</text>
  </view>

  <!-- 通知列表 -->
  <view wx:if="{{!loading && notices.length > 0}}" class="notice-list">
    <view class="container">
      <view class="stats-bar">
        <text class="stats-total">共 {{notices.length}} 条</text>
        <text wx:if="{{unreadCount > 0}}" class="stats-unread">{{unreadCount}} 条未读</text>
        <text wx:else class="stats-read-all">全部已读</text>
      </view>
      <!-- 未读红点 -->
      <view wx:if="{{item.isRead === 0}}" class="unread-dot"></view>

        <view class="empty-icon-wrap">
          <view class="line-icon line-icon--lg icon-notice"></view>
        </view>
      <view class="notice-header">
        <view class="notice-icon-wrap">
          <view class="line-icon {{item.typeIconClass}}"></view>
        </view>
        <text class="notice-title">{{item.title}}</text>
      </view>

      <!-- 内容 -->
      <text class="notice-content" user-select>{{item.content}}</text>

      <!-- 底部元数据 -->
      <view class="notice-meta">
        <text class="meta-order" wx:if="{{item.orderNo}}" user-select>订单：{{item.orderNo}}</text>
        <text class="meta-time">{{item.timeAgo}}</text>
      </view>
    </view>
  </view>

  <!-- 全部标记已读按钮 -->
  <view wx:if="{{unreadCount > 0}}" class="mark-all-btn" bindtap="markAllRead">
    <text>全部标为已读</text>
  </view>

  <!-- 催单回复编辑表单（蒙层+弹出卡片）-->
  <view wx:if="{{editFormVisible}}" class="edit-overlay" catchtap="onEditFormCancel">
    <view class="edit-card" catchtap="_noop">
      <view class="edit-card-title-row">
        <view class="line-icon icon-package"></view>
        <text class="edit-card-title">催单回复 — {{editForm.orderNo}}</text>
      </view>
      <text class="edit-card-hint">请确认排期并回复跟单员</text>

      <view class="edit-field">
        <text class="edit-label">预计出货日期</text>
        <input
          class="edit-input"
          type="text"
          placeholder="如：2026-05-20"
          value="{{editForm.expectedShipDate}}"
          data-field="expectedShipDate"
          bindinput="onEditFormInput"
        />
      </view>
      <view class="edit-field">
        <text class="edit-label">工厂备注</text>
        <textarea
          class="edit-textarea"
          placeholder="说明当前排期情况或问题..."
          value="{{editForm.remarks}}"
          data-field="remarks"
          bindinput="onEditFormInput"
          maxlength="200"
        />
      </view>

      <view class="edit-btns">
        <view class="edit-btn-cancel" bindtap="onEditFormCancel">取消</view>
        <view
          class="edit-btn-submit {{editForm.submitting ? 'edit-btn-disabled' : ''}}"
          bindtap="onEditFormSubmit"
        >{{editForm.submitting ? '提交中...' : '确认回复'}}</view>
      </view>
    </view>
  </view>
</view>
