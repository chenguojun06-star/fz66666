page {
  background: #f7f8fa;
}

.container .card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 12px;
}

.input {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
}

.btn-primary {
  border-radius: 999px;
  padding: 10px 14px;
  font-size: 12px;
}

.tabbar-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.tabbar {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 6px;
  padding: 6px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
}

.tab {
  padding: 6px 0;
  border-radius: 999px;
  background: transparent;
  color: #6b7280;
  font-size: 12px;
  text-align: center;
}

.tab-active {
  background: #f3f5f9;
  color: #1f2937;
  border: 1px solid #e5e7eb;
  font-weight: 600;
}

.tabbar-scan {
  padding: 8px 14px;
  white-space: nowrap;
}

.home-section-title {
  margin-top: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}

.home-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 8px;
}

.home-stats-secondary {
  margin-top: 10px;
}

.home-stat {
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 10px 12px;
  background: #ffffff;
}

.home-stat-value {
  font-size: 14px;
  font-weight: 600;
  color: #111827;
}

.home-stat-label {
  font-size: 12px;
  color: #6b7280;
}

.home-entries {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 10px;
}

.home-entry {
  border: 1px solid #e5e7eb;
  background: #ffffff;
  color: #111827;
  border-radius: 999px;
  padding: 8px 8px;
  text-align: center;
  font-size: 12px;
}

.home-activity {
  padding: 10px 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  margin-top: 10px;
  background: #ffffff;
}

.home-activity-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}

.home-activity-content {
  flex: 1;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.home-activity-time {
  font-size: 12px;
  color: #8b8b94;
  white-space: nowrap;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.6);
  color: #1f2937;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
  text-align: center;
  font-size: 12px;
}

.list-item {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
  margin-top: 10px;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.item-head-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.order-checkbox {
  transform: scale(0.9);
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: 14px;
  font-weight: 600;
}

.item-sub {
  display: block;
  width: 100%;
  margin-top: 6px;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.item-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 8px;
}

.section-title {
  margin-top: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}

.rollback-card {
  margin-top: 10px;
  padding: 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
}

.batch-card {
  margin-top: 10px;
  padding: 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
}

.batch-meta {
  margin-top: 6px;
  font-size: 11px;
  color: #6b7280;
}
