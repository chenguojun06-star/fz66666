/* 生产页面 · 对齐 WeUI 设计规范 */
page {
  background: var(--color-bg-page);
  padding-bottom: calc(80px + env(safe-area-inset-bottom));
}

.container {
  padding: 16px;
}

/* ===== 卡片容器 ===== */
.card {
  margin: 0 0 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  border: 1px solid var(--color-border-light);
  padding: 16px;
}


.refresh-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  flex-shrink: 0;
}

.refresh-btn-loading {
  opacity: 0.6;
}

.refresh-btn-hover {
  background: var(--color-bg-hover);
}

.refresh-icon {
  font-size: var(--font-size-xs);
}

.refresh-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* ===== 标签栏 ===== */
.tabbar {
  display: flex;
  padding: 4px;
  background: var(--color-bg-gray);
  border-radius: var(--radius-full);
  margin-bottom: 12px;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 8px 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  border-radius: var(--radius-full);
  transition: all 0.2s ease;
}

.tab-active {
  background: var(--color-bg-card);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  font-size: var(--font-size-base);
  box-shadow: var(--shadow-sm);
}

.tab-hover {
  opacity: 0.7;
}

/* ===== 订单统计行 ===== */
.order-stats-bar {
  display: flex;
  align-items: center;
  padding: 10px 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-full);
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}

.stats-bar-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.stats-bar-value {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-bold);
  margin-left: 4px;
}

.stats-primary,
.stats-accent {
  color: var(--color-primary);
}

.stats-bar-sep {
  margin: 0 12px;
  color: var(--color-border);
}

/* ===== 组织筛选行 ===== */
.org-filter-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.org-filter-pill {
  display: flex;
  align-items: center;
  padding: 8px 14px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  gap: 6px;
}

.org-filter-pill-active {
  border-color: var(--color-primary);
  background: var(--color-bg-light);
}

.org-filter-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.org-filter-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-semibold);
}

/* ===== 订单列表 ===== */
.list-item {
  display: flex;
  flex-direction: column;
  padding: 16px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-lg);
  margin-bottom: 10px;
  box-shadow: var(--shadow-sm);
}

.list-item:last-child {
  margin-bottom: 0;
}

.list-item-closed {
  opacity: 0.6;
}

.list-item-highlight {
  background: var(--color-bg-card);
  border-color: rgba(var(--color-primary-rgb), 0.25);
  box-shadow: 0 0 0 2px rgba(var(--color-primary-rgb), 0.06);
}

.list-item-overdue {
  border-left: 3px solid var(--color-danger);
  background: var(--color-bg-card);
}

.item-cover-box {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-page);
  border: 1px solid var(--color-border-light);
}

.item-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.item-cover-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
  text-align: center;
  white-space: pre-line;
}

.item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 4px;
}

.item-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4px;
  line-height: var(--line-height-tight);
}

.item-title-closed {
  text-decoration: line-through;
}

.item-tags {
  display: flex;
  gap: 4px;
  flex-shrink: 0;
}

.order-tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
}

.order-tag-plate {
  background: rgba(var(--color-primary-rgb), 0.08);
  color: var(--color-primary);
}

.order-tag-urgent {
  background: rgba(var(--color-error-rgb, 239, 68, 68), 0.1);
  color: var(--color-error);
}

.order-tag-normal {
  background: rgba(120, 120, 128, 0.12);
  color: var(--color-text-tertiary);
}

.tag {
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
}

.tag-completed {
  background: rgba(7, 193, 96, 0.1);
  color: var(--color-success);
}

.tag-process {
  background: rgba(var(--color-primary-rgb), 0.08);
  color: var(--color-primary);
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 2px;
  flex-wrap: wrap;
  line-height: var(--line-height-tight);
}

.meta-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.meta-value {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.meta-value-bold {
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.meta-sep {
  color: var(--color-border);
  margin: 0 4px;
}

/* ===== 码数明细（紧凑版） ===== */
.size-compact {
  padding: 4px 0;
}

.size-compact-header {
  display: flex;
  align-items: center;
  padding: 2px 0;
  border-bottom: 1px dashed var(--color-border-light);
}

.size-compact-row {
  display: flex;
  align-items: center;
  padding: 2px 0;
}

.size-compact-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  min-width: 36px;
  font-weight: var(--font-weight-medium);
}

.size-compact-cell {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  min-width: 24px;
  text-align: center;
}

.size-compact-qty {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* ===== 交期天数色 ===== */
.days-normal {
  color: var(--color-primary);
}

.days-warning {
  color: var(--color-warning);
}

.days-critical {
  color: var(--color-error);
}

.days-overdue {
  color: var(--color-error);
}

/* ===== 提示 ===== */
.hint {
  text-align: center;
  padding: 48px 20px;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-base);
}

/* ===== 加载更多 ===== */
.btn {
  margin-top: 8px;
  text-align: center;
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 24px;
  background: var(--color-primary);
  border: none;
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-white);
}

.btn-secondary-hover {
  opacity: 0.9;
}

.btn-disabled {
  background: var(--color-bg-gray);
  color: var(--color-text-disabled);
}

/* ==================== 生成菲号操作按钮 ==================== */
.item-actions { display: flex; justify-content: flex-end; padding: 4px 0 8px; }
.action-btn { padding: 8px 16px; border-radius: var(--radius-md); font-size: var(--font-size-sm); font-weight: var(--font-weight-medium); }
.action-btn-primary { background: var(--color-primary); color: var(--color-text-white); }

/* ==================== 菲号生成弹窗 ==================== */
.bundle-modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: var(--z-modal); display: flex; align-items: center; justify-content: center; }
.bundle-modal { background: var(--color-bg-card); border-radius: var(--radius-lg); width: 92vw; max-height: 80vh; overflow-y: auto; padding: 20px; box-sizing: border-box; }
.bundle-modal-title { font-size: var(--font-size-lg); font-weight: var(--font-weight-bold); color: var(--color-text-primary); text-align: center; margin-bottom: 8px; }
.bundle-modal-meta { display: flex; gap: 12px; font-size: var(--font-size-xs); color: var(--color-text-secondary); margin-bottom: 12px; justify-content: center; }
.bundle-size-row { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
.bundle-size-label { font-size: var(--font-size-base); color: var(--color-text-primary); white-space: nowrap; }
.bundle-size-input { flex: 1; height: 40px; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 0 12px; font-size: var(--font-size-base); text-align: center; }
.bundle-size-unit { font-size: var(--font-size-sm); color: var(--color-text-secondary); white-space: nowrap; }
.bundle-rows-container { background: var(--color-bg-gray); border-radius: var(--radius-md); padding: 0 12px; margin-bottom: 12px; }
.bundle-rows-header { display: flex; padding: 8px 0; border-bottom: 1px solid var(--color-border-light); }
.bundle-rows-header text { font-size: var(--font-size-xs); color: var(--color-text-secondary); font-weight: var(--font-weight-semibold); }
.bundle-row-item { display: flex; align-items: center; padding: 6px 0; border-bottom: 1px solid var(--color-border-light); }
.bundle-row-item:last-child { border-bottom: none; }
.bundle-rows-total { padding: 8px 0; text-align: right; font-size: var(--font-size-sm); color: var(--color-primary); font-weight: var(--font-weight-semibold); border-top: 1px solid var(--color-border-light); }
.bundle-empty { text-align: center; padding: 20px 0; font-size: var(--font-size-sm); color: var(--color-text-disabled); margin-bottom: 12px; }
.col-color { width: 55px; font-size: var(--font-size-sm); color: var(--color-text-primary); }
.col-size { width: 35px; font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.col-qty { flex: 1; font-size: var(--font-size-sm); color: var(--color-text-primary); }
.col-cutting { flex: 1; font-size: var(--font-size-sm); color: var(--color-text-primary); }
.col-cutting-warn { color: var(--color-warning); font-weight: var(--font-weight-bold); }
.col-count { width: 80px; font-size: var(--font-size-sm); color: var(--color-primary); text-align: right; font-weight: var(--font-weight-medium); }
.col-count-num { display: block; }
.last-bundle-edit { display: flex; align-items: center; justify-content: flex-end; gap: 2px; margin-top: 4px; }
.last-bundle-label { font-size: var(--font-size-xs); color: var(--color-text-disabled); }
.last-bundle-input { width: 40px; height: 24px; line-height: 24px; font-size: var(--font-size-xs); color: var(--color-text-primary); text-align: center; border: 1px solid var(--color-border-light); border-radius: var(--radius-sm); background: var(--color-bg-card); }
.bundle-footer { display: flex; gap: 12px; }
.bundle-btn { flex: 1; height: 44px; line-height: 44px; text-align: center; border-radius: var(--radius-md); font-size: var(--font-size-base); font-weight: var(--font-weight-medium); }
.bundle-btn-cancel { background: var(--color-bg-gray); color: var(--color-text-secondary); }
.bundle-btn-confirm { background: var(--color-primary); color: var(--color-text-white); }
.bundle-btn-confirm.btn-loading { opacity: .6; }

/* ===== 折叠卡片 ===== */
.item-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12px;
}

.item-header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.item-header-sub {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 4px;
}

.header-style-no {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.header-sep {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.header-delivery {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.header-remain-days {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  padding: 0;
  background: transparent;
  border-radius: 0;
}

.header-progress-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6px;
  margin-top: 2px;
}

.header-progress-bar {
  flex: 1;
  height: 3px;
  background: var(--color-border-light);
  border-radius: 2px;
  overflow: hidden;
}

.header-progress-bar .progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 2px;
  transition: width 0.3s ease;
}

.header-progress-bar.progress-completed .progress-fill {
  background: var(--color-success);
}

.header-progress-pct {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  white-space: nowrap;
  flex-shrink: 0;
}

.collapse-arrow {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  align-self: center;
  transition: transform 0.25s;
  padding: 4px 2px;
}

.collapse-arrow.collapse-up {
  transform: rotate(180deg);
}

.item-collapse-body {
  border-top: 1px solid var(--color-border-light);
  margin-top: 12px;
  padding-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
