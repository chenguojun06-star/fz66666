page {
  background: #f7f8fa;  padding-bottom: calc(60px + env(safe-area-inset-bottom));}

/* 搜索栏/搜索结果样式已移至 app.wxss 统一管理 */

.result-item:last-child {
  border-bottom: none;
}

.result-item:active {
  background: rgba(224, 242, 254, 0.3);
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}

.result-type {
  padding: 2px 8px;
  font-size: 11px;
  font-weight: 500;
  color: #ffffff;
  background: #3b82f6;
  border-radius: 999px;
}

.result-status {
  font-size: 12px;
  font-weight: 500;
}

.result-info {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 4px;
}

.result-order,
.result-style {
  font-size: 13px;
  color: #1f2937;
}

.result-detail {
  font-size: 12px;
  color: #6b7280;
  margin-top: 4px;
}

/* 进度条样式 */
.progress-wrapper {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}

.progress-bar {
  flex: 1;
  height: 6px;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 999px;
  overflow: hidden;
}

/* 生产中 - 绿色 */
.progress-bar.progress-active .progress-fill {
  background: linear-gradient(90deg, #10b981 0%, #059669 100%);
  height: 100%;
  border-radius: 999px;
  transition: width 0.3s ease;
}

/* 已完成/关单 - 灰色 */
.progress-bar.progress-closed .progress-fill {
  background: linear-gradient(90deg, #9ca3af 0%, #6b7280 100%);
  height: 100%;
  border-radius: 999px;
}

.progress-text {
  font-size: 12px;
  color: #6b7280;
  font-weight: 500;
  white-space: nowrap;
}

.progress-percent {
  min-width: 40px;
  text-align: right;
}

.current-process {
  margin-top: 4px;
  font-size: 13px;
  color: #10b981;
  font-weight: 500;
}

/* 无搜索结果 */
.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 20px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  margin-bottom: 12px;
}

.no-results-icon {
  font-size: 48px;
  margin-bottom: 12px;
  opacity: 0.3;
}

.no-results-text {
  font-size: 14px;
  color: #6b7280;
  margin-bottom: 16px;
}

.no-results .close-btn {
  padding: 8px 24px;
  font-size: 14px;
  color: #1f2937;
  background: rgba(224, 242, 254, 0.8);
  border: 1px solid rgba(224, 242, 254, 0.9);
  border-radius: 999px;
}

.tabbar-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.tabbar {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 4px;
  padding: 4px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
}

.tab {
  padding: 5px 6px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.55);
  color: #6b7280;
  font-size: 11px;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  border: 1px solid rgba(255, 255, 255, 0.7);
  box-shadow:
    0 6px 14px rgba(15, 23, 42, 0.05),
    inset 0 1px 0 rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.tab-active {
  background: rgba(224, 242, 254, 0.8); /* 很浅的雾蓝色 */
  color: #1f2937;
  border: 1px solid rgba(224, 242, 254, 0.9);
  font-weight: 600;
}

.tab:active {
  background: rgba(224, 242, 254, 0.8); /* 很浅的雾蓝色 */
}

.tabbar-scan {
  padding: 1px 18px;
  font-size: 12px;
  border-radius: 999px;
  white-space: nowrap;
}

.section-title {
  margin-top: 10px;
  font-size: 14px; /* 三级标题 */
  font-weight: 600;
  color: #1f2937;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 8px;
}

.home-stats-secondary {
  margin-top: 10px;
}

.stat-card {
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  padding: 10px 12px;
  background: #ffffff;
}

.stat-value {
  font-size: 14px; /* 正文字体 */
  font-weight: 600;
  color: #111827;
}

.stat-label {
  font-size: 12px; /* 辅助字体 */
  color: #6b7280;
}

.home-entries {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 10px;
}

.home-entry {
  border: 1px solid #e5e7eb;
  background: #ffffff;
  color: #111827;
  border-radius: 999px;
  padding: 8px 8px;
  text-align: center;
  font-size: 12px;
}

.home-activity {
  padding: 10px 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  margin-top: 10px;
  background: #ffffff;
}

.home-activity-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}

.home-activity-content {
  flex: 1;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.home-activity-time {
  font-size: 12px;
  color: #8b8b94;
  white-space: nowrap;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.item-head-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.order-checkbox {
  transform: scale(0.9);
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: 14px;
  font-weight: 600;
}

.item-sub {
  display: block;
  width: 100%;
  margin-top: 6px;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.item-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 8px;
}

.section-title {
  margin-top: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}

.rollback-card {
  margin-top: 10px;
  padding: 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
}

.batch-card {
  margin-top: 10px;
  padding: 12px;
  border: 1px solid #e5e7eb;
  border-radius: 18px;
  background: #ffffff;
}

.batch-meta {
  margin-top: 6px;
  font-size: 11px;
  color: #6b7280;
}

/* ============ 通用搜索栏 ============ */
.universal-search {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 8px;
  padding: 3px 6px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.universal-search .search-box {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 3px 10px;
  background: rgba(224, 242, 254, 0.3);
  border: 1px solid rgba(224, 242, 254, 0.5);
  border-radius: 999px;
}

.universal-search .search-icon {
  font-size: 12px;
  margin-right: 4px;
}

.universal-search .search-input {
  flex: 1;
  font-size: 11px;
  color: #1f2937;
}

.universal-search .search-btn {
  padding: 3px 18px;
  font-size: 12px;
  font-weight: 500;
  color: #1f2937;
  background: rgba(224, 242, 254, 0.8);
  border: 1px solid rgba(224, 242, 254, 0.9);
  border-radius: 999px;
  box-shadow: 0 2px 6px rgba(59, 130, 246, 0.15);
  white-space: nowrap;
}

.universal-search .clear-btn {
  padding: 3px 18px;
  font-size: 12px;
  color: #6b7280;
  background: #f3f4f6;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  white-space: nowrap;
}

/* 生成菲号按钮 */
.item-actions {
  margin-top: 8px;
  display: flex;
  gap: 8px;
}

.action-btn {
  padding: 6px 12px;
  background: linear-gradient(135deg, rgba(224, 242, 254, 0.9) 0%, rgba(224, 242, 254, 0.7) 100%);
  border: 1px solid rgba(147, 197, 253, 0.5);
  border-radius: 999px;
  font-size: 11px;
  font-weight: 500;
  color: #1f2937;
  text-align: center;
  box-shadow: 0 2px 6px rgba(59, 130, 246, 0.15);
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 生成菲号弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 16px;
}

.modal-box {
  width: 100%;
  max-width: 300px;
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  transform: scale(1);
  animation: modalFadeIn 0.2s ease-out;
}

.modal-box.wide {
  max-width: 90vw;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-head {
  padding: 12px 14px;
  background: rgba(255, 255, 255, 0.8);
  color: #1f2937;
  border-bottom: 1px solid #e5e7eb;
  font-size: 14px;
  font-weight: 500;
  flex-shrink: 0;
}

.modal-body {
  padding: 12px;
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  min-height: 0;
}

.cf-list {
  background: #f9fafb;
  border-radius: 8px;
  padding: 8px;
  margin-bottom: 10px;
}

.cf-item {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  border-bottom: 1px solid #eee;
}

.cf-item:last-child {
  border-bottom: none;
}

.cf-k {
  font-size: 11px;
  color: #999;
}

.cf-v {
  font-size: 12px;
  color: #333;
  max-width: 160px;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cf-v.hl {
  color: #475569;
  font-weight: 500;
}

.bundle-input-list {
  margin-top: 12px;
}

.bundle-input-item {
  background: #f9fafb;
  border-radius: 12px;
  padding: 12px;
  margin-bottom: 10px;
  border: 1px solid #e5e7eb;
  position: relative;
}

.bundle-input-item:last-child {
  margin-bottom: 0;
}

.bii-row {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.bii-row:last-child {
  margin-bottom: 0;
}

.bii-label {
  width: 60px;
  font-size: 12px;
  color: #6b7280;
  flex-shrink: 0;
}

.bii-input {
  flex: 1;
  background: #fff;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  padding: 8px 12px;
  font-size: 13px;
  height: 36px;
}

.bii-remove {
  margin-top: 8px;
  padding: 6px;
  text-align: center;
  font-size: 11px;
  color: #ef4444;
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: 8px;
}

.bii-remove:active {
  background: #fee2e2;
}

.bundle-add-btn {
  margin-top: 12px;
  padding: 10px;
  text-align: center;
  font-size: 12px;
  font-weight: 500;
  color: #3b82f6;
  background: #eff6ff;
  border: 1px dashed #93c5fd;
  border-radius: 8px;
}

.bundle-add-btn:active {
  background: #dbeafe;
}

.modal-btns {
  display: flex;
  gap: 8px;
  padding: 10px 12px;
  border-top: 1px solid #f0f0f0;
  flex-shrink: 0;
}

.mbtn {
  flex: 1;
  padding: 10px;
  border-radius: 999px;
  text-align: center;
  font-size: 12px;
  font-weight: 500;
}

.mbtn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.mbtn.cancel {
  background: rgba(255, 255, 255, 0.6);
  color: #6b7280;
  border: 1px solid rgba(229, 231, 235, 0.8);
}

.mbtn.ok {
  background: linear-gradient(135deg, rgba(224, 242, 254, 0.9) 0%, rgba(224, 242, 254, 0.7) 100%);
  color: #1f2937;
  border: 1px solid rgba(147, 197, 253, 0.5);
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
}

.mbtn.ok.off {
  opacity: 0.5;
}
