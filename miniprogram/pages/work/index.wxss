page {
  background: linear-gradient(
    135deg,
    rgba(169, 201, 255, 0.18),
    rgba(255, 255, 255, 0.72)
  );
}

.container .card {
  background: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 26px;
  padding: 14px;
  box-shadow: none;
}

.title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 10px;
  color: #1f2937;
}

.input {
  background: rgba(255, 255, 255, 0.65);
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 18px;
  padding: 8px 12px;
}

.btn-primary {
  border-radius: 999px;
  padding: 10px 14px;
  font-size: 12px;
}

.tabbar-actions {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.tabbar {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 6px;
  padding: 6px;
  background: rgba(255, 255, 255, 0.55);
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 999px;
}

.tab {
  padding: 8px 0;
  border-radius: 999px;
  background: transparent;
  color: #6e6e73;
  font-size: 12px;
  text-align: center;
}

.tab-active {
  background: rgba(10, 132, 255, 0.85);
  color: #fff;
  font-weight: 600;
}

.tabbar-scan {
  padding: 8px 14px;
  white-space: nowrap;
}

.home-section-title {
  margin-top: 12px;
  font-size: 13px;
  font-weight: 600;
  color: #2c2c2e;
}

.home-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: 10px;
}

.home-stats-secondary {
  margin-top: 10px;
}

.home-stat {
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 22px;
  padding: 10px 12px;
  background: rgba(255, 255, 255, 0.6);
  box-shadow: none;
}

.home-stat-value {
  font-size: 16px;
  font-weight: 600;
  color: #1c1c1e;
}

.home-stat-label {
  font-size: 12px;
  color: #8e8e93;
}

.home-entries {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 10px;
}

.home-entry {
  border: 1px solid rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.55);
  color: #111827;
  border-radius: 999px;
  padding: 10px 8px;
  text-align: center;
  font-size: 12px;
}

.home-activity {
  padding: 10px 12px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 22px;
  margin-top: 10px;
  background: rgba(255, 255, 255, 0.55);
}

.home-activity-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
}

.home-activity-content {
  flex: 1;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.home-activity-time {
  font-size: 12px;
  color: #9ca3af;
  white-space: nowrap;
}

.btn-secondary {
  background: rgba(148, 163, 184, 0.18);
  color: #374151;
  border-radius: 999px;
  padding: 8px 12px;
  text-align: center;
  font-size: 12px;
}

.list-item {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 12px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 22px;
  background: rgba(255, 255, 255, 0.55);
  margin-top: 10px;
}

.item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.item-head-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.order-checkbox {
  transform: scale(0.9);
}

.item-title {
  flex: 1;
  min-width: 0;
  font-size: 13px;
  font-weight: 600;
}

.item-sub {
  display: block;
  width: 100%;
  margin-top: 6px;
  font-size: 12px;
  color: #374151;
  line-height: 1.5;
}

.item-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 8px;
}

.section-title {
  margin-top: 12px;
  font-size: 13px;
  font-weight: 600;
  color: #2c2c2e;
}

.rollback-card {
  margin-top: 12px;
  padding: 12px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.55);
}

.batch-card {
  margin-top: 12px;
  padding: 12px;
  border: 1px solid rgba(255, 255, 255, 0.7);
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.55);
}

.batch-meta {
  margin-top: 6px;
  font-size: 11px;
  color: #6b7280;
}
