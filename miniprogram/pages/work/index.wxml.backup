<view class="container">
  <view class="card">
    <view class="title">生产</view>

    <!-- 搜索组件放在最上面 -->
    <global-search
      keyword="{{globalSearch.keyword}}"
      results="{{globalSearch.results}}"
      has-searched="{{globalSearch.hasSearched}}"
      bind:input="onGlobalSearchInput"
      bind:search="doGlobalSearch"
      bind:clear="clearGlobalSearch"
      bind:close="closeGlobalSearch"
      bind:itemtap="onResultItemTap"
    />

    <!-- 标签栏在搜索栏下面 -->
    <view class="tabbar">
      <view class="tab {{activeTab === 'all' ? 'tab-active' : ''}}" data-tab="all" bindtap="onTab">全部</view>
      <view class="tab {{activeTab === 'procurement' ? 'tab-active' : ''}}" data-tab="procurement" bindtap="onTab">采购</view>
      <view class="tab {{activeTab === 'cutting' ? 'tab-active' : ''}}" data-tab="cutting" bindtap="onTab">裁剪</view>
      <view class="tab {{activeTab === 'sewing' ? 'tab-active' : ''}}" data-tab="sewing" bindtap="onTab">车缝</view>
      <view class="tab {{activeTab === 'warehousing' ? 'tab-active' : ''}}" data-tab="warehousing" bindtap="onTab">入库</view>
    </view>

    <!-- 订单列表 -->
    <view>

      <view wx:if="{{orders.list.length === 0 && !orders.loading}}" class="hint">暂无数据</view>
        <view wx:for="{{orders.list}}" wx:key="id" class="list-item">
          <view class="item-head">
            <view class="item-title">{{item.orderNo || '-'}}</view>
            <text class="tag">{{item.statusText || '-'}}</text>
          </view>
          <view class="item-sub">款号：{{item.styleNo || '-'}}</view>
          <view class="item-sub">工厂：{{item.factoryName || '-'}}</view>
          <view class="item-sub">数量：{{item.orderQuantity || 0}}，完成：{{item.completedQuantity || 0}}</view>
          <view class="progress-wrapper">
            <view class="progress-bar {{item.status === 'completed' ? 'progress-closed' : 'progress-active'}}">
              <view class="progress-fill" style="width: {{item.productionProgress || 0}}%"></view>
            </view>
            <text class="progress-text progress-percent">{{item.productionProgress || 0}}%</text>
          </view>
          <view class="current-process">{{item.currentProcessName || '待开始'}}</view>
        </view>

      <view class="btn">
        <view class="btn-secondary {{orders.loading || !orders.hasMore ? 'btn-disabled' : ''}}" bindtap="loadMoreActive">{{orders.loading ? '加载中...' : (orders.hasMore ? '加载更多' : '没有更多了')}}</view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'warehousing'}}">
      
      <view class="field">
        <view class="label">质检状态</view>
        <picker mode="selector" range="{{qualityOptions}}" range-key="label" value="{{filters.qualityIndex}}" bindchange="onQualityPickerChange">
          <view class="input">{{qualityOptions[filters.qualityIndex].label}}</view>
        </picker>
      </view>

      <view wx:if="{{warehousing.list.length === 0 && !warehousing.loading}}" class="hint">暂无数据</view>
      <view wx:for="{{warehousing.list}}" wx:key="id" class="list-item">
        <view class="item-head">
          <view class="item-title">{{item.warehousingNo || '-'}} </view>
          <text class="tag">{{item.qualityStatusText || '-'}}</text>
        </view>
        <view class="item-sub">订单号：{{item.orderNo || '-'}}，款号：{{item.styleNo || '-'}}</view>
        <view class="item-sub">仓库：{{item.warehouse || '-'}}</view>
        <view class="item-sub">入库：{{item.warehousingQuantity || 0}}，合格：{{item.qualifiedQuantity || 0}}，次品：{{item.unqualifiedQuantity || 0}}</view>
        <view wx:if="{{item.cuttingBundleQrCode}}" class="item-sub">扎号：{{item.cuttingBundleQrCode}}</view>
        <view wx:if="{{item.repairRemark}}" class="item-sub">返修信息：{{item.repairRemark}}</view>
      </view>
      <view class="btn">
        <view class="btn-secondary {{warehousing.loading || !warehousing.hasMore ? 'btn-disabled' : ''}}" bindtap="loadMoreActive">{{warehousing.loading ? '加载中...' : (warehousing.hasMore ? '加载更多' : '没有更多了')}}</view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'exceptions'}}">
      <view class="filters">
        <input placeholder="搜索订单号/款号" value="{{filters.searchKeyword}}" bindinput="onSearchKeywordInput" />
      </view>
      <view wx:if="{{exceptions.list.length === 0 && !exceptions.loading}}" class="hint">暂无数据</view>
      <view wx:for="{{exceptions.list}}" wx:key="id" class="list-item">
        <view class="item-head">
          <view class="item-title">{{item.orderNo || '-'}}</view>
          <text class="tag" style="background-color: #ef4444">{{item.scanResultText || '失败'}}</text>
        </view>
        <view class="item-sub">款号：{{item.styleNo || '-'}}</view>
        <view class="item-sub">动作：{{item.progressStage || item.processName || '-'}}</view>
        <view class="item-sub">原因：{{item.remark || '-'}}</view>
        <view wx:if="{{item.scanTime}}" class="item-sub">时间：{{item.scanTime}}</view>
      </view>
      <view class="btn">
        <view class="btn-secondary {{exceptions.loading || !exceptions.hasMore ? 'btn-disabled' : ''}}" bindtap="loadMoreActive">{{exceptions.loading ? '加载中...' : (exceptions.hasMore ? '加载更多' : '没有更多了')}}</view>
      </view>
    </view>

    <view wx:if="{{activeTab === 'status_filter'}}">
      <view class="filters">
        <picker mode="selector" range="{{statusOptions}}" range-key="label" value="{{filters.statusIndex}}" bindchange="onStatusPickerChange">
          <view class="picker-cell">生产状态：{{statusOptions[filters.statusIndex].label}}</view>
        </picker>
      </view>
      <view wx:if="{{statusFiltered.list.length === 0 && !statusFiltered.loading}}" class="hint">暂无数据</view>
      <view wx:for="{{statusFiltered.list}}" wx:key="id" class="list-item">
        <view class="item-head">
          <view class="item-title">{{item.orderNo || '-'}}</view>
          <text class="tag" style="background-color: {{item.statusColor}}">{{item.statusText || '-'}}</text>
        </view>
        <view class="item-sub">款号：{{item.styleNo || '-'}}</view>
        <view class="item-sub">工厂：{{item.factoryName || '-'}}</view>
        <view class="item-sub">数量：{{item.orderQuantity || 0}}，完成：{{item.completedQuantity || 0}}</view>
        <view class="progress-wrapper">
          <view class="progress-bar {{item.status === 'completed' ? 'progress-closed' : 'progress-active'}}">
            <view class="progress-fill" style="width: {{item.productionProgress || 0}}%"></view>
          </view>
          <text class="progress-text progress-percent">{{item.productionProgress || 0}}%</text>
        </view>
        <view class="current-process">{{item.currentProcessName || '待开始'}}</view>
      </view>

      <view class="btn">
        <view class="btn-secondary {{statusFiltered.loading || !statusFiltered.hasMore ? 'btn-disabled' : ''}}" bindtap="loadMoreActive">{{statusFiltered.loading ? '加载中...' : (statusFiltered.hasMore ? '加载更多' : '没有更多了')}}</view>
      </view>
    </view>
  </view>

</view>
