<view class="container">
  <custom-nav
    title="生产"
    show-search="{{true}}"
    search-keyword="{{globalSearch.keyword}}"
    search-placeholder="搜索订单号/款号"
    bind:searchinput="onGlobalSearchInput"
    bind:searchconfirm="doGlobalSearch"
    bind:searchclear="clearGlobalSearch"
  />

  <view class="card">
    <view wx:if="{{globalSearch.hasSearched && globalSearch.results.length > 0}}" class="global-results">
      <view class="results-header">
        <text class="results-title">搜索结果 ({{globalSearch.results.length}})</text>
        <text class="close-results" bindtap="closeGlobalSearch">✕</text>
      </view>
      <scroll-view class="results-list" scroll-y>
        <view wx:for="{{globalSearch.results}}" wx:key="id" class="result-item" hover-class="result-item-hover" hover-stay-time="100" bindtap="onResultItemTap" data-item="{{item}}">
          <view class="result-header">
            <text class="result-type">{{item.typeText}}</text>
            <text class="result-status" style="color: {{item.statusColor}}">{{item.statusText}}</text>
          </view>
          <view class="result-info">
            <text class="result-order">订单号: {{item.orderNo}}</text>
            <text class="result-style">款号: {{item.styleNo}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view wx:if="{{globalSearch.hasSearched && globalSearch.results.length === 0}}" class="no-results">
      <text class="no-results-icon">🔍</text>
      <text class="no-results-text">未找到匹配的订单</text>
      <view class="close-btn" bindtap="closeGlobalSearch">关闭</view>
    </view>

    <view wx:if="{{!globalSearch.hasSearched}}">

    <!-- 标签栏在搜索栏下面 -->
    <view class="tabbar">
      <view class="tab {{activeTab === 'all' ? 'tab-active' : ''}}" data-tab="all" hover-class="tab-hover" hover-stay-time="100" bindtap="onTab">全部</view>
      <view class="tab {{activeTab === 'procurement' ? 'tab-active' : ''}}" data-tab="procurement" hover-class="tab-hover" hover-stay-time="100" bindtap="onTab">采购</view>
      <view class="tab {{activeTab === 'cutting' ? 'tab-active' : ''}}" data-tab="cutting" hover-class="tab-hover" hover-stay-time="100" bindtap="onTab">裁剪</view>
      <view class="tab {{activeTab === 'sewing' ? 'tab-active' : ''}}" data-tab="sewing" hover-class="tab-hover" hover-stay-time="100" bindtap="onTab">车缝</view>
      <view class="tab {{activeTab === 'warehousing' ? 'tab-active' : ''}}" data-tab="warehousing" hover-class="tab-hover" hover-stay-time="100" bindtap="onTab">入库</view>
    </view>

    <!-- 订单统计行（tab栏下方） -->
    <view class="order-stats-bar">
      <text class="stats-bar-label">订单</text>
      <text class="stats-bar-value stats-primary">{{orderStats.orderCount}}</text>
      <text class="stats-bar-sep">｜</text>
      <text class="stats-bar-label">总量</text>
      <text class="stats-bar-value stats-accent">{{orderStats.totalQuantity}}</text>
    </view>

    <view class="org-filter-row">
      <picker mode="selector" range="{{factoryTypeOptions}}" range-key="label" value="{{selectedFactoryTypeIndex}}" bindchange="onFactoryTypeFilterChange">
        <view class="org-filter-pill">
          <text class="org-filter-label">工厂</text>
          <text class="org-filter-value">{{factoryTypeOptions[selectedFactoryTypeIndex].label}}</text>
        </view>
      </picker>
      <view class="org-filter-pill {{delayedOnly ? 'org-filter-pill-active' : ''}}" bindtap="toggleDelayedOnly">
        <text class="org-filter-label">⏰</text>
        <text class="org-filter-value">{{delayedOnly ? '全部' : '延期'}}</text>
      </view>
      <view class="refresh-btn {{orders.loading ? 'refresh-btn-loading' : ''}}" bindtap="onRefresh" hover-class="refresh-btn-hover">
        <text class="refresh-icon">{{orders.loading ? '⏳' : '🔄'}}</text>
        <text class="refresh-text">刷新</text>
      </view>
    </view>

    <!-- 订单列表 -->

      <view wx:if="{{orders.list.length === 0 && !orders.loading}}" class="hint">暂无数据</view>
        <view wx:for="{{orders.list}}" wx:key="id" class="list-item {{item.isClosed ? 'list-item-closed' : ''}} {{highlightOrderNo && item.orderNo === highlightOrderNo ? 'list-item-highlight' : ''}} {{item.remainDaysClass === 'days-overdue' ? 'list-item-overdue' : ''}}">
          <view class="item-body">
            <!-- 左侧款式图片 -->
            <view class="item-cover-box">
              <image wx:if="{{item.styleCoverUrl}}" class="item-cover" src="{{item.styleCoverUrl}}" mode="aspectFill" lazy-load data-index="{{index}}" binderror="onCoverImageError" />
              <view wx:else class="item-cover-empty">暂无\n图片</view>
            </view>
            <!-- 右侧信息区 -->
            <view class="item-info">
              <view class="item-head">
                <view class="item-title {{item.isClosed ? 'item-title-closed' : ''}}">
                  {{item.orderNo || '-'}}
                  <text wx:if="{{item.plateTypeTagText}}" class="order-tag order-tag-plate">{{item.plateTypeTagText}}</text>
                  <text wx:if="{{item.urgencyTagText}}" class="order-tag {{item.urgencyTagText === '急' ? 'order-tag-urgent' : 'order-tag-normal'}}">{{item.urgencyTagText}}</text>
                  <text wx:if="{{item.remainDaysClass === 'days-overdue'}}" class="overdue-indicator">⏰延期</text>
                </view>
                <view class="item-tags">
                  <!-- 已完成显示"已完成"标签，否则显示当前工序 -->
                  <text wx:if="{{item.isClosed}}" class="tag tag-completed">已完成</text>
                  <text wx:elif="{{item.currentProcessName}}" class="tag {{item.currentProcessName === '裁剪' ? 'tag-process' : ''}}">{{item.currentProcessName}}</text>
                </view>
              </view>
              <view class="item-meta">
                <text class="meta-label">款号</text>
                <text class="meta-value">{{item.styleNo || '-'}}</text>
                <text class="meta-sep">|</text>
                <text class="meta-label">数量</text>
                <text class="meta-value meta-value-bold">{{item.sizeTotal ? item.sizeTotal : (item.orderQuantity || 0)}}</text>
                <text class="meta-sep">|</text>
                <text class="meta-label">完成</text>
                <text class="meta-value meta-value-bold">{{item.completedQuantity || 0}}</text>
              </view>
              <view class="item-meta">
                <text class="meta-label">工厂</text>
                <text class="meta-value">{{item.factoryName || '-'}}</text>
                <text wx:if="{{item.factoryTypeText}}" class="meta-sep">|</text>
                <text wx:if="{{item.factoryTypeText}}" class="meta-value">{{item.factoryTypeText}}</text>
              </view>
            </view>
          </view>
          <!-- 进度条作为分隔线 -->
          <view class="progress-divider">
            <view class="progress-bar {{item.isClosed ? 'progress-completed' : ''}}">
              <view class="progress-fill" style="width: {{item.productionProgress || 0}}%"></view>
            </view>
            <text class="progress-percent">{{item.productionProgress || 0}}%</text>
          </view>
          <!-- 码数明细（紧凑版） -->
          <view wx:if="{{item.colorGroups && item.colorGroups.length}}" class="size-compact">
            <view class="size-compact-header">
              <text class="size-compact-label">码数</text>
              <text wx:for="{{item.allSizes}}" wx:key="*this" wx:for-item="size" class="size-compact-cell">{{size}}</text>
            </view>
            <block wx:for="{{item.colorGroups}}" wx:key="color" wx:for-item="group">
              <view class="size-compact-row">
                <text class="size-compact-label">{{group.color || '-'}}</text>
                <text wx:for="{{group.sizeQtyList}}" wx:key="index" wx:for-item="qty" class="size-compact-cell">{{qty}}</text>
              </view>
            </block>
          </view>
          <view wx:elif="{{item.sizeList && item.sizeList.length}}" class="size-compact">
            <view class="size-compact-row">
              <text class="size-compact-label">码数</text>
              <text wx:for="{{item.sizeList}}" wx:key="*this" wx:for-item="size" class="size-compact-cell">{{size}}</text>
            </view>
            <view class="size-compact-row">
              <text class="size-compact-label">数量</text>
              <text wx:for="{{item.sizeQtyList}}" wx:key="index" wx:for-item="qty" class="size-compact-cell size-compact-qty">{{qty}}</text>
            </view>
          </view>
          <!-- 交期信息 -->
          <view wx:if="{{item.deliveryDateStr}}" class="delivery-row">
            <text class="delivery-label">交期：{{item.deliveryDateStr}}</text>
            <text class="delivery-days {{item.remainDaysClass}}">{{item.remainDaysText}}</text>
          </view>
        </view>

      <view class="btn">
        <view class="btn-secondary {{orders.loading || !orders.hasMore ? 'btn-disabled' : ''}}" hover-class="btn-secondary-hover" bindtap="loadMoreActive">{{orders.loading ? '加载中...' : (orders.hasMore ? '加载更多' : '没有更多了')}}</view>
      </view>
    </view>
  </view>
</view>

<!-- 小云 AI 助手（全页面悬浮） -->
<ai-assistant notice-count="{{unreadNoticeCount}}" />

<!-- 隐私保护授权弹窗（微信 2023-09-15 强制要求） -->
<privacy-dialog id="privacyDialog" />
