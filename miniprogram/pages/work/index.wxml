<view class="container">
  <view class="card">
    <view class="title">生产</view>

    <!-- 搜索组件放在最上面 -->
    <global-search
      keyword="{{globalSearch.keyword}}"
      results="{{globalSearch.results}}"
      has-searched="{{globalSearch.hasSearched}}"
      bind:input="onGlobalSearchInput"
      bind:search="doGlobalSearch"
      bind:clear="clearGlobalSearch"
      bind:close="closeGlobalSearch"
      bind:itemtap="onResultItemTap"
    />

    <!-- 标签栏在搜索栏下面 -->
    <view class="tabbar">
      <view class="tab {{activeTab === 'all' ? 'tab-active' : ''}}" data-tab="all" bindtap="onTab">全部</view>
      <view class="tab {{activeTab === 'procurement' ? 'tab-active' : ''}}" data-tab="procurement" bindtap="onTab">采购</view>
      <view class="tab {{activeTab === 'cutting' ? 'tab-active' : ''}}" data-tab="cutting" bindtap="onTab">裁剪</view>
      <view class="tab {{activeTab === 'sewing' ? 'tab-active' : ''}}" data-tab="sewing" bindtap="onTab">车缝</view>
      <view class="tab {{activeTab === 'warehousing' ? 'tab-active' : ''}}" data-tab="warehousing" bindtap="onTab">入库</view>
    </view>

    <!-- 订单列表 -->
    <view>

      <view wx:if="{{orders.list.length === 0 && !orders.loading}}" class="hint">暂无数据</view>
        <view wx:for="{{orders.list}}" wx:key="id" class="list-item">
          <view class="item-head">
            <view class="item-title">{{item.orderNo || '-'}}</view>
            <text class="tag">{{item.statusText || '-'}}</text>
          </view>
          <view class="item-sub">款号：{{item.styleNo || '-'}}</view>
          <view class="item-sub">工厂：{{item.factoryName || '-'}}</view>
          <view class="item-sub">数量：{{item.orderQuantity || 0}}，完成：{{item.completedQuantity || 0}}</view>
          <view class="progress-wrapper">
            <view class="progress-bar {{item.status === 'completed' ? 'progress-closed' : 'progress-active'}}">
              <view class="progress-fill" style="width: {{item.productionProgress || 0}}%"></view>
            </view>
            <text class="progress-text progress-percent">{{item.productionProgress || 0}}%</text>
          </view>
          <view class="current-process">{{item.currentProcessName || '待开始'}}</view>
          <!-- 生成菲号按钮 -->
          <view wx:if="{{item.currentProcessName === '裁剪' || item.currentProcessName === '采购'}}" class="item-actions">
            <view class="action-btn" bindtap="onGenerateBundle" data-order="{{item}}">
              <text>📋 生成菲号</text>
            </view>
          </view>
        </view>

      <view class="btn">
        <view class="btn-secondary {{orders.loading || !orders.hasMore ? 'btn-disabled' : ''}}" bindtap="loadMoreActive">{{orders.loading ? '加载中...' : (orders.hasMore ? '加载更多' : '没有更多了')}}</view>
      </view>
    </view>
  </view>

  <!-- 生成菲号弹窗 -->
  <view wx:if="{{bundleModal.visible}}" class="modal">
    <view class="modal-box wide">
      <view class="modal-head">
        生成菲号
      </view>
      <view class="modal-body">
        <view class="cf-list">
          <view class="cf-item"><text class="cf-k">订单</text><text class="cf-v hl">{{bundleModal.orderNo}}</text></view>
          <view class="cf-item"><text class="cf-k">款号</text><text class="cf-v">{{bundleModal.styleNo}}</text></view>
        </view>
        
        <view class="bundle-input-list">
          <view wx:for="{{bundleModal.items}}" wx:key="index" class="bundle-input-item">
            <view class="bii-row">
              <text class="bii-label">颜色</text>
              <input class="bii-input" placeholder="如：红色" value="{{item.color}}" bindinput="onBundleColorInput" data-idx="{{index}}" />
            </view>
            <view class="bii-row">
              <text class="bii-label">尺码</text>
              <input class="bii-input" placeholder="如：L" value="{{item.size}}" bindinput="onBundleSizeInput" data-idx="{{index}}" />
            </view>
            <view class="bii-row">
              <text class="bii-label">数量</text>
              <input class="bii-input" type="digit" placeholder="如：20" value="{{item.quantity}}" bindinput="onBundleQuantityInput" data-idx="{{index}}" />
            </view>
            <view wx:if="{{bundleModal.items.length > 1}}" class="bii-remove" bindtap="onRemoveBundleItem" data-idx="{{index}}">
              <text>✕ 删除</text>
            </view>
          </view>
        </view>
        
        <view class="bundle-add-btn" bindtap="onAddBundleItem">
          <text>+ 添加一行</text>
        </view>
      </view>
      <view class="modal-btns">
        <view class="mbtn cancel" bindtap="onCancelBundle">取消</view>
        <view class="mbtn ok {{bundleModal.loading ? 'off' : ''}}" bindtap="onConfirmBundle">
          {{bundleModal.loading ? '生成中...' : '确认生成'}}
        </view>
      </view>
    </view>
  </view>
</view>
