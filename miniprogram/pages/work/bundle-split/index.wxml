<wxs module="fmt">
function abbr(str) {
  if (!str) return '?';
  return str.substring(0, 2);
}
module.exports = { abbr: abbr };
</wxs>
<view class="container">
  <custom-nav title="拆菲号 / 单价调整" show-back="{{true}}" show-search="{{false}}" />

  <!-- ======== Tab 切换栏 ======== -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'tab-active' : ''}}" data-tab="0" bindtap="switchTab">拆菲号</view>
    <view class="tab-item {{activeTab === 1 ? 'tab-active' : ''}}" data-tab="1" bindtap="switchTab">待确认</view>
    <view class="tab-item {{activeTab === 2 ? 'tab-active' : ''}}" data-tab="2" bindtap="switchTab">单价调整</view>
  </view>

  <!-- ======== Panel 0: 拆菲号 ======== -->
  <view wx:if="{{activeTab === 0}}">

    <!-- 搜索订单 -->
    <view wx:if="{{needSearch}}" class="search-bar-wrap">
      <view class="search-bar-row">
        <input class="search-bar-input" placeholder="输入订单号或扫码查单" value="{{searchOrderNo}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="doSearch" />
        <view class="search-bar-btn" bindtap="doSearch" hover-class="search-bar-btn-hover">查询</view>
      </view>
      <view class="scan-bundle-bar">
        <view class="scan-bundle-btn" bindtap="scanBundleQr" hover-class="scan-bundle-btn-hover">
          <text class="scan-icon">📷</text>
          <text>扫码菲号直接拆</text>
        </view>
      </view>
    </view>

    <!-- 已有订单号时的主内容 -->
    <block wx:else>
      <view class="order-bar">
        <view class="order-bar-left">
          <text class="order-label">订单号</text>
          <text class="order-no">{{orderNo}}</text>
        </view>
        <view class="order-bar-actions">
          <view class="scan-bundle-btn-inline" bindtap="scanBundleQr" hover-class="change-btn-hover">📷 扫菲号</view>
          <view class="change-btn" bindtap="changeOrder" hover-class="change-btn-hover">换单</view>
        </view>
      </view>

      <view wx:if="{{loading}}" class="loading-state"><text>加载菲号中...</text></view>

      <view wx:elif="{{bundles.length}}" class="bundle-list">
        <view wx:for="{{bundles}}" wx:key="id" class="bundle-card {{selectedIdx === index ? 'selected' : ''}}" bindtap="selectBundle" data-idx="{{index}}">
          <!-- 卡片头部：左图右信息 -->
          <view class="bundle-card-hd">
            <!-- 左侧款式图 -->
            <view class="bundle-thumb">
              <image wx:if="{{orderStyleCover}}" class="bundle-thumb-img" src="{{orderStyleCover}}" mode="aspectFill" lazy-load="{{true}}" />
              <view wx:else class="bundle-thumb-placeholder">
                <text class="thumb-abbr">{{fmt.abbr(item.styleNo)}}</text>
              </view>
            </view>
            <!-- 右侧 3 行信息 -->
            <view class="bundle-info">
              <!-- 第 1 行：订单号 -->
              <view class="bundle-info-row">
                <text class="bi-label">订单号</text>
                <text class="bi-val bi-order-no">{{item.productionOrderNo || orderNo}}</text>
              </view>
              <!-- 第 2 行：款号 · 颜色 -->
              <view class="bundle-info-row">
                <text class="bi-val bi-style-no">{{item.styleNo || '-'}}</text>
                <text class="bi-dot"> · </text>
                <text class="bi-val bi-color">{{item.color || '-'}}</text>
              </view>
              <!-- 第 3 行：菲号 + 数量徽章 -->
              <view class="bundle-info-row">
                <text class="bi-label">菲号</text>
                <text class="bi-val bi-bundle-label">{{item.bundleLabel || item.bundleNo}}</text>
                <text class="bi-badge">{{item.quantity}}件</text>
              </view>
            </view>
          </view>
          <!-- 持有人（可选） -->
          <view wx:if="{{item.operatorName}}" class="bundle-holder">
            <text class="holder-icon">👤</text>
            <text class="holder-label">持有：</text>
            <text class="holder-name">{{item.operatorName}}</text>
          </view>

          <view wx:if="{{selectedIdx === index}}" class="split-form" catchtap="">
            <view class="form-row">
              <text class="form-label">转出数量</text>
              <input class="form-input" type="number" placeholder="输入件数" value="{{splitQty}}" bindinput="onQtyInput" />
            </view>
            <view class="form-row">
              <text class="form-label">当前工序</text>
              <picker mode="selector" range="{{processes}}" range-key="processName" value="{{processIdx}}" bindchange="onProcessChange">
                <view class="picker-box">
                  <text class="{{processIdx >= 0 ? '' : 'placeholder'}}">{{processIdx >= 0 ? processes[processIdx].processName : '选择工序'}}</text>
                  <text class="arrow">›</text>
                </view>
              </picker>
            </view>
            <view class="form-row">
              <text class="form-label">接手工人</text>
              <picker mode="selector" range="{{workers}}" range-key="workerName" value="{{workerIdx}}" bindchange="onWorkerChange">
                <view class="picker-box">
                  <text class="{{workerIdx >= 0 ? '' : 'placeholder'}}">{{workerIdx >= 0 ? workers[workerIdx].workerName : '选择工人'}}</text>
                  <text class="arrow">›</text>
                </view>
              </picker>
            </view>
            <view class="split-summary" wx:if="{{processIdx >= 0 && splitQty}}">
              <text>剩余 {{(bundles[selectedIdx].quantity || 0) - splitQty}} 件保留，{{splitQty}} 件转给 {{workers[workerIdx].workerName || '--'}}</text>
            </view>
            <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="submitSplit" hover-class="submit-hover">{{submitting ? '提交中...' : '确认拆分'}}</view>
          </view>
        </view>
      </view>

      <view wx:else class="empty-state empty-state-card">
        <text class="empty-icon">📦</text>
        <text class="empty-text">该订单暂无菲号</text>
        <text class="empty-hint">请确认订单号是否正确，或扫码菲号直接拆</text>
      </view>
    </block>

    <!-- 拆分记录 -->
    <view wx:if="{{splitRecords.length}}" class="records-section">
      <view class="records-header">
        <text class="records-title">拆分记录</text>
        <text class="records-clear" bindtap="clearRecords">清空</text>
      </view>
      <view class="record-item" wx:for="{{splitRecords}}" wx:key="time">
        <view class="record-top">
          <text class="record-order">{{item.orderNo}}</text>
          <text class="record-time">{{item.timeLabel}}</text>
        </view>
        <view class="record-bottom">
          <text class="record-bundle">{{item.bundleNo}}</text>
          <text class="record-detail">{{item.qty}}件 → {{item.workerName}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ======== Panel 1: 待确认 ======== -->
  <view wx:if="{{activeTab === 1}}">
    <view wx:if="{{pendingLoading}}" class="loading-state"><text>加载中...</text></view>

    <view wx:elif="{{pendingSplits.length}}" class="pending-list">
      <view wx:for="{{pendingSplits}}" wx:key="id" class="pending-card">
        <view class="pending-header">
          <text class="pending-label">拆菲请求</text>
          <text class="pending-status pending">{{item.splitStatus}}</text>
        </view>
        <view class="pending-row">
          <text class="pending-key">订单号</text>
          <text class="pending-val">{{item.orderNo || '-'}}</text>
        </view>
        <view class="pending-row">
          <text class="pending-key">菲号</text>
          <text class="pending-val">{{item.sourceBundleName || item.sourceBundleLabel || '-'}}</text>
        </view>
        <view class="pending-row">
          <text class="pending-key">工序</text>
          <text class="pending-val">{{item.currentProcessName || '-'}}</text>
        </view>
        <view class="pending-row">
          <text class="pending-key">数量</text>
          <text class="pending-val highlight">{{item.transferQuantity || 0}} 件</text>
        </view>
        <view class="pending-row">
          <text class="pending-key">来自</text>
          <text class="pending-val">{{item.fromWorkerName || '-'}}</text>
        </view>
        <view class="confirm-btn {{confirmingId === item.id ? 'disabled' : ''}}" data-id="{{item.id}}" bindtap="confirmPendingSplit" hover-class="submit-hover">
          {{confirmingId === item.id ? '确认中...' : '接收并确认'}}
        </view>
      </view>
    </view>

    <view wx:else class="empty-state empty-state-card">
      <text class="empty-icon">📥</text>
      <text class="empty-text">暂无待确认的拆菲请求</text>
      <text class="empty-hint">当有工友向你拆菲转派时会显示在这里</text>
    </view>
  </view>

  <!-- ======== Panel 2: 单价调整 ======== -->
  <view wx:if="{{activeTab === 2}}">

    <!-- 搜索订单 -->
    <view class="search-bar-wrap">
      <view class="search-bar-row">
        <input class="search-bar-input" placeholder="输入订单号查询工序" value="{{priceSearchInput}}" bindinput="onPriceSearchInput" confirm-type="search" bindconfirm="doPriceSearch" />
        <view class="search-bar-btn" bindtap="doPriceSearch" hover-class="search-bar-btn-hover">查询</view>
      </view>
    </view>

    <!-- 工序列表 -->
    <view wx:if="{{priceLoading}}" class="loading-state"><text>加载工序中...</text></view>

    <view wx:elif="{{priceProcesses.length}}" class="process-list">
      <view wx:for="{{priceProcesses}}" wx:key="processName" class="process-card {{selectedProcessIdx === index ? 'selected' : ''}}" bindtap="selectPriceProcess" data-idx="{{index}}">
        <view class="process-row">
          <text class="process-name">{{item.processName}}</text>
          <text class="process-price">¥{{item.unitPrice || '0.00'}}</text>
        </view>
        <view class="process-meta">
          <text wx:if="{{item.progressStage}}">{{item.progressStage}}</text>
          <text class="meta-sep" wx:if="{{item.progressStage}}">/</text>
          <text>{{item.bundleCount || 0}} 个菲号</text>
        </view>

        <!-- 展开的调整表单 -->
        <view wx:if="{{selectedProcessIdx === index}}" class="adjust-form" catchtap="">
          <view wx:if="{{!isAdmin}}" class="admin-tip">⚠️ 仅管理员可调整单价</view>
          <view class="form-row">
            <text class="form-label">新单价（元）</text>
            <input class="form-input" type="digit" placeholder="输入新单价" value="{{adjustPrice}}" bindinput="onAdjustPriceInput" />
          </view>
          <view class="form-row form-row-full">
            <text class="form-label">调整原因（必填）</text>
            <textarea class="reason-textarea" placeholder="请输入调整原因，如：面料加厚工艺变复杂" value="{{adjustReason}}" bindinput="onAdjustReasonInput" maxlength="200" />
          </view>
          <view class="submit-btn {{adjustSubmitting || !isAdmin ? 'disabled' : ''}}" bindtap="submitAdjust" hover-class="submit-hover">{{adjustSubmitting ? '提交中...' : '确认调整'}}</view>
        </view>
      </view>
    </view>

    <view wx:elif="{{priceOrderNo && !priceLoading}}" class="empty-state empty-state-card">
      <text class="empty-icon">📋</text>
      <text class="empty-text">该订单暂无工序数据</text>
      <text class="empty-hint">请确认订单已分配工序</text>
    </view>

    <!-- 调整历史 -->
    <view wx:if="{{adjustHistory.length}}" class="records-section">
      <view class="records-header">
        <text class="records-title">调整记录</text>
      </view>
      <view class="record-item" wx:for="{{adjustHistory}}" wx:key="id">
        <view class="record-top">
          <text class="record-order">{{item.processName}}</text>
          <text class="record-time">{{item.adjustedAt}}</text>
        </view>
        <view class="record-bottom">
          <text class="record-bundle">¥{{item.originalPrice}} → ¥{{item.adjustedPrice}}</text>
          <text class="record-detail adjust-by">{{item.adjustedByName}}</text>
        </view>
        <view wx:if="{{item.reason}}" class="record-reason">
          <text>原因：{{item.reason}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 小云 AI 助手浮动入口 -->
  <ai-assistant id="bundleSplitAiAssistant" notice-count="{{unreadNoticeCount}}" />
</view>
