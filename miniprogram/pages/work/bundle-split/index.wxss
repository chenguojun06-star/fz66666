@import '/styles/page-utils.wxss';

/* ======== 搜索栏（两个面板共用）======== */
.search-bar-wrap {
  padding: 24rpx 32rpx 8rpx;
}
.search-bar-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: 20rpx;
  border: 2rpx solid var(--color-border);
  padding: 0 16rpx 0 20rpx;
  height: 96rpx;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  overflow: hidden;
}
.search-bar-input {
  flex: 1;
  height: 96rpx;
  font-size: var(--font-size-lg);
  color: var(--color-text-primary);
  background: transparent;
}
.search-bar-btn {
  flex-shrink: 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: 16rpx;
  font-size: var(--font-size-lg);
  font-weight: 600;
  margin-left: 12rpx;
}
.search-bar-btn-hover { opacity: 0.85; }

/* 扫码菲号入口 */
.scan-bundle-bar {
  margin-top: 16rpx;
}
.scan-bundle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: var(--font-size-lg);
  font-weight: 600;
  box-shadow: 0 4px 16px rgba(255,107,53,0.25);
}
.scan-bundle-btn-hover { opacity: 0.85; }
.scan-icon { font-size: 40rpx; }

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ======== Tab 切换栏 ======== */
.tab-bar {
  display: flex;
  background: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--font-size-md-lg);
  font-weight: 500;
  color: var(--color-text-secondary);
  position: relative;
  transition: color 0.2s;
}
.tab-item.tab-active {
  color: var(--color-primary);
  font-weight: 700;
}
.tab-item.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--color-primary);
}

/* ======== 订单栏 ======== */
.order-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 32rpx 16rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg, 16rpx);
  box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
}
.order-bar-left { flex: 1; display: flex; align-items: center; gap: 12rpx; min-width: 0; }
.order-bar-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.order-label {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}
.order-no {
  font-size: var(--font-size-md-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.scan-bundle-btn-inline {
  font-size: var(--font-size-md);
  color: #ff6b35;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ff6b35;
  border-radius: var(--radius-lg, 16rpx);
  white-space: nowrap;
}
.change-btn {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--color-primary);
  border-radius: var(--radius-lg, 16rpx);
  white-space: nowrap;
}
.change-btn-hover { opacity: 0.7; }

/* ======== 加载 ======== */
.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-secondary);
  font-size: var(--font-size-base);
}

/* ======== 菲号列表 ======== */
.bundle-list {
  padding: 0 32rpx;
}
.bundle-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg, 16rpx);
  margin-bottom: 20rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.bundle-card.selected {
  border-color: var(--color-primary);
}
.bundle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.bundle-no {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}
.bundle-qty {
  font-size: var(--font-size-md-lg);
  color: var(--color-primary);
  font-weight: 500;
}
.bundle-meta {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 8rpx;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}
.bundle-style {
  color: var(--color-primary);
  font-weight: 500;
}
.meta-sep {
  color: var(--color-border);
}
.bundle-operator {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 8rpx;
  padding: 6rpx 12rpx;
  background: #fff3e0;
  border-radius: 8rpx;
}
.operator-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.operator-name {
  font-size: var(--font-size-sm);
  color: #e65100;
  font-weight: 600;
}

/* ======== 拆分表单 ======== */
.split-form {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}
.split-summary {
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: #f0f7ff;
  border-radius: 12rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: var(--line-height-medium);
}
.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.form-row-full { flex-direction: column; align-items: stretch; }
.form-label {
  width: 170rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}
.form-row-full .form-label { width: auto; margin-bottom: 12rpx; }
.form-input {
  flex: 1;
  height: 76rpx;
  background: var(--color-bg-page);
  border-bottom: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg, 16rpx);
  padding: 0 20rpx;
  font-size: var(--font-size-md-lg);
}

.picker-box {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 76rpx;
  background: var(--color-bg-page);
  border-bottom: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg, 16rpx);
  padding: 0 20rpx;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}
.picker-box .placeholder {
  color: var(--color-text-secondary);
}
.picker-box .arrow {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

/* ======== 提交按钮 ======== */
.submit-btn {
  margin-top: 8rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-lg, 16rpx);
  font-size: var(--font-size-lg);
  font-weight: 600;
}
.submit-hover { opacity: 0.85; }
.submit-btn.disabled { opacity: 0.5; pointer-events: none; }

/* ======== 工序列表（Panel 2）======== */
.process-list {
  padding: 0 32rpx;
}
.process-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg, 16rpx);
  margin-bottom: 20rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.process-card.selected {
  border-color: var(--color-primary);
}
.process-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.process-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}
.process-price {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-warning);
}
.process-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* ======== 调整表单 ======== */
.adjust-form {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border);
}
.admin-tip {
  font-size: var(--font-size-md);
  color: var(--color-warning);
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: var(--color-warning-bg);
  border-radius: var(--radius-lg, 16rpx);
}
.reason-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--color-bg-page);
  border-bottom: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg, 16rpx);
  padding: 16rpx 20rpx;
  font-size: var(--font-size-base);
  box-sizing: border-box;
  line-height: var(--line-height-relaxed);
}

/* ======== 记录区域（拆分记录 + 调整历史共用）======== */
.records-section {
  margin: 24rpx 32rpx 0;
}
.records-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.records-title {
  font-size: var(--font-size-md-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}
.records-clear {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}
.record-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg, 16rpx);
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm, 0 2px 8px rgba(0,0,0,0.04));
}
.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.record-order {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
}
.record-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.record-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.record-bundle {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}
.record-detail {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.adjust-by {
  color: var(--color-primary);
}
.record-reason {
  margin-top: 8rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-medium);
}
