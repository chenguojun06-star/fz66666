@import '/styles/page-utils.wxss';

/* ======== 搜索栏（两个面板共用）======== */
.search-bar-wrap {
  padding: var(--spacing-lg) 0 var(--spacing-xs);
}

.search-bar-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border);
  padding: 0 var(--spacing-md) 0 var(--spacing-lg);
  height: 48px;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.search-bar-input {
  flex: 1;
  height: var(--input-height-sm);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: transparent;
}

.search-bar-btn {
  flex-shrink: 0;
  height: var(--btn-height-sm);
  line-height: var(--btn-height-sm);
  padding: 0 var(--spacing-xl);
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  margin-left: var(--spacing-sm);
}

.search-bar-btn-hover { opacity: 0.85; }

/* 扫码菲号入口 */
.scan-bundle-bar {
  margin-top: var(--spacing-sm);
}

.scan-bundle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  height: var(--btn-height-md);
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
}

.scan-bundle-btn-hover { opacity: 0.85; }
.scan-icon { font-size: var(--font-size-2xl); }

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x) calc(20px + env(safe-area-inset-bottom));
}

/* ======== Tab 切换栏 ======== */
.tab-bar {
  display: flex;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--spacing-md) 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  position: relative;
  transition: color 0.2s;
}

.tab-item.tab-active {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

.tab-item.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 3px;
  border-radius: 2px;
  background: var(--color-primary);
}

/* ======== 订单栏 ======== */
.order-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin: var(--spacing-lg) 0 var(--spacing-md);
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}

.order-bar-left { flex: 1; display: flex; align-items: center; gap: var(--spacing-sm); min-width: 0; }
.order-bar-actions {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex-shrink: 0;
}

.order-label {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.order-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scan-bundle-btn-inline {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: var(--spacing-xs) var(--spacing-md);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-lg);
  white-space: nowrap;
}

.change-btn {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: var(--spacing-xs) var(--spacing-md);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-lg);
  white-space: nowrap;
}

.change-btn-hover { opacity: 0.7; }

/* ======== 加载 ======== */
.loading-state {
  text-align: center;
  padding: 60px 0;
  color: var(--color-text-secondary);
  font-size: var(--font-size-base);
}

/* ======== 菲号列表 ======== */
.bundle-list { padding: 0; }

.bundle-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  border: 1px solid transparent;
  transition: border-color 0.2s;
}

.bundle-card.selected {
  border-color: var(--color-primary);
}

/* ======== 卡片头部：左图右信息布局 ======== */
.bundle-card-hd {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: var(--spacing-md);
}

.bundle-thumb {
  flex-shrink: 0;
  width: 60px;
  height: 60px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  background: var(--color-bg-page);
}

.bundle-thumb-img {
  width: 60px;
  height: 60px;
}

.bundle-thumb-placeholder {
  width: 60px;
  height: 60px;
  background: var(--color-info-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.thumb-abbr {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.bundle-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  justify-content: center;
}

.bundle-info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
  min-width: 0;
}

.bi-label {
  flex-shrink: 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-page);
  padding: 1px 5px;
  border-radius: var(--radius-xs);
}

.bi-val {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bi-order-no {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bi-style-no {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.bi-dot {
  color: var(--color-border);
  flex-shrink: 0;
}

.bi-color {
  color: var(--color-text-secondary);
}

.bi-bundle-label {
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bi-badge {
  flex-shrink: 0;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-sm);
  padding: 2px 9px;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-semibold);
}

/* 持有人条 */
.bundle-holder {
  display: flex;
  align-items: center;
  gap: 3px;
  margin-top: 7px;
  padding: 4px 7px;
  background: var(--color-info-bg);
  border-radius: var(--radius-xs);
}

.holder-icon {
  font-size: var(--font-size-sm);
}

.holder-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.holder-name {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* ======== 拆分表单 ======== */
.split-form {
  margin-top: var(--spacing-md);
  padding: var(--spacing-lg) var(--spacing-md) var(--spacing-sm);
  background: var(--color-bg-page);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border-light);
}

.split-summary {
  margin-top: 2px;
  margin-bottom: var(--spacing-sm);
  padding: var(--spacing-xs) var(--spacing-md);
  background: var(--color-primary-bg);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: var(--line-height-medium);
}

.form-row {
  display: flex;
  align-items: center;
  height: 40px;
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: 1px solid var(--color-border-light);
}

.form-row:last-of-type {
  border-bottom: none;
}

.form-row-full { flex-direction: column; align-items: stretch; }
.form-label {
  width: 80px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  font-weight: var(--font-weight-medium);
}

.form-row-full .form-label { width: auto; margin-bottom: var(--spacing-sm); }

.form-input {
  flex: 1;
  height: 40px;
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  border-radius: var(--input-radius);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  padding: 0 var(--spacing-md);
  box-sizing: border-box;
}

.picker-box {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 40px;
  background: transparent;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  padding: 0 4px 0 0;
}

.picker-box .placeholder {
  color: var(--color-text-secondary);
}

.picker-box .arrow {
  font-size: var(--font-size-xl);
  color: var(--color-text-secondary);
  line-height: 1;
}

/* ======== 提交按钮 ======== */
.submit-btn,
.confirm-btn {
  margin-top: var(--spacing-xs);
  height: 42px;
  line-height: 42px;
  text-align: center;
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
}

.submit-hover { opacity: 0.85; }
.submit-btn.disabled,
.confirm-btn.disabled { opacity: 0.5; pointer-events: none; }
.confirm-btn { background: var(--color-success); color: var(--color-text-white); border: none; }

/* ======== 待确认列表 ======== */
.pending-list { padding: 0; }

.pending-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-info-bg);
}

.pending-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.pending-label {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.pending-status {
  font-size: var(--font-size-sm);
  padding: 2px 8px;
  border-radius: var(--radius-xs);
  background: var(--color-warning-bg);
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
}

.pending-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.pending-key {
  width: 60px;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.pending-val {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.pending-val.highlight {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* ======== 工序列表（Panel 2）======== */
.process-list { padding: 0; }

.process-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-md);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  border: 1px solid transparent;
  transition: border-color 0.2s;
}

.process-card.selected {
  border-color: var(--color-primary);
}

.process-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.process-name {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.process-price {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-warning);
}

.process-meta {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* ======== 调整表单 ======== */
.adjust-form {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1px solid var(--color-border);
}

.admin-tip {
  font-size: var(--font-size-md);
  color: var(--color-warning);
  margin-bottom: var(--spacing-sm);
  padding: var(--spacing-xs) var(--spacing-md);
  background: var(--color-warning-bg);
  border-radius: var(--radius-lg);
}

.reason-textarea {
  width: 100%;
  min-height: 80px;
  background: var(--color-bg-page);
  border-bottom: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--font-size-base);
  box-sizing: border-box;
  line-height: var(--line-height-relaxed);
}

/* ======== 记录区域（拆分记录 + 调整历史共用）======== */
.records-section {
  margin: var(--spacing-lg) 0 0;
}

.records-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.records-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.records-clear {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

.record-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border-light);
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-order {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.record-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.record-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: var(--spacing-xs);
}

.record-bundle {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.record-detail {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.adjust-by {
  color: var(--color-primary);
}

.record-reason {
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-medium);
}
