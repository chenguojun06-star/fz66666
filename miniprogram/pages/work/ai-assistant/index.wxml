<view class="chat-wrapper">

  <!-- 动态实时提醒 -->
  <view class="dynamic-suggestions" wx:if="{{dynamicSuggestions.length > 0 && messages.length <= 1 && !sending}}">
    <view class="dynamic-suggestions-label">🔔 实时提醒</view>
    <view class="dynamic-suggestions-list">
      <view class="dynamic-suggestion-chip" hover-class="dynamic-suggestion-chip-hover" hover-stay-time="100" bindtap="onQuickPrompt" data-text="{{item.text}}" data-cmd="{{false}}" wx:for="{{dynamicSuggestions}}" wx:key="label">
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 快捷提问芯片（查询型直接发送；指令型填入输入框等待补充订单号） -->
  <view class="quick-chips">
    <view
      wx:for="{{quickPrompts}}"
      wx:key="label"
      class="chip {{item.cmd ? 'chip-cmd' : ''}}"
      bindtap="onQuickPrompt"
      data-text="{{item.text}}"
      data-cmd="{{item.cmd}}"
    >
      {{item.label}}
      <text wx:if="{{item.cmd}}" class="chip-hint"> +单号</text>
    </view>
  </view>

  <!-- 对话气泡区 -->
  <view class="msg-list">
    <view
      wx:for="{{visibleMessages}}"
      wx:key="id"
      class="msg-row {{item.role === 'user' ? 'row-user' : 'row-ai'}}"
    >
      <!-- AI 头像 -->
      <view wx:if="{{item.role === 'ai'}}" class="avatar avatar-ai">
        <view class="chat-cloud">
          <view class="chat-cloud-part chat-cloud-part-left"></view>
          <view class="chat-cloud-part chat-cloud-part-center"></view>
          <view class="chat-cloud-part chat-cloud-part-right"></view>
          <view class="chat-cloud-base"></view>
          <view class="chat-cloud-eye chat-cloud-eye-left"><view class="chat-cloud-eye-dot"></view></view>
          <view class="chat-cloud-eye chat-cloud-eye-right"><view class="chat-cloud-eye-dot"></view></view>
          <view class="chat-cloud-smile"></view>
        </view>
      </view>

      <!-- 气泡 -->
      <view class="bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-ai'}}">
        <text wx:if="{{item.loading}}" class="loading-text">小云正在思考，你可以继续输入下一个问题…</text>
        <block wx:else>
          <!-- 用户发送的图片 -->
          <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" class="bubble-image" mode="widthFix" bindtap="previewImage" data-src="{{item.imageUrl}}" />
          <view class="text-segments" wx:if="{{item.textSegments}}">
            <text
              wx:for="{{item.textSegments}}" wx:for-item="seg" wx:key="index"
              class="{{seg.isOrder ? 'order-link-seg' : ''}}"
              bindtap="onSegmentTap"
              data-type="{{seg.isOrder ? 'order' : 'text'}}"
              data-orderno="{{seg.orderNo}}"
            >{{seg.content}}</text>
          </view>
          <text wx:elif="{{item.text}}" decode="{{true}}" space="nbsp" user-select>{{item.text}}</text>

          <!-- 可执行命令卡片 -->
          <block wx:for="{{item.actionCards}}" wx:for-item="card" wx:for-index="ci" wx:key="ci">
          <view class="action-card {{card._cardType}}">
            <view class="action-card-hd">⚡ {{card.title}}</view>
            <view wx:if="{{card.desc}}" class="action-card-desc">{{card.desc}}</view>
            <view class="action-card-btns">
              <view
                wx:for="{{card.actions}}" wx:for-item="act" wx:for-index="ai" wx:key="ai"
                class="action-btn {{act.type === 'mark_urgent' ? 'btn-danger' : act.type === 'send_notification' ? 'btn-warning' : 'btn-primary'}}"
                hover-class="btn-primary-hover" hover-stay-time="100"
                bindtap="onCardAction"
                data-type="{{act.type}}"
                data-path="{{act.path}}"
                data-orderid="{{card.orderId}}"
                data-cardtitle="{{card.title}}"
              >{{act.label}}</view>
            </view>
          </view>
          </block>

          <!-- 图表卡片（简化文字摘要） -->
          <block wx:for="{{item.charts}}" wx:for-item="chart" wx:for-index="chi" wx:key="chi">
          <view class="chart-card">
            <view class="chart-card-hd">📊 {{chart.title || '数据图表'}}</view>
            <view class="chart-card-type">类型：{{chart.chartType || '图表'}}</view>
          </view>
          </block>

          <!-- 团队状态卡片 -->
          <block wx:for="{{item.teamStatusCards}}" wx:for-item="ts" wx:for-index="ti" wx:key="ti">
          <view class="team-card">
            <view class="team-card-hd-row">
              <view class="team-card-hd">👥 {{ts.title || '团队状态'}}</view>
              <view wx:if="{{ts.routePath}}" class="team-card-nav-btn"
                bindtap="onTeamCardNavigate" data-path="{{ts.routePath}}">去处理页 →</view>
            </view>
            <view wx:if="{{ts.summary}}" class="team-card-desc">{{ts.summary}}</view>
            <view wx:if="{{ts.stats}}" class="team-card-stats">
              <text wx:if="{{ts.stats.noticeCount}}">通知 {{ts.stats.noticeCount}} · </text>
              <text wx:if="{{ts.stats.overdue}}" class="tag-overdue">已超期 · </text>
              <text wx:if="{{ts.stats.dueAt}}">截止 {{ts.stats.dueAt}} · </text>
              <text wx:if="{{ts.stats.nextStep}}">{{ts.stats.nextStep}}</text>
            </view>
            <view wx:for="{{ts.recipients}}" wx:for-item="r" wx:key="index" class="team-card-recipient-row">
              <text class="r-name">{{r.displayName || r.roleName}}</text>
              <text class="r-stage">{{r.processingStage}}</text>
              <text class="r-status">{{r.dispatchStatus}}</text>
            </view>
            <view wx:if="{{ts.history.length}}" class="team-card-hist-label">处理记录</view>
            <view wx:for="{{ts.history}}" wx:for-item="h" wx:key="index" class="team-card-hist-row">
              <text class="h-time">{{h.createdAt}}</text>
              <text class="h-actor">{{h.actor}}</text>
              <text class="h-remark">{{h.stage}} {{h.remark}}</text>
            </view>
          </view>
          </block>

          <!-- 菲号拆分卡片 -->
          <block wx:for="{{item.bundleSplitCards}}" wx:for-item="bs" wx:for-index="bi" wx:key="bi">
          <view class="bundle-card">
            <view class="bundle-card-hd">✂️ {{bs.title || '菲号拆分'}}</view>
            <view class="bundle-card-meta">
              <text>{{bs.rootBundleLabel}}</text>
              <text wx:if="{{bs.orderNo}}"> · {{bs.orderNo}}</text>
              <text wx:if="{{bs.currentProcessName}}"> · {{bs.currentProcessName}}</text>
              <text wx:if="{{bs.stats.activeChildren}}"> · {{bs.stats.activeChildren}}个子菲号</text>
            </view>
            <view wx:for="{{bs.bundles}}" wx:for-item="b" wx:key="index" class="bundle-row">
              <view class="bundle-row-info">
                <text class="b-label">{{b.bundleLabel}}</text>
                <text class="b-no">{{b.bundleNo}}</text>
                <text class="b-qty">×{{b.quantity}}</text>
                <text class="b-status">{{b.splitStatus}}</text>
                <text wx:if="{{b.operatorName}}" class="b-op">{{b.operatorName}}</text>
              </view>
              <image wx:if="{{b.qrUrl}}" src="{{b.qrUrl}}" class="bundle-qr" mode="aspectFit"/>
            </view>
            <view wx:if="{{bs.rootBundleLabel}}" class="bundle-card-btn"
              bindtap="onCardAction" data-type="view_cutting" data-cardtitle="打印子菲号">
              打印子菲号
            </view>
          </view>
          </block>

          <!-- 步骤向导卡片 -->
          <block wx:for="{{item.stepWizardCards}}" wx:for-item="wiz" wx:for-index="wi" wx:key="wi">
          <view class="sw-card" wx:if="{{!wiz._submitted}}">
            <view class="sw-header">
              <text class="sw-icon">{{wiz.icon || '📋'}}</text>
              <text class="sw-title">{{wiz.title}}</text>
            </view>
            <view class="sw-steps">
              <text wx:for="{{wiz.steps}}" wx:for-item="s" wx:for-index="si" wx:key="stepKey"
                class="sw-step-dot {{si === wiz._currentStep ? 'active' : si < wiz._currentStep ? 'done' : ''}}">
                {{si < wiz._currentStep ? '✓' : si + 1}}
              </text>
            </view>
            <block wx:if="{{wiz.steps[wiz._currentStep]}}">
              <view class="sw-content">
                <view wx:if="{{wiz.steps[wiz._currentStep].desc}}" class="sw-step-desc">{{wiz.steps[wiz._currentStep].desc}}</view>
                <block wx:for="{{wiz.steps[wiz._currentStep].fields}}" wx:for-item="field" wx:for-index="fi" wx:key="key">
                  <view class="sw-field">
                    <text class="sw-label">{{field.label}}<text wx:if="{{field.required}}" class="sw-required">*</text></text>
                    <view wx:if="{{field.inputType === 'select'}}" class="sw-options">
                      <view wx:for="{{field.options}}" wx:for-item="opt" wx:for-index="oi" wx:key="value"
                        class="sw-opt-btn {{wiz._formData[field.key] === opt.value ? 'selected' : ''}}"
                        bindtap="onWizardSelect" data-msgid="{{item.id}}" data-wi="{{wi}}" data-key="{{field.key}}" data-value="{{opt.value}}">
                        <text wx:if="{{opt.icon}}">{{opt.icon}} </text>{{opt.label}}
                      </view>
                    </view>
                    <view wx:if="{{field.inputType === 'multi_select'}}" class="sw-options">
                      <view wx:for="{{field.options}}" wx:for-item="opt" wx:for-index="oi" wx:key="value"
                        class="sw-opt-btn {{wiz._formDataSelectedSet[field.key] && wiz._formDataSelectedSet[field.key][opt.value] ? 'selected' : ''}}" 
                        bindtap="onWizardMultiSelect" data-msgid="{{item.id}}" data-wi="{{wi}}" data-key="{{field.key}}" data-value="{{opt.value}}">
                        <text wx:if="{{opt.icon}}">{{opt.icon}} </text>{{opt.label}}
                      </view>
                    </view>
                    <input wx:if="{{field.inputType === 'text'}}" class="sw-input" type="text"
                      placeholder="{{field.placeholder || field.label}}"
                      value="{{wiz._formData[field.key] || ''}}"
                      bindinput="onWizardInput" data-msgid="{{item.id}}" data-wi="{{wi}}" data-key="{{field.key}}" />
                    <input wx:if="{{field.inputType === 'number'}}" class="sw-input" type="digit"
                      placeholder="{{field.placeholder || field.label}}"
                      value="{{wiz._formData[field.key] || ''}}"
                      bindinput="onWizardInput" data-msgid="{{item.id}}" data-wi="{{wi}}" data-key="{{field.key}}" />
                    <picker wx:if="{{field.inputType === 'date'}}" mode="date" value="{{wiz._formData[field.key] || ''}}"
                      bindchange="onWizardDate" data-msgid="{{item.id}}" data-wi="{{wi}}" data-key="{{field.key}}">
                      <view class="sw-input sw-date-picker">{{wiz._formData[field.key] || '请选择日期'}}</view>
                    </picker>
                  </view>
                </block>
              </view>
            </block>
            <view class="sw-footer">
              <view wx:if="{{wiz._currentStep > 0}}" class="sw-prev" hover-class="sw-prev-hover"
                bindtap="onWizardPrev" data-msgid="{{item.id}}" data-wi="{{wi}}">上一步</view>
              <view class="sw-next {{!wiz._canNext ? 'disabled' : ''}}" hover-class="{{wiz._canNext ? 'sw-next-hover' : ''}}"
                bindtap="onWizardNext" data-msgid="{{item.id}}" data-wi="{{wi}}">{{wiz._currentStep === wiz.steps.length - 1 ? (wiz.submitLabel || '确认提交') : '下一步'}}</view>
            </view>
          </view>
          <view class="sw-card" wx:else>
            <view class="sw-success">✅ 指令已提交，小云正在处理…</view>
          </view>
          </block>

          <!-- 洞察卡片 -->
          <block wx:for="{{item.insightCards}}" wx:for-item="ic" wx:for-index="ici" wx:key="ici">
          <view class="insight-card insight-{{ic.level || 'info'}}">
            <view class="insight-title">{{ic.level === 'danger' ? '🔴' : ic.level === 'warning' ? '🟠' : ic.level === 'success' ? '🟢' : '🔵'}} {{ic.title}}</view>
            <view wx:if="{{ic.summary}}" class="insight-summary">{{ic.summary}}</view>
            <view wx:if="{{ic.painPoint}}" class="insight-pain">⚠ {{ic.painPoint}}</view>
            <view wx:if="{{ic.execute}}" class="insight-action">→ {{ic.execute}}</view>
            <view wx:if="{{ic.evidence.length}}" class="insight-evidence">
              <view wx:for="{{ic.evidence}}" wx:for-item="ev" wx:for-index="evi" wx:key="evi" class="insight-ev-item">· {{ev}}</view>
            </view>
            <view wx:if="{{ic.source || ic.confidence}}" class="insight-meta">
              <text wx:if="{{ic.source}}" class="insight-source">来源:{{ic.source}}</text>
              <text wx:if="{{ic.confidence}}" class="insight-confidence">{{ic.confidence}}</text>
            </view>
          </view>
          </block>

          <!-- 澄清追问 -->
          <block wx:if="{{item.clarificationHints.length > 0}}">
          <view class="clarification-text">
            <text wx:for="{{item.clarificationHints}}" wx:for-item="hint" wx:for-index="hi" wx:key="hi" class="clarification-hint-line">· {{hint}}
</text>
          </view>
          </block>
        </block>
      </view>

      <!-- 用户头像 -->
      <view wx:if="{{item.role === 'user'}}" class="avatar avatar-user">我</view>
    </view>



  </view>

  <!-- 底部输入栏 -->
  <view class="input-bar">
    <input
      class="msg-input msg-input-full"
      placeholder="输入关键字查询内部资料，如：扫码规范、质检流程"
      value="{{inputText}}"
      bindinput="onInputChange"
      confirm-type="send"
      bindconfirm="onSend"
      adjust-position
    />
    <view
      class="send-btn {{(!inputText) ? 'send-disabled' : ''}}"
      bindtap="onSend"
    >发送</view>
  </view>
  <privacy-dialog id="privacyDialog" />
</view>
