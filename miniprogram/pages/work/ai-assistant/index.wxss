.chat-wrapper {
  min-height: 100vh;
  background: var(--color-bg-light);
  display: flex;
  flex-direction: column;
  padding-bottom: 90px; /* 留给 input-bar ，输入框加高后同步调整 */
}

/* ==================== 快捷芯片 ==================== */
.quick-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  padding: 12px 12px 4px;
}
.chip {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-full);
  padding: 6px 12px;
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  white-space: nowrap;
}
/* 指令型芯片（需补充订单号） */
.chip-cmd {
  border-color: var(--color-warning);
  color: var(--color-warning);
  background: var(--color-bg-light);
}
.chip-hint {
  font-size: var(--font-size-2xs);
  color: var(--color-text-disabled);
  margin-left: 2px;
}

/* ==================== 消息列表 ==================== */
.msg-list {
  flex: 1;
  padding: 8px 12px 12px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.msg-row {
  display: flex;
  align-items: flex-end;
  gap: 6px;
}
.row-user {
  flex-direction: row-reverse; /* 用户消息靠右 */
}
.row-ai {
  flex-direction: row;
}

/* 头像 */
.avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-base);
  flex-shrink: 0;
}
.avatar-ai {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.avatar-user {
  background: var(--color-success);
  color: var(--color-text-white);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-bold);
}

/* 气泡 */
.bubble {
  max-width: 72%;
  padding: 10px 13px;
  border-radius: 10px;
  font-size: var(--font-size-md);
  line-height: var(--line-height-relaxed);
  word-break: break-word;
}
.bubble-ai {
  background: var(--color-bg-card);
  color: var(--color-text-primary);
  border-radius: 2px 10px 10px 10px;
}
.bubble-user {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: 10px 2px 10px 10px;
}

/* 打字动画 */
.loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ==================== 输入栏 ==================== */
/* 待发送图片预览 */
.pending-preview {
  position: fixed;
  bottom: calc(50px + env(safe-area-inset-bottom));
  left: 12px;
  z-index: 10;
  display: flex;
  align-items: flex-start;
}
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  background: var(--color-bg-card);
  border-top: 1px solid var(--color-border-light);
  box-sizing: border-box;
  padding-bottom: calc(10px + env(safe-area-inset-bottom));
}
.msg-input {
  flex: 1;
  background: var(--color-bg-light);
  border-radius: var(--radius-md);
  padding: 0 14px;
  height: 48px;
  line-height: 48px;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}
.send-btn {
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  height: 48px;
  line-height: 48px;
  padding: 0 20px;
  border-radius: var(--radius-md);
  white-space: nowrap;
}
.send-disabled {
  opacity: 0.4;
}

/* 气泡内图片 */
.bubble-image {
  max-width: 100%;
  border-radius: var(--radius-md);
  margin-bottom: 6px;
}

/* ==================== 可执行命令卡片 ==================== */
.action-card {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: var(--radius-md);
  background: var(--color-bg-light);
  border-left: 3px solid var(--color-primary);
}
.action-card.card-danger { border-left-color: var(--color-danger); }
.action-card.card-warning { border-left-color: var(--color-warning); }
.action-card.card-normal { border-left-color: var(--color-primary); }

.action-card-hd {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 4px;
}
.action-card-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-bottom: 8px;
  line-height: var(--line-height-medium);
}
.text-segments {
  display: inline;
}
.order-link-seg {
  color: var(--color-info);
  text-decoration: underline;
}
.action-card-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.action-btn {
  font-size: var(--font-size-xs);
  padding: 5px 14px;
  border-radius: var(--radius-full);
  color: var(--color-text-white);
  text-align: center;
}
.btn-primary { background: var(--color-primary); }
.btn-danger { background: var(--color-danger); }
.btn-warning { background: var(--color-warning); }

/* ==================== 图表/团队/菲号卡片 ==================== */
.chart-card, .team-card, .bundle-card {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: var(--radius-md);
  background: var(--color-bg-light);
  border-left: 3px solid var(--color-primary-light);
}
.chart-card-hd, .team-card-hd, .bundle-card-hd {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 4px;
}
.chart-card-type, .team-card-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: var(--line-height-medium);
}

/* ── 团队状态卡 子样式 ── */
.team-card-hd-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
.team-card-nav-btn { font-size: var(--font-size-xs); color: var(--color-primary); }
.team-card-stats { display: flex; flex-wrap: wrap; margin-bottom: 8px; font-size: var(--font-size-xs); color: var(--color-text-secondary); }
.tag-overdue { color: var(--color-danger); }
.team-card-recipient-row { display: flex; gap: 8px; padding: 4px 0; border-bottom: 1px solid var(--color-border-light); font-size: var(--font-size-xs); color: var(--color-text-primary); }
.r-name { font-weight: var(--font-weight-semibold); }
.r-stage, .r-status { color: var(--color-text-secondary); }
.team-card-hist-label { font-size: var(--font-size-2xs); color: var(--color-text-disabled); margin-top: 8px; margin-bottom: 2px; }
.team-card-hist-row { display: flex; gap: 6px; padding: 2px 0; font-size: var(--font-size-2xs); color: var(--color-text-secondary); }
.h-time { color: var(--color-text-disabled); }

/* ── 菲号拆分卡 子样式 ── */
.bundle-card-meta { font-size: var(--font-size-xs); color: var(--color-text-secondary); margin-bottom: 8px; }
.bundle-row { display: flex; align-items: center; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid var(--color-border-light); }
.bundle-row-info { display: flex; gap: 6px; flex-wrap: wrap; font-size: var(--font-size-xs); color: var(--color-text-primary); }
.b-label { font-weight: var(--font-weight-semibold); }
.b-status, .b-op { color: var(--color-text-secondary); }
.bundle-qr { width: 58px; height: 58px; flex-shrink: 0; border-radius: var(--radius-sm); }
.bundle-card-btn { margin-top: 10px; text-align: center; padding: 7px; border-radius: var(--radius-md); background: var(--color-primary); color: var(--color-text-white); font-size: var(--font-size-xs); }


.dynamic-suggestions {
  padding: 10px 12px 0;
}
.dynamic-suggestions-label {
  font-size: var(--font-size-xxs);
  color: var(--color-danger);
  margin-bottom: 6px;
  font-weight: 600;
}
.dynamic-suggestions-list {
  display: flex;
  flex-direction: row;
  gap: 8px;
  flex-wrap: wrap;
}
.dynamic-suggestion-chip {
  background: var(--color-error-bg);
  color: var(--color-danger);
  border-radius: var(--radius-full);
  padding: 6px 12px;
  font-size: var(--font-size-xs);
  line-height: var(--line-height-normal);
  border: 1px solid var(--color-error-border);
}
.dynamic-suggestion-chip-hover {
  background: var(--color-danger);
  color: var(--color-text-white);
}

/* ==================== 步骤向导卡片 ==================== */
.sw-card {
  margin-top: 10px;
  padding: 10px 12px;
  border-radius: var(--radius-md);
  background: var(--color-bg-light);
  border: 1px solid var(--color-border-light);
}
.sw-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 8px;
}
.sw-icon { font-size: 18px; }
.sw-title { font-size: var(--font-size-md); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
.sw-steps {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 10px;
}
.sw-step-dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  background: #f0f0f0;
  color: #999;
  font-weight: 600;
}
.sw-step-dot.active { background: var(--color-primary); color: #fff; }
.sw-step-dot.done { background: var(--color-success); color: #fff; }
.sw-content { min-height: 40px; }
.sw-step-desc {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-bottom: 8px;
  padding: 6px 8px;
  background: #fafafa;
  border-radius: 6px;
  border-left: 3px solid var(--color-primary);
}
.sw-field { margin-bottom: 8px; }
.sw-label { display: block; font-size: var(--font-size-xs); font-weight: 500; color: var(--color-text-primary); margin-bottom: 4px; }
.sw-required { color: var(--color-danger); margin-left: 2px; }
.sw-options { display: flex; flex-wrap: wrap; gap: 6px; }
.sw-opt-btn {
  padding: 5px 10px;
  border: 1.5px solid #e8e8e8;
  border-radius: 8px;
  background: #fff;
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
}
.sw-opt-btn.selected { border-color: var(--color-primary); background: #e6f4ff; color: var(--color-primary); }
.sw-input {
  width: 100%;
  padding: 7px 10px;
  border: 1.5px solid #e8e8e8;
  border-radius: 8px;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  box-sizing: border-box;
}
.sw-date-picker { color: var(--color-text-secondary); }
.sw-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 8px;
  padding-top: 8px;
  border-top: 1px solid #f0f0f0;
}
.sw-prev {
  padding: 6px 14px;
  border: 1px solid #d9d9d9;
  border-radius: 8px;
  background: #fff;
  color: var(--color-text-secondary);
  font-size: var(--font-size-xs);
}
.sw-prev-hover { background: #f5f5f5; }
.sw-next {
  padding: 6px 16px;
  border: none;
  border-radius: 8px;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-size-xs);
  font-weight: 500;
}
.sw-next.disabled { background: #d9d9d9; }
.sw-next-hover { opacity: 0.85; }
.sw-success { text-align: center; padding: 12px 0; color: var(--color-success); font-weight: 500; font-size: var(--font-size-md); }

.insight-card {
  margin-top: 8px;
  border-radius: 8px;
  padding: 10px 12px;
  border-left: 3px solid #1677ff;
}
.insight-danger { border-left-color: #ff4d4f; background: #fff1f0; }
.insight-warning { border-left-color: #fa8c16; background: #fff7e6; }
.insight-success { border-left-color: #52c41a; background: #f6ffed; }
.insight-info { border-left-color: #1677ff; background: #f0f5ff; }
.insight-title { font-weight: 600; font-size: 13px; color: #333; margin-bottom: 4px; }
.insight-danger .insight-title { color: #cf1322; }
.insight-warning .insight-title { color: #d46b08; }
.insight-success .insight-title { color: #389e0d; }
.insight-info .insight-title { color: #1d39c4; }
.insight-summary { font-size: 12px; color: #333; margin-top: 2px; }
.insight-pain { font-size: 12px; color: #cf1322; margin-top: 2px; }
.insight-action { font-size: 12px; color: #1677ff; margin-top: 2px; }
.insight-evidence { margin-top: 4px; }
.insight-ev-item { font-size: 11px; color: #8c8c8c; line-height: 1.6; }

.clarification-text { margin-top: 8px; }
.clarification-hint-line { font-size: 12px; color: #8c8c8c; line-height: 1.8; display: block; }

.insight-meta { margin-top: 4px; display: flex; gap: 6px; }
.insight-source { font-size: 10px; color: #bfbfbf; }
.insight-confidence { font-size: 10px; color: #bfbfbf; }
