.chat-wrapper {
  min-height: 100vh;
  background: #f0f2ff;
  display: flex;
  flex-direction: column;
  padding-bottom: 140rpx; /* 留给 input-bar */
}

/* ── 快捷芯片 ── */
.quick-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 24rpx 24rpx 8rpx;
}
.chip {
  background: #fff;
  border: 1rpx solid #dde0ff;
  border-radius: 100rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #5B6AF0;
  white-space: nowrap;
}

/* ── 消息列表 ── */
.msg-list {
  flex: 1;
  padding: 16rpx 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.msg-row {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}
.row-user {
  flex-direction: row-reverse; /* 用户消息靠右 */
}
.row-ai {
  flex-direction: row;
}

/* 头像 */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}
.avatar-ai {
  background: #5B6AF0;
  color: #fff;
}
.avatar-user {
  background: #20c997;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* 气泡 */
.bubble {
  max-width: 72%;
  padding: 20rpx 26rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}
.bubble-ai {
  background: #fff;
  color: #1a1a2e;
  border-radius: 4rpx 20rpx 20rpx 20rpx;
}
.bubble-user {
  background: #5B6AF0;
  color: #fff;
  border-radius: 20rpx 4rpx 20rpx 20rpx;
}

/* 打字动画 */
.typing-dots {
  display: flex;
  gap: 10rpx;
  height: 36rpx;
  align-items: center;
}
.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #b0b8e8;
  animation: blink 1.2s infinite;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes blink {
  0%, 80%, 100% { opacity: 0.2; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

/* ── 输入栏 ── */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  box-sizing: border-box;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.msg-input {
  flex: 1;
  background: #f0f2ff;
  border-radius: 100rpx;
  padding: 18rpx 28rpx;
  font-size: 28rpx;
  color: #1a1a2e;
}
.send-btn {
  background: #5B6AF0;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 32rpx;
  border-radius: 100rpx;
  white-space: nowrap;
}
.send-disabled {
  opacity: 0.4;
}
