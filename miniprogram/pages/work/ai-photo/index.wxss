@import '/styles/page-utils.wxss';

.page {
  padding: 24rpx 28rpx 60rpx;
  background: var(--color-bg-page);
  min-height: 100vh;
  box-sizing: border-box;
}

/* ---- 标题 ---- */
.section-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

/* ---- 任务选择卡片 ---- */
.task-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}
.task-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 12rpx 20rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg, 16rpx);
  border: 2rpx solid var(--color-border);
  transition: all 0.2s;
}
.task-card.active {
  border-color: var(--color-primary);
  background: rgba(78, 110, 242, 0.06);
}
.task-icon { font-size: var(--font-size-3xl); margin-bottom: 10rpx; }
.task-label { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text-primary); }
.task-desc  { font-size: var(--font-size-xxs); color: var(--color-text-secondary); margin-top: 6rpx; text-align: center; }

/* ---- 拍照区域 ---- */
.photo-area {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg, 16rpx);
  border: 2rpx dashed var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 28rpx;
}
.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.camera-icon { width: 80rpx; height: 80rpx; }
.photo-hint  { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.preview-img { width: 100%; height: 100%; }

/* 遮罩 */
.overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}
.overlay-text { color: var(--color-text-white); font-size: var(--font-size-base); font-weight: 600; }

/* ---- 按钮行 ---- */
.btn-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}
.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-lg, 16rpx);
  font-size: var(--font-size-md);
  font-weight: 600;
}
.btn-primary {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.btn-outline {
  background: var(--color-bg-card);
  color: var(--color-text-primary);
  border: 2rpx solid var(--color-border);
}

/* ---- 结果卡片 ---- */
.result-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg, 16rpx);
  padding: 28rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0,0,0,0.06));
}
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.result-title { font-size: var(--font-size-base); font-weight: 600; color: var(--color-text-primary); }

/* 严重度徽章 */
.severity {
  font-size: var(--font-size-xs);
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.severity-NONE, .severity-LOW    { background: var(--color-success-bg); color: var(--color-success); }
.severity-MEDIUM                 { background: var(--color-warning-bg); color: var(--color-warning); }
.severity-HIGH, .severity-CRITICAL { background: var(--color-error-bg); color: var(--color-danger); }

.result-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--color-border-light));
}
.row-label { font-size: var(--font-size-sm); color: var(--color-text-secondary); }
.row-value { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text-primary); }

/* 检测明细 */
.detected-list { margin-top: 20rpx; }
.detected-title { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text-primary); margin-bottom: 12rpx; }
.detected-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.item-type { font-size: var(--font-size-xs); font-weight: 600; color: var(--color-primary); min-width: 120rpx; }
.item-desc { font-size: var(--font-size-xs); color: var(--color-text-primary); flex: 1; }
.item-conf { font-size: var(--font-size-xxs); color: var(--color-text-secondary); }

/* AI 报告 / 建议 */
.report-block { margin-top: 20rpx; }
.report-label { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text-primary); display: block; margin-bottom: 8rpx; }
.report-text  { font-size: var(--font-size-sm); color: var(--color-text-secondary); line-height: 1.7; display: block; }
