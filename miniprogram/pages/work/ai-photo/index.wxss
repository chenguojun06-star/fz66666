@import '/styles/page-utils.wxss';
@import '/styles/line-icons.wxss';

.page {
  padding: 24rpx 28rpx 60rpx;
  background: var(--color-bg-page, #f5f6fa);
  min-height: 100vh;
  box-sizing: border-box;
}

/* ---- 标题 ---- */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary, #222);
  margin-bottom: 20rpx;
}

/* ---- 任务选择卡片 ---- */
.task-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}
.task-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 12rpx 20rpx;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  border: 2rpx solid var(--color-border, #eee);
  transition: all 0.2s;
}
.task-card.active {
  border-color: var(--color-primary, #4e6ef2);
  background: rgba(78, 110, 242, 0.06);
}
.task-icon { font-size: 48rpx; margin-bottom: 10rpx; }
.task-label { font-size: 26rpx; font-weight: 600; color: var(--color-text-primary, #222); }
.task-desc  { font-size: 22rpx; color: var(--color-text-secondary, #999); margin-top: 6rpx; text-align: center; }

/* ---- 拍照区域 ---- */
.photo-area {
  position: relative;
  width: 100%;
  height: 480rpx;
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  border: 2rpx dashed var(--color-border, #ddd);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 28rpx;
}
.photo-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.camera-icon { width: 80rpx; height: 80rpx; }
.photo-hint  { font-size: 26rpx; color: var(--color-text-secondary, #999); }
.preview-img { width: 100%; height: 100%; }

/* 遮罩 */
.overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}
.overlay-text { color: #fff; font-size: 30rpx; font-weight: 600; }

/* ---- 按钮行 ---- */
.btn-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}
.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-lg, 16rpx);
  font-size: 28rpx;
  font-weight: 600;
}
.btn-primary {
  background: var(--color-primary, #4e6ef2);
  color: #fff;
}
.btn-outline {
  background: var(--color-bg-card, #fff);
  color: var(--color-text-primary, #333);
  border: 2rpx solid var(--color-border, #ddd);
}

/* ---- 结果卡片 ---- */
.result-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 28rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 12rpx rgba(0,0,0,0.06));
}
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.result-title { font-size: 30rpx; font-weight: 600; color: var(--color-text-primary, #222); }

/* 严重度徽章 */
.severity {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.severity-NONE, .severity-LOW    { background: #e6f7e9; color: #389e0d; }
.severity-MEDIUM                 { background: #fff7e6; color: #d48806; }
.severity-HIGH, .severity-CRITICAL { background: #fff1f0; color: #cf1322; }

.result-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--color-border, #f0f0f0);
}
.row-label { font-size: 26rpx; color: var(--color-text-secondary, #888); }
.row-value { font-size: 26rpx; font-weight: 600; color: var(--color-text-primary, #333); }

/* 检测明细 */
.detected-list { margin-top: 20rpx; }
.detected-title { font-size: 26rpx; font-weight: 600; color: var(--color-text-primary, #333); margin-bottom: 12rpx; }
.detected-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--color-border, #f5f5f5);
}
.item-type { font-size: 24rpx; font-weight: 600; color: var(--color-primary, #4e6ef2); min-width: 120rpx; }
.item-desc { font-size: 24rpx; color: var(--color-text-primary, #555); flex: 1; }
.item-conf { font-size: 22rpx; color: var(--color-text-secondary, #999); }

/* AI 报告 / 建议 */
.report-block { margin-top: 20rpx; }
.report-label { font-size: 26rpx; font-weight: 600; color: var(--color-text-primary, #333); display: block; margin-bottom: 8rpx; }
.report-text  { font-size: 26rpx; color: var(--color-text-secondary, #666); line-height: 1.7; display: block; }
