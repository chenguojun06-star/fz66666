page {
  background: #f5f5f7;
}

.container {
  padding: 16px 16px calc(16px + 40px + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 14px;
  padding: 16px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}

.title {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 12px;
  color: #1d1d1f;
}

.field {
  margin-bottom: 12px;
}

.label {
  font-size: 12px;
  color: #6e6e73;
  margin-bottom: 6px;
}

.input {
  border: 1px solid #e5e5ea;
  border-radius: 10px;
  padding: 10px 12px;
  background: #ffffff;
  font-size: 12px;
}

.row {
  display: flex;
  gap: 12px;
}

.col {
  flex: 1;
}

.btn {
  margin-top: 12px;
}

.btn-primary {
  background: #0a84ff;
  color: #ffffff;
  border: none;
  border-radius: 12px;
  padding: 12px;
  text-align: center;
  font-size: 12px;
}

.btn-disabled {
  opacity: 0.6;
}

.hint {
  margin-top: 10px;
  font-size: 12px;
  color: #8e8e93;
}

.result {
  margin-top: 12px;
  font-size: 12px;
  color: #3a3a3c;
  line-height: 1.7;
}

.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 12px;
  background: rgba(10, 132, 255, 0.12);
  color: #0a84ff;
}

.tag-ok {
  background: rgba(52, 199, 89, 0.12);
  color: #16a34a;
}

.tag-bad {
  background: rgba(255, 59, 48, 0.12);
  color: #dc2626;
}
