/**
 * 全局样式 - 服装供应链系统小程序
 * 对齐 WeUI 设计规范：纯色按钮、方圆角、极简阴影、高对比度文字
 * 全部使用 design-tokens 变量，禁止硬编码 px/rpx
 * @version 6.0
 * @date 2026-07-10
 */

@import './styles/design-tokens.wxss';
@import './styles/line-icons.wxss';

page {
  background: var(--color-bg-page);
  color: var(--color-text-primary);
  font-size: var(--font-size-md);
  line-height: var(--line-height-medium);
  font-family:
    -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
}

/* ========== 页面容器 ========== */
.container {
  padding: var(--spacing-md);
  padding-bottom: calc(var(--spacing-lg) + var(--nav-bar-height) + env(safe-area-inset-bottom));
}

.page-content {
  padding: 0 var(--page-padding-x);
}

/* ========== 卡片 ========== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.card-compact {
  padding: var(--spacing-md);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.card-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin: 0;
}

/* ========== 标题系统 ========== */
.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin: var(--spacing-lg) 0 var(--spacing-md);
}

.sub-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

/* ========== 表单 ========== */
.form-item {
  margin-bottom: var(--spacing-md);
}

.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
  display: block;
}

.form-input {
  height: var(--input-height);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  background: var(--color-bg-card);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  width: 100%;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--color-primary);
}

.form-input-sm {
  height: var(--input-height-sm);
  font-size: var(--font-size-sm);
  padding: 0 var(--spacing-sm);
}

.form-textarea {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  width: 100%;
  box-sizing: border-box;
  min-height: 80px;
}

/* ========== 按钮系统（统一高度/圆角/字号） ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  border: none;
  box-sizing: border-box;
  white-space: nowrap;
}

.btn-primary {
  height: var(--btn-height-md);
  background: var(--color-primary);
  color: var(--color-text-white);
  padding: 0 var(--spacing-lg);
  min-width: 88px;
}

.btn-primary-hover {
  opacity: 0.85;
}

.btn-primary:disabled {
  opacity: 0.5;
}

.btn-secondary {
  height: var(--btn-height-md);
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
  padding: 0 var(--spacing-lg);
  min-width: 88px;
  border: 1px solid var(--color-border);
}

.btn-secondary-hover {
  background: var(--color-bg-hover);
}

.btn-danger {
  height: var(--btn-height-md);
  background: var(--color-danger);
  color: var(--color-text-white);
  padding: 0 var(--spacing-lg);
  min-width: 88px;
}

.btn-danger-hover {
  opacity: 0.85;
}

.btn-ghost {
  height: var(--btn-height-md);
  background: transparent;
  color: var(--color-primary);
  padding: 0 var(--spacing-md);
}

.btn-sm {
  height: var(--btn-height-sm);
  font-size: var(--font-size-sm);
  padding: 0 var(--spacing-md);
}

.btn-xs {
  height: var(--btn-height-xs);
  font-size: var(--font-size-xs);
  padding: 0 var(--spacing-sm);
}

.btn-lg {
  height: var(--btn-height-lg);
  font-size: var(--font-size-lg);
}

.btn-block {
  width: 100%;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ========== 文字颜色 ========== */
.text-primary { color: var(--color-text-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary { color: var(--color-text-tertiary); }
.text-placeholder { color: var(--color-text-placeholder); }
.text-white { color: var(--color-text-white); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-info { color: var(--color-info); }
.text-primary-color { color: var(--color-primary); }

/* ========== 间距工具 ========== */
.mt-xs { margin-top: var(--spacing-xs); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mt-xl { margin-top: var(--spacing-xl); }

.mb-xs { margin-bottom: var(--spacing-xs); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }

.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }

/* ========== flex 布局工具 ========== */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-end { display: flex; align-items: center; justify-content: flex-end; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.gap-xs { gap: var(--spacing-xs); }
.gap-sm { gap: var(--spacing-sm); }
.gap-md { gap: var(--spacing-md); }
.gap-lg { gap: var(--spacing-lg); }
.flex-wrap { flex-wrap: wrap; }
.flex-shrink-0 { flex-shrink: 0; }

/* ========== 列表项 ========== */
.list-item {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: var(--spacing-lg);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  margin-bottom: var(--spacing-md);
}

.list-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border-light);
}

.list-cell:last-child {
  border-bottom: none;
}

/* ========== 进度条 ========== */
.progress-bar {
  flex: 1;
  height: 6px;
  background: rgba(var(--color-primary-rgb), 0.12);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.progress-completed .progress-fill {
  background: var(--color-text-tertiary);
}

/* ========== 空状态 ========== */
.empty-state-card {
  padding: var(--spacing-xxl) var(--spacing-lg);
  margin: 0 var(--page-padding-x);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border-light);
}
.empty-state-card .empty-icon {
  font-size: var(--font-size-6xl);
  color: var(--color-text-tertiary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64px 24px;
}

.empty-icon {
  font-size: var(--font-size-6xl);
  margin-bottom: var(--spacing-md);
  color: var(--color-text-tertiary);
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: var(--spacing-xs);
}

.empty-hint {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-align: center;
}

/* ========== 加载状态 ========== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* ========== 提示文字 ========== */
.hint {
  margin-top: var(--spacing-xs);
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.result-text {
  margin-top: var(--spacing-md);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

/* ========== 弹窗 ========== */
.modal-close {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xl);
  color: var(--color-text-tertiary);
}

.modal-close-hover {
  background: var(--color-bg-hover);
}

.modal-body {
  padding: 0 var(--spacing-lg) var(--spacing-md);
  max-height: 60vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

.modal-btn {
  flex: 1;
  height: var(--btn-height-md);
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  border: none;
  font-weight: var(--font-weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
  border: none;
}

.modal-btn-cancel-hover {
  background: var(--color-bg-hover);
}

.modal-btn.confirm {
  background: var(--color-primary);
  color: var(--color-text-white);
  border: none;
}

.modal-btn-confirm-hover {
  opacity: 0.85;
}

/* ========== 底部固定操作栏 ========== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--spacing-xs);
  padding: var(--spacing-xs) var(--spacing-md) calc(var(--spacing-xs) + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1px solid var(--color-border-light);
  z-index: var(--z-dropdown);
}

.footer-bar .btn-cancel,
.footer-bar .btn-secondary {
  flex: 1;
  height: var(--btn-height-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
  border: none;
}

.footer-bar .btn-submit {
  flex: 1;
  height: var(--btn-height-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  background: var(--color-primary);
  color: var(--color-text-white);
  border: none;
}

.footer-bar .btn-danger {
  flex: 1;
  height: var(--btn-height-md);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  background: var(--color-danger);
  color: var(--color-text-white);
  border: none;
}

.footer-bar .btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.footer-bar-hover {
  opacity: 0.85;
}

/* ========== 分割线 ========== */
.divider {
  height: 1px;
  background: var(--color-border-light);
  margin: var(--spacing-md) 0;
}

.divider-thick {
  height: 8px;
  background: var(--color-bg-page);
  margin: var(--spacing-md) calc(-1 * var(--spacing-lg));
}

/* ========== 省略号 ========== */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ========== 搜索框 ========== */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  height: var(--input-height);
  border: 1px solid var(--color-border-light);
}

.search-bar input {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.search-icon {
  color: var(--color-text-tertiary);
  margin-right: var(--spacing-xs);
  font-size: var(--font-size-md);
}
