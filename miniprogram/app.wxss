page {
  background: #f7f8fa;
  color: #1f2937;
  font-size: 12px;
  line-height: 1.4;
  font-family:
    -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
    "Hiragino Sans GB", "Microsoft YaHei", Arial, sans-serif;
}

.container {
  padding: 12px 12px calc(12px + 40px + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border-radius: 18px;
  padding: 12px;
  border: 1px solid #e5e7eb;
  box-shadow: none;
}

.title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 10px;
  color: #111827;
}

.section-title {
  margin-top: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}

.field {
  margin-bottom: 10px;
}

.label {
  font-size: 12px;
  color: #6b7280;
  margin-bottom: 6px;
}

.input {
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 8px 12px;
  background: #ffffff;
  font-size: 12px;
}

.row {
  display: flex;
  gap: 10px;
}

.col {
  flex: 1;
}

.btn {
  margin-top: 10px;
}

.btn-primary {
  background: #0a84ff;
  color: #ffffff;
  border: none;
  border-radius: 999px;
  padding: 10px 14px;
  text-align: center;
  font-size: 12px;
}

.btn-secondary {
  background: #eef2ff;
  color: #374151;
  border-radius: 999px;
  padding: 8px 12px;
  text-align: center;
  font-size: 12px;
}

.btn-disabled {
  opacity: 0.6;
}

.hint {
  margin-top: 8px;
  font-size: 11px;
  color: #8b8b94;
}

.result {
  margin-top: 10px;
  font-size: 12px;
  color: #374151;
  line-height: 1.6;
}

.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 11px;
  background: rgba(10, 132, 255, 0.12);
  color: #0a84ff;
}

.tag-ok {
  background: rgba(52, 199, 89, 0.12);
  color: #16a34a;
}

.tag-bad {
  background: rgba(255, 59, 48, 0.12);
  color: #dc2626;
}
