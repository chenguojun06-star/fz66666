/**
 * 全局样式 - 服装供应链系统小程序
 * 对齐 WeUI 设计规范：纯色按钮、方圆角、极简阴影、高对比度文字
 * @version 5.0
 * @date 2026-04-14
 */

@import './styles/design-tokens.wxss';
@import './styles/line-icons.wxss';
@import './styles/xiaoyun-tokens.wxss';

page {
  background: var(--color-bg-page);
  color: var(--color-text-primary);
  font-size: var(--font-size-base);
  line-height: var(--line-height-medium);
  font-family:
    -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
}

.container {
  padding: 16px 16px calc(16px + 44px + env(safe-area-inset-bottom));
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 16px;
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.title {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-semibold);
  margin-bottom: 12px;
  color: var(--color-text-primary);
}

.section-title {
  margin-top: 16px;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.field {
  margin-bottom: 16px;
}

.label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 8px;
}

.input {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 10px 12px;
  background: var(--color-bg-card);
  font-size: var(--font-size-base);
}

.btn {
  margin-top: 12px;
}

.btn-primary {
  background: var(--color-primary);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-md);
  padding: 0 16px;
  text-align: center;
  font-size: var(--font-size-lg);
  height: 44px;
  min-width: 88px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: var(--font-weight-medium);
}

.btn-primary-hover {
  opacity: 0.8;
}

.btn-secondary {
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 16px;
  text-align: center;
  font-size: var(--font-size-lg);
  height: 44px;
  min-width: 88px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: var(--font-weight-medium);
}

.btn-secondary-hover {
  background: var(--color-bg-hover);
}

.btn-disabled {
  opacity: 0.5;
}

.hint {
  margin-top: 8px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.result {
  margin-top: 12px;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  background: var(--color-success-bg);
  color: var(--color-success);
}

.list-item {
  display: block;
  width: 100%;
  box-sizing: border-box;
  padding: 16px;
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-lg);
  background: var(--color-bg-card);
  margin-top: 12px;
}

.progress-bar {
  flex: 1;
  height: 6px;
  background: rgba(var(--color-primary-rgb), 0.12);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.progress-completed .progress-fill {
  background: var(--color-text-tertiary);
}

.result-item {
  padding: 12px 16px;
  border-bottom: 1px solid var(--color-border-light);
}

/* ============ 空状态 ============ */
.empty-state-card {
  padding: 48px 24px;
  margin: 0 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-border-light);
}
.empty-state-card .empty-icon {
  font-size: var(--font-size-6xl);
  color: var(--color-text-tertiary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64px 24px;
}

.empty-icon {
  font-size: var(--font-size-6xl);
  margin-bottom: 16px;
  color: var(--color-text-tertiary);
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-align: center;
}

/* ============ 加载状态 ============ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px 24px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 12px;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

/* ============ 弹窗保留项（关闭按钮 + 内容区 + 操作按钮） ============ */

.modal-close {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  font-size: var(--font-size-xl);
  color: var(--color-text-tertiary);
}

.modal-close-hover {
  background: var(--color-bg-hover);
}

.modal-body {
  padding: 0 24px 20px;
  max-height: 60vh;
  overflow-y: auto;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
}

.modal-btn {
  flex: 1;
  height: 44px;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  border: none;
  font-weight: var(--font-weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-btn.cancel {
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
  border: none;
}

.modal-btn-cancel-hover {
  background: var(--color-bg-hover);
}

.modal-btn.confirm {
  background: var(--color-primary);
  color: var(--color-text-white);
  border: none;
}

.modal-btn-confirm-hover {
  opacity: 0.8;
}

/* ============ 底部固定操作栏（对齐 WeUI） ============ */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 12px;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1px solid var(--color-border-light);
  z-index: var(--z-dropdown);
}

.footer-bar .btn-cancel,
.footer-bar .btn-secondary {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
  border: none;
}

.footer-bar .btn-submit {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  background: var(--color-primary);
  color: var(--color-text-white);
  border: none;
}

.footer-bar .btn-danger {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  background: var(--color-error);
  color: var(--color-text-white);
  border: none;
}

.footer-bar .btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.footer-bar-hover {
  opacity: 0.8;
}
