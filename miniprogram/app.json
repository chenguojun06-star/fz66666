  "preloadRule": {
    "pages/home/index":  { "network": "wifi", "packages": ["pkg-warehouse", "pkg-register", "pkg-bundle-split", "pkg-dashboard", "pkg-smart-ops"] },
    "pages/defect/index":  { "network": "wifi", "packages": ["pkg-work-inbox", "pkg-work-ai", "pkg-bundle-split", "pkg-cutting", "pkg-procurement"] },
    "pages/scan/index":  { "network": "wifi", "packages": ["pkg-scan-history", "pkg-scan-pattern", "pkg-scan-rescan", "pkg-scan-result", "pkg-scan-confirm", "pkg-scan-quality"] },
    "pages/admin/index": { "network": "wifi", "packages": ["pkg-admin-approval", "pkg-payroll", "pkg-privacy", "pkg-admin-misc"] }
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#3b82f6",
