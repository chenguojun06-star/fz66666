{
  "pages": [
    "pages/login/index",
    "pages/home/index",
    "pages/work/index",
    "pages/scan/index",
    "pages/admin/index"
  ],
  "subpackages": [
    {
      "root": "pages/register",
      "name": "pkg-register",
      "pages": ["index"]
    },
    {
      "root": "pages/work/inbox",
      "name": "pkg-work-inbox",
      "pages": ["index"]
    },
    {
      "root": "pages/work/ai-assistant",
      "name": "pkg-work-ai",
      "pages": ["index"]
    },
    {
      "root": "pages/scan/history",
      "name": "pkg-scan-history",
      "pages": ["index"]
    },
    {
      "root": "pages/payroll",
      "name": "pkg-payroll",
      "pages": ["payroll"]
    },
    {
      "root": "pages/admin/user-approval",
      "name": "pkg-admin-approval",
      "pages": ["index"]
    },
    {
      "root": "pages/warehouse",
      "name": "pkg-warehouse",
      "pages": [
        "material/scan/index",
        "sample/scan-action/index"
      ]
    },
    {
      "root": "pages/privacy",
      "name": "pkg-privacy",
      "pages": ["index"]
    },
    {
      "root": "pages/admin/change-password",
      "name": "pkg-admin-changepwd",
      "pages": ["index"]
    },
    {
      "root": "pages/admin/feedback",
      "name": "pkg-admin-feedback",
      "pages": ["index"]
    },
    {
      "root": "pages/admin/invite",
      "name": "pkg-admin-invite",
      "pages": ["index"]
    },
    {
      "root": "pages/work/bundle-split",
      "name": "pkg-bundle-split",
      "pages": ["index"]
    },
    {
      "root": "pages/cutting",
      "name": "pkg-cutting",
      "pages": ["task-list/index", "task-detail/index"]
    },
    {
      "root": "pages/procurement",
      "name": "pkg-procurement",
      "pages": ["task-detail/index"]
    },
    {
      "root": "pages/scan/pattern",
      "name": "pkg-scan-pattern",
      "pages": ["index"]
    },
    {
      "root": "pages/scan/rescan",
      "name": "pkg-scan-rescan",
      "pages": ["index"]
    },
    {
      "root": "pages/scan/scan-result",
      "name": "pkg-scan-result",
      "pages": ["index"]
    },
    {
      "root": "pages/scan/confirm",
      "name": "pkg-scan-confirm",
      "pages": ["index"]
    },
    {
      "root": "pages/scan/quality",
      "name": "pkg-scan-quality",
      "pages": ["index"]
    },
    {
      "root": "pages/work/ai-photo",
      "name": "pkg-work-ai-photo",
      "pages": ["index"]
    },
    {
      "root": "pages/dashboard",
      "name": "pkg-dashboard",
      "pages": ["index"]
    }
  ],
  "preloadRule": {
    "pages/home/index":  { "network": "all", "packages": ["pkg-warehouse", "pkg-register", "pkg-bundle-split", "pkg-dashboard"] },
    "pages/work/index":  { "network": "all", "packages": ["pkg-work-inbox", "pkg-bundle-split", "pkg-cutting", "pkg-procurement", "pkg-work-ai-photo"] },
    "pages/scan/index":  { "network": "all", "packages": ["pkg-scan-history", "pkg-scan-pattern", "pkg-scan-rescan", "pkg-scan-result", "pkg-scan-confirm", "pkg-scan-quality"] },
    "pages/admin/index": { "network": "all", "packages": ["pkg-admin-approval", "pkg-payroll", "pkg-privacy", "pkg-admin-changepwd", "pkg-admin-feedback", "pkg-admin-invite"] }
  },
  "tabBar": {
    "custom": true,
    "color": "#999999",
    "selectedColor": "#3b82f6",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页",
        "iconPath": "/assets/tabbar/home.png",
        "selectedIconPath": "/assets/tabbar/home-active.png"
      },
      {
        "pagePath": "pages/work/index",
        "text": "生产",
        "iconPath": "/assets/tabbar/work.png",
        "selectedIconPath": "/assets/tabbar/work-active.png"
      },
      {
        "pagePath": "pages/scan/index",
        "text": "扫码",
        "iconPath": "/assets/tabbar/scan.png",
        "selectedIconPath": "/assets/tabbar/scan-active.png"
      },
      {
        "pagePath": "pages/admin/index",
        "text": "我的",
        "iconPath": "/assets/tabbar/admin.png",
        "selectedIconPath": "/assets/tabbar/admin-active.png"
      }
    ]
  },
  "window": {
    "navigationBarTitleText": "生产管理",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTextStyle": "black",
    "backgroundTextStyle": "light"
  },
  "lazyCodeLoading": "requiredComponents",
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "__usePrivacyCheck__": true,
  "requiredBackgroundModes": []
}
