{
  "pages": [
    "pages/login/index",
    "pages/home/index",
    "pages/work/index",
    "pages/scan/index",
    "pages/admin/index"
  ],
  "subpackages": [
    {
      "root": "pages/register",
      "name": "pkg-register",
      "pages": ["index"]
    },
    {
      "root": "pages/work/inbox",
      "name": "pkg-work-inbox",
      "pages": ["index"]
    },
    {
      "root": "pages/work/ai-assistant",
      "name": "pkg-work-ai",
      "pages": ["index"]
    },
    {
      "root": "pages/scan/history",
      "name": "pkg-scan-history",
      "pages": ["index"]
    },
    {
      "root": "pages/scan/monthly",
      "name": "pkg-scan-monthly",
      "pages": ["index"]
    },
    {
      "root": "pages/payroll",
      "name": "pkg-payroll",
      "pages": ["payroll"]
    },
    {
      "root": "pages/admin/notification",
      "name": "pkg-admin-notification",
      "pages": ["index"]
    },
    {
      "root": "pages/admin/production-detail",
      "name": "pkg-admin-detail",
      "pages": ["index"]
    },
    {
      "root": "pages/admin/user-approval",
      "name": "pkg-admin-approval",
      "pages": ["index"]
    },
    {
      "root": "pages/warehouse",
      "name": "pkg-warehouse",
      "pages": [
        "sample/list/index",
        "finished/list/index",
        "material/alerts/index",
        "material/detail-page/index",
        "material/scan/index"
      ]
    },
    {
      "root": "pages/order",
      "name": "pkg-order",
      "pages": ["index"]
    },
    {
      "root": "pages/privacy",
      "name": "pkg-privacy",
      "pages": ["index"]
    }
  ],
  "preloadRule": {
    "pages/home/index":  { "network": "all", "packages": ["pkg-warehouse", "pkg-order", "pkg-register"] },
    "pages/work/index":  { "network": "all", "packages": ["pkg-work-inbox", "pkg-work-ai"] },
    "pages/scan/index":  { "network": "all", "packages": ["pkg-scan-history", "pkg-scan-monthly"] },
    "pages/admin/index": { "network": "all", "packages": ["pkg-admin-notification", "pkg-admin-detail", "pkg-admin-approval", "pkg-payroll", "pkg-privacy"] }
  },
  "usingComponents": {},
  "tabBar": {
    "custom": false,
    "color": "#999999",
    "selectedColor": "#3b82f6",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/home/index",
        "text": "首页",
        "iconPath": "/assets/tabbar/home.png",
        "selectedIconPath": "/assets/tabbar/home-active.png"
      },
      {
        "pagePath": "pages/work/index",
        "text": "生产",
        "iconPath": "/assets/tabbar/work.png",
        "selectedIconPath": "/assets/tabbar/work-active.png"
      },
      {
        "pagePath": "pages/scan/index",
        "text": "扫码",
        "iconPath": "/assets/tabbar/scan.png",
        "selectedIconPath": "/assets/tabbar/scan-active.png"
      },
      {
        "pagePath": "pages/admin/index",
        "text": "我的",
        "iconPath": "/assets/tabbar/admin.png",
        "selectedIconPath": "/assets/tabbar/admin-active.png"
      }
    ]
  },
  "window": {
    "navigationBarTitleText": "生产管理",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTextStyle": "black",
    "backgroundTextStyle": "light"
  },
  "lazyCodeLoading": "requiredComponents",
  "style": "v2",
  "sitemapLocation": "sitemap.json",
  "__usePrivacyCheck__": true
}
