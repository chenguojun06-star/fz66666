.container {
  height: 100vh;
  background-color: #f5f6f8;
  display: flex;
  flex-direction: column;
}

.search-bar {
  padding: 20rpx;
  background-color: var(--color-bg-card);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--color-bg-gray);
  border-radius: 36rpx;
  padding: 10rpx 20rpx;
}

.search-input {
  flex: 1;
  margin-left: 10rpx;
  font-size: 28rpx;
}

.list-container {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.list-item {
  background-color: var(--color-bg-card);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-content {
  flex: 1;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background-color: #e0f2fe;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.item-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.item-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.ml-20 {
  margin-left: 40rpx;
}

.item-action {
  margin-left: 16rpx;
}

.action-btn {
  background-color: var(--color-primary);
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  color: var(--color-text-disabled);
  font-size: 28rpx;
}

.empty-img {
  width: 200rpx;
  margin-bottom: 16rpx;
}

.loading-more, .no-more {
  text-align: center;
  padding: 20rpx;
  color: var(--color-text-disabled);
  font-size: 24rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.modal-box {
  width: 640rpx;
  background-color: var(--color-bg-card);
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-head {
  padding: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-body {
  padding: 20rpx;
}

.modal-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
}

.modal-row .label {
  color: var(--color-text-secondary);
}

.modal-row .value {
  color: var(--color-text-primary);
  font-weight: 600;
}

.modal-input {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
}

.modal-textarea {
  flex: 1;
  min-height: 100rpx;
  font-size: 24rpx;
  text-align: right;
}

.modal-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
}

.btn.cancel {
  color: var(--color-text-secondary);
}

.btn.ok {
  color: var(--color-primary);
  font-weight: 600;
}

.btn.disabled {
  color: var(--color-text-disabled);
}
