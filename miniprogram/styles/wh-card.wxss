/* ============================================================
   wh-card.wxss — 仓库页面通用卡片样式（样衣 / 成品 / 通用）
   用法：@import '/styles/wh-card.wxss';
   前缀：wc- (warehouse-card)
   ============================================================ */

/* ---- 卡片容器 ---- */
.wc-card {
  background: var(--color-bg-card);
  border-radius: 6px;
  padding: 10px;
  margin-bottom: 10px;
  display: flex;
  align-items: flex-start;
}

/* ---- 封面图 ---- */
.wc-img {
  width: 70px;
  height: 70px;
  border-radius: 4px;
  margin-right: 10px;
  flex-shrink: 0;
}

.wc-img-placeholder {
  width: 70px;
  height: 70px;
  border-radius: 4px;
  margin-right: 10px;
  flex-shrink: 0;
  background: var(--color-bg-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: var(--color-bg-gray);
  text-align: center;
  line-height: 1.4;
}

/* ---- 内容区 ---- */
.wc-content {
  flex: 1;
  min-width: 0;
}

/* ---- 首行：标题 + 右侧徽标/按钮 同行对齐 ---- */
.wc-head {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-bottom: 2px;
}

/* ---- 操作按钮行（在 wc-head 内则自动 flex-shrink:0）---- */
.wc-op-row {
  display: flex;
  gap: 4px;
  flex-shrink: 0;
}

.wc-op-btn {
  font-size: 11px;
  padding: 3px 9px;
  border-radius: 10px;
  border: 1px solid var(--color-bg-gray);
  color: var(--color-text-secondary);
  background: var(--color-bg-light);
  white-space: nowrap;
  flex-shrink: 0;
}

.wc-op-btn-primary {
  background: var(--color-primary, var(--color-primary));
  color: var(--color-text-white);
  border-color: var(--color-primary, var(--color-primary));
}

/* ---- 款号（单独使用时 display:block；在 wc-head 内自动 flex:1）---- */
.wc-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--color-text-primary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

/* ---- 款式名称 ---- */
.wc-subtitle {
  font-size: 12px;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---- 标签行（颜色 / 尺码 / 类型）---- */
.wc-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 3px;
}

.wc-tag {
  font-size: 10px;
  padding: 2px 7px;
  border-radius: 10px;
  white-space: nowrap;
}

/* 颜色标签 — 玫红 */
.wc-tag-color {
  background: var(--color-error-bg);
  color: var(--color-danger);
}

/* 尺码标签 — 蓝 */
.wc-tag-size {
  background: var(--color-info-bg);
  color: var(--color-primary);
}

/* 类型标签 — 绿 */
.wc-tag-type {
  background: var(--color-success-bg);
  color: var(--color-success);
}

/* ---- 库存数据行 ---- */
.wc-stock {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 5px;
  padding-top: 5px;
  border-top: 1px solid var(--color-bg-light);
}

.wc-stock-item {
  display: flex;
  align-items: baseline;
  gap: 2px;
}

.wc-stock-label {
  font-size: 11px;
  color: var(--color-text-disabled);
}

.wc-stock-val {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-text-primary);
}

.wc-stock-val.green  { color: var(--color-success); }
.wc-stock-val.orange { color: var(--color-warning); }
.wc-stock-val.red    { color: var(--color-danger); }

.wc-stock-unit {
  font-size: 10px;
  color: var(--color-text-disabled);
}

/* ---- 底部操作链接（如「借调记录」）---- */
.wc-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 5px;
}

.wc-action-link {
  font-size: 11px;
  color: var(--color-primary, var(--color-primary));
  padding: 2px 7px;
  border: 1px solid var(--color-info-bg);
  border-radius: 10px;
  background: var(--color-bg-light);
}
