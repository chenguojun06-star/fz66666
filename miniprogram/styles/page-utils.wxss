/* =====================================================
 * page-utils.wxss — 页面通用样式工具集
 * 翻页加载
 *
 * 使用方式：
 *   @import '/styles/page-utils.wxss';
 *
 * 注意：
 *   - 标签 tag 样式已在 design-tokens.wxss 全局定义
 *   - 按钮样式已在 app.wxss 全局定义（含 btn-submit/btn-cancel 等别名）
 *   - 此文件不再重复定义，避免冲突
 * ===================================================== */

/* =====================================================
 * 一、空状态 Empty State → 已移至 app.wxss（全局加载，无需再 @import）
 * .empty-state / .empty-icon / .empty-img / .empty-text / .empty-hint
 * 均在 app.wxss "空状态"区块定义。
 * ===================================================== */



/* =====================================================
 * 二、翻页 / 加载态 Pagination & Load-more
 * ===================================================== */

/* 可点击的"加载更多"行 */
.load-more {
  text-align: center;
  padding: 12px 10px;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

/* 禁用态："没有更多了" */
.load-more.disabled {
  color: var(--color-text-disabled);
  pointer-events: none;
}

/* 点击反馈（hover-class="load-more-hover"） */
.load-more-hover {
  opacity: 0.7;
}

/* 已全部加载 */
.no-more {
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}

/* 加载中动画行 */
.loading-more {
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}
