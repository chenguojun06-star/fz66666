/* =====================================================
 * page-utils.wxss — 页面通用样式工具集
 * 📦 空状态 / 翻页加载 / 标签 chip
 *
 * 使用方式：
 *   @import '/styles/page-utils.wxss';
 *
 * 类名前缀约定：无前缀（语义即名称）
 * ===================================================== */

/* =====================================================
 * 一、空状态 Empty State → 已移至 app.wxss（全局加载，无需再 @import）
 * .empty-state / .empty-icon / .empty-img / .empty-text / .empty-hint
 * 均在 app.wxss “空状态”区块定义。
 * ===================================================== */



/* =====================================================
 * 二、翻页 / 加载态 Pagination & Load-more
 * ===================================================== */

/* 可点击的"加载更多"行 */
.load-more {
  text-align: center;
  padding: 12px 10px;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

/* 禁用态："没有更多了" */
.load-more.disabled {
  color: var(--color-text-disabled);
  pointer-events: none;
}

/* 点击反馈（hover-class="load-more-hover"） */
.load-more-hover {
  opacity: 0.7;
}

/* 已全部加载 */
.no-more {
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}

/* 加载中动画行 */
.loading-more {
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}


/* =====================================================
 * 三、标签 Chip / Tag
 * 注意：所有 .tag-* 类（基础样式 + 颜色）已在 design-tokens.wxss 统一。
 *       本文件只保留 .tag-color / .tag-size 的更紧凑覆盖（字号 10px）。
 * ===================================================== */

/* 颜色标签：更小更紧凑 */
.tag-color { font-size: 10px; padding: 1px 5px; }
/* 尺码标签：更小更紧凑 */
.tag-size  { font-size: 10px; padding: 1px 5px; }
