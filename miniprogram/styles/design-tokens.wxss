/**
 * 服装供应链系统 - 统一设计 Token v10.0
 *
 * Apple Design Library 风格
 * 主色 #007aff (Apple System Blue)
 * 背景 #f2f2f7 (Apple System Gray 6)
 * 文字 #1d1d1f (Apple Label)
 *
 * @version 10.0
 * @date 2026-07-12
 */

page {
  /* ========== 品牌色（Apple System Blue） ========== */
  --color-primary: #007aff;
  --color-primary-light: #2e8dff;
  --color-primary-dark: #0064d6;
  --color-primary-rgb: 0, 122, 255;
  --color-primary-bg: #e8f2ff;
  --color-primary-bg-dark: #cfe5ff;
  --color-primary-border: rgba(0, 122, 255, 0.2);

  --gradient-progress: linear-gradient(90deg, #34c759 0%, #007aff 100%);

  /* ========== 语义色（Apple System Colors） ========== */
  --color-success: #34c759;
  --color-success-bg: #e9f9ee;
  --color-success-border: rgba(52, 199, 89, 0.2);

  --color-warning: #ff9500;
  --color-warning-bg: #fff5e6;
  --color-warning-border: rgba(255, 149, 0, 0.2);

  --color-danger: #ff3b30;
  --color-danger-bg: #ffecea;
  --color-danger-border: rgba(255, 59, 48, 0.2);

  --color-info: #5ac8fa;
  --color-info-bg: rgba(90, 200, 250, 0.08);
  --color-info-border: rgba(90, 200, 250, 0.2);
  --color-info-50: rgba(90, 200, 250, 0.06);
  --color-info-100: rgba(90, 200, 250, 0.15);
  --color-info-700: #0a6ca8;

  --color-purple: #5856d6;
  --color-purple-light: #7a78f0;
  --color-purple-bg: #f0effe;
  --color-purple-bg-light: rgba(88, 86, 214, 0.1);
  --color-purple-border: rgba(88, 86, 214, 0.2);

  --color-violet: #af52de;
  --color-violet-bg: #f8f0fd;
  --color-violet-bg-light: rgba(175, 82, 222, 0.1);
  --color-violet-border: rgba(175, 82, 222, 0.2);

  --color-magenta: #ff2d55;
  --color-magenta-bg: rgba(255, 45, 85, 0.1);

  --color-link: #007aff;

  /* ========== 背景色（Apple System Gray） ========== */
  --color-bg-page: #f2f2f7;
  --color-bg-card: #ffffff;
  --color-bg-hover: rgba(0, 0, 0, 0.03);
  --color-bg-active: rgba(0, 0, 0, 0.06);
  --color-bg-subtle: #f5f5f5;
  --color-bg-muted: #f7f7fa;
  --color-bg-info: #e8f2ff;

  /* ========== 文字色（Apple Label Colors） ========== */
  --color-text-primary: #1d1d1f;
  --color-text-secondary: #6e6e73;
  --color-text-tertiary: #8e8e93;
  --color-text-quaternary: #c7c7cc;
  --color-text-placeholder: #8e8e93;
  --color-text-disabled: #c7c7cc;
  --color-text-white: #ffffff;

  /* ========== 边框色（与设计稿对齐：实色） ========== */
  --color-border: #e5e5ea;
  --color-border-light: #f2f2f7;
  --color-border-lighter: #f5f5f7;
  --color-border-blue: rgba(0, 122, 255, 0.18);

  /* ========== 遮罩 ========== */
  --color-overlay: rgba(0, 0, 0, 0.4);

  /* ========== 圆角系统（与设计稿 Tailwind 对齐） ========== */
  --radius-xs: 4px;
  --radius-sm: 8px;
  --radius-md: 10px;
  --radius-lg: 10px;
  --radius-xl: 12px;
  --radius-2xl: 19px;
  --radius-full: 999px;

  /* 语义化圆角别名 */
  --radius-card: var(--radius-2xl);
  --radius-button: var(--radius-full);
  --radius-tag: var(--radius-full);
  --radius-input: var(--radius-sm);
  --radius-modal: var(--radius-xl);

  /* ========== 间距系统 ========== */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 20px;
  --spacing-2xl: 24px;
  --spacing-3xl: 32px;

  /* 语义化间距别名 */
  --card-padding: 12px;
  --card-gap: 12px;
  --page-padding-x: 16px;
  --page-padding-y: 12px;

  /* ========== 阴影系统（Apple 风格：柔和多层） ========== */
  --shadow-2xs: 0 1px 2px -1px rgba(0, 0, 0, 0.04);
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.04), 0 1px 3px -1px rgba(0, 0, 0, 0.05);
  --shadow-md: 0 4px 8px -2px rgba(0, 0, 0, 0.06), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 8px 24px -8px rgba(0, 0, 0, 0.08), 0 4px 8px -4px rgba(0, 0, 0, 0.05);
  --shadow-xl: 0 16px 40px -10px rgba(0, 0, 0, 0.10), 0 8px 16px -8px rgba(0, 0, 0, 0.06);
  --shadow-modal: 0 24px 64px -12px rgba(0, 0, 0, 0.12);
  --shadow-card: 0 1px 2px 0 rgba(0, 0, 0, 0.04), 0 1px 3px -1px rgba(0, 0, 0, 0.05);
  --shadow-card-hover: 0 4px 8px -2px rgba(0, 0, 0, 0.06), 0 2px 4px -2px rgba(0, 0, 0, 0.05);

  /* ========== 字体系统（Apple HIG） ========== */
  --font-size-xxs: 10px;
  --font-size-2xs: 11px;
  --font-size-xs: 12px;
  --font-size-sm: 13px;
  --font-size-md: 14px;
  --font-size-md-lg: 15px;
  --font-size-base: 15px;
  --font-size-lg: 16px;
  --font-size-lg-xl: 17px;
  --font-size-xl: 18px;
  --font-size-2xl: 20px;
  --font-size-3xl: 22px;
  --font-size-4xl: 24px;
  --font-size-5xl: 30px;
  --font-size-6xl: 34px;

  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  --line-height-tight: 1.2;
  --line-height-normal: 1.35;
  --line-height-medium: 1.5;
  --line-height-relaxed: 1.6;

  /* ========== 输入框系统 ========== */
  --input-height: 40px;
  --input-height-sm: 32px;
  --input-height-xs: 28px;
  --input-bg: #f2f2f7;
  --input-border: transparent;
  --input-focus-border: #007aff;
  --input-placeholder: #8e8e93;
  --input-radius: var(--radius-md);

  /* ========== 按钮系统（Apple 风格：填充式） ========== */
  --btn-height-lg: 50px;
  --btn-height-md: 44px;
  --btn-height-sm: 36px;
  --btn-height-xs: 28px;
  --btn-font-size: 14px;
  --btn-radius: var(--radius-xl);

  /* ========== 层级系统 ========== */
  --z-base: 1;
  --z-dropdown: 100;
  --z-sticky: 200;
  --z-overlay: 500;
  --z-modal: 600;
  --z-popover: 700;
  --z-tooltip: 800;
  --z-notification: 900;
  --z-float-trigger: 900;

  /* ========== 页面布局 ========== */
  --page-padding-x: 16px;
  --page-padding-y: 12px;
  --card-gap: 12px;
  --nav-bar-height: 44px;

  /* ========== 菜单图标渐变系统（Apple 风格：柔和渐变） ========== */
  /* Apple 风格：纯色淡背景，不用渐变 */
  --icon-bg-purple: #ecebfe;
  --icon-bg-blue: #dbeafe;
  --icon-bg-teal: #d1f4f0;
  --icon-bg-amber: #fef3c7;
  --icon-bg-green: #d1fae5;
  --icon-bg-orange: #ffe4d6;
  --icon-bg-rose: #ffe4e8;
  --icon-bg-indigo: #e0e7ff;
  --icon-bg-cyan: #cffafe;
  --icon-bg-red: #ffe4e0;
  --icon-bg-gray: #e5e5ea;

  /* Apple 风格图标颜色（深色，在淡背景上清晰可见） */
  --icon-color-purple: #5856d6;
  --icon-color-blue: #007aff;
  --icon-color-teal: #0d9488;
  --icon-color-amber: #d97706;
  --icon-color-green: #34c759;
  --icon-color-orange: #f97316;
  --icon-color-rose: #f43f5e;
  --icon-color-indigo: #4f46e5;
  --icon-color-cyan: #06b6d4;
  --icon-color-red: #ff3b30;
  --icon-color-gray: #6b7280;
}

/* ========== 统一状态标签颜色（Apple 风格） ========== */
.status-tag,
.tag {
  font-size: var(--font-size-xs);
  padding: 2px 10px;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1.4;
  text-align: center;
  vertical-align: middle;
}
.tag-default    { background: var(--color-bg-page); color: var(--color-text-secondary); }
.tag-success    { background: var(--color-success-bg); color: var(--color-success); }
.tag-warning    { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-error      { background: var(--color-danger-bg); color: var(--color-danger); }
.tag-info       { background: var(--color-bg-info); color: var(--color-info-700); }
.tag-processing { background: var(--color-primary-bg); color: var(--color-primary); }

/* 兼容旧 class 名称 */
.tag-orange  { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-blue    { background: var(--color-primary-bg); color: var(--color-primary); }
.tag-green   { background: var(--color-success-bg); color: var(--color-success); }
.tag-gray    { background: var(--color-bg-page); color: var(--color-text-secondary); }
.tag-red     { background: var(--color-danger-bg); color: var(--color-danger); }

/* 业务别名 */
.tag-color   { background: var(--color-primary-bg); color: var(--color-primary); }
.tag-size    { background: var(--color-bg-page); color: var(--color-text-secondary); }
.tag-warn    { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-danger  { background: var(--color-danger-bg); color: var(--color-danger); }
