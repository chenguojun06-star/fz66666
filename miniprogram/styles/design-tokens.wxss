/**
 * 服装供应链系统 - 设计 Token  v4.0
 *
 * 统一配色：中性灰底 + 白卡片 + 品牌蓝点缀（行业标准B端风格）
 *
 * @version 4.0
 * @date 2026-04-08
 */

/* 页面级 CSS 变量定义（组件通过 styleIsolation: apply-shared 继承）*/
page {
  /* ========== 颜色系统 ========== */

  /* 主色调 */
  --color-primary: #2563eb;
  --color-primary-light: #3b82f6;
  --color-primary-dark: #1d4ed8;
  --color-primary-rgb: 37, 99, 235;

  /* 浅色渐变 —— 用于卡片背景、tag填充 */
  --gradient-primary: linear-gradient(135deg, #eff4ff 0%, #eef0ff 100%);
  --gradient-primary-solid: linear-gradient(135deg, #eff4ff 0%, #eef0ff 100%);
  --gradient-primary-alpha: linear-gradient(
    135deg,
    rgba(239, 244, 255, 0.92) 0%,
    rgba(238, 240, 255, 0.75) 100%
  );
  --gradient-card: linear-gradient(135deg, #eff4ff 0%, #eef0ff 100%);

  /* 实色蓝渐变 —— 专用于主 CTA 按钮（白字）*/
  --gradient-action: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);

  /* 进度条渐变 */
  --gradient-progress: linear-gradient(90deg, #10b981 0%, #2563eb 100%);

  /* 辅助色 - 蓝色系 */
  --color-blue: #2563eb;
  --color-blue-light: rgba(37, 99, 235, 0.08);
  --color-blue-lighter: rgba(37, 99, 235, 0.04);

  /* 功能色 */
  --color-success: #059669;
  --color-warning: #d97706;
  --color-error: #dc2626;
  --color-danger: #ef4444;
  --color-info: #2563eb;
  --color-purple: #7c3aed;

  /* 状态浅底色 */
  --color-warning-bg: #fffbeb;
  --color-error-bg: #fef2f2;
  --color-success-bg: #f0fdf4;
  --color-info-bg: #eff6ff;

  /* 状态边框色 */
  --color-warning-border: #fde68a;
  --color-error-border: #fca5a5;
  --color-success-border: #a7f3d0;
  --color-info-border: #93c5fd;

  /* 中性色 —— 纯灰底，无蓝调 */
  --color-bg-page: #f5f7fa;
  --color-bg-card: #ffffff;
  --color-bg-gray: #f0f2f5;
  --color-bg-light: #fafbfc;
  --color-bg-hover: #f5f5f5;
  --color-bg-active: #ebebeb;

  /* 边框 —— 中性灰边框 */
  --color-border: #e5e7eb;
  --color-border-light: #f0f0f0;
  --color-border-blue: rgba(37, 99, 235, 0.2);

  /* 分割线 */
  --color-divider: #f0f0f0;

  /* 文字色 */
  --color-text-primary: #1e293b;
  --color-text-secondary: #64748b;
  --color-text-tertiary: #94a3b8;
  --color-text-placeholder: #c0c4cc;
  --color-text-disabled: #94a3b8;
  --color-text-white: #ffffff;

  /* ========== 圆角系统 ========== */
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 18px;
  --radius-full: 999px;

  /* ========== 间距系统 ========== */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 20px;
  --spacing-xxl: 24px;

  /* ========== 阴影系统 —— 中性灰阴影，干净不花哨 ========== */
  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 4px 16px rgba(0, 0, 0, 0.08);
  --shadow-xl: 0 8px 24px rgba(0, 0, 0, 0.10);
  --shadow-modal: 0 16px 48px rgba(0, 0, 0, 0.12);

  /* ========== 字体系统 ========== */
  --font-size-xs: 12px;    /* 3级：辅助信息、标签 */
  --font-size-sm: 13px;    /* 2级：次要文字、说明 */
  --font-size-md: 14px;    /* 小正文（替代 28rpx） */
  --font-size-base: 15px;  /* 1级：主体内容 */
  --font-size-md-lg: 16px; /* 中标题（替代 32rpx） */
  --font-size-lg: 17px;    /* 大标题 */
  --font-size-lg-xl: 18px; /* 大标题变体（替代 36rpx） */
  --font-size-xl: 19px;    /* 页面标题 */
  --font-size-2xl: 22px;   /* 超大展示数字 */

  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  /* ========== 行高系统 ========== */
  --line-height-tight: 1.2;   /* 紧凑：标签、徽章 */
  --line-height-normal: 1.5;  /* 标准：正文 */
  --line-height-relaxed: 1.8; /* 宽松：长文本、说明 */
}
