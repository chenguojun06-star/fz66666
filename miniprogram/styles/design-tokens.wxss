/**
 * 设计规范 - 统一样式变量
 * 所有页面应遵循此设计系统
 */

/* ========== 颜色系统 ========== */

/* 主色 - 紫色渐变 */
--color-primary: #667eea;
--color-primary-light: #764ba2;
--gradient-primary: linear-gradient(135deg, #667eea 0%, #764ba2 100%);

/* 辅助色 - 蓝色系 */
--color-blue: #3b82f6;
--color-blue-light: rgba(224, 242, 254, 0.8);
--color-blue-lighter: rgba(224, 242, 254, 0.3);

/* 功能色 */
--color-success: #10b981;
--color-warning: #f59e0b;
--color-error: #ef4444;
--color-info: #3b82f6;

/* 中性色 */
--color-bg-page: #f7f8fa;
--color-bg-card: #ffffff;
--color-bg-gray: #f3f4f6;
--color-bg-light: #f9fafb;

--color-border: #e5e7eb;
--color-border-light: #f3f4f6;

--color-text-primary: #111827;
--color-text-secondary: #6b7280;
--color-text-disabled: #9ca3af;
--color-text-white: #ffffff;

/* ========== 圆角系统 ========== */

/* 标准圆角 */
--radius-sm: 8px;     /* 小圆角 - 小按钮、标签 */
--radius-md: 12px;    /* 中圆角 - 卡片、输入框 */
--radius-lg: 16px;    /* 大圆角 - 主要卡片 */
--radius-xl: 18px;    /* 特大圆角 - 容器 */
--radius-full: 999px; /* 全圆角 - 按钮、标签、搜索框 */

/* ========== 间距系统 ========== */

--spacing-xs: 4px;
--spacing-sm: 8px;
--spacing-md: 12px;
--spacing-lg: 16px;
--spacing-xl: 20px;
--spacing-2xl: 24px;

/* ========== 阴影系统 ========== */

--shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
--shadow-md: 0 2px 6px rgba(0, 0, 0, 0.05);
--shadow-lg: 0 4px 12px rgba(0, 0, 0, 0.08);
--shadow-primary: 0 4px 12px rgba(102, 126, 234, 0.25);

/* ========== 字体系统 ========== */

--font-size-xs: 11px;   /* 辅助文字 */
--font-size-sm: 12px;   /* 小文字 */
--font-size-base: 14px; /* 正文 */
--font-size-lg: 16px;   /* 二级标题 */
--font-size-xl: 18px;   /* 一级标题 */
--font-size-2xl: 20px;  /* 数值强调 */

--font-weight-normal: 400;
--font-weight-medium: 500;
--font-weight-semibold: 600;
--font-weight-bold: 700;
