/**
 * 服装供应链系统 - 设计 Token  v5.0
 *
 * 对齐 WeUI 设计规范：圆角、间距、字号、阴影等
 * 保持品牌蓝色主色调不变
 *
 * @version 5.0
 * @date 2026-04-14
 */

page {
  /* ========== 颜色系统 ========== */

  --color-primary: #2563eb;
  --color-primary-light: #3b82f6;
  --color-primary-dark: #1d4ed8;
  --color-primary-rgb: 37, 99, 235;

  --gradient-primary: linear-gradient(135deg, #eff4ff 0%, #eef0ff 100%);
  --gradient-primary-solid: linear-gradient(135deg, #eff4ff 0%, #eef0ff 100%);
  --gradient-primary-alpha: linear-gradient(
    135deg,
    rgba(239, 244, 255, 0.92) 0%,
    rgba(238, 240, 255, 0.75) 100%
  );
  --gradient-card: linear-gradient(135deg, #eff4ff 0%, #eef0ff 100%);
  --gradient-action: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  --gradient-progress: linear-gradient(90deg, #10b981 0%, #2563eb 100%);

  --color-blue: #2563eb;
  --color-blue-light: rgba(37, 99, 235, 0.08);
  --color-blue-lighter: rgba(37, 99, 235, 0.04);

  --color-success: #07c160;
  --color-warning: #d97706;
  --color-error: #fa5151;
  --color-danger: #fa5151;
  --color-info: #2563eb;
  --color-purple: #7c3aed;

  --color-warning-bg: #fffbeb;
  --color-error-bg: #fef2f2;
  --color-success-bg: #f0fdf4;
  --color-info-bg: #eff6ff;

  --color-warning-border: #fde68a;
  --color-error-border: #fca5a5;
  --color-success-border: #a7f3d0;
  --color-info-border: #93c5fd;

  --color-bg-page: #f7f7f7;
  --color-bg-card: #ffffff;
  --color-bg-gray: #f0f2f5;
  --color-bg-light: #fafbfc;
  --color-bg-hover: #f5f5f5;
  --color-bg-active: #ebebeb;

  --color-border: #e5e5e5;
  --color-border-light: #f0f0f0;
  --color-border-blue: rgba(37, 99, 235, 0.2);

  --color-divider: #f0f0f0;

  --color-text-primary: rgba(0, 0, 0, 0.9);
  --color-text-secondary: rgba(0, 0, 0, 0.5);
  --color-text-tertiary: rgba(0, 0, 0, 0.3);
  --color-text-placeholder: rgba(0, 0, 0, 0.25);
  --color-text-disabled: rgba(0, 0, 0, 0.3);
  --color-text-white: #ffffff;

  /* ========== 圆角系统（对齐 WeUI） ========== */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 12px;
  --radius-full: 999px;

  /* ========== 间距系统（对齐 WeUI 16px 基准） ========== */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 20px;
  --spacing-xxl: 24px;

  /* ========== 阴影系统（WeUI 极简风格） ========== */
  --shadow-sm: 0 0 1px 0 rgba(0, 0, 0, 0.05);
  --shadow-md: 0 0 1px 0 rgba(0, 0, 0, 0.05), 0 2px 4px 0 rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 0 1px 0 rgba(0, 0, 0, 0.05), 0 4px 8px 0 rgba(0, 0, 0, 0.08);
  --shadow-xl: 0 0 1px 0 rgba(0, 0, 0, 0.05), 0 8px 16px 0 rgba(0, 0, 0, 0.1);
  --shadow-modal: 0 16px 48px rgba(0, 0, 0, 0.12);

  /* ========== 字体系统（对齐 WeUI） ========== */
  --font-size-xs: 12px;
  --font-size-sm: 13px;
  --font-size-md: 14px;
  --font-size-base: 15px;
  --font-size-md-lg: 16px;
  --font-size-lg: 17px;
  --font-size-lg-xl: 18px;
  --font-size-xl: 20px;
  --font-size-2xl: 22px;

  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  --line-height-tight: 1.2;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.8;
}
