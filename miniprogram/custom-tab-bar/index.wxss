.tab-bar {
  display: flex;
  flex-direction: row;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #ffffff;
  border-top: 1rpx solid #e5e5e5;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 10rpx;
}

.tab-bar-icon {
  width: 76rpx;
  height: 76rpx;
}

.tab-bar-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.tab-bar-label.active {
  color: #3b82f6;
}
