  "edges": [
    {"from": "entity:StyleInfo", "to": "entity:ProductSku", "label": "价格联动 price/tagPrice/salesPrice", "type": "sync_bidirectional", "chain": "A"},
    {"from": "entity:StyleInfo", "to": "entity:ProductSku", "label": "颜色图片 skuColorImage", "type": "sync_unidirectional", "chain": "A"},
    {"from": "entity:StyleInfo", "to": "entity:ProductSku", "label": "数量矩阵 stockQuantity", "type": "sync_bidirectional", "chain": "A"},
    {"from": "entity:StyleInfo", "to": "entity:PatternProduction", "label": "款号新建自动联动", "type": "auto_create", "chain": "A"},
    {"from": "entity:StyleBom", "to": "entity:StyleQuotation", "label": "物料成本实时重算", "type": "trigger_recalc", "chain": "A"},
    {"from": "entity:StyleProcess", "to": "entity:StyleQuotation", "label": "工序成本实时重算", "type": "trigger_recalc", "chain": "A"},
    {"from": "entity:StyleBom", "to": "entity:MaterialPurchase", "label": "BOM 回写采购", "type": "generate", "chain": "B"},
    {"from": "entity:StyleBom", "to": "entity:MaterialStock", "label": "库存检查", "type": "check", "chain": "B"},

    {"from": "endpoint:scan-execute", "to": "entity:ScanRecord", "label": "写入扫码记录", "type": "write", "chain": "B"},
    {"from": "entity:ScanRecord", "to": "entity:ProductionOrder", "label": "首次扫码 status→production", "type": "status_update", "chain": "B"},
    {"from": "entity:ScanRecord", "to": "entity:CuttingBundle", "label": "scanBlocked 次品锁定", "type": "status_update", "chain": "B"},
    {"from": "entity:ScanRecord", "to": "entity:ProductWarehousing", "label": "质检/入库记录", "type": "write", "chain": "B"},
    {"from": "entity:ProductWarehousing", "to": "entity:ProductionOrder", "label": "入库率≥90% → completed", "type": "status_update", "chain": "B"},
    {"from": "endpoint:scan-undo", "to": "entity:ScanRecord", "label": "撤回（已结算禁止）", "type": "delete_with_guard", "chain": "B"},

    {"from": "entity:MaterialPurchase", "to": "entity:MaterialInbound", "label": "采购到货入库", "type": "inbound", "chain": "B"},
    {"from": "entity:MaterialInbound", "to": "entity:MaterialStock", "label": "库存累加", "type": "stock_add", "chain": "B"},
    {"from": "entity:MaterialInbound", "to": "entity:MaterialReconciliation", "label": "syncFromInbound", "type": "auto_create", "chain": "C"},

    {"from": "entity:ScanRecord", "to": "entity:PayrollSettlement", "label": "聚合（factory_id IS NULL）", "type": "aggregate_with_guard", "chain": "C"},
    {"from": "endpoint:payroll-generate", "to": "entity:PayrollSettlement", "label": "生成结算单", "type": "write", "chain": "C"},
    {"from": "endpoint:payroll-generate", "to": "entity:ScanRecord", "label": "回写 settlementStatus=payroll_settled", "type": "status_writeback", "chain": "C"},
    {"from": "endpoint:payroll-approve", "to": "entity:PayrollSettlement", "label": "status: pending→approved", "type": "status_update", "chain": "C"},
    {"from": "endpoint:payroll-approve", "to": "entity:ScanRecord", "label": "settlementStatus→payroll_approved", "type": "status_writeback", "chain": "C"},
    {"from": "endpoint:payroll-approve", "to": "entity:BillAggregation", "label": "pushBill PAYABLE/PAYROLL", "type": "push_bill", "chain": "C"},
    {"from": "entity:MaterialReconciliation", "to": "entity:BillAggregation", "label": "审批后 pushBill", "type": "push_bill", "chain": "C"},
    {"from": "entity:PayrollSettlement", "to": "entity:WagePayment", "label": "initiatePayment", "type": "generate", "chain": "C"},

    {"from": "entity:ProductWarehousing", "to": "entity:EcSalesRevenue", "label": "出库触发 recordOnOutbound", "type": "auto_create", "chain": "C"},
    {"from": "entity:EcSalesRevenue", "to": "entity:BillAggregation", "label": "reconcile 后 pushBill", "type": "push_bill", "chain": "C"},
    {"from": "entity:EcommerceOrder", "to": "entity:EcSalesRevenue", "label": "onWarehouseOutbound", "type": "trigger", "chain": "C"},

    {"from": "frontend:PC", "to": "endpoint:scan-execute", "label": "PC 扫码", "type": "call", "chain": "D"},
    {"from": "frontend:MiniProgram", "to": "endpoint:scan-execute", "label": "小程序扫码", "type": "call", "chain": "D"},
    {"from": "frontend:H5", "to": "endpoint:scan-execute", "label": "H5 扫码", "type": "call", "chain": "D"},
    {"from": "frontend:PC", "to": "endpoint:background-task-active", "label": "BackgroundTaskPanel 轮询", "type": "poll", "chain": "D"},
    {"from": "frontend:PC", "to": "endpoint:pending-tasks-my", "label": "usePendingTasks 轮询", "type": "poll", "chain": "D"},
    {"from": "frontend:PC", "to": "endpoint:payroll-generate", "label": "工资结算", "type": "call", "chain": "D"},
    {"from": "frontend:PC", "to": "endpoint:bom-generate-purchase", "label": "BOM 生成采购", "type": "call", "chain": "D"},
    {"from": "frontend:PC", "to": "endpoint:sku-color-images", "label": "颜色图片同步", "type": "call", "chain": "D"},

    {"from": "external:Jushuitan", "to": "entity:EcommerceOrder", "label": "订单拉取", "type": "sync_pull", "chain": "D"},
    {"from": "external:Jushuitan", "to": "entity:ProductSku", "label": "商品/库存/价格推送", "type": "sync_push", "chain": "D"},
    {"from": "external:OpenAPI", "to": "entity:ProductionOrder", "label": "客户下单", "type": "create_order", "chain": "D"},
    {"from": "external:B2B", "to": "entity:EcommerceOrder", "label": "B2B 订单", "type": "create_order", "chain": "D"}
  ],
  "legends": {
    "node_types": {
      "entity": "数据库实体（蓝色）",
      "endpoint": "API 接口（绿色）",
      "external": "外部系统（紫色）",
      "frontend": "前端端（橙色）"
    },
    "edge_types": {
      "sync_bidirectional": "双向同步（实线）",
      "sync_unidirectional": "单向同步（实线箭头）",
      "write": "写入（实线）",
      "status_update": "状态更新（粗线）",
      "status_writeback": "状态回写（虚线）",
      "auto_create": "自动创建（点线）",
      "trigger_recalc": "触发重算（点划线）",
      "generate": "生成（实线）",
      "push_bill": "推送账单（粗线）",
      "aggregate_with_guard": "聚合+守护（粗线带盾）",
      "delete_with_guard": "删除+守护（粗线带盾）",
      "call": "前端调用（细线）",
      "poll": "轮询（细虚线）",
      "sync_pull": "外部拉取（紫色线）",
      "sync_push": "外部推送（紫色线）"
    },
    "chain_labels": {
      "A": "链路A：款式开发 → SKU → BOM → 工艺 → 样衣",
      "B": "链路B：扫码 → 工序 → 质检 → 入库 → BOM 回写",
      "C": "链路C：工资结算闭环 + 财务对账",
      "D": "链路D：多端对接（PC/小程序/H5/外部平台）"
    },
    "alert_levels": {
      "green": "正常",
      "yellow": "已知问题/告警",
      "red": "断链/错误（接口 404/500）",
      "gray": "未探测"
    }
  }
}
