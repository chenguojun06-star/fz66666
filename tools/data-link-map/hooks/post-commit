#!/bin/bash
# 数据链路地图 - Git post-commit hook
# 代码提交后自动重新扫描生成地图
# 安装：cp hooks/post-commit /Volumes/macoo2/Users/guojunmini4/Documents/服装66666/.git/hooks/post-commit && chmod +x /Volumes/macoo2/Users/guojunmini4/Documents/服装66666/.git/hooks/post-commit

set -e
PROJECT_ROOT="/Volumes/macoo2/Users/guojunmini4/Documents/服装66666"
TOOL_DIR="$PROJECT_ROOT/tools/data-link-map"

echo "[data-link-map] 检测到代码提交，重新扫描地图..."

cd "$PROJECT_ROOT"

# 1. 静态扫描
python3 "$TOOL_DIR/scanner/scan_static.py" > /dev/null 2>&1 && \
  echo "[data-link-map] ✅ 静态扫描完成" || \
  echo "[data-link-map] ⚠️ 静态扫描失败（不影响提交）"

# 2. 实时探测（本地后端，如果运行中）
if curl -s -o /dev/null -w "%{http_code}" http://localhost:8088/api/system/system-status | grep -q "^[23]"; then
  python3 "$TOOL_DIR/probe/probe_endpoints.py" --base-url http://localhost:8088 > /dev/null 2>&1 && \
    echo "[data-link-map] ✅ 本地探测完成" || \
    echo "[data-link-map] ⚠️ 本地探测失败"
else
  echo "[data-link-map] ℹ️ 本地后端未运行，跳过探测"
fi

echo "[data-link-map] 地图已更新: file://$TOOL_DIR/viewer/index.html"
