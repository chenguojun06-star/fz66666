.ai-assistant-container {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: var(--z-float-trigger);
}

.ai-trigger-btn {
  position: fixed;
  width: 50px;
  height: 50px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  z-index: var(--z-notification);
  box-shadow: var(--shadow-md);
  will-change: transform;
}

.ai-trigger-hover {
  transform: scale(0.95);
}

.mini-cloud-wrapper {
  position: relative;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-cloud-glow {
  position: absolute;
  top: 4px;
  right: 4px;
  bottom: 4px;
  left: 4px;
  border-radius: var(--radius-full);
  background: radial-gradient(circle, rgba(74, 140, 255, 0.18), transparent 66%);
  filter: blur(8px);
}

.mini-cloud {
  position: relative;
  width: 40px;
  height: 29px;
  animation: cloudFloat 4.8s ease-in-out infinite;
}

.mini-cloud-part,
.mini-cloud-base {
  position: absolute;
  background: linear-gradient(180deg, var(--color-bg-page) 0%, var(--color-primary-bg) 100%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 3px 7px rgba(31,117,234,0.1);
}

.mini-cloud-part {
  border-radius: 50%;
}

.mini-cloud-part-left {
  width: 13px;
  height: 13px;
  left: 4px;
  top: 10px;
}

.mini-cloud-part-center {
  width: 17px;
  height: 17px;
  left: 11px;
  top: 3px;
}

.mini-cloud-part-right {
  width: 12px;
  height: 12px;
  right: 4px;
  top: 11px;
}

.mini-cloud-base {
  left: 5px;
  right: 5px;
  bottom: 4px;
  height: 11px;
  border-radius: var(--radius-full);
}

.mini-cloud-eye {
  position: absolute;
  top: 13px;
  width: 5px;
  height: 6px;
  border-radius: var(--radius-full);
  background: var(--color-primary-dark);
  z-index: 2;
  overflow: hidden;
  animation: cloudBlink 6.6s ease-in-out infinite;
}

.mini-cloud-eye-left {
  left: 10px;
}

.mini-cloud-eye-right {
  right: 10px;
}

.mini-cloud-eye-dot {
  width: 2px;
  height: 2px;
  margin: 1px 0 0 1px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
}

.mini-cloud-smile {
  position: absolute;
  left: 50%;
  bottom: 5px;
  width: 10px;
  height: 5px;
  margin-left: -5px;
  border-bottom: 2px solid var(--color-primary-dark);
  border-radius: 0 0 10px 10px;
  z-index: 2;
}

.mini-cloud-spark {
  position: absolute;
  width: 4px;
  height: 4px;
  background: var(--color-primary);
  clip-path: polygon(50% 0%, 62% 38%, 100% 50%, 62% 62%, 50% 100%, 38% 62%, 0% 50%, 38% 38%);
  animation: sparkle 2s ease-in-out infinite;
  z-index: 3;
}

.mini-cloud-spark-left {
  left: 2px;
  top: 6px;
  animation-delay: 0s;
}

.mini-cloud-spark-right {
  right: 2px;
  top: 7px;
  animation-delay: 0.6s;
}

@keyframes cloudFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-2px); }
}

@keyframes cloudBlink {
  0%, 44%, 48%, 92%, 96%, 100% { transform: scaleY(1); }
  46%, 94% { transform: scaleY(0.18); }
}

@keyframes sparkle {
  0%, 100% { opacity: 0.3; transform: scale(0.85); }
  50% { opacity: 1; transform: scale(1.05); }
}

.ai-badge {
  position: fixed;
  min-width: 22px;
  height: 22px;
  border-radius: var(--radius-2xl);
  background: var(--color-danger);
  color: var(--color-text-white);
  font-size: var(--font-size-sm);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 5px;
  box-sizing: border-box;
  border: 2px solid var(--color-bg-card);
  box-shadow: 0 1px 4px rgba(255,59,48,0.5);
  z-index: var(--z-float-trigger);
  pointer-events: none;
}

.chat-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--color-overlay);
  pointer-events: auto;
  z-index: var(--z-float-trigger);
}

.chat-modal {
  position: fixed; bottom: 0; left: 0; right: 0; height: 75vh;
  background: var(--color-bg-card); border-top-left-radius: 18px; border-top-right-radius: 18px; overflow: hidden;
  display: flex; flex-direction: column; pointer-events: auto;
  box-shadow: var(--shadow-modal);
  animation: slideUp 0.3s ease-out forwards;
  z-index: var(--z-float-trigger);
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.chat-header {
  padding: 10px 12px; display: flex; justify-content: space-between; align-items: center;
  border-bottom: 1px solid var(--color-border); background: var(--color-bg-page);
}
.chat-header-actions { display: flex; align-items: center; gap: 4px; }
.header-action-btn { font-size: var(--font-size-lg); color: var(--color-text-disabled); padding: 4px 6px; border-radius: var(--radius-sm); }
.header-action-btn-hover { background: var(--color-bg-page); }
.close-btn { font-size: var(--font-size-xl); color: var(--color-text-disabled); }

.quick-chips { display: flex; flex-direction: row; padding: 8px 12px 0; gap: 8px; flex-wrap: wrap; }

/* ============ AI 新增：空状态与快捷提示 ============ */
.ai-empty { padding: 16px 12px 20px; text-align: center; }
.ai-empty-hero { padding: 14px 0 18px; }
.ai-empty-cloud { width: 56px; height: 56px; margin: 0 auto 10px; position: relative; background: linear-gradient(135deg, var(--color-purple) 0%, var(--color-purple-light) 100%); border-radius: 50%; box-shadow: 0 6px 16px var(--color-purple-border); }
.ai-empty-cloud .chat-cloud-part { display: none; }
.ai-empty-title { display: block; font-size: var(--font-size-xl); font-weight: 700; color: var(--color-text-primary); }
.ai-empty-sub { display: block; font-size: var(--font-size-sm); color: var(--color-text-secondary); margin-top: 4px; }

.ai-quick-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 12px; padding: 0 4px; }
.ai-quick-card { display: flex; flex-direction: column; align-items: center; padding: 14px 8px; background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-xl); transition: transform 0.15s ease, box-shadow 0.15s ease; box-shadow: var(--shadow-sm); }
.ai-quick-card-hover { transform: translateY(-2px); box-shadow: 0 6px 14px rgba(124,58,237,0.12); background: var(--color-purple-bg); }
.ai-quick-icon { font-size: var(--font-size-3xl); margin-bottom: 4px; }
.ai-quick-label { font-size: var(--font-size-xs); color: var(--color-text-primary); text-align: center; line-height: 1.4; }

.ai-extra-label { display: block; text-align: left; font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text-secondary); margin: 16px 4px 4px; }

/* ============ AI 新增：图片输入相关样式 ============ */
.msg-image { display: block; width: 100%; max-width: 220px; border-radius: var(--radius-xl); margin-bottom: 6px; overflow: hidden; min-height: 120px; }
.chat-image-btn { width: 38px; height: 38px; border-radius: var(--radius-full); background: var(--color-bg-page); display: flex; align-items: center; justify-content: center; font-size: var(--font-size-xl); transition: background 0.15s ease, transform 0.15s ease; flex-shrink: 0; }
.chat-image-btn-hover { background: var(--color-purple-bg); transform: scale(0.95); }
.chat-image-preview { position: relative; width: 44px; height: 44px; margin-right: 2px; border-radius: var(--radius-lg); overflow: hidden; flex-shrink: 0; border: 1px solid var(--color-border); }
.chat-image-preview-img { width: 100%; height: 100%; display: block; }
.chat-image-preview-close { position: absolute; top: -4px; right: -4px; width: 18px; height: 18px; border-radius: var(--radius-full); background: var(--color-overlay); color: var(--color-text-white); font-size: var(--font-size-sm); line-height: 18px; text-align: center; }
.quick-chip { background: var(--color-bg-page); color: var(--color-primary); border-radius: var(--radius-xl); padding: 4px 10px; font-size: var(--font-size-xxs); line-height: var(--line-height-normal); border: 1px solid var(--color-info-bg); }
.quick-chip-hover { background: var(--color-info-bg); }
.page-context-chips { padding: 10px 12px 0; }
.page-context-label { font-size: var(--font-size-xxs); color: var(--color-text-disabled); margin-bottom: 6px; }
.page-context-list { display: flex; flex-direction: row; gap: 8px; flex-wrap: wrap; }
.chat-history-wrapper { flex: 1; min-height: 0; overflow: hidden; width: 100%; }
.chat-history { height: 100%; width: 100%; box-sizing: border-box; padding: 12px; background: var(--color-bg-page); }
.message-row { display: flex; margin-bottom: 12px; align-items: flex-start; }
.my-message { flex-direction: row-reverse; }
.ai-message { flex-direction: row; }
.avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: var(--font-size-xs); margin: 0 8px; flex-shrink: 0; }
.avatar-user { background: var(--color-primary); color: var(--color-bg-card); }
.avatar-ai { background: var(--color-primary-bg); padding: 0; overflow: hidden; }
.my-message .bubble { background: var(--color-primary); color: var(--color-bg-card); border-radius: var(--radius-md) 0 8px 8px; }
.ai-message .bubble { background: var(--color-bg-card); color: var(--color-text-primary); border-radius: 0 8px 8px 8px; }

.chat-cloud {
  position: relative;
  width: 32px;
  height: 22px;
  margin-top: 6px;
}
.chat-cloud-part {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(180deg, var(--color-bg-page) 0%, var(--color-primary-bg) 100%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 4px rgba(31,117,234,0.1);
}
.chat-cloud-part-left { width: 10px; height: 10px; left: 2px; top: 8px; }
.chat-cloud-part-center { width: 14px; height: 14px; left: 9px; top: 1px; }
.chat-cloud-part-right { width: 9px; height: 9px; right: 2px; top: 9px; }
.chat-cloud-base {
  position: absolute;
  left: 3px; right: 3px; bottom: 2px;
  height: 9px; border-radius: var(--radius-full);
  background: linear-gradient(180deg, var(--color-bg-page) 0%, var(--color-primary-bg) 100%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 2px 4px rgba(31,117,234,0.1);
}
.chat-cloud-eye {
  position: absolute;
  top: 10px;
  width: 4px; height: 5px;
  border-radius: var(--radius-full);
  background: var(--color-primary-dark);
  z-index: 2;
  overflow: hidden;
}
.chat-cloud-eye-left { left: 7px; }
.chat-cloud-eye-right { right: 7px; }
.chat-cloud-eye-dot {
  width: 2px; height: 2px;
  margin: 1px 0 0 1px;
  border-radius: 50%;
  background: rgba(255,255,255,0.96);
}
.chat-cloud-smile {
  position: absolute;
  left: 50%; bottom: 3px;
  width: 8px; height: 4px;
  margin-left: -4px;
  border-bottom: 1.5px solid var(--color-primary-dark);
  border-radius: 0 0 8px 8px;
  z-index: 2;
}
.bubble { padding: 8px 12px; max-width: 60%; font-size: var(--font-size-md); box-shadow: 0 1px 4px var(--color-border); }
.message-text { word-break: break-all; white-space: pre-wrap; line-height: var(--line-height-medium); }
.chat-input-area { display: flex; padding: 10px 12px calc(10px + env(safe-area-inset-bottom)); border-top: 1px solid var(--color-bg-page); background: var(--color-bg-card); align-items: center; gap: 8px; flex-shrink: 0; }
.chat-input { flex: 1; background: var(--color-bg-page); border: 1px solid var(--input-border); border-radius: var(--radius-xl); padding: 0 14px; font-size: var(--font-size-md); height: 44px; line-height: 44px; box-sizing: border-box; }

.send-btn-mini {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1px solid var(--color-primary);
  border-radius: 50%;
  flex-shrink: 0;
}

.send-btn-mini .send-icon {
  font-size: var(--font-size-lg);
  color: var(--color-primary);
}

.send-btn-mini.btn-disabled {
  background: var(--color-bg-page);
}

.send-btn-mini.btn-disabled .send-icon {
  color: var(--color-text-disabled);
}

.loading-indicator { text-align: center; color: var(--color-text-disabled); font-size: var(--font-size-xs); padding: 10px; }
.loading-hint-text { font-size: var(--font-size-xs); color: var(--color-text-secondary); }

.chat-main { flex: 1; display: flex; flex-direction: column; min-height: 0; width: 100%; overflow: hidden; }

.header-tabs {
  display: flex;
  align-items: center;
  gap: 4px;
}
.tab-item {
  position: relative;
  display: flex;
  align-items: center;
  gap: 2px;
  padding: 5px 10px;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  border-radius: var(--radius-lg);
  transition: all 0.2s;
}
.tab-item.active {
  color: var(--color-primary);
  background: var(--color-info-bg);
  border: 1px solid var(--color-info-border);
  font-weight: 600;
}
.tab-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 16px;
  height: 16px;
  line-height: 16px;
  padding: 0 4px;
  border-radius: var(--radius-xl);
  background: var(--color-danger);
  color: var(--color-text-white);
  font-size: var(--font-size-2xs);
  font-weight: 600;
  margin-left: 3px;
}

.tasks-main {
  flex: 1;
  height: 0;
  padding: 10px 12px;
  background: var(--color-bg-page);
  box-sizing: border-box;
}

.tasks-main .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
}
.tasks-main .empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-disabled);
}

/* ──── Task sections ──── */
.task-section { margin-bottom: 12px; }

.task-section-header {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 7px 10px;
  border-radius: var(--radius-md);
  margin-bottom: 8px;
  border: 1px solid var(--color-border);
  background: var(--color-warning-bg);
  border-color: var(--color-warning-border);
}
.section-title {
  font-size: var(--font-size-md);
  font-weight: 700;
  color: var(--color-text-primary);
}
.section-badge {
  font-size: var(--font-size-xxs);
  color: var(--color-text-disabled);
}

/* Section header pill */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 7px 10px;
  border-radius: var(--radius-md);
  margin-bottom: 8px;
  border: 1px solid var(--color-border);
}
.quality-header  { background: var(--color-info-bg); border-color: var(--color-info-border); }
.cutting-header  { background: var(--color-warning-bg); border-color: var(--color-warning-border); }
.purchase-header { background: var(--color-info-bg); border-color: var(--color-info-border); }
.repair-header   { background: var(--color-danger-bg); border-color: var(--color-danger-border); }
.overdue-header  { background: var(--color-danger-bg); border-color: var(--color-danger-border); }
.pending-header  { background: var(--color-success-bg); border-color: var(--color-success-border); }

.section-header-left { display: flex; align-items: center; gap: 5px; }
.section-name { font-size: var(--font-size-md); font-weight: 700; color: var(--color-text-primary); }

.section-count-badge {
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xxs);
  font-weight: 700;
  color: var(--color-text-white);
  box-sizing: border-box;
}
.quality-badge  { background: var(--color-primary); }
.cutting-badge  { background: var(--color-primary); }
.purchase-badge { background: var(--color-purple); }
.repair-badge   { background: var(--color-danger); }
.overdue-badge  { background: var(--color-danger); }
.pending-badge  { background: var(--color-success); }

/* Task card — left accent bar + two-column layout */
.task-card {
  position: relative;
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  margin-bottom: 7px;
  overflow: hidden;
  display: flex;
  flex-direction: row;
  box-shadow: var(--shadow-sm);
}
.task-dismiss {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-2xl);
  color: var(--color-text-disabled);
  z-index: 2;
  border-radius: 50%;
}
.task-dismiss:active { color: var(--color-text-secondary); background: var(--color-bg-page); }
/* 新增：×关闭按钮与查看按钮同行排列，避免重叠 */
.task-dismiss-inline {
  width: 26px;
  height: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg);
  color: var(--color-text-disabled);
  border-radius: 50%;
  margin-bottom: 4px;
  flex-shrink: 0;
}
.task-dismiss-inline:active { color: var(--color-text-secondary); background: var(--color-bg-page); }
.task-card-hover { background: var(--color-bg-page); }

/* 新增：任务卡款式图 */
.task-cover-img {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--color-bg-page);
  object-fit: cover;
}
.task-cover-placeholder {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--color-info-bg);
  color: var(--color-primary);
  font-size: var(--font-size-xxs);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2px;
  text-align: center;
  line-height: 1.1;
  overflow: hidden;
  box-sizing: border-box;
}

.task-accent-bar { width: 3px; flex-shrink: 0; }
.task-type-quality  .task-accent-bar { background: var(--color-primary); }
.task-type-cutting  .task-accent-bar { background: var(--color-primary); }
.task-type-purchase .task-accent-bar { background: var(--color-purple); }
.task-type-repair   .task-accent-bar { background: var(--color-danger); }
.task-type-overdue  .task-accent-bar { background: var(--color-danger); }
.task-type-pending  .task-accent-bar { background: var(--color-success); }
.task-type-timeout  .task-accent-bar { background: var(--color-warning); }

.task-card-main {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 9px 9px 9px 10px;
  gap: 7px;
  box-sizing: border-box;
  min-width: 0;
}
.task-card-info { flex: 1; min-width: 0; }

.task-order-row {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-bottom: 4px;
}
.task-order-no {
  font-size: var(--font-size-sm);
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 0.2px;
}
.task-style-tag {
  font-size: var(--font-size-xxs);
  color: var(--color-primary);
  background: var(--color-info-bg);
  border: 1px solid var(--color-info-border);
  padding: 1px 6px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}
.cutting-tag  { color: var(--color-primary); background: var(--color-info-bg); border-color: var(--color-info-border); }
.purchase-tag { color: var(--color-purple); background: var(--color-purple-bg-light); border-color: var(--color-purple-border); }
.repair-tag   { color: var(--color-danger); background: var(--color-danger-bg); border-color: var(--color-danger-border); }
.overdue-tag  { color: var(--color-danger); background: var(--color-danger-bg); border-color: var(--color-danger-border); }
.timeout-tag  { color: var(--color-warning); background: var(--color-warning-bg); border-color: var(--color-warning-border); }

.task-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
  margin-bottom: 5px;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.task-chips { display: flex; flex-wrap: wrap; gap: 4px; }
.task-chip {
  font-size: var(--font-size-xxs);
  color: var(--color-text-disabled);
  background: var(--color-bg-page);
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  line-height: var(--line-height-medium);
}
.time-chip { color: var(--color-text-disabled); }

/* 修改：× 关闭按钮和查看按钮纵向排列在同一列，避免重叠 */
.task-action-col { flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end; justify-content: center; gap: 4px; width: 64px; }
.task-approve-col { flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end; gap: 4px; width: 64px; }
.task-action-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: var(--font-size-xxs) !important;
  font-weight: var(--font-weight-semibold) !important;
  min-width: 52px !important;
  padding: 0 8px !important;
  height: 26px !important;
  line-height: 1 !important;
  border-radius: var(--radius-lg) !important;
  color: var(--color-primary) !important;
  background: transparent !important;
  border: 1px solid var(--color-primary) !important;
  white-space: nowrap;
  box-sizing: border-box;
  text-align: center;
  margin: 0 !important;
}
.quality-btn  { background: transparent !important; border: 1px solid var(--color-primary) !important; box-shadow: none; }
.cutting-btn  { background: transparent !important; border: 1px solid var(--color-primary) !important; box-shadow: none; }
.repair-btn   { background: var(--color-danger) !important; box-shadow: 0 2px 6px rgba(255,77,79,0.2); }
.approve-btn  { background: var(--color-success) !important; box-shadow: 0 2px 6px rgba(5,150,105,0.18); margin-right: 6px !important; }
.reject-btn   { background: var(--color-danger) !important; box-shadow: 0 2px 6px rgba(255,77,79,0.18); }
.default-btn  { background: transparent !important; border: 1px solid var(--color-primary) !important; box-shadow: none; }
.task-action-btn::after { border: none !important; }


.recommend-wrapper {
  margin-top: 8px;
  padding-top: 6px;
  border-top: 1px solid rgba(0,0,0,0.06);
}
.recommend-title {
  font-size: var(--font-size-xxs);
  color: var(--color-text-disabled);
  margin-bottom: 5px;
}
.recommend-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.recommend-pill {
  background: var(--color-bg-page);
  color: var(--color-primary);
  font-size: var(--font-size-xxs);
  padding: 3px 8px;
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-info-bg);
}
.recommend-pill-hover {
  background: var(--color-info-bg);
}

.dynamic-suggestions {
  padding: 8px 12px 0;
}
.dynamic-suggestions-label {
  font-size: var(--font-size-xxs);
  color: var(--color-danger);
  margin-bottom: 6px;
  font-weight: 600;
}
.dynamic-suggestions-list {
  display: flex;
  flex-direction: row;
  gap: 8px;
  flex-wrap: wrap;
}
.dynamic-suggestion-chip {
  background: var(--color-danger-bg);
  color: var(--color-danger);
  border-radius: var(--radius-xl);
  padding: 4px 10px;
  font-size: var(--font-size-xxs);
  line-height: var(--line-height-normal);
  border: 1px solid var(--color-danger-border);
}
.dynamic-suggestion-chip-hover {
  background: var(--color-danger);
  color: var(--color-text-white);
}

.action-cards {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.action-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 8px 10px;
  border: 1px solid var(--color-border);
}
.action-card-body {
  display: flex;
  align-items: center;
  gap: 6px;
  flex: 1;
  min-width: 0;
}
.action-card-icon {
  font-size: var(--font-size-md-lg);
  flex-shrink: 0;
}
.action-card-info {
  flex: 1;
  min-width: 0;
}
.action-card-label {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.action-card-desc {
  font-size: var(--font-size-xxs);
  color: var(--color-text-disabled);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 2px;
}
.action-card-btn {
  flex-shrink: 0;
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  font-size: var(--font-size-xxs);
  padding: 3px 10px;
  border-radius: var(--radius-lg);
  margin-left: 6px;
}
.action-card-btn-hover {
  opacity: 0.85;
  transform: scale(0.97);
}

.insight-cards { margin-top: 6px; }
.insight-card {
  border-radius: var(--radius-sm);
  padding: 8px 10px;
  margin-bottom: 6px;
  border-left: 1px solid var(--color-primary);
}
.insight-danger { border-left-color: var(--color-danger); background: var(--color-danger-bg); }
.insight-warning { border-left-color: var(--color-warning); background: var(--color-warning-bg); }
.insight-success { border-left-color: var(--color-success); background: var(--color-success-bg); }
.insight-info { border-left-color: var(--color-primary); background: var(--color-primary-bg); }
.insight-title { font-weight: 600; font-size: var(--font-size-xs); color: var(--color-text-primary); margin-bottom: 2px; }
.insight-danger .insight-title { color: var(--color-danger); }
.insight-warning .insight-title { color: var(--color-warning); }
.insight-success .insight-title { color: var(--color-success); }
.insight-info .insight-title { color: var(--color-primary); }
.insight-summary { font-size: var(--font-size-2xs); color: var(--color-text-primary); margin-top: 2px; }
.insight-pain { font-size: var(--font-size-2xs); color: var(--color-danger); margin-top: 2px; }
.insight-action { font-size: var(--font-size-2xs); color: var(--color-primary); margin-top: 2px; }
.insight-evidence { margin-top: 4px; }
.insight-ev-item { font-size: var(--font-size-xxs); color: var(--color-text-tertiary); line-height: 1.6; }

.clarification-card {
  margin-top: 6px;
  background: var(--color-warning-bg);
  border-radius: var(--radius-sm);
  padding: 8px 10px;
}
.clarification-label { font-size: var(--font-size-xs); color: var(--color-warning); margin-bottom: 6px; }
.clarification-btns { display: flex; flex-wrap: wrap; gap: 6px; }
.clarification-btn {
  font-size: var(--font-size-xs);
  padding: 4px 12px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-warning-border);
  border-radius: var(--radius-lg);
  color: var(--color-warning);
}
.clarification-btn-hover { background: var(--color-danger-bg); }

.wizard-cards { margin-top: 8px; display: flex; flex-direction: column; gap: 8px; }
.wizard-card { background: var(--color-bg-page); border-radius: var(--radius-xl); padding: 10px; border: 1px solid var(--color-info-border); }
.wizard-header { display: flex; align-items: flex-start; gap: 6px; margin-bottom: 8px; }
.wizard-icon { font-size: var(--font-size-xl); flex-shrink: 0; margin-top: 1px; }
.wizard-header-text { flex: 1; min-width: 0; }
.wizard-title { font-size: var(--font-size-md); font-weight: 700; color: var(--color-text-primary); display: block; }
.wizard-desc { font-size: var(--font-size-2xs); color: var(--color-text-disabled); display: block; margin-top: 2px; }
.wizard-step-section { margin-top: 6px; margin-bottom: 4px; padding-bottom: 4px; border-bottom: 1px dashed var(--color-border); }
.wizard-step-title { font-size: var(--font-size-xs); font-weight: 600; color: var(--color-primary); }
.wizard-fields { display: flex; flex-direction: column; gap: 8px; }
.wizard-field { display: flex; flex-direction: column; gap: 4px; }
.wizard-field-label { font-size: var(--font-size-xs); font-weight: 600; color: var(--color-text-primary); }
.wizard-options { display: flex; flex-wrap: wrap; gap: 5px; }
.wizard-option { font-size: var(--font-size-2xs); padding: 4px 10px; border-radius: var(--radius-lg); background: var(--color-bg-card); color: var(--color-text-secondary); border: 1px solid var(--color-border); }
.wizard-option-hover { background: var(--color-info-bg); }
.wizard-option-selected { background: transparent; color: var(--color-primary); border-color: var(--color-primary); }
.wizard-input { font-size: var(--font-size-xs); padding: 6px 10px; border-radius: var(--radius-sm); background: var(--input-bg); border: 1px solid var(--input-border); height: 36px; box-sizing: border-box; }
.wizard-date-trigger { display: flex; align-items: center; justify-content: space-between; font-size: var(--font-size-xs); padding: 6px 10px; border-radius: var(--radius-sm); background: var(--input-bg); border: 1px solid var(--input-border); }
.wizard-date-placeholder { color: var(--color-text-disabled); }
.wizard-date-arrow { color: var(--color-text-disabled); font-size: var(--font-size-xs); }
.wizard-submit { margin-top: 10px; background: transparent; color: var(--color-primary); border: 1px solid var(--color-primary); font-size: var(--font-size-sm); font-weight: 600; text-align: center; padding: 8px 0; border-radius: var(--radius-xl); }
.wizard-submit-hover { opacity: 0.85; }

.team-status-cards { margin-top: 8px; display: flex; flex-direction: column; gap: 8px; }
.team-status-card { background: var(--color-bg-page); border-radius: var(--radius-xl); padding: 10px; border: 1px solid var(--color-success-border); }
.ts-header { display: flex; align-items: flex-start; gap: 6px; margin-bottom: 6px; }
.ts-icon { font-size: var(--font-size-lg); flex-shrink: 0; }
.ts-summary { font-size: var(--font-size-sm); font-weight: 600; color: var(--color-text-primary); flex: 1; }
.ts-meta { display: flex; flex-wrap: wrap; gap: 6px 12px; margin-bottom: 6px; }
.ts-meta-item { display: flex; align-items: center; gap: 3px; }
.ts-meta-label { font-size: var(--font-size-2xs); color: var(--color-text-disabled); }
.ts-meta-value { font-size: var(--font-size-2xs); color: var(--color-text-primary); font-weight: 500; }
.ts-order-no { color: var(--color-primary); font-weight: 700; }
.ts-stage-tag { background: var(--color-info-bg); color: var(--color-primary); padding: 1px 6px; border-radius: var(--radius-sm); font-size: var(--font-size-xxs); }
.ts-due { color: var(--color-warning); }
.ts-section-title { font-size: var(--font-size-2xs); color: var(--color-text-disabled); margin-bottom: 4px; display: block; }
.ts-recipients { margin-bottom: 6px; }
.ts-recipient { display: flex; align-items: center; justify-content: space-between; padding: 4px 0; }
.ts-recipient-info { display: flex; align-items: center; gap: 5px; }
.ts-recipient-name { font-size: var(--font-size-xs); font-weight: 600; color: var(--color-text-primary); }
.ts-recipient-role { font-size: var(--font-size-2xs); color: var(--color-text-disabled); }
.ts-status-tag { font-size: var(--font-size-xxs); padding: 1px 6px; border-radius: var(--radius-sm); }
.ts-status-notified { background: var(--color-info-bg); color: var(--color-primary); }
.ts-status-pending { background: var(--color-warning-bg); color: var(--color-warning); }
.ts-history { }
.ts-history-item { display: flex; align-items: flex-start; gap: 6px; padding: 3px 0; }
.ts-history-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-success); flex-shrink: 0; margin-top: 5px; }
.ts-history-content { flex: 1; min-width: 0; }
.ts-history-main { font-size: var(--font-size-2xs); color: var(--color-text-secondary); display: block; }
.ts-history-time { font-size: var(--font-size-xxs); color: var(--color-text-disabled); display: block; }
