<view class="image-preview" style="width:100%;height:100%" bindtap="onTap">
  <image wx:if="{{hasSrc && !error}}" class="img" src="{{src}}" mode="{{mode}}" binderror="onError" bindload="onLoad" />
  <view wx:else class="placeholder">
    <view class="line-icon line-icon--lg icon-search"></view>
    <text wx:if="{{placeholder}}" class="placeholder-text">{{placeholder}}</text>
  </view>
</view>
