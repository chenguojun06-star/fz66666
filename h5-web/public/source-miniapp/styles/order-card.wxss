/* =====================================================
 * order-card.wxss — 通用订单/任务卡片样式（全局共享）
 *
 * 用法：
 *   @import '/styles/order-card.wxss';
 *
 * 适用页面：procurement/task-list, cutting/bundle-detail,
 *          sales/order-list, dashboard, advance/list, defect 等
 *
 * 设计原则：
 *   - 全部使用 design-tokens CSS 变量，禁止硬编码颜色
 *   - 与 sticky-search-bar 通用组件配套使用
 *   - 与 design-tokens.wxss 的 .tag-* 颜色类配套
 * ===================================================== */

/* =====================================================
 * 一、筛选 pill（与 sticky-search-bar 的 filter slot 配套）
 *   .filter-scroll / .filter-pill / .filter-text / .filter-num
 *   .filter-pill--on / --prod / --done / --danger
 * ===================================================== */

.filter-scroll {
  white-space: nowrap;
  padding: 0;
}

.filter-pill {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 4px;
  padding: 0 12px;
  height: 32px;
  border-radius: var(--radius-full);
  background: var(--color-bg-page);
  border: 1px solid var(--color-border);
  margin-right: 8px;
  min-width: 52px;
}

.filter-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.filter-num {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  line-height: 1.1;
}

/* 选中态：实心蓝底白字（优先级最高，覆盖所有类型样式） */
.filter-pill--on {
  background: var(--color-primary) !important;
  border-color: var(--color-primary) !important;
}
.filter-pill--on .filter-text,
.filter-pill--on .filter-num {
  color: var(--color-text-white) !important;
}

/* 未选中 - 进行中：浅蓝底蓝字 */
.filter-pill--prod {
  background: var(--color-primary-bg);
  border-color: transparent;
}
.filter-pill--prod .filter-text,
.filter-pill--prod .filter-num {
  color: var(--color-primary);
}

/* 未选中 - 已完成：浅绿底绿字 */
.filter-pill--done {
  background: var(--color-success-bg);
  border-color: transparent;
}
.filter-pill--done .filter-text,
.filter-pill--done .filter-num {
  color: var(--color-success);
}

/* 未选中 - 异常/延期：浅红底红字 */
.filter-pill--danger {
  background: var(--color-danger-bg);
  border-color: transparent;
}
.filter-pill--danger .filter-text,
.filter-pill--danger .filter-num {
  color: var(--color-danger);
}

/* =====================================================
 * 二、通用任务/订单卡片 .task-card
 *   圆角 + 边框 + 阴影，与设计稿对齐
 * ===================================================== */

.task-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-card);
  transition: transform 0.18s ease, background-color 0.18s ease;
}

.task-card:active {
  background: var(--color-bg-active, var(--color-bg-page));
}

/* ---- 卡片头部：图片 + 标题区 + 状态标签 ---- */

.card-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.card-media {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  overflow: hidden;
  background: var(--color-bg-page);
}

.media-img {
  width: 100%;
  height: 100%;
}

.media-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-tertiary);
  background: var(--color-primary-bg);
}

.media-placeholder .cover-abbr {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

.card-title-area {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-top: 2px;
}

.material-name {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.material-code {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

/* 状态标签 — .tag 基础类和 .tag-* 颜色类在 design-tokens.wxss 全局定义 */
.card-header .tag {
  flex-shrink: 0;
  align-self: flex-start;
}

/* =====================================================
 * 三、卡片详情行（2 列网格）
 * ===================================================== */

.card-body {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px 12px;
}

.info-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
  min-width: 0;
}

/* 跨两列 */
.info-row-full {
  grid-column: 1 / -1;
}

.info-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  white-space: nowrap;
}

.info-value {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* =====================================================
 * 四、卡片操作按钮
 *   主操作：主色填充；次操作：镂空描边
 * ===================================================== */

.card-footer {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

/* 镂空描边按钮（查看详情） */
.btn-detail {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 32px;
  padding: 0 12px;
  background: transparent;
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
  transition: opacity 0.18s ease;
}

.btn-detail:active,
.btn-detail-hover {
  opacity: 0.7;
}

/* 主色填充按钮（领取/确认等主操作） */
.btn-claim {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  height: 40px;
  padding: 0 10px;
  background: var(--color-primary);
  color: var(--color-text-white);
  border: none;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  white-space: nowrap;
  transition: opacity 0.18s ease, transform 0.18s ease;
}

.btn-claim:active,
.btn-claim-hover {
  opacity: 0.88;
  transform: scale(0.98);
}

.claim-arrow {
  font-size: var(--font-size-md);
}
