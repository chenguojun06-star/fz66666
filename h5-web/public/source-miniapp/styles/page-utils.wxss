/* =====================================================
 * page-utils.wxss — 页面通用样式工具集
 * 📦 空状态 / 翻页加载 / 标签 chip
 *
 * 使用方式：
 *   @import '/styles/page-utils.wxss';
 *
 * 类名前缀约定：无前缀（语义即名称）
 * ===================================================== */

/* =====================================================
 * 一、空状态 Empty State → 已移至 app.wxss（全局加载，无需再 @import）
 * .empty-state / .empty-icon / .empty-img / .empty-text / .empty-hint
 * 均在 app.wxss “空状态”区块定义。
 * ===================================================== */



/* =====================================================
 * 二、翻页 / 加载态 Pagination & Load-more
 * ===================================================== */

/* 可点击的"加载更多"行 */
.load-more {
  text-align: center;
  padding: 12px 10px;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

/* 禁用态："没有更多了" */
.load-more.disabled {
  color: var(--color-text-disabled);
  pointer-events: none;
}

/* 点击反馈（hover-class="load-more-hover"） */
.load-more-hover {
  opacity: 0.7;
}

/* 已全部加载 */
.no-more {
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}

/* 加载中动画行 */
.loading-more {
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
}


/* =====================================================
 * 三、标签 Chip / Tag
 * 注意：所有 .tag-* 类（基础样式 + 颜色）已在 design-tokens.wxss 统一。
 *       本文件只保留 .tag-color / .tag-size 的更紧凑覆盖（字号 10px）。
 * ===================================================== */

/* 颜色标签：更小更紧凑 */
.tag-color { font-size: 10px; padding: 1px 5px; }
/* 尺码标签：更小更紧凑 */
.tag-size  { font-size: 10px; padding: 1px 5px; }


/* =====================================================
 * 四、Apple 风格通用组件
 * ===================================================== */

/* ---------- 4.1 卡片 Card ---------- */
.apple-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: var(--card-padding);
  margin-bottom: var(--card-gap);
  transition: box-shadow 0.2s ease, transform 0.15s ease;
}

.apple-card:active {
  box-shadow: var(--shadow-2xs);
  transform: scale(0.995);
}

.apple-card-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}

.apple-card-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
}

.apple-card-section {
  padding-top: var(--spacing-md);
  margin-top: var(--spacing-md);
  border-top: 1px solid var(--color-border-light);
}

.apple-card-section:first-child {
  padding-top: 0;
  margin-top: 0;
  border-top: none;
}

/* ---------- 4.2 列表项 List Item ---------- */
.apple-list {
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  margin-bottom: var(--card-gap);
}

.apple-list-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) var(--card-padding);
  background: var(--color-bg-card);
  transition: background-color 0.15s ease;
}

.apple-list-item:active {
  background: var(--color-bg-hover);
}

.apple-list-item + .apple-list-item {
  position: relative;
}

.apple-list-item + .apple-list-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: var(--card-padding);
  right: 0;
  height: 0.5px;
  background: var(--color-border-light);
}

.apple-list-item-icon {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  font-size: 16px;
}

.apple-list-item-content {
  flex: 1;
  min-width: 0;
}

.apple-list-item-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  line-height: 1.4;
}

.apple-list-item-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

.apple-list-item-arrow {
  color: var(--color-text-tertiary);
  font-size: 14px;
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
}

/* ---------- 4.3 按钮 Button ---------- */
.apple-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: var(--btn-height-md);
  padding: 0 var(--spacing-lg);
  border-radius: var(--radius-button);
  font-size: var(--btn-font-size);
  font-weight: var(--font-weight-medium);
  line-height: 1;
  transition: opacity 0.15s ease, transform 0.1s ease;
  border: none;
  outline: none;
  white-space: nowrap;
}

.apple-btn:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.apple-btn-primary {
  background: var(--color-primary);
  color: var(--color-text-white);
}

.apple-btn-secondary {
  background: var(--color-bg-gray);
  color: var(--color-text-primary);
}

.apple-btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 1.5px solid var(--color-primary);
  height: calc(var(--btn-height-md) - 3px);
}

.apple-btn-danger {
  background: var(--color-danger);
  color: var(--color-text-white);
}

.apple-btn-success {
  background: var(--color-success);
  color: var(--color-text-white);
}

.apple-btn-block {
  display: flex;
  width: 100%;
}

.apple-btn-sm {
  height: var(--btn-height-sm);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-sm);
}

.apple-btn-xs {
  height: var(--btn-height-xs);
  padding: 0 var(--spacing-sm);
  font-size: var(--font-size-xs);
}

.apple-btn.disabled,
.apple-btn[disabled] {
  opacity: 0.4;
  pointer-events: none;
}

/* ---------- 4.4 信息对 Info Row ---------- */
.apple-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) 0;
}

.apple-info-label {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.apple-info-value {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  text-align: right;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.apple-info-value-primary { color: var(--color-primary); }
.apple-info-value-success { color: var(--color-success); }
.apple-info-value-danger  { color: var(--color-danger); }
.apple-info-value-warning { color: var(--color-warning); }

/* ---------- 4.5 页面分区标题 Section Header ---------- */
.apple-section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin: var(--spacing-lg) var(--page-padding-x) var(--spacing-sm);
}

.apple-section-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin: 0 var(--page-padding-x) var(--spacing-md);
}

/* ---------- 4.6 网格卡片 Grid Card ---------- */
.apple-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  padding: 0 var(--page-padding-x);
  margin-bottom: var(--card-gap);
}

.apple-grid-item {
  flex: 1;
  min-width: calc(50% - 6px);
  background: var(--color-bg-card);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
  padding: var(--spacing-md);
  transition: box-shadow 0.2s ease;
}

.apple-grid-item:active {
  box-shadow: var(--shadow-2xs);
}

.apple-grid-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 4px;
}

.apple-grid-value {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.2;
}

.apple-grid-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-normal);
  margin-left: 2px;
}

/* ---------- 4.7 顶部操作栏 Top Bar ---------- */
.apple-topbar {
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
  background: rgba(242, 242, 247, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: var(--spacing-sm) var(--page-padding-x);
  border-bottom: 0.5px solid var(--color-border-light);
}

/* ---------- 4.8 底部操作栏 Bottom Bar ---------- */
.apple-bottombar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  background: var(--color-bg-card);
  padding: var(--spacing-sm) var(--page-padding-x) calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  box-shadow: 0 -1px 0 rgba(0, 0, 0, 0.04), 0 -4px 16px rgba(0, 0, 0, 0.04);
  display: flex;
  gap: var(--spacing-sm);
  align-items: center;
}

/* ---------- 4.9 搜索框 Search ---------- */
.apple-search {
  display: flex;
  align-items: center;
  height: var(--input-height);
  padding: 0 var(--spacing-md);
  background: var(--input-bg);
  border-radius: var(--input-radius);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
}

.apple-search-icon {
  color: var(--color-text-tertiary);
  font-size: 14px;
  margin-right: var(--spacing-xs);
}

.apple-search input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  background: transparent;
  border: none;
  outline: none;
}

.apple-search input::placeholder {
  color: var(--input-placeholder);
}
