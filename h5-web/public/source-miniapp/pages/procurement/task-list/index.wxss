@import '/styles/page-utils.wxss';
@import '/styles/order-card.wxss';

/* =====================================================
 * 采购任务列表页 — 物料级别卡片
 * 顶部搜索+扫码+筛选器统一使用 sticky-search-bar 通用组件
 * 卡片样式统一走全局 styles/order-card.wxss（.task-card / .card-header
 *   / .card-body / .card-footer / .filter-pill / .btn-claim / .btn-detail 等）
 * ===================================================== */

.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x) calc(var(--spacing-2xl) + env(safe-area-inset-bottom));
}

/* 空状态图标 — line-icon 需要额外居中（页面级修正，未抽入全局） */
.empty-icon.line-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
}
