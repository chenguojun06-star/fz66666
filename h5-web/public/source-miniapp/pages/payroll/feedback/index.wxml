<view class="page">
  <view class="header">
    <text class="title">工资结算反馈</text>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:if="{{!loading && settlements.length === 0}}" class="empty">
    <text class="empty-icon"><text class="line-icon line-icon--lg icon-clipboard"></text></text>
    <text class="empty-text">暂无已发放的工资结算单</text>
  </view>

  <view wx:for="{{settlements}}" wx:key="id" class="settlement-card" bindtap="onSettlementTap" data-id="{{item.id}}" data-no="{{item.settlementNo}}">
    <view class="card-header">
      <text class="settlement-no">{{item.settlementNo || item.id}}</text>
      <view class="feedback-status {{item.feedbackStatus ? 'status-' + item.feedbackStatus : 'status-none'}}">
        <text wx:if="{{!item.feedbackStatus}}">待反馈</text>
        <text wx:elif="{{item.feedbackStatus === 'PENDING'}}">已反馈·待处理</text>
        <text wx:elif="{{item.feedbackStatus === 'RESOLVED'}}">已解决</text>
        <text wx:elif="{{item.feedbackStatus === 'REJECTED'}}">已驳回</text>
      </view>
    </view>
    <view class="card-body">
      <view class="card-info-row" wx:if="{{item.styleNo}}">
        <text class="card-info-label">款号</text>
        <text class="card-info-value">{{item.styleNo}}</text>
      </view>
      <view class="card-info-row">
        <text class="card-info-label">订单号</text>
        <text class="card-info-value">{{item.orderNo || '-'}}</text>
      </view>
      <view class="amount-row">
        <text class="amount-main">¥{{item.totalAmount || 0}}</text>
        <text class="amount-qty">{{item.totalQuantity || 0}}件</text>
      </view>
    </view>
    <view class="card-footer">
      <text class="time">{{item.createTimeText}}</text>
      <view wx:if="{{!item.feedbackStatus}}" class="feedback-action">
        <text>点击反馈</text>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </view>
    </view>
  </view>

  <view wx:if="{{showForm}}" class="modal-mask" bindtap="closeForm">
    <view class="modal-content" catchtap="">
      <view class="modal-drag-handle"></view>
      <view class="modal-title">提交工资结算反馈</view>

      <view class="form-group">
        <text class="form-label">结算单号</text>
        <input class="form-input form-input-readonly" value="{{currentSettlementNo}}" disabled="{{true}}" />
      </view>

      <view class="form-group">
        <text class="form-label">反馈类型</text>
        <view class="radio-group">
          <view class="radio-item {{feedbackType === 'CONFIRM' ? 'radio-item-active' : ''}}" bindtap="onFeedbackTypeChange" data-value="CONFIRM">
            <text>确认无误</text>
          </view>
          <view class="radio-item {{feedbackType === 'OBJECTION' ? 'radio-item-active' : ''}}" bindtap="onFeedbackTypeChange" data-value="OBJECTION">
            <text>提出异议</text>
          </view>
        </view>
      </view>

      <view wx:if="{{feedbackType === 'OBJECTION'}}" class="form-group">
        <text class="form-label">异议内容</text>
        <textarea class="form-textarea" placeholder="请描述您的问题，如：数量不对、金额有误等" value="{{feedbackContent}}" bindinput="onFeedbackContentInput" maxlength="500" />
      </view>

      <view class="form-actions">
        <view class="btn-cancel" hover-class="btn-hover" bindtap="closeForm">取消</view>
        <view class="btn-submit" hover-class="btn-hover" bindtap="submitFeedback">{{submitting ? '提交中...' : '提交'}}</view>
      </view>
    </view>
  </view>
</view>
