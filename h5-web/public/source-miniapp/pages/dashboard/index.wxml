<!-- 生产管理 · 美团风格订单卡片 -->
<view class="page">
  <!-- 吸顶区：搜索 + 扫码 + 筛选器（统一使用通用组件 sticky-search-bar） -->
  <sticky-search-bar
    placeholder="搜索订单号/款号/工厂"
    value="{{searchKey}}"
    show-scan="{{true}}"
    show-filter="{{true}}"
    bind:input="onSearchInput"
    bind:scan="onScanTap"
  >
    <view slot="filter">
      <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="filter-pill {{activeFilter === item.key ? 'filter-pill--on' : ''}} {{item.key === 'in_production' ? 'filter-pill--prod' : ''}} {{item.key === 'completed' ? 'filter-pill--done' : ''}} {{item.key === 'overdue' ? 'filter-pill--danger' : ''}}"
              wx:for="{{statFilters}}" wx:key="key"
              data-key="{{item.key}}" bindtap="onStatTap">
          <text class="filter-text">{{item.label}}</text>
          <text class="filter-num">{{statCounts[item.key] || 0}}</text>
        </view>
      </scroll-view>
    </view>
  </sticky-search-bar>

  <!-- ===== 订单列表 ===== -->
  <view class="order-list" wx:if="{{orders.list.length > 0}}">
    <view class="order-card {{item.expanded ? 'order-card--open' : ''}}"
          wx:for="{{orders.list}}" wx:key="id">

      <!-- 主行：封面图 + 基本信息 -->
      <view class="order-main" data-index="{{index}}" bindtap="onCardToggle">
        <view class="order-cover" catchtap="onCoverPreview" data-url="{{item.styleCoverUrl}}">
          <image wx:if="{{item.styleCoverUrl}}" class="cover-pic" src="{{item.styleCoverUrl}}" mode="aspectFill" lazy-load />
          <view wx:else class="cover-placeholder">
            <view class="cover-ph-text"><view class="line-icon line-icon--xl icon-package"></view></view>
          </view>
        </view>

        <view class="order-info">
          <!-- 行1：订单号 + 急标签 + 状态标签 -->
          <view class="info-line1">
            <text class="order-no">{{item.orderNo}}</text>
            <view class="info-badges">
              <text wx:if="{{item.isUrgent}}" class="urgent-badge">急</text>
              <text wx:if="{{item.statusText}}" class="status-badge status-badge--{{item.statusClass}}">{{item.statusText}}</text>
            </view>
          </view>
          <!-- 行2：款名 -->
          <view class="info-style">{{item.styleName || item.styleNo || '暂无款名'}}</view>
          <!-- 行3：客户名 -->
          <view class="info-customer" wx:if="{{item.customerName}}">{{item.customerName}}</view>
          <!-- 行4：工厂名 -->
          <view class="info-factory" wx:if="{{item.factoryName}}">{{item.factoryName}}</view>
        </view>
      </view>

      <!-- 进度行：数量·交期 + 进度条 + 百分比 + 剩余天数（同一行） -->
      <view class="info-progress">
        <view class="ip-left">
          <text class="ip-qty">{{item.cuttingQty || item.totalQuantity || item.orderQuantity || 0}}件</text>
          <text class="ip-dot">·</text>
          <text class="ip-delivery" wx:if="{{item.deliveryDateStr}}">交期 {{item.deliveryDateStr}}</text>
        </view>
        <view class="ip-bar">
          <view class="ip-fill {{item.remainDaysClass === 'days-overdue' ? 'ip-fill--overdue' : ''}} {{item.isClosed ? 'ip-fill--done' : ''}}" style="width:{{item.calculatedProgress > 100 ? 100 : item.calculatedProgress}}%"></view>
        </view>
        <text class="ip-pct">{{item.calculatedProgress || 0}}%</text>
        <text class="ip-remain {{item.remainDaysClass}}" wx:if="{{item.remainDaysText}}">{{item.remainDaysText}}</text>
      </view>

      <!-- 展开按钮 -->
      <view class="order-expand-btn" data-index="{{index}}" catchtap="onCardToggle">
        <text class="expand-btn-text">{{item.expanded ? '收起菲号明细' : '展开菲号明细'}}</text>
        <view class="expand-btn-arrow {{item.expanded ? 'expand-btn-arrow--up' : ''}}"><view class="icon-chevron-down-sm"></view></view>
      </view>

      <!-- 展开区域 -->
      <view class="order-expand" wx:if="{{item.expanded}}">
        <!-- 菲号明细 -->
        <view class="detail-head">
          <text class="detail-title">菲号明细</text>
          <text class="detail-count">共{{item.colorGroups.length || 0}}菲</text>
        </view>
        <view class="detail-table">
          <view class="detail-row detail-row--head">
            <view class="detail-cell detail-cell--no">菲号</view>
            <view class="detail-cell detail-cell--proc">工序明细</view>
            <view class="detail-cell detail-cell--qty">数量</view>
          </view>
          <block wx:if="{{item.colorGroups && item.colorGroups.length > 0}}">
            <view class="detail-row" wx:for="{{item.colorGroups}}" wx:for-item="cg" wx:key="color">
              <view class="detail-cell detail-cell--no">{{cg.color}}</view>
              <view class="detail-cell detail-cell--proc">
                <text wx:for="{{item.processNodes}}" wx:for-item="pn" wx:for-index="pni" wx:key="name" class="proc-node">{{pn.name}}<text wx:if="{{pni < item.processNodes.length - 1}}" class="proc-sep">→</text></text>
              </view>
              <view class="detail-cell detail-cell--qty">{{cg.total}}件</view>
            </view>
          </block>
          <view class="detail-row detail-row--empty" wx:else>
            <view class="detail-cell detail-cell--empty">暂无菲号明细</view>
          </view>
        </view>

        <!-- 工序进度明细 -->
        <view class="expand-section" wx:if="{{item.processNodes && item.processNodes.length > 0}}">
          <text class="expand-title">工序进度</text>
          <view class="process-node" wx:for="{{item.processNodes}}" wx:for-item="node" wx:key="name">
            <view class="node-hd">
              <text class="node-name">{{node.name}}</text>
              <text class="node-pct {{node.percent >= 100 ? 'node-pct--done' : ''}}">{{node.percent}}%</text>
            </view>
            <view class="node-meta">
              <text class="node-qty" wx:if="{{node.qtyInfo}}">{{node.qtyInfo.completed}}/{{node.qtyInfo.total}}件</text>
              <text class="node-dot" wx:if="{{node.qtyInfo && node.bundleInfo}}">·</text>
              <text class="node-bundle-text" wx:if="{{node.bundleInfo}}">{{node.bundleInfo.scanned}}/{{node.bundleInfo.total}}菲</text>
            </view>
            <view class="node-bar-bg">
              <view class="node-bar-fill {{node.percent >= 100 ? 'node-bar-fill--done' : ''}}" style="width:{{node.percent > 100 ? 100 : node.percent}}%"></view>
            </view>
            <!-- 子工序列表 -->
            <view class="node-sub-procs" wx:if="{{node.children && node.children.length > 0}}">
              <view class="sub-proc-item" wx:for="{{node.children}}" wx:for-item="sp" wx:key="name">
                <text class="sp-name">{{sp.name}}</text>
                <text class="sp-price" wx:if="{{sp.unitPrice > 0}}">¥{{sp.unitPrice}}</text>
                <text class="sp-price sp-price--free" wx:else>待定价</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 颜色尺码矩阵 -->
        <view class="expand-section" wx:if="{{item.colorGroups && item.colorGroups.length > 0}}">
          <text class="expand-title">颜色尺码</text>
          <scroll-view scroll-x class="sku-scroll" enhanced show-scrollbar="{{false}}">
            <view class="sku-table">
              <view class="sku-row sku-row--head">
                <text class="sku-cell sku-cell--color">颜色</text>
                <text class="sku-cell" wx:for="{{item.allSizes}}" wx:for-item="sz" wx:key="*this">{{sz}}</text>
                <text class="sku-cell sku-cell--total">合计</text>
              </view>
              <view class="sku-row" wx:for="{{item.colorGroups}}" wx:for-item="cg" wx:key="color">
                <text class="sku-cell sku-cell--color">{{cg.color}}</text>
                <text class="sku-cell" wx:for="{{item.allSizes}}" wx:for-item="sz" wx:key="*this">{{cg.sizeMap[sz] || '-'}}</text>
                <text class="sku-cell sku-cell--total">{{cg.total}}</text>
              </view>
            </view>
          </scroll-view>
        </view>

        <!-- 快捷操作 -->
        <view class="expand-actions">
          <view class="act-btn act-btn--detail" catchtap="onViewDetail" data-order-no="{{item.orderNo}}" data-index="{{index}}">详情</view>
          <view class="act-btn act-btn--primary" catchtap="onGoProcurement" data-index="{{index}}">采购</view>
          <view class="act-btn act-btn--primary" catchtap="onViewCuttingBundles" data-order-no="{{item.orderNo}}">裁剪</view>
          <view class="act-btn act-btn--primary" catchtap="onEditProcess" data-order-id="{{item.id}}" data-order-no="{{item.orderNo}}" data-status="{{item.status}}" wx:if="{{item.status === 'production'}}">工序</view>
          <view class="act-btn act-btn--warn" catchtap="onTransferOrder" data-order-id="{{item.id}}" data-order-no="{{item.orderNo}}">转单</view>
          <view class="act-btn act-btn--remark" catchtap="onOpenRemark" data-index="{{index}}">备注</view>
          <view class="act-btn" catchtap="onCopyOrderNo" data-order-no="{{item.orderNo}}">复制单号</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-tip" wx:if="{{orders.loading}}">加载中…</view>
  <view class="load-tip load-tip--end" wx:if="{{!orders.loading && !orders.hasMore && orders.list.length > 0}}">— 没有更多了 —</view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && !orders.loading && orders.list.length === 0}}">
    <view class="empty-icon"><view class="line-icon line-icon--xl icon-clipboard"></view></view>
    <text class="empty-text">暂无订单数据</text>
  </view>

  <!-- 小云 AI 助手 -->
  <ai-assistant id="dashboardAiAssistant" notice-count="{{unreadNoticeCount}}" />
</view>
