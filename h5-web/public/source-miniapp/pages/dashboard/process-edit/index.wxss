@import '/styles/design-tokens.wxss';
@import '/styles/modal-form.wxss';

.page {
  padding: 0 var(--page-padding-x) 80px;
  background: var(--color-bg-page, #f5f5f5);
  min-height: 100vh;
}

/* ===== 订单信息条（一行：订单号+款号+状态） ===== */
.order-info-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border, #f0f0f0);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
}
.oib-no {
  font-size: var(--font-size-md-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.oib-style {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.order-status {
  font-size: var(--font-size-2xs);
  padding: 2px 10px;
  border-radius: var(--radius-full);
  margin-left: auto;
  font-weight: 500;
}
.order-status--production {
  color: var(--color-primary);
  background: var(--color-primary-bg);
}
.order-status--completed {
  color: var(--color-success);
  background: var(--color-success-bg);
}
.order-status--other {
  color: var(--color-text-tertiary);
  background: var(--color-bg-hover);
}

/* ===== 加载中 ===== */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  margin-top: 12px;
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

/* ===== 阶段分组 ===== */
.stage-group {
  margin: var(--card-gap-y) 0 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.stage-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px;
  background: transparent;
  border-bottom: 1px solid var(--color-border);
}
.stage-title-row {
  display: flex;
  align-items: center;
  gap: 8px;
}
.stage-name {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}
.stage-count {
  font-size: var(--font-size-2xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-page);
  padding: 1px 6px;
  border-radius: var(--radius-sm);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}
.stage-total {
  margin-left: auto;
  margin-right: 8px;
}
.stage-total-price {
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}
.stage-actions {
  display: flex;
  align-items: center;
}
.stage-add-icon {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: var(--font-size-lg);
}
.stage-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin: 4px 14px 10px;
  padding: 8px 0;
  border: 1px dashed var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}

/* ===== 工序行 ===== */
.process-item {
  padding: 6px 14px;
  border-top: 1px solid var(--color-border);
}
.process-item:first-of-type {
  border-top: none;
}
.process-item--editing {
  background: var(--color-primary-bg);
}
.process-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.process-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.process-name-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
.process-code {
  font-size: var(--font-size-xxs);
  color: var(--color-text-tertiary);
  background: var(--color-bg-page);
  padding: 1px 6px;
  border-radius: var(--radius-xs);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.process-modified-badge {
  font-size: var(--font-size-xxs);
  padding: 1px 6px;
  border-radius: var(--radius-xs);
  background: var(--color-warning-bg);
  color: var(--color-warning);
  font-weight: 500;
  flex-shrink: 0;
}
.process-name {
  font-size: var(--font-size-md-lg);
  color: var(--color-text-primary);
  font-weight: 500;
}
.process-meta-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 4px;
}
.process-machine {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.process-meta-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}
.process-diff-badge {
  font-size: var(--font-size-xxs);
  padding: 1px 4px;
  border-radius: var(--radius-xs);
  font-weight: 500;
}
.process-diff-badge--easy {
  color: var(--color-success);
  background: var(--color-success-bg);
}
.process-diff-badge--medium {
  color: var(--color-warning);
  background: var(--color-warning-bg);
}
.process-diff-badge--hard {
  color: var(--color-danger);
  background: var(--color-danger-bg);
}
.price-value {
  font-size: var(--font-size-md-lg);
  color: var(--color-text-primary);
  font-weight: 600;
  margin-left: auto;
  font-variant-numeric: tabular-nums;
}
.price-value--empty {
  color: var(--color-text-tertiary);
  font-weight: 400;
  font-size: var(--font-size-sm);
}
.process-actions {
  display: flex;
  gap: 6px;
}
.pact-btn {
  font-size: var(--font-size-lg);
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
}
.pact-btn--edit {
  color: var(--color-text-tertiary);
}
.pact-btn--move {
  color: var(--color-text-tertiary);
}
.pact-btn--del {
  color: var(--color-text-tertiary);
}

/* ===== 编辑表单 ===== */
.process-edit-form {
  padding: 4px 0;
}
.pef-row {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}
.pef-label {
  width: 80px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}
.pef-input {
  flex: 1;
  height: 36px;
  border: 1px solid var(--input-border);
  border-radius: var(--radius-sm);
  padding: 0 10px;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--input-bg);
  box-sizing: border-box;
}
.pef-difficulty {
  display: flex;
  gap: 8px;
}
.diff-opt {
  font-size: var(--font-size-sm);
  padding: 3px 12px;
  border: 1px solid var(--input-border);
  border-radius: var(--radius-xs);
  color: var(--color-text-secondary);
  background: var(--input-bg);
}
.diff-opt--active {
  color: var(--color-warning);
  border-color: var(--color-warning);
  background: var(--color-warning-bg);
}
.pef-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  margin-top: 4px;
}
.pef-btn {
  font-size: var(--font-size-md);
  padding: 0 20px;
  height: 36px;
  line-height: 36px;
  border-radius: var(--radius-md);
}
.pef-btn--cancel {
  color: var(--color-text-secondary);
  background: var(--color-bg-page);
}
.pef-btn--save {
  color: var(--color-text-white);
  background: var(--color-primary);
}

/* ===== 空阶段 ===== */
.empty-stage {
  padding: 16px;
  text-align: center;
}
.empty-stage-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom, 0px));
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 1px solid var(--color-border);
  z-index: 100;
}
.bottom-bar-info {
  flex: 1;
}
.bbi-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}
.bbi-modified {
  font-size: var(--font-size-sm);
  color: var(--color-warning);
  font-weight: 500;
}
.bottom-bar-actions {
  display: flex;
  gap: 8px;
}
.bba-btn {
  font-size: var(--font-size-sm);
  padding: 0 16px;
  height: 36px;
  line-height: 36px;
  border-radius: var(--radius-sm);
  font-weight: 500;
  text-align: center;
}
.bba-btn--reset {
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
}
.bba-btn--save {
  color: var(--color-text-white);
  background: var(--color-primary);
  font-weight: 600;
}

/* ===== 不可编辑提示 ===== */
.readonly-notice {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12px 16px;
  background: var(--color-warning-bg);
  text-align: center;
  z-index: 100;
}
.readonly-notice-text {
  font-size: var(--font-size-sm);
  color: var(--color-warning);
}

/* ===== 添加工序内联表单 ===== */
.inline-form-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 16px;
  margin: 12px 0;
  box-shadow: var(--shadow-sm);
}
.inline-form-title {
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
}

/* ===== 添加弹窗 footer ===== */
.mf-footer {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  padding: 12px 16px;
}
.mf-btn {
  font-size: var(--font-size-md-lg);
  padding: 0 24px;
  height: 44px;
  line-height: 44px;
  border-radius: var(--radius-md);
  font-weight: 500;
  text-align: center;
}
.mf-btn--cancel {
  color: var(--color-text-secondary);
  background: var(--color-bg-page);
}
.mf-btn--confirm {
  color: var(--color-text-white);
  background: var(--color-primary);
}
.mf-input--picker {
  color: var(--color-primary);
  font-size: var(--font-size-sm);
  margin-bottom: 6px;
}
.mf-input--manual {
  font-size: var(--font-size-sm);
}
