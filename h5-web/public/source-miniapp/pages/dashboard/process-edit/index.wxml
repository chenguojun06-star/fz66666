<!-- 工序编辑 · 单行紧凑布局 + 完整优化 -->
<view class="page {{keyboardOpen ? 'page--keyboard' : ''}}">
  <view class="order-info-bar" wx:if="{{orderNo}}">
    <view class="oib-left">
      <text class="oib-no">{{orderNo}}</text>
      <text class="oib-style" wx:if="{{styleNo}}">{{styleNo}}</text>
    </view>
    <text class="order-status {{statusClass}}">{{statusCn}}</text>
  </view>

  <view class="loading-box" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载工序数据...</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 空订单引导 -->
    <view class="empty-guide" wx:if="{{totalProcessCount === 0 && editable && !addStageId}}">
      <view class="eg-icon">📋</view>
      <text class="eg-title">该订单暂无工序</text>
      <text class="eg-desc">点击下方"添加"开始配置生产工序</text>
    </view>

    <view class="stage-group" wx:for="{{stages}}" wx:key="id">
      <view class="stage-header">
        <view class="stage-title-row">
          <text class="stage-name">{{item.name}}</text>
          <text class="stage-count">{{item.processes.length}}道</text>
          <text class="stage-subtotal" wx:if="{{item.processes.length > 0}}">¥{{item.subtotal}}</text>
        </view>
        <view class="stage-actions" wx:if="{{editable}}">
          <view class="stage-add-btn" catchtap="onToggleAddForm" data-stage-id="{{item.id}}" data-stage-name="{{item.name}}">+ 添加</view>
        </view>
      </view>

      <!-- 内联添加表单 -->
      <view class="add-form-container" wx:if="{{addStageId === item.id && editable}}">
        <view class="add-form">
          <view class="af-row">
            <picker mode="selector" range="{{processDict}}" range-key="dictLabel" bindchange="onDictPickProcess">
              <view class="af-picker">{{addForm.processName || '选择'}}</view>
            </picker>
            <input class="af-input af-input--name" value="{{addForm.processName}}" bindinput="onAddFormInput" data-field="processName" placeholder="工序名称" />
            <input class="af-input af-input--price" type="digit" value="{{addForm.price}}" bindinput="onAddFormInput" data-field="price" placeholder="¥" />
            <input class="af-input af-input--time" type="number" value="{{addForm.standardTime}}" bindinput="onAddFormInput" data-field="standardTime" placeholder="秒" />
          </view>
          <view class="af-row">
            <input class="af-input" value="{{addForm.machineType}}" bindinput="onAddFormInput" data-field="machineType" placeholder="机器" />
            <input class="af-input af-input--desc" value="{{addForm.description}}" bindinput="onAddFormInput" data-field="description" placeholder="描述" />
            <view class="af-difficulty">
              <view class="diff-opt {{addForm.difficulty === '易' ? 'diff-opt--active' : ''}}" catchtap="onAddSetDifficulty" data-val="易">易</view>
              <view class="diff-opt {{addForm.difficulty === '中' ? 'diff-opt--active' : ''}}" catchtap="onAddSetDifficulty" data-val="中">中</view>
              <view class="diff-opt {{addForm.difficulty === '难' ? 'diff-opt--active' : ''}}" catchtap="onAddSetDifficulty" data-val="难">难</view>
            </view>
          </view>
          <view class="af-actions">
            <view class="af-btn af-btn--cancel" catchtap="onCancelAdd">取消</view>
            <view class="af-btn af-btn--continue" catchtap="onConfirmAddContinue">添加并继续</view>
            <view class="af-btn af-btn--confirm" catchtap="onConfirmAdd">添加</view>
          </view>
        </view>
      </view>

      <view class="process-item {{child._modified ? 'process-item--modified' : ''}}" wx:for="{{item.processes}}" wx:for-item="child" wx:key="id">
        <!-- 展示行 -->
        <view class="process-row" wx:if="{{processEditId !== child.id}}">
          <view class="pr-left">
            <text class="pr-code">{{child.processCodeText}}</text>
            <text class="pr-name">{{child.processName}}</text>
            <text class="pr-tag" wx:if="{{child.machineType}}">{{child.machineType}}</text>
            <text class="pr-tag pr-tag--diff" wx:if="{{child.difficulty}}">{{child.difficulty}}</text>
            <text class="pr-tag" wx:if="{{child.standardTime}}">{{child.standardTime}}秒</text>
            <text class="pr-tag" wx:if="{{child.description}}">{{child.description}}</text>
            <text class="pr-modified-flag" wx:if="{{child._modified}}">已改</text>
          </view>
          <text class="pr-price" wx:if="{{child.price}}">¥{{child.price}}</text>
          <text class="pr-price pr-price--empty" wx:else>--</text>
          <view class="pr-actions" wx:if="{{editable}}">
            <view class="pr-btn pr-btn--up" catchtap="onMoveUp" data-id="{{child.id}}" data-stage-id="{{item.id}}">↑</view>
            <view class="pr-btn pr-btn--down" catchtap="onMoveDown" data-id="{{child.id}}" data-stage-id="{{item.id}}">↓</view>
            <view class="pr-btn pr-btn--edit" catchtap="onEditProcess" data-id="{{child.id}}" data-stage-id="{{item.id}}">编</view>
            <view class="pr-btn pr-btn--del" catchtap="onDeleteProcess" data-id="{{child.id}}" data-stage-id="{{item.id}}">删</view>
          </view>
        </view>

        <!-- 内联编辑 -->
        <view class="edit-row" wx:if="{{processEditId === child.id}}">
          <input class="er-input er-input--name" value="{{editForm.processName}}" bindinput="onEditFormInput" data-field="processName" placeholder="工序名称" />
          <input class="er-input er-input--price" type="digit" value="{{editForm.price}}" bindinput="onEditFormInput" data-field="price" placeholder="¥" />
          <input class="er-input er-input--time" type="number" value="{{editForm.standardTime}}" bindinput="onEditFormInput" data-field="standardTime" placeholder="秒" />
          <view class="er-difficulty">
            <view class="diff-opt {{editForm.difficulty === '易' ? 'diff-opt--active' : ''}}" catchtap="onSetDifficulty" data-val="易">易</view>
            <view class="diff-opt {{editForm.difficulty === '中' ? 'diff-opt--active' : ''}}" catchtap="onSetDifficulty" data-val="中">中</view>
            <view class="diff-opt {{editForm.difficulty === '难' ? 'diff-opt--active' : ''}}" catchtap="onSetDifficulty" data-val="难">难</view>
          </view>
          <view class="er-actions">
            <view class="er-btn er-btn--cancel" catchtap="onCancelEdit">✕</view>
            <view class="er-btn er-btn--save" catchtap="onSaveEdit">✓</view>
          </view>
        </view>
        <view class="edit-row edit-row--second" wx:if="{{processEditId === child.id}}">
          <input class="er-input" value="{{editForm.machineType}}" bindinput="onEditFormInput" data-field="machineType" placeholder="机器" />
          <input class="er-input er-input--desc" value="{{editForm.description}}" bindinput="onEditFormInput" data-field="description" placeholder="描述" />
        </view>
      </view>

      <view class="empty-stage" wx:if="{{item.processes.length === 0 && addStageId !== item.id}}">
        <text class="empty-stage-text">暂无工序</text>
      </view>
    </view>
  </block>

  <!-- 底部固定栏：合计 + 保存 -->
  <view class="bottom-bar" wx:if="{{!loading && editable && !keyboardOpen}}">
    <view class="bottom-bar-info">
      <text class="bbi-stats">共 {{totalProcessCount}} 道 · 合计 ¥{{totalPrice}}</text>
      <text class="bbi-text" wx:if="{{hasChanges}}"> · 已修改</text>
    </view>
    <view class="bottom-bar-actions">
      <view class="bba-btn bba-btn--reset" wx:if="{{hasChanges}}" bindtap="onResetChanges">重置</view>
      <view class="bba-btn bba-btn--save" bindtap="onSaveAll">{{hasChanges ? '保存全部' : '刷新'}}</view>
    </view>
  </view>

  <!-- 键盘弹起时的迷你保存栏 -->
  <view class="mini-save-bar" wx:if="{{!loading && editable && keyboardOpen && hasChanges}}">
    <view class="mss-btn" bindtap="onSaveAll">保存</view>
  </view>

  <view class="readonly-notice" wx:if="{{!loading && !editable}}">
    <text class="readonly-notice-text">当前订单状态不可编辑工序</text>
  </view>
</view>