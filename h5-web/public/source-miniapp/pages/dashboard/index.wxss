/* 进度看板 · 对齐 WeUI 设计规范 */
@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  padding: 16px 16px calc(env(safe-area-inset-bottom) + 16px);
  background: var(--color-bg-page);
  box-sizing: border-box;
}

/* ===== 概览头部白底卡片 ===== */
.overview-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: var(--shadow-sm);
}

/* ===== 日期栏 ===== */
.date-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.date-text {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.scan-badge {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: rgba(0, 0, 0, 0.04);
  padding: 4px 12px;
  border-radius: var(--radius-full);
}

/* ===== 2×2 卡片网格 ===== */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

/* ===== 摘要卡片 ===== */
.summary-card {
  width: calc(50% - 6px);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 12px;
  box-sizing: border-box;
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
}

/* 卡片左侧色条装饰 */
.summary-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12px;
  bottom: 12px;
  width: 3px;
  border-radius: 2px;
}
.card--purple::before { background: var(--color-purple); }
.card--blue::before   { background: var(--color-primary); }
.card--green::before  { background: var(--color-success); }
.card--orange::before { background: var(--color-warning); }

/* ===== 卡片头部 ===== */
.card-hd {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}
.card-icon {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg);
  margin-right: 8px;
  flex-shrink: 0;
}
.icon--purple { background: rgba(124, 92, 252, 0.1); }
.icon--blue   { background: rgba(59, 130, 246, 0.1); }
.icon--green  { background: rgba(34, 197, 94, 0.1); }
.icon--orange { background: rgba(245, 158, 11, 0.1); }

.card-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

/* ===== 指标体 ===== */
.card-bd {
  display: flex;
  align-items: flex-end;
  gap: 0;
}
.metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.metric-divider {
  width: 1px;
  height: 28px;
  background: rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}
.metric-val {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: var(--line-height-tight);
}
.metric-lbl {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4px;
}

/* 数值变体 */
.val--muted {
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
}
.val--danger {
  color: var(--color-error);
}

/* ===== 骨架屏 ===== */
.skeleton {
  animation: pulse 1.5s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%      { opacity: 0.4; }
}
.skel-line {
  background: rgba(0, 0, 0, 0.06);
  border-radius: var(--radius-sm);
}
.skel-title {
  width: 60%;
  height: 16px;
  margin-bottom: 16px;
}
.skel-num {
  width: 40%;
  height: 32px;
  margin-bottom: 8px;
}
.skel-label {
  width: 50%;
  height: 12px;
}

/* ===== 搜索栏 ===== */
.search-bar {
  margin: 16px 0 0;
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-full);
  padding: 8px 16px;
  box-shadow: var(--shadow-sm);
}
.search-icon { font-size: var(--font-size-md); margin-right: 8px; }
.search-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  height: 28px;
}
.search-clear {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  padding: 0 4px;
}

/* ===== 状态过滤条 ===== */
.stats-bar {
  display: flex;
  gap: 8px;
  margin: 16px 0 12px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.stats-bar::-webkit-scrollbar { display: none; }

.stat-pill {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6px 12px;
  border-radius: var(--radius-md);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  min-width: 56px;
}
.stat-pill--active {
  background: var(--color-primary);
  box-shadow: 0 2px 8px rgba(var(--color-primary-rgb), 0.25);
}
.stat-count {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: var(--line-height-tight);
}
.stat-pill--active .stat-count { color: var(--color-text-white); }
.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 2px;
}
.stat-pill--active .stat-label { color: rgba(255, 255, 255, 0.85); }

/* 延期标签高亮 */
.stat-pill--overdue .stat-count { color: var(--color-danger); }
.stat-pill--overdue.stat-pill--active { background: var(--color-danger); box-shadow: 0 2px 8px rgba(239, 68, 68, 0.25); }
.stat-pill--overdue.stat-pill--active .stat-count { color: var(--color-text-white); }

/* 已完成标签高亮 */
.stat-pill--completed .stat-count { color: var(--color-success); }
.stat-pill--completed.stat-pill--active { background: var(--color-success); box-shadow: 0 2px 8px rgba(34, 197, 94, 0.25); }
.stat-pill--completed.stat-pill--active .stat-count { color: var(--color-text-white); }

/* ===== 订单卡片列表 ===== */
.order-list { margin-top: 4px; }

.order-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}
.order-card--overdue {
  border-left: 3px solid var(--color-danger);
}

/* — 数量概览行（折叠也可见） — */
.qty-row {
  display: flex;
  align-items: center;
  margin-top: 8px;
  padding: 8px 0;
  border-top: 1px solid var(--color-border-light);
}
.qty-item {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4px;
}
.qty-val {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.qty-lbl {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.qty-divider {
  width: 1px;
  height: 16px;
  background: var(--color-border-light);
}

/* — 头部：封面图 + 信息 — */
.order-header {
  display: flex;
  gap: 12px;
}
.cover-box {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-2xl);
  color: var(--color-text-tertiary);
  background: var(--color-bg-gray);
}
.header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 4px;
}
.header-top {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}
.order-no {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.tag {
  font-size: var(--font-size-xs);
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  font-weight: var(--font-weight-medium);
  line-height: var(--line-height-relaxed);
  display: inline-block;
}
.tag-urgent { background: rgba(250, 81, 81, 0.1); color: var(--color-error); }
.tag-normal { background: rgba(120, 120, 128, 0.12); color: var(--color-text-tertiary); }

.header-meta {
  display: flex;
  align-items: center;
  gap: 8px;
}
.style-no {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.meta-factory {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.header-delivery {
  display: flex;
  align-items: center;
  gap: 6px;
}
.delivery-date {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.remain-days {
  font-size: var(--font-size-xs);
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  font-weight: var(--font-weight-medium);
}
.days-safe    { background: rgba(34, 197, 94, 0.1); color: var(--color-success); }
.days-warn    { background: rgba(245, 158, 11, 0.1); color: var(--color-warning); }
.days-urgent  { background: rgba(239, 68, 68, 0.1); color: var(--color-danger); }
.days-overdue { background: rgba(239, 68, 68, 0.12); color: var(--color-danger); font-weight: var(--font-weight-semibold); }
.days-done    { background: rgba(34, 197, 94, 0.1); color: var(--color-success); }

/* — 进度条 + 箭头 — */
.progress-row {
  display: flex;
  align-items: center;
  margin-top: 8px;
  gap: 8px;
}
.progress-bar {
  flex: 1;
  height: 3px;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 2px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 2px;
  transition: width 0.3s;
}
.progress-fill--overdue {
  background: var(--color-danger);
}
.progress-pct {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  min-width: 36px;
  text-align: right;
}
.collapse-arrow {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  transition: transform 0.2s;
  margin-left: 2px;
}
.collapse-arrow--open {
  transform: rotate(180deg);
  color: var(--color-primary);
}

/* — 展开区域 — */
.order-body {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border-light);
}

/* 数量汇总 */
.body-stats {
  display: flex;
  text-align: center;
  margin-bottom: 16px;
}
.body-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.body-stat-val {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}
.body-stat-lbl {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

/* 工序进度明细 */
.process-list {
  margin-bottom: 16px;
}
.process-item {
  margin-bottom: 10px;
}
.process-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4px;
}
.process-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}
.process-pct {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.process-bar {
  height: 3px;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 2px;
  overflow: hidden;
}
.process-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 2px;
  transition: width 0.3s;
}
.process-bar-fill--done {
  background: var(--color-success);
}
.process-bar-wrap {
  position: relative;
}
.bundle-stats {
  display: block;
  font-size: 10px;
  color: var(--color-text-tertiary);
  margin-bottom: 2px;
  line-height: 1;
}

/* 颜色尺码矩阵 */
.sku-section {
  margin-bottom: 12px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.sku-table {
  min-width: 100%;
}
.sku-row {
  display: flex;
  border-bottom: 1px solid var(--color-border-light);
}
.sku-row--head {
  background: var(--color-bg-light);
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  font-weight: var(--font-weight-medium);
}
.sku-cell {
  flex: 1;
  min-width: 40px;
  padding: 8px 4px;
  font-size: var(--font-size-xs);
  text-align: center;
  color: var(--color-text-primary);
}
.sku-cell--color {
  flex: none;
  width: 56px;
  text-align: left;
  padding-left: 8px;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.sku-cell--total {
  flex: none;
  width: 48px;
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}

/* ===== 卡片快捷操作 ===== */
.card-actions {
  display: flex;
  justify-content: flex-end;
  padding: 8px 0 0;
  border-top: 1px solid var(--color-border-light);
  margin-top: 8px;
}
.card-action-btn {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  padding: 6px 12px;
  border-radius: var(--radius-md);
  background: var(--color-bg-light);
}

/* ===== 加载更多 / 没有更多 ===== */
.loading-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.no-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.empty-icon {
  font-size: var(--font-size-6xl);
  margin-bottom: 12px;
}
.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-tertiary);
}
