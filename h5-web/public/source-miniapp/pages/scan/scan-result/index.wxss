
.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 8px var(--page-padding-x) calc(env(safe-area-inset-bottom) + 80px);
}

/* ============ 扫描成功状态卡片（对齐设计稿：白底 + 绿色圆圈 + 边框） ============ */

.success-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-2xl);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}

.success-icon-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-success);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.success-check {
  width: 28px;
  height: 28px;
  background-size: 28px 28px;
}

.success-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.success-title {
  font-size: var(--font-size-lg-xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.success-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.success-date {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
}

.success-date-label {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
}

.success-date-value {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

/* ============ 分区组（对齐设计稿：bg-200 头 + 白底内容 + 字段分隔线） ============ */

.group-section {
  overflow: hidden;
  border-radius: var(--radius-2xl);
  border: 1rpx solid var(--color-border);
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

.group-header {
  padding: 20rpx 32rpx;
  background: var(--color-bg-page);
}

.group-header-title {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.group-body {
  padding: 0;
}

/* ============ 分区字段行（对齐设计稿：label 左 + value 右 + 分隔线） ============ */

.group-field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}
.group-field-row:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border);
}
.group-field-row--block {
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

.group-field-label {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  white-space: nowrap;
  flex-shrink: 0;
}

.group-field-value {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  text-align: right;
  word-break: break-all;
}
.group-field-value--bold {
  font-weight: var(--font-weight-semibold);
  font-variant-numeric: tabular-nums;
}
.group-field-value--block {
  font-size: var(--font-size-sm);
  font-weight: 400;
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
  text-align: left;
}

/* ============ 款式头部（对齐设计稿：缩略图 + 品名 + 标签） ============ */

.style-body {
  padding: 32rpx;
}
.style-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.style-thumb {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-primary-bg);
  border: 1rpx solid var(--color-primary-bg-dark);
}
.style-header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.style-header-name {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.style-header-sub {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.style-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}
.style-tag {
  display: inline-flex;
  align-items: center;
  font-size: var(--font-size-2xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
  white-space: nowrap;
}
.style-tag--brand {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

/* ============ AI 智能提示 ============ */

.insight-card {
  display: flex;
  align-items: flex-start;
  background: var(--color-primary-bg);
  border: 1rpx solid var(--color-primary-bg-dark);
  border-radius: var(--radius-2xl);
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
}
.insight-icon {
  font-size: var(--font-size-lg-xl);
  margin-right: 12rpx;
  flex-shrink: 0;
}
.insight-text {
  flex: 1;
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
}

/* ============ 菲号工序进度 ============ */

.stage-hint-item {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 40rpx;
  padding: 12rpx 32rpx;
}
.stage-hint-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border);
}

/* ============ 生产提示区域 ============ */

.hint-value-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.hint-badge {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 16rpx;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-xs);
}

.hint-badge--low {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.hint-badge--medium {
  background: var(--color-warning);
  color: var(--color-text-white);
}

.hint-badge--high {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.hint-badge--critical {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

.hint-score {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

/* ============ 选择工序（对齐设计稿：方框 checkbox + 价格 + 汇总条） ============ */

.process-scroll {
  padding: 0;
}

.process-chip {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
}
.process-chip:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border);
}

.process-chip-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.process-checkbox {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-xs);
  border: 4rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.15s;
}
.process-checkbox--checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.process-check {
  width: 16px;
  height: 16px;
  background-size: 16px 16px;
}

.chip-label {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.process-chip.active .chip-label {
  color: var(--color-text-primary);
}

.chip-price {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.process-chip.active .chip-price {
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
}

/* ============ 汇总条（对齐设计稿：brand-50 底 + border-top） ============ */

.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--color-primary-bg);
  border-top: 1rpx solid var(--color-primary-bg-dark);
}
.summary-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.summary-amount {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  font-variant-numeric: tabular-nums;
}

/* ============ 仓库选择 ============ */

.input-box {
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.warehouse-chip {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
}
.warehouse-chip--active {
  background: var(--color-primary-bg);
  border-color: var(--color-border);
  color: var(--color-primary);
  font-weight: 600;
}
.warehouse-chip--clear {
  color: var(--color-text-secondary);
}
.warehouse-chip--disabled {
  opacity: 0.35;
}
.warehouse-chip-hover {
  opacity: 0.7;
}

.warehouse-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 32rpx;
}

.warehouse-name {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.warehouse-name-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-right: 8rpx;
}

.warehouse-name-value {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-text-primary);
}
