/* ================ 大货扫码结果页 - 苹果风格（iOS Grouped List） ================ */

page {
  background: #f2f2f7;
}

.container {
  min-height: 100vh;
  background: #f2f2f7;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 140rpx);
}

/* ================ 顶部状态卡（苹果风格大白卡） ================ */
.status-card {
  display: flex;
  align-items: center;
  margin: 24rpx 24rpx 0;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.status-card__icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #34c759;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}
.status-card__check {
  width: 22rpx;
  height: 12rpx;
  border-left: 5rpx solid #fff;
  border-bottom: 5rpx solid #fff;
  transform: rotate(-45deg);
  margin-top: -6rpx;
}
.status-card__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.status-card__title {
  font-size: 24rpx;
  color: #8e8e93;
  line-height: 1.2;
  letter-spacing: 1rpx;
}
.status-card__subtitle {
  font-size: 38rpx;
  font-weight: 600;
  color: #1c1c1e;
  line-height: 1.3;
  letter-spacing: 1rpx;
  word-break: break-all;
}
.status-card__delivery {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 18rpx;
  background: #fff3e0;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.status-card__deliveryLabel {
  font-size: 20rpx;
  color: #fb923c;
  line-height: 1;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}
.status-card__deliveryValue {
  font-size: 26rpx;
  font-weight: 600;
  color: #ea580c;
  line-height: 1.2;
  font-variant-numeric: tabular-nums;
}

/* ================ 分组列表（iOS Grouped Table View） ================ */
.group {
  margin: 32rpx 24rpx 0;
}
.group__header {
  font-size: 24rpx;
  color: #6d6d72;
  padding: 0 12rpx 12rpx;
  letter-spacing: 0.5rpx;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}
.group__header--withHint {
  justify-content: space-between;
}
.group__hint {
  font-size: 22rpx;
  color: #8e8e93;
  font-weight: 400;
}
.group__body {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.group__footer {
  font-size: 22rpx;
  color: #8e8e93;
  padding: 12rpx 12rpx 0;
  line-height: 1.5;
}

/* ================ Cell 单元格 ================ */
.cell {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  min-height: 88rpx;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.cell-hover {
  background: #f2f2f7;
}
.cell-divider {
  height: 1rpx;
  background: #e5e5ea;
  margin-left: 24rpx;
}
.cell--column {
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}
.cell--media {
  align-items: center;
  gap: 20rpx;
}
.cell--toggle {
  cursor: pointer;
  transition: background-color 0.12s ease;
}
.cell--selected {
  background: #f0f7ff;
}
.cell--summary {
  background: #fafafa;
}
.cell--input {
  padding: 16rpx 24rpx;
}

.cell__label {
  font-size: 30rpx;
  color: #1c1c1e;
  flex-shrink: 0;
  min-width: 140rpx;
  line-height: 1.4;
}
.cell__value {
  flex: 1;
  font-size: 30rpx;
  color: #1c1c1e;
  text-align: right;
  word-break: break-all;
  line-height: 1.4;
  font-variant-numeric: tabular-nums;
}
.cell__value--bold {
  font-weight: 600;
  color: #000;
}
.cell__value--qty {
  color: #007aff;
  font-weight: 600;
}
.cell__value--accent {
  color: #007aff;
  font-weight: 500;
}
.cell__value--desc {
  text-align: left;
  color: #3c3c43;
  font-size: 28rpx;
  line-height: 1.5;
}
.cell__value--insight {
  text-align: left;
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.5;
}
.cell__value--flex {
  flex: 1;
  text-align: left;
  font-weight: 500;
}
.cell__price {
  font-size: 26rpx;
  color: #8e8e93;
  font-weight: 400;
  margin-left: 12rpx;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.cell--selected .cell__price {
  color: #007aff;
  font-weight: 600;
}
.cell--selected .cell__value {
  color: #007aff;
  font-weight: 600;
}

/* media cell 子元素 */
.cell__cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: #f2f2f7;
  flex-shrink: 0;
  overflow: hidden;
}
.cell__mediaBody {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.cell__styleNo {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1c1e;
  line-height: 1.3;
  letter-spacing: 0.5rpx;
}
.cell__styleName {
  font-size: 24rpx;
  color: #8e8e93;
  line-height: 1.3;
}
.cell__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 4rpx;
}
.tag {
  font-size: 22rpx;
  color: #6d6d72;
  background: #f2f2f7;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

/* column cell 子元素 */
.cell__columnBody {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.cell__hint {
  font-size: 22rpx;
  color: #8e8e93;
  line-height: 1.4;
}
.cell__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  width: 100%;
}
.chip {
  font-size: 24rpx;
  color: #1c1c1e;
  background: #f2f2f7;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  line-height: 1.4;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
}
.chip--on {
  background: #007aff;
  color: #fff;
  font-weight: 500;
}
.chip--clear {
  color: #6d6d72;
}
.chip--disabled {
  opacity: 0.4;
}
.chip-hover {
  opacity: 0.6;
}

/* toggle 圆形 checkbox */
.cell__check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d1d6;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
  background: #fff;
  transition: background-color 0.15s ease, border-color 0.15s ease;
}
.cell__check--on {
  background: #007aff;
  border-color: #007aff;
}
.cell__check--on::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: translate(-50%, -65%) rotate(-45deg);
}

/* input cell */
.cell__input {
  width: 100%;
  height: 64rpx;
  font-size: 28rpx;
  color: #1c1c1e;
  background: transparent;
}

/* ================ 难度徽章 ================ */
.cell__accessory {
  flex-shrink: 0;
  margin-left: 12rpx;
}
.badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-weight: 500;
}
.badge__text {
  font-size: 26rpx;
  line-height: 1.2;
}
.badge__score {
  font-size: 20rpx;
  opacity: 0.8;
  line-height: 1.2;
}
.badge--critical {
  background: #fff2f2;
  color: #c92a2a;
}
.badge--high {
  background: #fff4e6;
  color: #d9480f;
}
.badge--medium {
  background: #fff9db;
  color: #a06a09;
}
.badge--low {
  background: #ebfbef;
  color: #1a7a37;
}

/* ================ 工序滚动区 ================ */
.process-scroll {
  padding: 0;
}

/* ================ 底部固定操作栏（iOS 风格） ================ */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(env(safe-area-inset-bottom) + 16rpx);
  background: rgba(255,255,255,0.92);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 1rpx solid rgba(0,0,0,0.08);
  z-index: 100;
}
.action-bar__btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  -webkit-tap-highlight-color: transparent;
  touch-action: manipulation;
  transition: opacity 0.12s ease, transform 0.12s ease;
}
.action-bar__btn--secondary {
  background: #e5e5ea;
  color: #1c1c1e;
}
.action-bar__btn--primary {
  background: #007aff;
  color: #fff;
}
.action-bar__btn--disabled {
  opacity: 0.4;
}
.btn-hover {
  opacity: 0.7;
  transform: scale(0.97);
}

/* ================ 尊重用户减少动画偏好 ================ */
@media (prefers-reduced-motion: reduce) {
  .cell--toggle,
  .cell__check,
  .action-bar__btn,
  .btn-hover {
    transition: none !important;
    animation: none !important;
    transform: none !important;
  }
}
