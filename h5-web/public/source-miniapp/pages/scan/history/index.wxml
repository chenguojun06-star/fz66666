<view class="container">
  <!-- 时间模式切换 -->
  <view class="mode-tabs">
    <view class="mode-tab {{dateMode === 'month' ? 'mode-tab-active' : ''}}" bindtap="onModeChange" data-mode="month">按月</view>
    <view class="mode-tab {{dateMode === 'custom' ? 'mode-tab-active' : ''}}" bindtap="onModeChange" data-mode="custom">自定义</view>
  </view>

  <!-- 月份选择器（按月模式） -->
  <view class="month-selector" wx:if="{{dateMode === 'month'}}">
    <view class="month-arrow" hover-class="month-arrow-hover" hover-stay-time="100" bindtap="onPrevMonth"><view class="icon-arrow-left-sm"></view></view>
    <text class="month-text">{{displayMonth}}</text>
    <view class="month-arrow" hover-class="month-arrow-hover" hover-stay-time="100" bindtap="onNextMonth"><view class="icon-arrow-right-sm"></view></view>
  </view>

  <!-- 日期范围选择（自定义模式） -->
  <view class="filter-section" wx:if="{{dateMode === 'custom'}}">
    <view class="date-row">
      <view class="date-col">
        <text class="date-label">开始</text>
        <date-picker value="{{startDate}}" bindchange="onStartDateChange" />
      </view>
      <text class="date-separator">—</text>
      <view class="date-col">
        <text class="date-label">结束</text>
        <date-picker value="{{endDate}}" bindchange="onEndDateChange" />
      </view>
    </view>
  </view>

  <!-- 搜索（对齐设计稿：输入框上方、按钮下方） -->
  <view class="filter-section search-card">
    <view class="search-input-box">
      <view class="line-icon line-icon--sm icon-search search-icon"></view>
      <input class="search-input" placeholder="订单号 / 菲号 / 工序" value="{{searchKeyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="onSearch" />
    </view>
    <view class="search-btn-row">
      <view class="search-btn" bindtap="onSearch" hover-class="search-btn-hover" hover-stay-time="50">搜索</view>
      <view class="clear-btn" wx:if="{{searchKeyword}}" bindtap="onClearSearch" hover-class="clear-btn-hover" hover-stay-time="50">重置</view>
    </view>
  </view>

  <!-- 汇总卡片 -->
  <view class="summary-card">
    <view class="summary-item">
      <text class="summary-num">{{summary.totalQuantity || 0}}</text>
      <text class="summary-label">总数量</text>
    </view>
    <view class="summary-item">
      <text class="summary-num">{{summary.orderCount || 0}}</text>
      <text class="summary-label">订单数</text>
    </view>
    <view class="summary-item">
      <text class="summary-num">{{summary.recordCount || 0}}</text>
      <text class="summary-label">记录数</text>
      <text class="summary-sub-label">样衣{{summary.patternRecordCount || 0}}</text>
    </view>
    <view class="summary-item summary-hl {{showOnlyPayable ? 'summary-payable-active' : ''}}" bindtap="onTogglePayableFilter" hover-class="summary-item-hl-hover" hover-stay-time="50">
      <text class="summary-num">¥{{summary.totalWage || '0.00'}}</text>
      <text class="summary-label">工资</text>
    </view>
  </view>

  <!-- 记录卡片列表（对齐设计稿：卡片式，非表格） -->
  <view class="records-list" wx:if="{{displayRecords.length > 0}}">
    <view wx:for="{{displayRecords}}" wx:key="id" class="record-card">
      <view class="record-top">
        <view class="record-top-left">
          <text class="record-date">{{item.displayTime}}</text>
          <text class="record-order">{{item.displayOrderNo}}</text>
        </view>
        <text wx:if="{{item.lineAmount > 0}}" class="record-amount">¥{{item.displayLineAmount}}</text>
      </view>
      <view class="record-bottom">
        <text class="record-bundle">{{item.displayBundleNo}}</text>
        <text class="record-dot">·</text>
        <text class="record-process">{{item.displayProcess}}</text>
        <text class="record-qty">{{item.displayQuantity}}件</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state wx:if="{{displayRecords.length === 0 && !loading}}" icon="icon-clipboard" text="{{emptyText}}" hint="{{emptyHint}}"></empty-state>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-row">
    <text class="loading-text">加载中...</text>
  </view>
  <load-more hasMore="{{hasMore}}" loading="{{loading}}" count="{{displayRecords.length}}" bind:loadmore="onLoadMore"></load-more>
</view>
