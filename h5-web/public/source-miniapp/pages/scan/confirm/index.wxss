.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--page-padding-x) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 80px);
}

/* ===== 头部卡片 ===== */
.info-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  /* Apple: removed hard border, use shadow */
}
.card-header {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
}
.cover-wrap {
  width: 60px;
  height: 60px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}
.header-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
  min-width: 0;
}
.procurement-badge {
  display: inline-block;
  align-self: flex-start;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  margin-bottom: 2px;
}
.cutting-badge {
  display: inline-block;
  align-self: flex-start;
  background: var(--color-success);
  color: var(--color-text-white);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  margin-bottom: 2px;
}
.style-no {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.sub-info {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tag-process {
  display: inline-block;
  align-self: flex-start;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-size-xs);
  padding: 2px 7px;
  border-radius: var(--radius-xs);
}

/* ===== 矩阵区域 ===== */
.matrix-section {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1px solid var(--color-border-light);
}
.matrix-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-sm);
  display: block;
}

/* ===== 提示卡片 ===== */
.insight-card, .warn-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-xs);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  font-size: var(--font-size-sm);
  line-height: var(--line-height-normal);
}
.insight-card { background: var(--color-info-bg); color: var(--color-primary); }
.warn-card { background: var(--color-warning-bg); color: var(--color-warning); }
.insight-icon, .warn-icon { flex-shrink: 0; font-size: var(--font-size-md); }
.insight-text, .warn-text { flex: 1; }

/* ===== 区段卡片 ===== */
.section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  /* Apple: removed hard border, use shadow */
}
.section-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
  display: block;
}

/* ===== 工艺制单 ===== */
.description-content {
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
}
.description-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
  white-space: pre-wrap;
  word-break: break-all;
}

/* ===== 二次工艺（重点突出） ===== */
.process-highlight-card {
  border: 1px solid var(--color-warning);
  background: var(--color-bg-card);
}
.process-highlight-title {
  color: var(--color-warning);
}
.process-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}
.process-item {
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  border-left: 1px solid var(--color-warning);
}
.process-item-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  flex-wrap: wrap;
}
.process-type-tag {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-white);
  background: var(--color-warning);
  padding: 2px 8px;
  border-radius: var(--radius-xs);
}
.process-name {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  flex: 1;
}
.process-status {
  font-size: var(--font-size-xs);
  padding: 1px 6px;
  border-radius: var(--radius-xs);
}
.status-done {
  color: var(--color-success);
  background: var(--color-success-bg);
}
.status-active {
  color: var(--color-warning);
  background: var(--color-warning-bg);
}
.process-item-desc {
  margin-top: var(--spacing-xs);
  padding-top: var(--spacing-xs);
  border-top: 1px solid var(--color-border-light);
}
.process-desc-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
  white-space: pre-wrap;
}
.process-item-detail {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-xs);
}
.process-detail-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.process-item-remark {
  margin-top: var(--spacing-xs);
}
.process-remark-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-style: italic;
}

/* ===== 面辅料列表 ===== */
.material-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}
.material-item {
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
}
.mat-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--spacing-xs);
}
.mat-row + .mat-row {
  margin-top: var(--spacing-xs);
  padding-top: var(--spacing-xs);
  border-top: 1px solid var(--color-border-light);
}
.mat-tag {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: var(--color-info-bg);
  padding: 1px 5px;
  border-radius: var(--radius-xs);
}
.mat-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.mat-row-qty {
  gap: 0;
}
.qty-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  flex: 1;
}
.qty-item + .qty-item {
  border-left: 1px solid var(--color-border-light);
  padding-left: var(--spacing-md);
}
.qty-val {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.qty-val.arrived { color: var(--color-success); }
.qty-val.pending { color: var(--color-warning); }
.qty-lbl {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ===== 裁剪任务信息 ===== */
.cutting-info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}
.cutting-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}
.cutting-lbl {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  width: 40px;
  flex-shrink: 0;
}
.cutting-val {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}
.status-pending { color: var(--color-warning); }
.status-received { color: var(--color-success); }

.empty-cutting {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
}
.empty-cutting-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}
.empty-cutting-hint {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: var(--spacing-xs);
}

.tip-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-xs);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  background: var(--color-info-bg);
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  line-height: var(--line-height-normal);
}
.tip-icon { flex-shrink: 0; font-size: var(--font-size-md); }
.tip-text { flex: 1; }

/* ===== 汇总卡片 ===== */
.summary-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-md);
  /* Apple: removed hard border, use shadow */
}
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 2px 0;
}
.summary-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.summary-value {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.summary-value.amount { color: var(--color-primary); }
.arrived-text { color: var(--color-success); }
.pending-text { color: var(--color-warning); }

/* ===== SKU列表（非采购模式） ===== */
.sku-list {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.sku-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 6px 8px;
  border-radius: var(--radius-sm);
  background: var(--color-bg-gray);
}
.sku-info {
  display: flex;
  flex-direction: column;
  gap: 1px;
  flex: 1;
  min-width: 0;
}
.sku-label {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.sku-total {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.sku-qty-wrap {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}
.sku-qty-input {
  width: 45px;
  height: 28px;
  text-align: center;
  /* Apple: removed hard border, use shadow */
  border-radius: var(--radius-xs);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  background: var(--color-bg-card);
}
.sku-qty-readonly {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
  border-color: transparent;
}
.sku-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ===== AI 智能提示气泡 ===== */
.ai-bubble {
  margin: var(--spacing-md) 0;
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-lg);
  background: var(--color-info-bg);
  border-left: 1px solid var(--color-primary);
  position: relative;
}
.ai-bubble-high {
  background: var(--color-danger-bg);
  border-left-color: var(--color-danger);
}
.ai-bubble-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}
.ai-bubble-icon {
  font-size: var(--font-size-md);
  margin-right: var(--spacing-xs);
}
.ai-bubble-stage {
  font-size: var(--font-size-xs);
  color: var(--color-text-white);
  background: var(--color-primary);
  padding: 1px 6px;
  border-radius: var(--radius-sm);
  margin-right: var(--spacing-xs);
}
.ai-bubble-high .ai-bubble-stage {
  background: var(--color-danger);
}
.ai-bubble-close {
  position: absolute;
  top: var(--spacing-xs);
  right: var(--spacing-sm);
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  padding: 4px;
  line-height: 1;
}
.ai-bubble-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
  white-space: pre-wrap;
}
.ai-bubble-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-xs);
}
.ai-bubble-tag {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 1px 6px;
  border-radius: var(--radius-xs);
}
.ai-bubble-high .ai-bubble-tag {
  color: var(--color-danger);
  background: var(--color-danger-bg);
}
