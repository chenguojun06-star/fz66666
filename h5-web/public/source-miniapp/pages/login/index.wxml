<view class="login-page">
  <!-- Header: logo + title (outside card, per design) -->
  <view class="login-header">
    <view class="login-logo-wrap">
      <view class="login-logo">
        <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M28 8 C28 6.5, 26.5 5.5, 25 5.5 C23.5 5.5, 22.5 7, 22.5 9" stroke="var(--color-primary, #007aff)" stroke-width="2" stroke-linecap="round" fill="none"/>
          <path d="M22.5 9 L10 17.5 L46 17.5 L33.5 9" stroke="var(--color-primary-light, #2e8dff)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M12 17.5 L12 43 C12 44.1, 12.9 45, 14 45 L42 45 C43.1 45, 44 44.1, 44 43 L44 17.5" stroke="var(--color-primary, #007aff)" stroke-width="2" fill="var(--color-primary-lightest, #e8f2ff)" stroke-linejoin="round"/>
          <path d="M23 17.5 L28 23.5 L33 17.5" stroke="var(--color-primary, #007aff)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <path d="M16 29 L40 29" stroke="var(--color-primary-light, #9fcbff)" stroke-width="1.5" stroke-dasharray="3 3" stroke-linecap="round"/>
          <circle cx="28" cy="33" r="2" fill="var(--color-primary, #007aff)"/>
          <circle cx="28" cy="39" r="2" fill="var(--color-primary, #007aff)"/>
        </svg>
      </view>
    </view>
    <view class="login-title">{{i18nTexts.brand}}</view>
    <view class="login-subtitle">服装供应链管理系统</view>
  </view>

  <!-- Form card (only fields + button, per design) -->
  <view class="login-shell">
    <view class="login-panel">
      <view wx:if="{{wechatChecking}}" class="wechat-checking">
        <view class="wechat-checking-badge">微信</view>
        <view class="wechat-checking-title">{{i18nTexts.wechatChecking}}</view>
      </view>

      <block wx:if="{{!wechatChecking}}">
        <view wx:if="{{inviteBanner}}" class="invite-banner">
          <view class="line-icon icon-star invite-banner-icon"></view>
          <text class="invite-banner-text">{{inviteBanner}}</text>
        </view>

        <!-- Company search -->
        <view class="login-field">
          <text class="login-field-label">企业编号</text>
          <view class="login-input-wrap">
            <view class="login-input-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            </view>
            <input
              class="login-input"
              placeholder="{{tenantsLoading ? i18nTexts.loading : i18nTexts.companySearchPlaceholder}}"
              value="{{tenantSearchText}}"
              bindinput="onTenantSearch"
              bindfocus="onTenantSearchFocus"
              disabled="{{loading || tenantsLoading || inviteTenantFixed}}"
            />
            <view wx:if="{{selectedTenantName && !inviteTenantFixed}}" class="login-input-clear icon-close" bindtap="onClearTenant"></view>
          </view>
          <view wx:if="{{selectedTenantName}}" class="tenant-selected-tag">{{i18nTexts.companySelectedPrefix}}{{selectedTenantName}}</view>
          <view wx:if="{{showTenantResults && filteredTenants.length > 0}}" class="tenant-results">
            <view wx:for="{{filteredTenants}}" wx:key="id" class="tenant-result-item" data-index="{{index}}" bindtap="onTenantSelect" hover-class="tenant-result-item-hover" hover-stay-time="50">{{item.tenantName}}</view>
          </view>
          <view wx:if="{{showTenantResults && filteredTenants.length === 0 && tenantSearchText}}" class="tenant-results">
            <view class="tenant-result-empty">{{i18nTexts.companyNotFound}}</view>
          </view>
        </view>

        <!-- Username -->
        <view class="login-field">
          <text class="login-field-label">用户名</text>
          <view class="login-input-wrap">
            <view class="login-input-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </view>
            <input class="login-input" placeholder="{{i18nTexts.usernamePlaceholder}}" value="{{username}}" bindinput="onUsernameInput" disabled="{{loading}}" />
          </view>
        </view>

        <!-- Password -->
        <view class="login-field">
          <text class="login-field-label">密码</text>
          <view class="login-input-wrap">
            <view class="login-input-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </view>
            <input class="login-input" placeholder="{{i18nTexts.passwordPlaceholder}}" password="{{!showPassword}}" value="{{password}}" bindinput="onPasswordInput" disabled="{{loading}}" />
            <text class="login-input-eye" bindtap="togglePassword">{{showPassword ? '隐' : '显'}}</text>
          </view>
        </view>

        <view class="login-btn-wrap">
          <view class="login-btn {{loading || !selectedTenantId ? 'login-btn-disabled' : ''}}" bindtap="onLogin" hover-class="login-btn-hover" hover-stay-time="50">{{loading ? i18nTexts.submitting : i18nTexts.submit}}</view>
        </view>

        <view wx:if="{{showDevFields}}" class="login-field login-field-dev">
          <text class="login-field-label">服务器地址</text>
          <view class="login-input-wrap">
            <view class="login-input-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>
            </view>
            <input class="login-input" placeholder="{{i18nTexts.serverUrlPlaceholder}}" value="{{apiBaseUrl}}" bindinput="onApiBaseUrlInput" />
          </view>
        </view>
      </block>
    </view>

    <!-- Register link (outside card, per design) -->
    <block wx:if="{{!wechatChecking}}">
      <view class="login-register-section">
        <view class="login-register-link" bindtap="onManualRegister" hover-class="login-register-link-hover" hover-stay-time="50">{{i18nTexts.noAccount}}{{i18nTexts.registerNow}}</view>
      </view>
    </block>

    <!-- Tip text (bottom, per design) -->
    <view class="login-tip">提示：默认账号 lilb / 123456</view>
  </view>
</view>
