<view class="page-container">

  <!-- 用户信息卡 -->
  <view wx:if="{{userInfo}}" class="profile-card">
    <view class="profile-edit-btn" hover-class="profile-edit-btn-hover" bindtap="onEditProfile">
      <view class="line-icon icon-edit profile-edit-icon"></view>
    </view>
    <view class="profile-header">
      <view class="profile-avatar">
        <image wx:if="{{avatarImgUrl}}" class="profile-avatar-img" src="{{avatarImgUrl}}" lazy-load mode="aspectFill" binderror="onAvatarError" />
        <text wx:else class="profile-avatar-letter">{{avatarLetter}}</text>
      </view>
      <view class="profile-info">
        <view class="profile-name-row">
          <text class="profile-name">{{userInfo.name || userInfo.username || '未知用户'}}</text>
          <view class="profile-role-badge">
            <text class="profile-role-text">{{roleDisplayName || '普通用户'}}</text>
          </view>
        </view>
        <text wx:if="{{factoryName}}" class="profile-factory">{{factoryName}}</text>
        <text wx:if="{{userPhone}}" class="profile-phone">{{userPhone}}</text>
      </view>
    </view>
  </view>

  <!-- 快捷统计 -->
  <view class="stats-card">
    <view class="stats-item">
      <text class="stats-value">{{stats.workHours}}</text>
      <text class="stats-label">本月工时</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-value">¥{{stats.wage}}</text>
      <text class="stats-label">本月工资</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-value">{{stats.scanCount}}</text>
      <text class="stats-label">扫码次数</text>
    </view>
  </view>

  <!-- 菜单分组 -->
  <view class="menu-group" wx:for="{{menuGroups}}" wx:key="id" wx:for-item="group">
    <view class="menu-card">
      <view
        class="menu-item"
        wx:for="{{group.items}}"
        wx:key="id"
        wx:for-item="item"
        wx:for-index="itemIdx"
        hover-class="menu-item-hover"
        data-group-idx="{{index}}"
        data-item-idx="{{itemIdx}}"
        bindtap="onMenuTap"
      >
        <view class="menu-icon-wrap menu-icon-{{item.iconColor || 'primary'}}">
          <view class="line-icon {{item.iconClass}}"></view>
        </view>
        <text class="menu-label">{{item.label}}</text>
        <view wx:if="{{item.badge && item.badge > 0}}" class="menu-badge">
          <text class="menu-badge-text">{{item.badge}}</text>
        </view>
        <text wx:if="{{item.value}}" class="menu-value">{{item.value}}</text>
        <view class="menu-arrow"></view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <view class="logout-btn" hover-class="logout-btn-hover" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

</view>

<!-- 菜单管理弹窗 -->
<view wx:if="{{menuManageVisible}}" class="mm-overlay" bindtap="closeMenuManage"></view>
<view wx:if="{{menuManageVisible}}" class="mm-panel">
  <view class="mm-header">
    <text class="mm-title">菜单管理</text>
    <view class="mm-close" hover-class="mm-close-hover" bindtap="closeMenuManage">
      <text class="mm-close-text">✕</text>
    </view>
  </view>
  <view class="mm-desc">按角色控制首页各功能入口的显示与隐藏，关闭后该角色用户首页不可见。</view>
  <scroll-view scroll-y class="mm-scroll">
    <view class="mm-role-group" wx:for="{{menuManageGroups}}" wx:key="role" wx:for-item="group" wx:for-index="roleIdx">
      <view class="mm-role-header">
        <text class="mm-role-label">{{group.roleLabel}}</text>
      </view>
      <view class="mm-list">
        <view class="mm-item" wx:for="{{group.menus}}" wx:key="shortKey" wx:for-item="menu" wx:for-index="menuIdx">
          <text class="mm-item-label">{{menu.label}}</text>
          <view class="mm-switch {{menu.enabled ? 'mm-switch-on' : 'mm-switch-off'}}" data-role-idx="{{roleIdx}}" data-menu-idx="{{menuIdx}}" bindtap="onMenuSwitch">
            <view class="mm-switch-dot"></view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  <view class="mm-footer">
    <view class="mm-btn mm-btn-cancel" hover-class="mm-btn-hover" bindtap="closeMenuManage">
      <text>取消</text>
    </view>
    <view class="mm-btn mm-btn-save {{savingMenuConfig ? 'mm-btn-disabled' : ''}}" bindtap="saveMenuConfig">
      <text>{{savingMenuConfig ? '保存中...' : '保存'}}</text>
    </view>
  </view>
</view>

<!-- 小云 AI 助手（全页面悬浮） -->
<ai-assistant visible="{{!menuManageVisible}}" />
