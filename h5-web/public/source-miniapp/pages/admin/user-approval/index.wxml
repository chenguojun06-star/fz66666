<view class="container">
  <view class="sub-header">
    <view class="count">待审批：{{activeTab === 'tenant' ? tenantTotal : total}}人</view>
  </view>

  <!-- Tab切换（仅超级管理员/系统管理员显示，普通租户只看工人注册） -->
  <view wx:if="{{isTenantOwner || isFactoryOwner}}" class="tab-bar">
    <view class="tab-item {{activeTab === 'tenant' ? 'tab-active' : ''}}" bindtap="onTabChange" data-tab="tenant">
      工人注册 ({{tenantTotal}})
    </view>
    <view wx:if="{{isPlatformAdmin}}" class="tab-item {{activeTab === 'system' ? 'tab-active' : ''}}" bindtap="onTabChange" data-tab="system">
      系统注册 ({{total}})
    </view>
  </view>

  <!-- 系统待审批列表 -->
  <view wx:if="{{activeTab === 'system'}}">
    <view wx:if="{{loading && pendingUsers.length === 0}}" class="loading">
      <view class="loading-spinner"></view>
      <view class="loading-text">加载中...</view>
    </view>

    <view wx:elif="{{pendingUsers.length === 0}}" class="empty">
      <view class="empty-icon icon-check-green"></view>
      <view class="empty-text">暂无待审批用户</view>
    </view>

    <view wx:else class="user-list">
      <view wx:for="{{pendingUsers}}" wx:key="id" class="user-card">
        <view class="user-header">
          <view class="user-avatar">
            <view class="line-icon line-icon--sm icon-user"></view>
          </view>
          <view class="user-info">
            <view class="user-name-row">
              <view class="user-name">{{item.name || item.username}}</view>
              <view class="user-time">{{item.createTime}}</view>
            </view>
            <view wx:if="{{item.phone}}" class="user-phone">{{item.phone}}</view>
          </view>
        </view>
        <view wx:if="{{item.roleName}}" class="user-meta-row">
          <view class="position-tag">{{item.roleName}}</view>
        </view>
        <view class="card-divider"></view>
        <view class="user-actions">
          <view class="action-btn approve-btn" data-user="{{item}}" bindtap="onApproveUser">通过</view>
          <view class="action-btn reject-btn" data-user="{{item}}" bindtap="onReject">拒绝</view>
        </view>
      </view>
    </view>

    <view wx:if="{{loading && pendingUsers.length > 0}}" class="loading-more">加载更多...</view>
  </view>

  <!-- 租户工人注册列表 -->
  <view wx:if="{{activeTab === 'tenant'}}">
    <view wx:if="{{tenantRegistrations.length === 0}}" class="empty">
      <view class="empty-icon line-icon line-icon--xl icon-clipboard"></view>
      <view class="empty-text">暂无工人注册申请</view>
      <view class="empty-hint">分享工厂注册二维码给员工，员工扫码即可提交注册申请</view>
    </view>

    <view wx:else class="user-list">
      <view wx:for="{{tenantRegistrations}}" wx:key="id" class="user-card">
        <view class="user-header">
          <view class="user-avatar avatar-tenant">
            <view class="line-icon line-icon--sm icon-user"></view>
          </view>
          <view class="user-info">
            <view class="user-name-row">
              <view class="user-name">
                {{item.name || item.username}}
                <text class="badge-tag">工人注册</text>
              </view>
              <view class="user-time">{{item.createTime}}</view>
            </view>
            <view wx:if="{{item.phone}}" class="user-phone">{{item.phone}}</view>
          </view>
        </view>
        <view class="user-meta-row">
          <view wx:if="{{item.factoryName}}" class="user-factory">
            <view class="icon-factory"></view>
            <text class="factory-name">{{item.factoryName}}</text>
          </view>
          <view wx:if="{{item.roleName}}" class="position-tag">{{item.roleName}}</view>
        </view>
        <view class="card-divider"></view>
        <view class="user-actions">
          <view class="action-btn approve-btn" data-user="{{item}}" bindtap="onTenantApprove">通过</view>
          <view class="action-btn reject-btn" data-user="{{item}}" bindtap="onTenantReject">拒绝</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 批准区域 —— 角色分配（页内展开） -->
  <view wx:if="{{showApprovalModal}}" class="inline-form-card">
    <view class="inline-form-title">批准用户</view>
    <view class="mf-body">
      <view class="modal-text">
        批准用户 <text class="highlight">{{currentUser.name || currentUser.username}}</text>
      </view>
      <view class="modal-hint">批准后该用户可以正常登录系统</view>

      <view class="mf-item">
        <view class="mf-label">选择角色 <text class="required">*</text></view>
        <view class="inline-selector">
          <scroll-view class="inline-selector-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
            <view
              wx:for="{{roleOptions}}"
              wx:key="id"
              class="inline-selector-item {{selectedRoleId === String(item.id) ? 'active' : ''}}"
              data-id="{{item.id}}"
              bindtap="onRoleSelect">
              <view class="inline-selector-left">
                <view class="inline-selector-radio {{selectedRoleId === String(item.id) ? 'checked' : ''}}">
                  <view wx:if="{{selectedRoleId === String(item.id)}}" class="inline-selector-radio-dot"></view>
                </view>
                <text class="inline-selector-label">{{item.roleName}}</text>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>
    </view>
    <view class="mf-actions">
      <view class="mf-btn cancel" bindtap="cancelApprove">取消</view>
      <view class="mf-btn ok" bindtap="confirmApprove">批准并分配角色</view>
    </view>
  </view>

  <!-- 拒绝区域（页内展开） -->
  <view wx:if="{{showRejectModal}}" class="inline-form-card">
    <view class="inline-form-title">拒绝用户</view>
    <view class="mf-body">
      <view class="modal-text">
        确定拒绝用户 <text class="highlight">{{currentUser.name || currentUser.username}}</text> 吗？
      </view>
      <view class="modal-hint danger">拒绝后该用户将无法登录系统</view>

      <view class="mf-item">
        <view class="mf-label">拒绝原因 <text class="required">*</text></view>
        <textarea
          class="mf-textarea"
          placeholder="请输入拒绝原因"
          value="{{rejectReason}}"
          bindinput="onRejectReasonInput"
          maxlength="200"
        />
      </view>
    </view>
    <view class="mf-actions">
      <view class="mf-btn cancel" bindtap="cancelReject">取消</view>
      <view class="mf-btn danger" bindtap="confirmReject">确定拒绝</view>
    </view>
  </view>
  <ai-assistant />
</view>
