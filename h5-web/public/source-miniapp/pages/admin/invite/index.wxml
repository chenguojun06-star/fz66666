<view class="container">
  <custom-nav title="邀请员工" show-back="{{true}}" />

  <view class="qr-section">
    <block wx:if="{{loading}}">
      <view class="qr-loading">
        <view class="qr-loading-spinner"></view>
        <text class="qr-loading-text">正在生成邀请码...</text>
      </view>
    </block>
    <block wx:elif="{{qrUrl}}">
      <view class="qr-card">
        <image class="qr-image" src="{{qrUrl}}" mode="widthFix" />
        <text class="qr-label">微信扫一扫，加入工厂</text>
      </view>
    </block>
    <block wx:else>
      <view class="qr-card qr-card-fail">
        <text class="qr-fail-text">二维码加载失败</text>
        <view class="retry-btn" hover-class="retry-btn-hover" hover-stay-time="100" bindtap="loadTenantInfo">点击重试</view>
      </view>
    </block>
  </view>

  <view class="invite-card">
    <view class="section-title">工厂邀请码</view>
    <view class="code-row">
      <view class="code-display">{{tenantCode || '--'}}</view>
      <view class="copy-btn" hover-class="copy-btn-hover" hover-stay-time="100" bindtap="onCopyTenantCode">复制</view>
    </view>

    <view class="divider"></view>

    <view class="section-title">PC端注册链接</view>
    <view class="hint-text">员工可通过此链接在电脑端注册账号</view>
    <view class="copy-btn copy-link" hover-class="copy-btn-hover" hover-stay-time="100" bindtap="onCopyInviteUrl">复制注册链接</view>
  </view>

  <view class="steps-card">
    <view class="steps-title">邀请步骤</view>
    <view class="step-item">
      <view class="step-num">1</view>
      <view class="step-content">
        <text class="step-text">分享二维码或工厂码给新员工</text>
      </view>
    </view>
    <view class="step-item">
      <view class="step-num">2</view>
      <view class="step-content">
        <text class="step-text">新员工扫码或输入工厂码注册</text>
      </view>
    </view>
    <view class="step-item">
      <view class="step-num">3</view>
      <view class="step-content">
        <text class="step-text">管理员在用户审批中确认成员</text>
      </view>
    </view>
  </view>

  <button class="share-btn" open-type="share">分享给微信好友</button>
</view>
