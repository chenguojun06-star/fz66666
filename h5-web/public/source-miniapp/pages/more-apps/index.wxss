/* ============ 更多应用页 ============ */
page {
  background: var(--color-bg-page);
}

.page {
  min-height: 100vh;
  padding-bottom: calc(20px + env(safe-area-inset-bottom));
}

/* -- 搜索栏 -- */
.search-bar-page {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--page-padding-x);
  background: var(--color-bg-page);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: 0 12px;
  height: 36px;
  background: #e5e5ea;
  border-radius: 19px;
}
.search-box:focus-within {
  border-color: var(--color-primary);
}

.search-icon {
  font-size: var(--font-size-sm);
  opacity: 0.5;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.search-clear {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  padding: 0 var(--spacing-xs);
}

.edit-btn {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  font-weight: 500;
  flex-shrink: 0;
  padding: 0 var(--spacing-xs);
}

.edit-btn-active {
  color: var(--color-danger);
}

/* -- 收藏区域 -- */
.fav-section {
  margin: var(--spacing-sm) var(--page-padding-x);
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: 19px;
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.section-title-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  background: var(--color-bg-page);
  min-width: 20px;
  height: 20px;
  padding: 0 6px;
  border-radius: var(--radius-full);
}

.section-count--blue {
  color: var(--color-primary);
  background: #cfe5ff;
}

.clear-btn {
  font-size: var(--font-size-sm);
  color: var(--color-danger);
}

/* -- 应用网格 -- */
.app-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  column-gap: 8px;
  row-gap: 12px;
}

.app-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-xs);
  position: relative;
}

.menu-icon-circle {
  width: 48px;
  height: 48px;
  border-radius: 19px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.15s ease;
}

.menu-icon-circle .line-icon--lg {
  width: 24px;
  height: 24px;
  background-size: 24px 24px;
}

.app-item:active .menu-icon-circle {
  transform: scale(0.92);
}

.app-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  text-align: center;
  line-height: 1.2;
}

.menu-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 18px;
  height: 18px;
  padding: 0 5px;
  background-color: var(--color-danger);
  color: var(--color-text-white);
  font-size: var(--font-size-xxs);
  font-weight: 600;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid var(--color-bg-card);
}

/* -- 编辑模式按钮 -- */
.fav-star {
  position: absolute;
  top: -4px;
  right: -4px;
  width: auto;
  height: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  z-index: 2;
}

.fav-star--active {
  color: var(--color-warning);
}

.fav-star--inactive {
  color: var(--color-text-tertiary);
}

.remove-btn {
  position: absolute;
  top: -6px;
  right: -6px;
  width: 20px;
  height: 20px;
  background-color: var(--color-danger);
  color: var(--color-text-white);
  font-size: var(--font-size-xxs);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

/* -- 全部应用区 -- */
.all-apps-section {
  margin: 0 var(--page-padding-x);
}

.app-group {
  margin-bottom: var(--spacing-md);
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: 19px;
  box-shadow: var(--shadow-sm);
}

.group-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
}

.group-count {
  font-size: var(--font-size-xs);
  font-weight: 400;
  color: var(--color-text-tertiary);
}

/* -- 空状态 -- */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
  gap: var(--spacing-sm);
}

.empty-icon {
  font-size: var(--font-size-3xl);
  opacity: 0.3;
}

.empty-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

/* -- 图标颜色 -- */
.menu-icon-circle--blue {
  background: var(--color-primary);
}
.menu-icon-circle--green {
  background: var(--color-success);
}
.menu-icon-circle--orange {
  background: var(--color-warning);
}
.menu-icon-circle--purple {
  background: var(--color-purple);
}
.menu-icon-circle--violet {
  background: var(--color-violet);
}
.menu-icon-circle--lightblue {
  background: var(--color-info);
}
.menu-icon-circle--teal {
  background: var(--icon-color-teal);
}
.menu-icon-circle--red {
  background: var(--color-danger);
}
.menu-icon-circle--gray {
  background: var(--color-text-tertiary);
}
