page {
  background: var(--color-bg-page);
  padding-bottom: calc(80px + env(safe-area-inset-bottom));
}

.container {
  padding: 12rpx var(--page-padding-x);
}

.card {
  margin: 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
  border: 1px solid var(--color-border-light);
  padding: 16px;
}

.filter-row {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-pill {
  padding: 6px 14px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-pill-active {
  background: var(--color-primary);
  color: var(--color-text-white);
  font-weight: var(--font-weight-semibold);
}

.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 12px 0;
  background: var(--color-bg-gray);
  border-radius: var(--radius-lg);
  margin-bottom: 12px;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.stats-value {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
}

.stats-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

.stats-error { color: var(--color-error); }
.stats-warning { color: var(--color-warning); }
.stats-info { color: var(--color-info); }
.stats-success { color: var(--color-success); }

.stats-divider {
  width: 1px;
  height: 24px;
  background: var(--color-border-light);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.defect-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-radius: var(--radius-lg);
  padding: 12px;
  box-shadow: var(--shadow-sm);
}

.defect-card-urgent {
  border-left: 3px solid var(--color-error);
}

.card-body {
  display: flex;
  gap: 12px;
}

.card-cover {
  width: 72px;
  height: 72px;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.card-cover-empty {
  background: var(--color-bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-placeholder {
  font-size: 28px;
}

.img-badge {
  position: absolute;
  right: 2px;
  bottom: 2px;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 10px;
  padding: 1px 5px;
  border-radius: 8px;
  min-width: 16px;
  text-align: center;
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.card-row-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  margin-bottom: 2px;
}

.card-order-no {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.defect-status-tag {
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  flex-shrink: 0;
  /* 颜色由 .tag-error / .tag-warning / .tag-processing / .tag-default 全局定义 */
}

/* .tag-success / .tag-error / .tag-warning / .tag-processing / .tag-default */
/* 已统一在 design-tokens.wxss 全局定义，此处不再重复 */

.card-row {
  display: flex;
  align-items: center;
  gap: 4px;
}

.card-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.card-value {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-value-ellipsis {
  flex: 1;
  min-width: 0;
}

.card-color-size {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-left: 4px;
}

.card-row-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  margin-top: 2px;
}

.card-defect-category {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
  font-weight: var(--font-weight-medium);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.card-unqualified {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.unqualified-num {
  color: var(--color-error);
  font-weight: var(--font-weight-bold);
  font-size: var(--font-size-sm);
}

.card-actions {
  border-top: 1px solid var(--color-border-light);
  margin-top: 10px;
  padding-top: 10px;
}

.action-row {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
}

.action-btn {
  padding: 6px 16px;
  border-radius: var(--radius-md);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  text-align: center;
}

.action-btn-primary {
  background: var(--color-primary);
  color: var(--color-text-white);
}

.action-btn-danger {
  background: var(--color-error);
  color: var(--color-text-white);
}

.load-more {
  margin-top: 12px;
  text-align: center;
}

.load-more-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 24px;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-md);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 24px;
}

.empty-icon {
  font-size: var(--font-size-6xl);
  margin-bottom: 16px;
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 8px;
}

.empty-hint {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  text-align: center;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 24px;
}

.loading-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 12px;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}
