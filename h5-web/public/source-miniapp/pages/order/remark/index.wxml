<view class="page">
  <view class="section-card">
    <view class="form-row-col">
      <text class="form-label">备注内容</text>
      <textarea class="remark-area" placeholder="输入备注内容…" value="{{content}}" bindinput="onContentInput" maxlength="1000" auto-height />
    </view>

    <view class="form-row-col" wx:if="{{images.length > 0}}">
      <text class="form-label">已选图片({{images.length}}/5)</text>
      <view class="photo-grid">
        <view wx:for="{{images}}" wx:key="*this" class="photo-item">
          <image-preview class="photo-img" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="onPreviewImage" />
          <view class="photo-del icon-multiply-sm" data-index="{{index}}" catchtap="onDeleteImage"></view>
        </view>
      </view>
    </view>

    <view class="action-bar">
      <view class="act-btn act-btn--photo" bindtap="onChooseImage">
        <view class="line-icon icon-camera"></view>
        <text> 拍照/选图</text>
      </view>
      <view class="act-btn act-btn--submit {{submitting ? 'act-btn--disabled' : ''}}" bindtap="onSubmitRemark">
        <text>{{submitting ? '提交中…' : '提交备注'}}</text>
      </view>
    </view>
  </view>

  <view class="section-card" wx:if="{{remarks.length > 0}}">
    <text class="section-title">备注记录</text>
    <view class="remark-list">
      <view class="remark-card" wx:for="{{remarks}}" wx:key="id">
        <view class="remark-header">
          <text class="remark-author">{{item.authorName || '匿名'}}</text>
          <text class="remark-role" wx:if="{{item.authorRole}}">{{item.authorRole}}</text>
          <text class="remark-time">{{item.timeDisplay}}</text>
        </view>
        <view class="remark-content">{{item.content}}</view>
        <view class="remark-images" wx:if="{{item.imageList.length > 0}}">
          <view class="photo-grid">
            <view wx:for="{{item.imageList}}" wx:for-item="imgUrl" wx:key="*this" class="photo-item">
              <image-preview class="photo-img" src="{{imgUrl}}" mode="aspectFill"
                     data-url="{{imgUrl}}" data-urls="{{item.imageList}}"
                     bindtap="onPreviewRemarkImage" />
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && remarks.length === 0}}">
    <text class="empty-text">暂无备注记录</text>
  </view>

  <view class="load-tip" wx:if="{{loading}}">加载中…</view>

  <privacy-dialog id="privacyDialog" />
  <ai-assistant />
</view>
