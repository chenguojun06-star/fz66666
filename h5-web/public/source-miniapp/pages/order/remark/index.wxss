.page { padding: 20rpx; padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx); }

.section-card {
  background: var(--color-bg-card, #fff);
  border-radius: var(--radius-lg, 16rpx);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1px solid var(--color-border-light, #f0f0f0);
  box-shadow: var(--shadow-sm, 0 1px 4px rgba(0,0,0,0.04));
}

.section-title {
  font-size: var(--font-size-lg, 32rpx);
  font-weight: var(--font-weight-semibold, 600);
  color: var(--color-text-primary, #333);
  margin-bottom: 20rpx;
}

.form-row-col {
  display: flex; flex-direction: column; gap: 12rpx;
  padding: 8rpx 0;
}

.form-label {
  font-size: var(--font-size-sm, 26rpx);
  color: var(--color-text-primary, #333);
  flex-shrink: 0;
}

.remark-area {
  width: 100%; min-height: 200rpx;
  padding: 20rpx; font-size: var(--font-size-base, 28rpx);
  border: 2rpx solid var(--color-border, #d9d9d9); border-radius: var(--radius-md, 12rpx);
  box-sizing: border-box; line-height: 1.6;
  background: var(--color-bg-gray, #fafafa);
}

.photo-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.photo-item { position: relative; width: 160rpx; height: 160rpx; border-radius: 12rpx; overflow: hidden; }
.photo-img { width: 100%; height: 100%; }
.photo-del {
  position: absolute; top: 4rpx; right: 4rpx;
  width: 40rpx; height: 40rpx; border-radius: 20rpx;
  background: rgba(0,0,0,0.55); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-size-md, 28rpx); line-height: 1;
}

.action-bar { display: flex; gap: 16rpx; margin-top: 20rpx; }
.act-btn {
  flex: 1; text-align: center; padding: 20rpx 0; border-radius: var(--radius-md, 12rpx);
  font-size: var(--font-size-base, 28rpx); font-weight: var(--font-weight-medium, 500);
}
.act-btn--photo {
  background: var(--color-bg-gray, #fafafa);
  border: 2rpx solid var(--color-border, #d9d9d9);
  color: var(--color-text-secondary, #666);
}
.act-btn--submit {
  background: var(--color-primary, #1677ff);
  color: #fff;
}
.act-btn--disabled { opacity: 0.6; }

.remark-list { display: flex; flex-direction: column; gap: 16rpx; }
.remark-card {
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border-light, #f0f0f0);
}
.remark-card:last-child { border-bottom: none; }

.remark-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 10rpx; }
.remark-author { font-weight: 600; font-size: var(--font-size-base, 28rpx); color: var(--color-text-primary, #333); }
.remark-role {
  font-size: var(--font-size-2xs, 22rpx); color: var(--color-primary, #1677ff);
  background: rgba(22,119,255,0.08); padding: 2rpx 12rpx; border-radius: 4rpx;
}
.remark-time { font-size: var(--font-size-2xs, 22rpx); color: var(--color-text-tertiary, #999); margin-left: auto; }
.remark-content {
  font-size: var(--font-size-base, 28rpx); white-space: pre-wrap; word-break: break-all;
  line-height: 1.6; color: var(--color-text-primary, #333);
}
.remark-images { margin-top: 12rpx; }

.empty-state { text-align: center; padding: 100rpx 0; }
.empty-text { font-size: var(--font-size-base, 28rpx); color: var(--color-text-tertiary, #999); }
.load-tip { text-align: center; padding: 40rpx 0; font-size: var(--font-size-sm, 26rpx); color: var(--color-text-tertiary, #999); }
