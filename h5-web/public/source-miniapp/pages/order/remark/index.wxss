.page {
  padding: 12px;
  padding-bottom: calc(env(safe-area-inset-bottom) + 12px);
}

.section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 16px;
  margin-bottom: 12px;
  border: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 12px;
}

.form-row-col {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 4px 0;
}

.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.remark-area {
  width: 100%;
  min-height: 100px;
  padding: 12px;
  font-size: var(--font-size-md);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  box-sizing: border-box;
  line-height: 1.6;
  background: var(--color-bg-gray);
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.photo-item {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-del {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: var(--color-text-white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-md);
  line-height: 1;
}

.action-bar {
  display: flex;
  gap: 12px;
  margin-top: 12px;
}

.act-btn {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
}

.act-btn--photo {
  background: var(--color-bg-gray);
  border: 1px solid var(--color-border);
  color: var(--color-text-secondary);
}

.act-btn--submit {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

.act-btn--disabled {
  opacity: 0.6;
}

.remark-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.remark-card {
  padding: 8px 0;
  border-bottom: 1px solid var(--color-border-light);
}

.remark-card:last-child {
  border-bottom: none;
}

.remark-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 6px;
}

.remark-author {
  font-weight: var(--font-weight-semibold);
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.remark-role {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 2px 8px;
  border-radius: var(--radius-xs);
}

.remark-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-left: auto;
}

.remark-content {
  font-size: var(--font-size-md);
  white-space: pre-wrap;
  word-break: break-all;
  line-height: 1.6;
  color: var(--color-text-primary);
}

.remark-images {
  margin-top: 8px;
}

.empty-state {
  text-align: center;
  padding: 50px 0;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

.load-tip {
  text-align: center;
  padding: 20px 0;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
