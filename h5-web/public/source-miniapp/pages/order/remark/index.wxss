@import '/styles/page-utils.wxss';

.page {
  padding: 0 var(--page-padding-x);
  padding-bottom: calc(env(safe-area-inset-bottom) + 12px);
  background: var(--color-bg-page);
  min-height: 100vh;
}

.section-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
}

.form-row-col {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  padding: 4px 0;
}

.form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  flex-shrink: 0;
  font-weight: var(--font-weight-medium);
}

.remark-area {
  width: 100%;
  min-height: 100px;
  padding: var(--spacing-md);
  font-size: var(--font-size-md);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  box-sizing: border-box;
  line-height: 1.6;
  background: var(--color-bg-page);
  color: var(--color-text-primary);
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
}
.photo-item {
  position: relative;
  width: 80px;
  height: 80px;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.photo-img { width: 100%; height: 100%; }
.photo-del {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 20px;
  height: 20px;
  border-radius: var(--radius-full);
  background-color: rgba(0,0,0,0.55);
  color: var(--color-text-white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-xs);
  line-height: 1;
}

.action-bar {
  display: flex;
  gap: var(--spacing-md);
  margin-top: var(--spacing-md);
}
.act-btn {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  border-radius: var(--radius-lg);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.act-btn--photo {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  color: var(--color-text-secondary);
}
.act-btn--submit {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.act-btn--disabled { opacity: 0.6; }

.remark-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}
.remark-card {
  
  border-bottom: 1px solid var(--color-border);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.remark-card:last-child { border-bottom: none; }

.remark-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-sm);
}
.remark-author {
  font-weight: 600;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}
.remark-role {
  font-size: var(--font-size-2xs);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 2px 8px;
  border-radius: var(--radius-xs);
}
.remark-time {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  margin-left: auto;
}
.remark-content {
  font-size: var(--font-size-md);
  white-space: pre-wrap;
  word-break: break-all;
  line-height: 1.6;
  color: var(--color-text-primary);
}
.remark-images { margin-top: var(--spacing-sm); }

/* 本地覆盖：使用 text-align: center 而非全局 flex 布局，此页空状态为纯文本 */
.empty-state { text-align: center; padding: 60px 0; }
.empty-text { font-size: var(--font-size-md); color: var(--color-text-tertiary); }
.load-tip { text-align: center; padding: 24px 0; font-size: var(--font-size-sm); color: var(--color-text-tertiary); }
