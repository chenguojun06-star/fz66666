@import '/styles/page-utils.wxss';

.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb), 0.06) 0%, transparent 60%),
    var(--color-bg-page);
  padding: 0 var(--page-padding-x) calc(40rpx + env(safe-area-inset-bottom));
}

/* ---- 统计标签 + 智能提示（一行 flex wrap，对齐 PC 端 PageStatCards） ---- */
.stat-cards-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin: 0 0 var(--spacing-md);
  min-height: 64rpx;
}
.stat-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--color-border-light);
  background: var(--color-bg-gray);
  font-size: 24rpx;
  line-height: 1.5;
  white-space: nowrap;
}
.stat-tag-active {
  border-width: 2rpx;
  border-color: var(--color-primary);
  background: rgba(var(--color-primary-rgb), 0.08);
}
.stat-tag-active-primary { border-color: var(--color-primary); background: rgba(var(--color-primary-rgb), 0.08); }
.stat-tag-active-success { border-color: #409e57; background: rgba(64, 158, 87, 0.08); }
.stat-tag-active-danger { border-color: #dc3545; background: rgba(220, 53, 69, 0.08); }

.stat-tag-primary .stat-value { color: var(--color-primary); }
.stat-tag-success .stat-value { color: #409e57; }
.stat-tag-danger .stat-value { color: #dc3545; }

.stat-label { color: var(--color-text-secondary); font-size: 24rpx; }
.stat-value { font-weight: 600; color: var(--color-text-primary); font-variant-numeric: tabular-nums; }
.stat-unit { color: var(--color-text-secondary); font-size: 24rpx; }

/* 竖分隔线 */
.stat-divider {
  width: 1rpx;
  height: 32rpx;
  background: var(--color-border-light);
  flex-shrink: 0;
}

/* 智能提示标题 */
.hint-title {
  color: #595959;
  font-weight: 500;
  font-size: 24rpx;
  flex-shrink: 0;
}

/* 智能提示标签 */
.hint-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
  border: 1rpx solid var(--color-border-light);
  background: var(--color-bg-card);
}
.hint-tag.hint-red {
  color: #dc3545;
  border-color: #dc3545;
  background: rgba(220, 53, 69, 0.06);
}
.hint-tag.hint-orange {
  color: #d46b08;
  border-color: #d46b08;
  background: rgba(212, 107, 8, 0.06);
}
.hint-tag.hint-tag-active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

/* ---- 跨岗位提示条 ---- */
.role-hint-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin: var(--spacing-sm) 0 var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--color-warning-bg);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-warning-border);
}
.role-hint-icon { font-size: var(--font-size-sm); flex-shrink: 0; }
.role-hint-text { font-size: var(--font-size-sm); color: var(--color-warning); line-height: 1.5; }

/* ---- 搜索栏（搜索框 4/5 + 扫码按钮 1/5，线条蓝色） ---- */
.search-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0 var(--spacing-md);
}
.search-input-wrap {
  flex: 4;  /* 4/5 */
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-sm) var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}
.search-icon { font-size: var(--font-size-base); color: var(--color-text-tertiary); margin-right: var(--spacing-sm); }
.search-input {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}
.search-clear { font-size: var(--font-size-sm); color: var(--color-text-tertiary); padding: 0 var(--spacing-xs); }
.scan-btn {
  flex: 1;  /* 1/5 */
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  padding: 0;
  background: transparent;
  border: 1rpx solid var(--color-primary);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}
.scan-btn .scan-icon { font-size: 32rpx; }
.scan-btn-hover { background: rgba(var(--color-primary-rgb), 0.06); }

/* ---- 状态筛选条 ---- */
.filter-tabs {
  display: flex;
  padding: var(--spacing-sm) 0 var(--spacing-md);
  gap: var(--spacing-sm);
  white-space: nowrap;
}
.filter-tab {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  border-radius: var(--radius-xl);
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 1rpx solid transparent;
}
.filter-tab.active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

/* ---- 加载态 ---- */
.loading-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-md);
}

/* ---- 任务卡片（精简版：整卡可点击） ---- */
.task-card {
  margin: 0 0 var(--card-gap);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  padding: var(--spacing-md) var(--spacing-lg);
}
.task-card-hover {
  opacity: 0.85;
  transform: scale(0.995);
}

/* ===== 第一行：封面图 + 主信息 ===== */
.card-main-row {
  display: flex;
  gap: var(--spacing-md);
  align-items: flex-start;
}
.card-cover-wrap {
  width: 120rpx;
  height: 150rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
  position: relative;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder-box {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-gray);
}
.cover-placeholder {
  font-size: 44rpx;
}

/* 右侧信息块 */
.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacing-sm);
}
.style-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
  font-variant-numeric: tabular-nums;
}
.style-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-meta-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
  flex-wrap: wrap;
}
.meta-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* 状态标签：与扫码页统一苹果系统色 */
.tag-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
  flex-shrink: 0;
}
.status-tag.tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: var(--font-size-xs);
  line-height: 1.6;
  font-weight: 500;
  white-space: nowrap;
}
.tag-default  { background: rgba(142, 142, 147, 0.12); color: #8e8e93; }
.tag-success  { background: rgba(52, 199, 89, 0.12);  color: #34c759; }
.tag-warning  { background: rgba(255, 149, 0, 0.12); color: #ff9500; }
.tag-error    { background: rgba(255, 59, 48, 0.12);  color: #ff3b30; }
.tag-processing { background: rgba(0, 122, 255, 0.12); color: #007aff; }

/* ===== 第二行：阶段进度条（紧凑 5 点） ===== */
.stage-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border-light);
}
.stage-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 0;
}
.sb-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #e0e0e0;
  border: 2rpx solid #d0d0d0;
  transition: all 0.2s;
}
.sb-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: 1.2;
}
/* 状态颜色 */
.stage-bar-item.completed .sb-dot {
  background: #34c759;
  border-color: #34c759;
}
.stage-bar-item.completed .sb-name {
  color: #34c759;
  font-weight: 500;
}
.stage-bar-item.in_progress .sb-dot {
  background: #007aff;
  border-color: #007aff;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.15);
}
.stage-bar-item.in_progress .sb-name {
  color: #007aff;
  font-weight: 500;
}
.stage-bar-item.not_started .sb-dot {
  background: #f2f2f7;
  border-color: #d1d1d6;
}
.stage-bar-item.not_started .sb-name {
  color: #8e8e93;
}

/* ---- 加载更多 / 已显示全部 ---- */
.load-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-primary);
  font-size: var(--font-size-sm);
}
.no-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-xs);
}
