<view class="container">
  <!-- 搜索栏（搜索框 4/5 + 扫码按钮 1/5） -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon icon-search"></text>
      <input class="search-input" placeholder="搜索款号/款式名" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" />
      <view wx:if="{{keyword}}" class="search-clear" data-clear="1" bindtap="onSearchInput">
        <view class="icon-close"></view>
      </view>
    </view>
    <view class="scan-btn" hover-class="scan-btn-hover" bindtap="onTopScan">
      <view class="scan-icon icon-camera"></view>
    </view>
  </view>

  <!-- 跨岗位提示条 -->
  <view wx:if="{{roleHint}}" class="role-hint-bar">
    <text class="role-hint-icon">⚠️</text>
    <text class="role-hint-text">{{roleHint}}</text>
  </view>

  <!-- 统计标签 + 智能提示（一行 flex wrap，对齐 PC 端 PageStatCards） -->
  <view class="stat-cards-row">
    <!-- 统计标签区 -->
    <view class="stat-tag {{(activeFilter === '' && !activeHint) ? 'stat-tag-active' : ''}}" data-key="" bindtap="onFilterTap">
      <text class="stat-label">全部款号</text>
      <text class="stat-value">{{totalCount}}</text>
      <text class="stat-unit">个</text>
    </view>
    <view class="stat-tag stat-tag-primary {{activeFilter === 'IN_PROGRESS' ? 'stat-tag-active stat-tag-active-primary' : ''}}" data-key="IN_PROGRESS" bindtap="onFilterTap">
      <text class="stat-label">开发中</text>
      <text class="stat-value">{{sampleCount}}</text>
      <text class="stat-unit">个</text>
    </view>
    <view class="stat-tag stat-tag-success {{activeFilter === 'COMPLETED' ? 'stat-tag-active stat-tag-active-success' : ''}}" data-key="COMPLETED" bindtap="onFilterTap">
      <text class="stat-label">已完成</text>
      <text class="stat-value">{{completedCount}}</text>
      <text class="stat-unit">个</text>
    </view>
    <view class="stat-tag stat-tag-danger {{activeHint === 'overdue' ? 'stat-tag-active stat-tag-active-danger' : ''}}" data-key="overdue" bindtap="onHintTap">
      <text class="stat-label">已延期</text>
      <text class="stat-value">{{overdueCount}}</text>
      <text class="stat-unit">个</text>
    </view>

    <!-- 竖分隔线 -->
    <view wx:if="{{overdueCount > 0 || warningCount > 0 || delayedHints.length > 0}}" class="stat-divider"></view>

    <!-- 智能提示标题 -->
    <text wx:if="{{overdueCount > 0 || warningCount > 0 || delayedHints.length > 0}}" class="hint-title">智能提示：</text>

    <!-- 智能提示标签 -->
    <view wx:if="{{overdueCount > 0}}" class="hint-tag hint-red {{activeHint === 'overdue' ? 'hint-tag-active' : ''}}" data-key="overdue" bindtap="onHintTap">
      <text>已延期 {{overdueCount}}</text>
    </view>
    <view wx:if="{{warningCount > 0}}" class="hint-tag hint-orange {{activeHint === 'warning' ? 'hint-tag-active' : ''}}" data-key="warning" bindtap="onHintTap">
      <text>临近交期 {{warningCount}}</text>
    </view>
    <view wx:for="{{delayedHints}}" wx:key="stageName" class="hint-tag hint-orange {{activeHint === item.stageName ? 'hint-tag-active' : ''}}" data-key="{{item.stageName}}" bindtap="onHintTap">
      <text>{{item.stageName}}延期 {{item.count}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading && displayList.length === 0}}" class="loading-state">
    <text>加载样衣中…</text>
  </view>

  <!-- 空状态 -->
  <empty-state wx:elif="{{!loading && displayList.length === 0}}" text="暂无样衣开发记录" hint="点击上方扫码录入新的样衣任务"></empty-state>

  <!-- 任务列表 -->
  <block wx:else>
    <view class="task-card" wx:for="{{displayList}}" wx:key="id" data-style-id="{{item.styleId}}" data-id="{{item.id}}" bindtap="onGoDetail" hover-class="task-card-hover">
      <!-- 第一行：封面图 + 主信息 -->
      <view class="card-main-row">
        <view class="card-cover-wrap" data-src="{{item._cover}}" catchtap="onPreviewImage">
          <image wx:if="{{item._cover}}" src="{{item._cover}}" mode="aspectFill" class="cover-img" lazy-load="true"></image>
          <view wx:else class="cover-placeholder-box">
            <text class="cover-placeholder icon-placeholder"></text>
          </view>
        </view>
        <view class="card-info">
          <view class="card-title-row">
            <text class="style-no">{{item._styleNo || '-'}}</text>
            <view class="tag-row">
              <text class="status-tag tag tag-{{item._progressColor}}">{{item._progressNode}}</text>
              <text wx:if="{{item._deliveryLabel && (item._deliveryTone === 'danger' || item._deliveryTone === 'warning' || item._deliveryTone === 'success')}}" class="status-tag tag tag-{{item._deliveryTone === 'danger' ? 'error' : (item._deliveryTone === 'warning' ? 'warning' : 'success')}}">{{item._deliveryLabel}}</text>
            </view>
          </view>
          <text wx:if="{{item.styleName || item.name}}" class="style-name">{{item.styleName || item.name}}</text>
          <view class="card-meta-row" wx:if="{{item._customer || item._category || item._season}}">
            <text wx:if="{{item._customer}}" class="meta-text">{{item._customer}}</text>
            <text wx:if="{{item._merchandiser}}" class="meta-text">· 跟单: {{item._merchandiser}}</text>
            <text wx:if="{{item._category}}" class="meta-text">· {{item._category}}</text>
            <text wx:if="{{item._season}}" class="meta-text">· {{item._season}}</text>
          </view>
          <view class="card-meta-row" wx:if="{{item._color || item._size}}">
            <text wx:if="{{item._color}}" class="meta-text">{{item._color}}</text>
            <text wx:if="{{item._size}}" class="meta-text">· {{item._size}}</text>
          </view>

          <!-- 数量行（样衣只有总数量，无已完成/剩余件数概念） -->
          <view class="info-qty-row" wx:if="{{item._quantity}}">
            <view class="iq-main">
              <text class="iq-num">{{item._quantity}}</text>
              <text class="iq-unit">件</text>
            </view>
          </view>
          <!-- 进度条（基于5阶段完成率） -->
          <view class="info-progress">
            <view class="ip-bar">
              <view class="ip-fill" style="width:{{item._progressPct || 0}}%"></view>
            </view>
            <text class="ip-pct">{{item._progressPct || 0}}%</text>
          </view>
        </view>
      </view>

      <!-- 第二行：阶段进度条 -->
      <view wx:if="{{item._stageSummary}}" class="stage-bar">
        <view wx:for="{{item._stageSummary}}" wx:key="key" wx:for-item="st" class="stage-bar-item {{st.status}}">
          <view class="sb-dot"></view>
          <text class="sb-name">{{st.short}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 / 已显示全部 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="onLoadMore">
      <text wx:if="{{loadingMore}}">加载中…</text>
      <text wx:else>加载更多</text>
    </view>
    <view wx:elif="{{list.length > 0}}" class="no-more">已显示全部 {{total}} 条</view>
  </block>
</view>
