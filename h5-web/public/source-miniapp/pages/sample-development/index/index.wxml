<view class="container">
  <!-- 统计条 -->
  <view class="stats-bar">
    <view class="stat-item stat-primary">
      <text class="stat-val">{{sampleCount}}</text>
      <text class="stat-lbl">开发中</text>
    </view>
    <view class="stat-item stat-success {{smartFilter === 'completed' ? 'stat-active' : ''}} {{completedCount === 0 ? 'stat-zero' : ''}}"
          data-key="completed" bindtap="onSmartFilterTap">
      <text class="stat-val">{{completedCount}}</text>
      <text class="stat-lbl">已完成</text>
    </view>
    <view class="stat-item stat-overdue {{smartFilter === 'overdue' ? 'stat-active' : ''}} {{overdueCount === 0 ? 'stat-zero' : ''}}"
          data-key="overdue" bindtap="onSmartFilterTap">
      <text class="stat-val">{{overdueCount}}</text>
      <text class="stat-lbl">已延期</text>
    </view>
    <view class="stat-item stat-warning {{smartFilter === 'warning' ? 'stat-active' : ''}} {{warningCount === 0 ? 'stat-zero' : ''}}"
          data-key="warning" bindtap="onSmartFilterTap">
      <text class="stat-val">{{warningCount}}</text>
      <text class="stat-lbl">临近交期</text>
    </view>
  </view>

  <!-- 清除智能筛选 -->
  <view wx:if="{{smartFilter}}" class="clear-filter-bar" bindtap="onClearSmartFilter">
    <text class="clear-filter-text">清除筛选 ✕</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索款号/款式名" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" />
      <text wx:if="{{keyword}}" class="search-clear" data-clear="1" bindtap="onSearchInput">✕</text>
    </view>
  </view>

  <!-- 扫码入口 -->
  <view class="top-action-bar">
    <button class="action-btn action-btn-outline action-btn-full" hover-class="btn-outline-hover" bindtap="onTopScan">
      <text class="scan-icon">📷</text>
      <text>扫码样衣</text>
    </button>
  </view>

  <!-- 跨岗位提示条 -->
  <view wx:if="{{roleHint}}" class="role-hint-bar">
    <text class="role-hint-icon">⚠️</text>
    <text class="role-hint-text">{{roleHint}}</text>
  </view>

  <!-- 状态筛选 Tab -->
  <view class="filter-tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="key"
      class="filter-tab {{activeFilter === item.key ? 'active' : ''}}"
      bindtap="onFilterTap"
      data-key="{{item.key}}"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading && displayList.length === 0}}" class="loading-state">
    <text>加载样衣中…</text>
  </view>

  <!-- 空状态 -->
  <empty-state wx:elif="{{!loading && displayList.length === 0}}" iconEmoji="👔" text="{{smartFilter ? '当前筛选条件下无样衣记录' : '暂无样衣开发记录'}}" hint="{{smartFilter ? '点击「清除筛选」查看全部' : '点击上方「扫码样衣」录入新的样衣任务'}}"></empty-state>

  <!-- 任务列表（精简卡片：封面+款号+款式名+客户+状态/交期+阶段进度条） -->
  <block wx:else>
    <view class="task-card" wx:for="{{displayList}}" wx:key="id" data-item="{{item}}" bindtap="onGoDetail" hover-class="task-card-hover">
      <!-- 第一行：封面图 + 主信息 -->
      <view class="card-main-row">
        <view class="card-cover-wrap" data-src="{{item._cover}}" catchtap="onPreviewImage">
          <image wx:if="{{item._cover}}" src="{{item._cover}}" mode="aspectFill" class="cover-img" lazy-load="true"></image>
          <view wx:else class="cover-placeholder-box">
            <text class="cover-placeholder">👔</text>
          </view>
        </view>
        <view class="card-info">
          <view class="card-title-row">
            <text class="style-name">{{item.styleName || item.name || '未命名款式'}}</text>
            <view class="tag-row">
              <text class="status-tag tag tag-{{item._progressColor}}">{{item._progressNode}}</text>
              <text wx:if="{{item._deliveryLabel && (item._deliveryTone === 'danger' || item._deliveryTone === 'warning' || item._deliveryTone === 'success')}}" class="status-tag tag tag-{{item._deliveryTone === 'danger' ? 'error' : (item._deliveryTone === 'warning' ? 'warning' : 'success')}}">{{item._deliveryLabel}}</text>
            </view>
          </view>
          <text class="style-no">{{item._styleNo || '-'}}</text>
          <view class="card-meta-row" wx:if="{{item._customer || item._category || item._season}}">
            <text wx:if="{{item._customer}}" class="meta-text">{{item._customer}}</text>
            <text wx:if="{{item._category}}" class="meta-text">· {{item._category}}</text>
            <text wx:if="{{item._season}}" class="meta-text">· {{item._season}}</text>
          </view>
          <view class="card-meta-row" wx:if="{{item._color || item._size || item._quantity}}">
            <text wx:if="{{item._color}}" class="meta-text">{{item._color}}</text>
            <text wx:if="{{item._size}}" class="meta-text">· {{item._size}}</text>
            <text wx:if="{{item._quantity}}" class="meta-text">· {{item._quantity}}件</text>
          </view>
        </view>
      </view>

      <!-- 第二行：阶段进度条（紧凑显示 5 个阶段点） -->
      <view wx:if="{{item._stageSummary}}" class="stage-bar">
        <view wx:for="{{item._stageSummary}}" wx:key="key" wx:for-item="st" class="stage-bar-item {{st.status}}">
          <view class="sb-dot"></view>
          <text class="sb-name">{{st.short}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 / 已显示全部 -->
    <view wx:if="{{hasMore}}" class="load-more" bindtap="onLoadMore">
      <text wx:if="{{loadingMore}}">加载中…</text>
      <text wx:else>加载更多</text>
    </view>
    <view wx:elif="{{list.length > 0}}" class="no-more">已显示全部 {{total}} 条</view>
  </block>
</view>
