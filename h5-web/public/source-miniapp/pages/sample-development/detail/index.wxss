/* 样衣开发详情页 · 按 PC 端逻辑重做 */
.detail-page { padding: 16rpx 20rpx 120rpx; background: #f5f5f7; min-height: 100vh; box-sizing: border-box; }

/* ══ 加载 ══ */
.loading-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 0; }
.loading-spinner { width: 56rpx; height: 56rpx; border: 4rpx solid #e5e5ea; border-top-color: #007aff; border-radius: 50%; animation: spin 0.8s linear infinite; }
.loading-text { margin-top: 16rpx; color: #8e8e93; font-size: 26rpx; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ══ ① 顶部基础信息卡 ══ */
.top-card { display: flex; background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; }
.top-left { margin-right: 24rpx; }
.cover-img, .cover-placeholder { width: 180rpx; height: 180rpx; border-radius: 16rpx; background: #f2f2f7; display: flex; align-items: center; justify-content: center; }
.cover-img { object-fit: cover; }
.cover-icon { font-size: 64rpx; }
.top-right { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.top-title { font-size: 32rpx; font-weight: 600; color: #1c1c1e; line-height: 1.3; }
.top-sub { font-size: 26rpx; color: #8e8e93; margin-top: 4rpx; }
.info-row { display: flex; align-items: center; margin-top: 10rpx; font-size: 26rpx; }
.info-label { color: #8e8e93; min-width: 120rpx; }
.info-value { color: #1c1c1e; flex: 1; }
.tag-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.status-tag.tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 10rpx; font-size: 22rpx; line-height: 1.4; }
.tag-default { background: #f2f2f7; color: #8e8e93; }
.tag-success { background: #e8f7ee; color: #34c759; }
.tag-warning { background: #fff4e6; color: #ff9500; }
.tag-error { background: #fdecec; color: #ff3b30; }
.tag-processing { background: #e6f0ff; color: #007aff; }
.tag-scrapped { background: #f2f2f7; color: #8e8e93; }

/* ══ ③ 顶层操作栏 ══ */
.top-action-bar { display: flex; justify-content: flex-end; padding: 0 8rpx 16rpx; gap: 16rpx; }
.action-btn-outline { padding: 10rpx 24rpx; border: 2rpx solid #d1d1d6; border-radius: 12rpx; background: #fff; }
.ab-label { font-size: 24rpx; color: #1c1c1e; }

/* ══ ④ 阶段进度概览条 ══ */
.stage-overview-bar { display: flex; align-items: center; justify-content: space-between; background: #fff; border-radius: 16rpx; padding: 20rpx 16rpx; margin-bottom: 16rpx; }
.stage-ov-item { display: flex; flex-direction: column; align-items: center; flex: 1; }
.ov-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #d1d1d6; margin-bottom: 6rpx; }
.stage-ov-item.completed .ov-dot { background: #34c759; }
.stage-ov-item.in_progress .ov-dot { background: #007aff; }
.stage-ov-item.not_started .ov-dot { background: #d1d1d6; }
.ov-name { font-size: 20rpx; color: #8e8e93; }

/* ══ Section 通用 ══ */
.section-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.section-hd { display: flex; align-items: center; justify-content: space-between; padding-bottom: 16rpx; border-bottom: 2rpx solid #f2f2f7; margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #1c1c1e; }
.section-count { font-size: 22rpx; color: #8e8e93; }
.section-link { font-size: 24rpx; color: #007aff; }
.empty-inline { padding: 24rpx 0; text-align: center; color: #8e8e93; font-size: 26rpx; }
.bottom-gap { height: 40rpx; }

/* ══ 阶段区块（stage-section） ══ */
.stage-section { padding: 0; overflow: hidden; }

/* 阶段控制栏 */
.stage-control-bar { display: flex; align-items: flex-start; justify-content: space-between; padding: 20rpx 24rpx; background: #fafafa; border-bottom: 2rpx solid #f2f2f7; }
.stage-control-bar.scb-completed { background: #f0faf3; }
.stage-control-bar.scb-in_progress { background: #f0f6ff; }
.stage-control-bar.scb-not_started { background: #fafafa; }
.scb-left { flex: 1; min-width: 0; }
.scb-title { font-size: 28rpx; font-weight: 600; color: #1c1c1e; display: block; margin-bottom: 6rpx; }
.scb-meta-row { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx; }
.scb-status { font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 8rpx; }
.ss-completed { background: #e8f7ee; color: #34c759; }
.ss-in_progress { background: #e6f0ff; color: #007aff; }
.ss-not_started { background: #f2f2f7; color: #8e8e93; }
.scb-assignee { font-size: 22rpx; color: #1c1c1e; }
.scb-time { font-size: 22rpx; color: #8e8e93; }
.scb-right { display: flex; align-items: center; gap: 12rpx; margin-left: 16rpx; }
.scb-btn { padding: 10rpx 24rpx; border-radius: 12rpx; font-size: 24rpx; line-height: 1.2; }
.sb-primary { background: #007aff; color: #fff; }
.sb-danger { background: #fff; color: #ff3b30; border: 2rpx solid #ff3b30; }
.scb-done-mark { color: #34c759; font-size: 32rpx; font-weight: bold; }
.stage-empty-hint { padding: 32rpx 24rpx; text-align: center; color: #8e8e93; font-size: 24rpx; }

/* 阶段内工具栏（如工序配置入口） */
.stage-toolbar { display: flex; justify-content: flex-end; padding: 12rpx 24rpx; border-bottom: 2rpx solid #f2f2f7; }

/* ══ 列表项通用 ══ */
.item-list { padding: 16rpx 0; }
.item-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 24rpx; border-bottom: 2rpx solid #f5f5f7; }
.item-row:last-child { border-bottom: none; }
.ir-main { flex: 1; min-width: 0; }
.ir-title { display: block; font-size: 28rpx; color: #1c1c1e; font-weight: 500; }
.ir-sub { display: block; font-size: 22rpx; color: #8e8e93; margin-top: 4rpx; }
.ir-right { display: flex; align-items: center; margin-left: 16rpx; }
.ir-qty { font-size: 28rpx; color: #1c1c1e; font-variant-numeric: tabular-nums; }
.ir-price { font-size: 26rpx; color: #ff3b30; font-variant-numeric: tabular-nums; }
.ir-link { font-size: 24rpx; color: #007aff; }

/* ══ BOM ══ */
.bom-right { gap: 12rpx; }
.bom-display-wrap { display: flex; align-items: center; gap: 12rpx; }
.bom-edit-link { font-size: 22rpx; color: #007aff; padding: 4rpx 12rpx; border: 2rpx solid #007aff; border-radius: 8rpx; }
.bom-edit-wrap { display: flex; align-items: center; gap: 8rpx; }
.bom-edit-input { width: 120rpx; height: 56rpx; border: 2rpx solid #007aff; border-radius: 8rpx; padding: 0 12rpx; font-size: 26rpx; }
.bom-unit { font-size: 22rpx; color: #8e8e93; }
.bom-edit-btns { display: flex; gap: 8rpx; }
.bom-save-btn { font-size: 22rpx; color: #fff; background: #007aff; padding: 6rpx 16rpx; border-radius: 8rpx; }
.bom-cancel-btn { font-size: 22rpx; color: #8e8e93; padding: 6rpx 16rpx; }
.bom-hint { padding: 12rpx 24rpx; font-size: 22rpx; color: #8e8e93; background: #fff8e6; }

/* 采购节点内嵌 */
.purchase-inline { margin-top: 16rpx; border-top: 2rpx dashed #e5e5ea; padding-top: 16rpx; }
.pi-hd { display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx 12rpx; }
.pi-title { font-size: 26rpx; font-weight: 600; color: #1c1c1e; }
.gen-purchase-btn { padding: 8rpx 20rpx; background: #007aff; color: #fff; border-radius: 10rpx; font-size: 22rpx; }
.gen-purchase-btn.btn-disabled { background: #c7c7cc; }
.purchase-list { padding: 0 24rpx 16rpx; }
.purchase-item { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 0; border-bottom: 2rpx solid #f5f5f7; }
.purchase-item:last-child { border-bottom: none; }
.pur-left { flex: 1; min-width: 0; }
.pur-name { font-size: 26rpx; color: #1c1c1e; display: block; }
.pur-meta { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 4rpx; }
.pur-qty { font-size: 22rpx; color: #8e8e93; }
.pur-supplier { font-size: 22rpx; color: #8e8e93; }
.pur-right { display: flex; align-items: center; gap: 12rpx; margin-left: 16rpx; }
.pur-status { font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 8rpx; }
.ps-pending { background: #fff4e6; color: #ff9500; }
.ps-in_progress { background: #e6f0ff; color: #007aff; }
.ps-completed { background: #e8f7ee; color: #34c759; }
.pur-actions { display: flex; gap: 8rpx; }
.pur-btn { padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.pb-primary { background: #007aff; color: #fff; }

/* ══ KV 列表 ══ */
.kv-list { padding: 16rpx 24rpx; }
.kv-row { display: flex; padding: 12rpx 0; border-bottom: 2rpx solid #f5f5f7; }
.kv-row:last-child { border-bottom: none; }
.kv-label { width: 160rpx; color: #8e8e93; font-size: 26rpx; }
.kv-value { flex: 1; color: #1c1c1e; font-size: 26rpx; word-break: break-all; }
.kv-long { line-height: 1.5; }
.price-danger { color: #ff3b30; font-weight: 600; }
.price-success { color: #34c759; font-weight: 600; }

/* ══ note-list（生产制单） ══ */
.note-list { padding: 16rpx 24rpx; }
.note-item { padding: 12rpx 0; border-bottom: 2rpx solid #f5f5f7; }
.note-item:last-child { border-bottom: none; }
.note-label { display: block; font-size: 22rpx; color: #8e8e93; margin-bottom: 6rpx; }
.note-value { display: block; font-size: 26rpx; color: #1c1c1e; line-height: 1.5; }

/* ══ 工序扫码进度 ══ */
.process-list { padding: 8rpx 0; }
.process-item { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 24rpx; border-bottom: 2rpx solid #f5f5f7; }
.process-item:last-child { border-bottom: none; }
.process-item.pi-done { background: #fafafa; }
.process-item.pi-active { background: #f0f6ff; }
.pi-left { display: flex; align-items: center; flex: 1; min-width: 0; }
.pi-dot { width: 20rpx; height: 20rpx; border-radius: 50%; margin-right: 16rpx; background: #d1d1d6; }
.pi-dot.stage-done { background: #34c759; }
.pi-dot.stage-doing { background: #007aff; }
.pi-dot.stage-pending { background: #d1d1d6; }
.pi-main { flex: 1; min-width: 0; }
.pi-name { font-size: 28rpx; color: #1c1c1e; }
.pi-right { display: flex; flex-direction: column; align-items: flex-end; margin-left: 16rpx; }
.pi-status { font-size: 24rpx; }
.pi-status.stage-done { color: #34c759; }
.pi-status.stage-doing { color: #007aff; }
.pi-status.stage-pending { color: #8e8e93; }
.pi-sub { font-size: 20rpx; color: #8e8e93; margin-top: 4rpx; }

/* ════════ ⑦ 工序单价 · 内联编辑器（参考大货 process-edit） ════════ */

/* 工具栏：工序数统计 + 导入模板 + 添加工序（一行三段式） */
.process-toolbar { display: flex; align-items: center; padding: 16rpx 24rpx; gap: 12rpx; border-bottom: 2rpx solid #f2f2f7; }
.pt-stat { display: flex; align-items: baseline; gap: 6rpx; flex-shrink: 0; }
.pt-stat-num { font-size: 32rpx; font-weight: 600; color: #1c1c1e; font-variant-numeric: tabular-nums; }
.pt-stat-lbl { font-size: 22rpx; color: #8e8e93; }
.pt-btn { padding: 10rpx 20rpx; border-radius: 12rpx; font-size: 24rpx; line-height: 1.2; flex-shrink: 0; }
.pt-btn-outline { background: #fff; color: #007aff; border: 2rpx solid #007aff; }
.pt-btn-primary { background: #007aff; color: #fff; margin-left: auto; }

/* 阶段分组（采购/裁剪/二次工艺/车缝/尾部/入库） */
.process-stage-group { padding: 12rpx 24rpx 16rpx; border-bottom: 2rpx solid #f5f5f7; }
.process-stage-group:last-child { border-bottom: none; }
.psg-header { display: flex; align-items: center; gap: 12rpx; padding: 8rpx 0 12rpx; }
.psg-name { font-size: 26rpx; font-weight: 600; color: #1c1c1e; }
.psg-count { font-size: 22rpx; color: #fff; background: #007aff; padding: 2rpx 12rpx; border-radius: 10rpx; min-width: 28rpx; text-align: center; }
.psg-add { margin-left: auto; width: 44rpx; height: 44rpx; line-height: 40rpx; text-align: center; border: 2rpx dashed #007aff; color: #007aff; border-radius: 50%; font-size: 28rpx; }
.psg-list { display: flex; flex-direction: column; }
.psg-empty { padding: 12rpx 0; font-size: 24rpx; color: #8e8e93; }
.psg-empty .section-link { color: #007aff; }

/* 工序行（展示态 / 编辑态共用容器） */
.process-row { background: #fff; border-radius: 12rpx; margin-bottom: 8rpx; padding: 16rpx; border: 2rpx solid #f2f2f7; }
.process-row:last-child { margin-bottom: 0; }

/* 展示态：单行紧凑布局（编码 + 名称 + 标签 + 价格） */
.pr-display { display: flex; flex-direction: column; gap: 8rpx; }
.prd-line1 { display: flex; align-items: center; gap: 10rpx; flex-wrap: wrap; }
.prd-code { font-size: 22rpx; color: #8e8e93; background: #f2f2f7; padding: 2rpx 10rpx; border-radius: 6rpx; font-variant-numeric: tabular-nums; flex-shrink: 0; }
.prd-name { font-size: 28rpx; color: #1c1c1e; font-weight: 500; flex: 1; min-width: 0; }
.prd-tag { font-size: 20rpx; color: #8e8e93; background: #f2f2f7; padding: 2rpx 10rpx; border-radius: 6rpx; flex-shrink: 0; }
.prd-tag-易 { color: #34c759; background: #e8f7ee; }
.prd-tag-中 { color: #ff9500; background: #fff4e6; }
.prd-tag-难 { color: #ff3b30; background: #fdecec; }
.prd-price { font-size: 28rpx; color: #ff3b30; font-weight: 600; font-variant-numeric: tabular-nums; margin-left: auto; flex-shrink: 0; }
.prd-line2 { display: flex; align-items: center; gap: 12rpx; padding-left: 56rpx; font-size: 22rpx; color: #8e8e93; }
.prd-time { font-variant-numeric: tabular-nums; }
.prd-desc { flex: 1; min-width: 0; }
.prd-actions { display: flex; gap: 16rpx; padding-left: 56rpx; margin-top: 4rpx; }
.prd-act { font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 8rpx; }
.prd-act-edit { color: #007aff; background: #e6f0ff; }
.prd-act-del { color: #ff3b30; background: #fdecec; }

/* 编辑态：行内输入框组（紧凑布局，三行） */
.pr-edit { display: flex; flex-direction: column; gap: 10rpx; background: #f0f6ff; border-radius: 10rpx; padding: 16rpx; border: 2rpx solid #007aff; }
.pre-line1 { display: flex; align-items: center; gap: 8rpx; }
.pre-line2 { display: flex; align-items: center; gap: 8rpx; }
.pre-line3 { display: flex; align-items: center; gap: 8rpx; }
.pre-code { font-size: 22rpx; color: #8e8e93; background: #fff; padding: 12rpx 14rpx; border-radius: 8rpx; font-variant-numeric: tabular-nums; flex-shrink: 0; border: 2rpx solid #e5e5ea; }
.pre-input { height: 64rpx; border: 2rpx solid #d1d1d6; border-radius: 8rpx; padding: 0 14rpx; font-size: 26rpx; background: #fff; box-sizing: border-box; }
.pre-input-name { flex: 1; min-width: 0; }
.pre-input-price { width: 140rpx; flex-shrink: 0; font-variant-numeric: tabular-nums; }
.pre-input-machine { flex: 1; min-width: 0; }
.pre-input-time { width: 160rpx; flex-shrink: 0; font-variant-numeric: tabular-nums; }
.pre-input-desc { flex: 1; min-width: 0; }
.pre-picker { height: 64rpx; line-height: 60rpx; padding: 0 20rpx; border: 2rpx solid #d1d1d6; border-radius: 8rpx; font-size: 26rpx; background: #fff; color: #1c1c1e; flex-shrink: 0; min-width: 80rpx; text-align: center; }
.pre-actions { display: flex; gap: 12rpx; justify-content: flex-end; margin-top: 4rpx; }
.pre-btn { padding: 10rpx 24rpx; border-radius: 10rpx; font-size: 24rpx; line-height: 1.2; }
.pre-btn-save { background: #34c759; color: #fff; }
.pre-btn-cancel { background: #fff; color: #8e8e93; border: 2rpx solid #d1d1d6; }

/* 新增工序表单（在该阶段下方内联展开，复用编辑态样式） */
.pr-add-form { display: flex; flex-direction: column; gap: 10rpx; background: #f0faf3; border-radius: 10rpx; padding: 16rpx; margin-top: 8rpx; border: 2rpx solid #34c759; }
.paf-line1 { display: flex; align-items: center; gap: 8rpx; }
.paf-line2 { display: flex; align-items: center; gap: 8rpx; }
.paf-line3 { display: flex; align-items: center; gap: 8rpx; }
.paf-actions { display: flex; gap: 12rpx; justify-content: flex-end; margin-top: 4rpx; }
.paf-actions .pre-btn-save { background: #34c759; }
.paf-actions .pre-btn-cancel { background: #fff; color: #8e8e93; border: 2rpx solid #d1d1d6; }

/* ════════ 工序模板导入 · 半屏 sheet ════════ */
.tpl-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.4); z-index: 999; }
.tpl-sheet { position: fixed; left: 0; right: 0; bottom: 0; max-height: 80vh; background: #fff; border-radius: 24rpx 24rpx 0 0; z-index: 1000; display: flex; flex-direction: column; box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.1); }
.tpl-sheet-handle { width: 64rpx; height: 8rpx; background: #d1d1d6; border-radius: 4rpx; margin: 16rpx auto 8rpx; }
.tpl-sheet-header { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 32rpx 16rpx; border-bottom: 2rpx solid #f2f2f7; }
.tpl-sheet-title { font-size: 30rpx; font-weight: 600; color: #1c1c1e; }
.tpl-sheet-close { font-size: 36rpx; color: #8e8e93; padding: 8rpx 16rpx; }
.tpl-sheet-body { flex: 1; overflow-y: auto; padding: 16rpx 0; }
.tpl-loading { padding: 60rpx 0; text-align: center; color: #8e8e93; font-size: 26rpx; }
.tpl-empty { display: flex; flex-direction: column; align-items: center; padding: 80rpx 32rpx; gap: 12rpx; }
.tpl-empty-icon { font-size: 80rpx; }
.tpl-empty-text { font-size: 28rpx; color: #1c1c1e; }
.tpl-empty-hint { font-size: 22rpx; color: #8e8e93; text-align: center; }
.tpl-list { display: flex; flex-direction: column; }
.tpl-item { display: flex; align-items: center; padding: 24rpx 32rpx; border-bottom: 2rpx solid #f5f5f7; gap: 16rpx; }
.tpl-item:last-child { border-bottom: none; }
.tpl-item-main { flex: 1; min-width: 0; }
.tpl-item-name { font-size: 28rpx; color: #1c1c1e; font-weight: 500; display: block; }
.tpl-item-meta { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 6rpx; }
.tpl-item-src { font-size: 22rpx; color: #8e8e93; }
.tpl-item-op { font-size: 22rpx; color: #007aff; }
.tpl-item-time { font-size: 22rpx; color: #8e8e93; }
.tpl-item-apply { padding: 12rpx 28rpx; border-radius: 10rpx; background: #007aff; color: #fff; font-size: 24rpx; flex-shrink: 0; }
.tpl-item-apply.loading { background: #c7c7cc; }

/* 模板预览视图 */
.tpl-preview-header { display: flex; align-items: center; gap: 16rpx; padding: 12rpx 32rpx 16rpx; border-bottom: 2rpx solid #f2f2f7; }
.tpl-back { font-size: 26rpx; color: #007aff; padding: 8rpx 0; }
.tpl-preview-title { font-size: 28rpx; font-weight: 600; color: #1c1c1e; flex: 1; min-width: 0; }
.tpl-preview-content { padding: 16rpx 32rpx 32rpx; }
.tpl-preview-list { display: flex; flex-direction: column; }
.tpl-preview-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 2rpx solid #f5f5f7; gap: 12rpx; }
.tpl-preview-row:last-child { border-bottom: none; }
.tpr-code { font-size: 22rpx; color: #8e8e93; background: #f2f2f7; padding: 4rpx 12rpx; border-radius: 6rpx; font-variant-numeric: tabular-nums; flex-shrink: 0; min-width: 56rpx; text-align: center; }
.tpr-main { flex: 1; min-width: 0; }
.tpr-name { font-size: 26rpx; color: #1c1c1e; font-weight: 500; display: block; }
.tpr-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 4rpx; }
.tpr-tag { font-size: 20rpx; color: #8e8e93; background: #f2f2f7; padding: 2rpx 10rpx; border-radius: 6rpx; }
.tpr-price { font-size: 26rpx; color: #ff3b30; font-weight: 600; font-variant-numeric: tabular-nums; flex-shrink: 0; }
.tpl-preview-actions { padding: 24rpx 0 0; }
