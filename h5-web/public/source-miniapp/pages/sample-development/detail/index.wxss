.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.tab-nav {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  color: #666;
  font-size: 24rpx;
}

.tab-item.active {
  color: #2563eb;
  border-bottom: 4rpx solid #2563eb;
}

.tab-text {
  font-size: 26rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #2563eb;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.loading-inline {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-inline {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

.tab-content {
  padding: 20rpx;
}

.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-card {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #666;
  font-size: 28rpx;
}

.info-value {
  color: #333;
  font-size: 28rpx;
}

.list-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  overflow: hidden;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.item-main {
  flex: 1;
}

.item-title {
  display: block;
  color: #333;
  font-size: 28rpx;
}

.item-sub {
  display: block;
  color: #999;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.item-right {
  margin-left: 20rpx;
}

.item-qty {
  color: #2563eb;
  font-size: 28rpx;
  font-weight: 500;
}

.item-price {
  color: #52c41a;
  font-size: 28rpx;
  font-weight: 500;
}

.process-list {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.process-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.process-item:last-child {
  border-bottom: none;
}

.process-left {
  flex: 1;
}

.process-name {
  color: #333;
  font-size: 28rpx;
}

.process-code {
  color: #999;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.process-right {
  text-align: right;
}

.process-price {
  color: #52c41a;
  font-size: 32rpx;
  font-weight: 600;
}

.process-unit {
  color: #999;
  font-size: 24rpx;
}

.progress-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.progress-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

.progress-item::before {
  content: '';
  position: absolute;
  left: 12rpx;
  top: 50rpx;
  bottom: -20rpx;
  width: 2rpx;
  background: #e8e8e8;
}

.progress-item:last-child::before {
  display: none;
}

.progress-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.progress-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.progress-name {
  color: #333;
  font-size: 28rpx;
}

.progress-status {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.progress-time {
  color: #999;
  font-size: 24rpx;
  margin-left: 20rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.refresh-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #2563eb;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

/* 款式头部 */
.style-header {
  background: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: flex-start;
}

.style-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.style-header-info {
  flex: 1;
  min-width: 0;
}

.style-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.style-no {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 基础字段标签行 */
.style-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}
.meta-tag {
  background: #f5f5f5;
  color: #666;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.meta-status-completed { background: #f6ffed; color: #52c41a; }
.meta-status-in_progress { background: #e6f7ff; color: #1890ff; }
.meta-status-PENDING { background: #fff7e6; color: #fa8c16; }
.meta-status-others { background: #f5f5f5; color: #666; }

/* 生产工序卡片式列表 */
.process-card { background: #fff; border-radius: 16rpx; overflow: hidden; }
.process-row { display: flex; align-items: center; padding: 28rpx 24rpx; border-bottom: 1rpx solid #f5f5f5; min-height: 120rpx; }
.process-row:last-child { border-bottom: none; }
.row-active { background: #f0f7ff; }
.row-locked { opacity: 0.5; }
.row-done { background: #fafafa; }
.row-status-dot { width: 56rpx; text-align: center; font-size: 36rpx; flex-shrink: 0; margin-right: 20rpx; }
.dot-check { color: #52c41a; font-size: 40rpx; }
.dot-arrow { color: #1890ff; font-size: 36rpx; }
.dot-lock { color: #999; font-size: 32rpx; }
.dot-empty { color: #d9d9d9; font-size: 32rpx; }
.row-main { flex: 1; min-width: 0; }
.row-process-name { display: block; color: #333; font-size: 32rpx; font-weight: 500; line-height: 1.4; }
.row-meta { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 8rpx; }
.row-meta-item { color: #999; font-size: 24rpx; background: #f5f5f5; padding: 2rpx 10rpx; border-radius: 4rpx; }
.row-right { flex-shrink: 0; text-align: right; margin-left: 20rpx; display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }
.row-operator { color: #333; font-size: 26rpx; font-weight: 500; }
.row-time { color: #999; font-size: 22rpx; margin-top: 2rpx; }
.row-action-tag { background: #1890ff; color: #fff; font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; margin-top: 4rpx; font-weight: 500; }
.row-done-tag { color: #52c41a; font-size: 24rpx; font-weight: 500; margin-top: 4rpx; }
.row-locked-tag { color: #999; font-size: 22rpx; margin-top: 4rpx; }
.row-pending-tag { color: #d9d9d9; font-size: 22rpx; margin-top: 4rpx; }
.process-summary { text-align: center; color: #999; font-size: 24rpx; padding: 20rpx 0 10rpx; }

/* 款式图片横向滚动 */
.image-scroll {
  white-space: nowrap;
  width: 100%;
}

.style-image-thumb {
  display: inline-block;
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  margin-right: 12rpx;
  vertical-align: top;
}

/* 生产工序扫码列表（与列表页风格一致） */
.process-scan-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  background: #fff;
}

.process-scan-item:last-child {
  border-bottom: none;
}

.process-scan-item.can-operate {
  background: #f0f7ff;
}

.process-scan-item.locked {
  opacity: 0.6;
}

.process-scan-dot {
  width: 48rpx;
  text-align: center;
  font-size: 32rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.process-scan-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.process-scan-name {
  color: #333;
  font-size: 30rpx;
  font-weight: 500;
}

.process-scan-hint {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.done-hint { color: #52c41a; }
.can-hint { color: #2563eb; font-weight: 500; }
.lock-hint { color: #999; }
.process-scan-arrow {
  font-size: 48rpx;
  color: #2563eb;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 阶段进度增强 */
.progress-dot-not_started { background: #d9d9d9; }
.progress-dot-in_progress { background: #2563eb; }
.progress-dot-completed { background: #52c41a; }

.progress-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.progress-status-not_started { color: #999; }
.progress-status-in_progress { color: #2563eb; }
.progress-status-completed { color: #52c41a; }

.progress-assignee { color: #666; }
.progress-hours { color: #999; }

.progress-action {
  padding: 8rpx 24rpx;
  background: #2563eb;
  color: #fff;
  border-radius: 24rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}
.progress-action-receive {
  background: #faad14;
  color: #fff;
}
.progress-done-icon {
  color: #52c41a;
  font-size: 32rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.progress-done-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.progress-action-rollback {
  padding: 6rpx 16rpx;
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 24rpx;
  font-size: 22rpx;
}

/* 信息块（制单/纸样） */
.info-block {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-block:last-child { border-bottom: none; }

.info-block .info-label {
  display: block;
  margin-bottom: 8rpx;
}

.info-block-value {
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 报价单样式 */
.quotation-value { color: #333; font-weight: 500; }
.quotation-total { color: #ff4d4f; font-size: 32rpx; font-weight: 600; }
.quotation-suggest { color: #52c41a; font-size: 32rpx; font-weight: 600; }
.total-row { border-top: 2rpx solid #e8e8e8; padding-top: 20rpx; margin-top: 8rpx; }

/* 附件 */
.attachment-item { cursor: pointer; }
.attachment-action { color: #2563eb; font-size: 26rpx; }
