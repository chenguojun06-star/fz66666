.location-scan-page {
  padding: 16px;
  background: var(--color-bg-page);
  min-height: 100vh;
}

/* 头部：纯文本，无卡片背景 */
.header {
  margin-bottom: 16px;
}

.location-code {
  font-size: 30px;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  line-height: 1.2;
  letter-spacing: -0.02em;
}

.zone-name {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  margin-top: 4px;
}

.loading-container,
.error-container,
.empty-container {
  text-align: center;
  padding: 40px 16px;
  color: var(--color-text-tertiary);
}

.error-container button {
  margin-top: 12px;
}

/* 信息卡片 */
.info-card {
  background: var(--color-bg-card);
  padding: 16px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
  margin-bottom: 16px;
  box-shadow: var(--shadow-sm);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 0;
}

.info-divider {
  height: 1px;
  background: var(--color-border);
  margin: 0;
}

.info-row .label {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
}

.info-row .value {
  color: var(--color-text-primary);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
}

/* 库存明细区域 */
.items-section {
  margin-top: 4px;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.list-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

.count {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

.items-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 每个库存项为独立卡片 */
.item-card {
  background: var(--color-bg-card);
  padding: 12px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-sm);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.style-no {
  font-size: 15px;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

.tags {
  display: flex;
  gap: 6px;
  margin-top: 8px;
}

.tag {
  font-size: var(--font-size-xs);
  height: 24px;
  line-height: 24px;
  padding: 0 8px;
  border-radius: var(--radius-sm);
}

.tag.color {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}

.tag.size {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}

.item-qty {
  display: flex;
  align-items: baseline;
  gap: 2px;
  flex-shrink: 0;
}

.item-qty .qty {
  font-size: 20px;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

.qty-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* 容量进度条 */
.capacity-row .value .capacity-used {
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.capacity-bar {
  height: 8px;
  width: 100%;
  border-radius: var(--radius-full);
  background: var(--color-bg-page);
  overflow: hidden;
  margin-top: 8px;
}

.capacity-bar-fill {
  height: 100%;
  border-radius: var(--radius-full);
  background: var(--color-primary);
}
