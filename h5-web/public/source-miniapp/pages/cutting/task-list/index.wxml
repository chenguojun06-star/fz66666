<view class="container">
  <!-- 跨岗位提示条 -->
  <view wx:if="{{roleHint}}" class="role-hint-bar">
    <text class="role-hint-icon">⚠️</text>
    <text class="role-hint-text">{{roleHint}}</text>
  </view>

  <!-- 状态筛选 Tab -->
  <view class="filter-tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="key"
      class="filter-tab {{activeStatus === item.key ? 'active' : ''}}"
      bindtap="onTabChange"
      data-key="{{item.key}}"
    >
      <text>{{item.label}}</text>
      <text wx:if="{{item.count > 0}}" class="tab-badge">{{item.count}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading && !tasks.length}}" class="loading-state">
    <text>加载裁剪任务中…</text>
  </view>

  <!-- 空状态 -->
  <empty-state wx:elif="{{!tasks.length}}" iconEmoji="✂️" text="暂无裁剪任务" hint="当有新的订单分配时，任务将出现在这里" card="{{true}}"></empty-state>

  <!-- 任务列表 -->
  <block wx:else>
    <view
      wx:for="{{filteredTasks}}"
      wx:key="id"
      class="task-card"
      bindtap="goDetail"
      data-task="{{item}}"
      hover-class="task-card-hover"
    >
      <!-- 主区域：图片 + 规格信息右栏（与样衣开发风格一致） -->
      <view class="card-main">
        <view class="card-cover" catchtap="onCoverPreview" data-url="{{item.styleCoverUrl}}">
          <image wx:if="{{item.styleCoverUrl}}" class="card-cover-img" src="{{item.styleCoverUrl}}" mode="aspectFill" lazy-load="{{true}}" />
          <view wx:else class="card-cover-empty">
            <text class="cover-abbr">✂</text>
          </view>
        </view>

        <view class="card-info">
          <!-- 顶部：订单号 + 状态标签 -->
          <view class="info-top">
            <text class="order-no">{{item.productionOrderNo || item.orderNo}}</text>
            <text class="status-tag tag tag-{{item.statusColor}}">{{item.statusText}}</text>
          </view>

          <!-- 规格信息行：款号 + 颜色 -->
          <view class="info-spec-row">
            <text class="info-spec-label">款号</text>
            <text class="info-spec-value">{{item.styleNo || '-'}}</text>
            <text class="info-spec-label" wx:if="{{item.color}}">颜色</text>
            <text class="info-spec-value" wx:if="{{item.color}}">{{item.color}}</text>
          </view>

          <!-- 规格信息行：数量 + 交期 -->
          <view class="info-spec-row">
            <text class="info-spec-label">数量</text>
            <text class="info-spec-value highlight">{{item.orderQuantity || 0}} 件</text>
            <text class="info-spec-label" wx:if="{{item.expectedShipDate || item.deliveryDate}}">交期</text>
            <text class="info-spec-value" wx:if="{{item.expectedShipDate || item.deliveryDate}}">{{item.expectedShipDate || item.deliveryDate}}</text>
          </view>

          <!-- 规格信息行：领取人 -->
          <view class="info-spec-row" wx:if="{{item.receiverName}}">
            <text class="info-spec-label">领取</text>
            <text class="info-spec-value">{{item.receiverName}}</text>
          </view>
        </view>
      </view>

      <!-- 底部操作 -->
      <view class="card-footer">
        <view wx:if="{{item.canReceive}}" class="btn-action btn-primary" hover-class="btn-primary-hover" hover-stay-time="100" catchtap="onReceive" data-task="{{item}}">
          领取任务
        </view>
        <view wx:elif="{{item.canOperate}}" class="btn-action btn-primary" hover-class="btn-primary-hover" hover-stay-time="100" catchtap="goDetail" data-task="{{item}}">
          开始裁剪
        </view>
        <view wx:else class="btn-action btn-disabled">
          {{item.statusText}}
        </view>
        <view class="btn-action btn-outline" hover-class="btn-outline-hover" hover-stay-time="100" catchtap="goBundleDetail" data-task="{{item}}">
          裁剪明细
        </view>
        <text class="card-arrow">›</text>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="no-more">已显示全部任务</view>
  </block>
</view>
