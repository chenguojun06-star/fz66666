/* ============ 首页（与设计稿对齐） ============ */
page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* -- 问候卡片 -- */
.header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0 var(--page-padding-x) var(--spacing-md);
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
}

.header-avatar {
  width: 56px;
  height: 56px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary), #66abff);
  color: var(--color-text-white);
  font-size: var(--font-size-2xl);
  font-weight: 600;
  flex-shrink: 0;
  overflow: hidden;
}

.header-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.header-avatar-letter {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.greeting-name {
  font-size: var(--font-size-2xl);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.greeting-sub {
  margin-top: 2px;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.greeting-date {
  margin-top: 2px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

/* -- 今日小贴士 -- */
.tip-card {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin: 0 var(--page-padding-x) var(--spacing-md);
  
  
  background: var(--color-primary-bg);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.tip-icon-circle {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-bg-dark);
  color: var(--color-primary);
  flex-shrink: 0;
}

.tip-icon-text {
  color: var(--color-primary);
  font-size: var(--font-size-lg);
  font-weight: 700;
  font-style: italic;
}

.tip-content {
  flex: 1;
  min-width: 0;
}

.tip-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.tip-text {
  margin-top: 4px;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--color-text-secondary);
  display: block;
}

/* -- 应用网格 -- */
.menu-section {
  margin: 0 var(--page-padding-x) var(--spacing-md);
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 16px;
  column-gap: 12px;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.menu-icon-circle {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease;
}

.menu-icon-circle .line-icon--lg {
  width: 28px;
  height: 28px;
  background-size: 28px 28px;
}

.menu-item-hover .menu-icon-circle {
  transform: scale(0.92);
}

.menu-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  text-align: center;
}

/* -- 图标颜色 -- */
.menu-icon-circle--blue {
  background: var(--color-primary);
}

.menu-icon-circle--green {
  background: var(--color-success);
}

.menu-icon-circle--orange {
  background: var(--color-warning);
}

.menu-icon-circle--purple {
  background: var(--color-purple);
}

.menu-icon-circle--violet {
  background: var(--color-violet);
}

.menu-icon-circle--lightblue {
  background: #66abff;
}

.menu-icon-circle--red {
  background: var(--color-danger);
}

.menu-icon-circle--gray {
  background: var(--color-text-tertiary);
}

/* ============ 考勤打卡卡片（紧凑版） ============ */
.attendance-card {
  margin: 0 var(--page-padding-x) var(--spacing-md);
  padding: 10px 14px;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.attendance-title-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.attendance-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.attendance-status {
  font-size: 10px;
  padding: 1px 6px;
  border-radius: var(--radius-full);
  font-weight: 500;
  line-height: 1.4;
}

.attendance-status--idle {
  background: var(--color-bg-page);
  color: var(--color-text-tertiary);
}

.attendance-status--working {
  background: var(--color-success-bg, #e9f9ee);
  color: var(--color-success);
}

.attendance-status--done {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.attendance-actions {
  margin-left: auto;
  display: flex;
  gap: 6px;
}

.attendance-btn {
  min-width: 56px;
  height: 28px;
  padding: 0 12px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--color-border);
  background: transparent;
  transition: all 0.2s ease;
}

.attendance-btn-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-weight: 500;
}

.attendance-btn--active {
  border-color: var(--color-primary);
  background: var(--color-primary);
}

.attendance-btn--active .attendance-btn-text {
  color: var(--color-text-white);
}

.attendance-btn-hover {
  opacity: 0.85;
}

.attendance-time-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.attendance-time-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}

.attendance-time-divider {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-xs);
}
