/* ============ 首页（与设计稿对齐） ============ */
page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* -- 问候卡片 -- */
.header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 0 var(--page-padding-x) var(--spacing-md);
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
}

.header-avatar {
  width: 56px;
  height: 56px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary), #66abff);
  color: var(--color-text-white);
  font-size: var(--font-size-2xl);
  font-weight: 600;
  flex-shrink: 0;
}

.header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.greeting-name {
  font-size: var(--font-size-2xl);
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.greeting-sub {
  margin-top: 2px;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.greeting-date {
  margin-top: 2px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

/* -- 今日小贴士 -- */
.tip-card {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin: 0 var(--page-padding-x) var(--spacing-md);
  padding: 16px;
  border-radius: var(--radius-2xl);
  background: var(--color-primary-bg);
}

.tip-icon-circle {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-bg-dark);
  color: var(--color-primary);
  flex-shrink: 0;
}

.tip-icon-text {
  color: var(--color-primary);
  font-size: var(--font-size-lg);
  font-weight: 700;
  font-style: italic;
}

.tip-content {
  flex: 1;
  min-width: 0;
}

.tip-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-primary);
  display: block;
}

.tip-text {
  margin-top: 4px;
  font-size: var(--font-size-sm);
  line-height: 1.6;
  color: var(--color-text-secondary);
  display: block;
}

/* -- 应用网格 -- */
.menu-section {
  margin: 0 var(--page-padding-x) var(--spacing-md);
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 16px;
  column-gap: 12px;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.menu-icon-circle {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease;
}

.menu-icon-circle .line-icon--lg {
  width: 28px;
  height: 28px;
  background-size: 28px 28px;
}

.menu-item-hover .menu-icon-circle {
  transform: scale(0.92);
}

.menu-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  text-align: center;
}

/* -- 图标颜色 -- */
.menu-icon-circle--blue {
  background: var(--color-primary);
}

.menu-icon-circle--green {
  background: var(--color-success);
}

.menu-icon-circle--orange {
  background: var(--color-warning);
}

.menu-icon-circle--purple {
  background: var(--color-purple);
}

.menu-icon-circle--violet {
  background: var(--color-violet);
}

.menu-icon-circle--lightblue {
  background: #66abff;
}

.menu-icon-circle--red {
  background: var(--color-danger);
}

.menu-icon-circle--gray {
  background: var(--color-text-tertiary);
}

/* -- AI助手卡片 -- */
.ai-card {
  margin: 0 var(--page-padding-x) var(--spacing-md);
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
}

.ai-card-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.ai-card-avatar {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary), var(--color-purple));
  flex-shrink: 0;
}

.ai-card-info {
  flex: 1;
  min-width: 0;
}

.ai-card-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ai-card-sub {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ai-card-input-row {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--color-bg-page);
  border-radius: var(--radius-full);
  padding: 10px 16px;
}

.ai-card-input-text {
  flex: 1;
  min-width: 0;
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

.ai-card-send-btn {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  flex-shrink: 0;
}

.ai-card-send-btn .icon-send-arrow {
  display: block;
  width: 16px;
  height: 16px;
  background-size: 16px 16px;
}
