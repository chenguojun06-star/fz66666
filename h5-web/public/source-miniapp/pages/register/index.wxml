<view class="container">
  <view class="card register-card">
    <view class="title">员工注册</view>
    <view class="subtitle">填写信息后请耐心等待管理员审批</view>

    <!-- 工厂编码/名称 -->
    <view class="field factory-field">
      <view class="label">工厂编码/名称 <text class="required">*</text></view>
      <view class="input-row">
        <view class="input-wrap" style="flex:1;">
          <view class="input-wrap-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/><path d="M9 9v.01"/><path d="M9 12v.01"/><path d="M9 15v.01"/><path d="M9 18v.01"/></svg>
          </view>
          <input
            class="input"
            placeholder="输入工厂编码或名称搜索"
            value="{{selectedFactory ? selectedFactory.tenantCode : tenantCode}}"
            bindinput="onTenantCodeInput"
            disabled="{{!!scannedCode}}"
          />
        </view>
        <view class="scan-btn" bindtap="onScanCode">
          <view class="scan-icon-svg">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8v8"/><path d="M11 8v8"/><path d="M15 8v8"/></svg>
          </view>
        </view>
      </view>
      <!-- 已选中工厂标签 -->
      <view wx:if="{{selectedFactory}}" class="tenant-info">
        <text class="tenant-tag">{{selectedFactory.tenantName || tenantName}}</text>
      </view>
      <!-- 搜索下拉列表 -->
      <view wx:if="{{showFactoryDropdown && !selectedFactory}}" class="factory-dropdown">
        <view
          wx:for="{{filteredTenants}}"
          wx:key="id"
          class="factory-dropdown-item"
          hover-class="factory-dropdown-item-hover"
          data-index="{{index}}"
          bindtap="onPickFactory"
        >
          <text class="factory-dropdown-name">{{item.tenantName || item.name}}</text>
          <text class="factory-dropdown-code">({{item.tenantCode}})</text>
        </view>
        <view wx:if="{{filteredTenants.length === 0}}" class="factory-dropdown-empty">
          未搜索到对应工厂，可直接输入编码
        </view>
      </view>
    </view>

    <!-- 用户名 -->
    <view class="field">
      <view class="label">用户名 <text class="required">*</text></view>
      <view class="input-wrap">
        <view class="input-wrap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </view>
        <input
          class="input"
          placeholder="3-20位字母、数字、下划线"
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="20"
        />
      </view>
    </view>

    <!-- 姓名 -->
    <view class="field">
      <view class="label">姓名 <text class="required">*</text></view>
      <view class="input-wrap">
        <view class="input-wrap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </view>
        <input
          class="input"
          placeholder="请输入姓名"
          value="{{name}}"
          bindinput="onNameInput"
        />
      </view>
    </view>

    <!-- 手机号 -->
    <view class="field">
      <view class="label">手机号（选填）</view>
      <view class="input-wrap">
        <view class="input-wrap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
        </view>
        <input
          class="input"
          type="number"
          placeholder="用于通知联系，可不填"
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="11"
        />
      </view>
    </view>

    <!-- 密码 -->
    <view class="field">
      <view class="label">密码 <text class="required">*</text></view>
      <view class="input-wrap">
        <view class="input-wrap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </view>
        <input
          class="input"
          password="true"
          placeholder="至少6位密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>
    </view>

    <!-- 确认密码 -->
    <view class="field">
      <view class="label">确认密码 <text class="required">*</text></view>
      <view class="input-wrap">
        <view class="input-wrap-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </view>
        <input
          class="input"
          password="true"
          placeholder="请再次输入密码"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
        />
      </view>
    </view>

    <view class="agreement-row">
      <view class="agreement-switch {{agreedPolicies ? 'switch-on' : ''}}" bindtap="onAgreePoliciesChange">
        <view class="agreement-switch-knob"></view>
      </view>
      <view class="agreement-text-wrap">
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" bindtap="onViewServiceAgreement">《用户服务协议》</text>
        <text class="agreement-text">和</text>
        <text class="agreement-link" bindtap="onViewPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="btn">
      <view class="btn-primary {{loading ? 'btn-disabled' : ''}}" hover-class="{{loading ? '' : 'btn-primary-hover'}}" hover-stay-time="100" bindtap="onSubmit">
        {{loading ? '提交中...' : '提交注册申请'}}
      </view>
    </view>

    <!-- 返回登录 -->
    <view class="back-link" bindtap="onBackToLogin">
      已有账号？返回登录
    </view>
  </view>
  <!-- 微信隐私授权弹窗（审核必须） -->
  <privacy-dialog id="privacyDialog" />
</view>
