{
  "name": "fashion-wechat-h5",
  "private": true,
  "version": "1.0.0",
  "description": "独立微信H5版本工作区，源码以现有小程序代码为唯一来源",
  "type": "module",
  "scripts": {
    "predev": "npm run prepare:h5",
    "dev": "vite",
    "prebuild": "npm run prepare:h5",
    "build": "vite build",
    "preview": "vite preview",
    "sync:miniapp": "node ./scripts/sync-miniprogram.mjs",
    "analyze:miniapp": "node ./scripts/analyze-miniapp-capabilities.mjs",
    "export:routes": "node ./scripts/export-route-manifest.mjs",
    "export:tokens": "node ./scripts/export-design-tokens.mjs",
    "prepare:h5": "npm run sync:miniapp && npm run analyze:miniapp && npm run export:routes && npm run export:tokens"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "html5-qrcode": "^2.3.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "vite": "^7.1.5"
  }
}
