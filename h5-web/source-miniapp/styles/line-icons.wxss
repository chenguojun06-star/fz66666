/* ===== 通用基础属性：所有 icon-* 类自动继承 ===== */
[class^="icon-"], [class*=" icon-"] {
  display: block;
  background-repeat: no-repeat;
  background-position: center;
}

.line-icon {
  display: block;
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 20px 20px;
}

.line-icon--sm {
  width: 16px;
  height: 16px;
  background-size: 16px 16px;
}

.line-icon--lg {
  width: 24px;
  height: 24px;
  background-size: 24px 24px;
}

.line-icon--soft {
  opacity: 0.9;
}

.line-icon--blue {
  filter: drop-shadow(0 2px 4px rgba(var(--color-primary-rgb), 0.18));
}

