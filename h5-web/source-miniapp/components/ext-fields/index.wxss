/* 扩展字段组件样式 */
.ext-fields {
  width: 100%;
}

.ext-section-title {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-text-primary, #333);
  padding: 20rpx 24rpx 12rpx;
  border-bottom: 1rpx solid var(--color-border, #eee);
}

/* 表单模式 */
.ext-row {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border, #f0f0f0);
  min-height: 88rpx;
}

.ext-row--textarea {
  flex-direction: column;
  align-items: stretch;
}

.ext-lbl {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary, #666);
  width: 180rpx;
  flex-shrink: 0;
}

.ext-row--textarea .ext-lbl {
  width: 100%;
  margin-bottom: 12rpx;
}

.ext-inp {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--color-text-primary, #333);
  text-align: right;
}

.ext-area {
  width: 100%;
  font-size: var(--font-size-md);
  color: var(--color-text-primary, #333);
  min-height: 120rpx;
  padding: 12rpx 0;
}

.ext-pick {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  font-size: var(--font-size-md);
  color: var(--color-text-primary, #333);
}

.ext-ph {
  color: var(--color-text-placeholder, #ccc);
}

/* 详情展示模式 */
.ext-info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border, #f5f5f5);
}

.ext-info-lbl {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary, #999);
  width: 180rpx;
  flex-shrink: 0;
}

.ext-info-val {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary, #333);
  flex: 1;
  word-break: break-all;
}
