.print-template-renderer {
  padding: 16px;
  background: var(--color-bg-card);
}

.status-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  margin-bottom: 12px;
}

.status-icon {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.status-icon.connected {
  background: var(--color-success-bg);
}

.status-icon.disconnected {
  background: var(--color-danger-bg);
}

.icon {
  width: 20px;
  height: 20px;
}

.status-text {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.action-bar {
  display: flex;
  gap: 12px;
  margin-top: 12px;
}

.btn-connect {
  flex: 1;
  height: 36px;
  font-size: var(--font-size-lg);
  background: var(--color-info);
  color: var(--color-bg-card);
  border-radius: var(--radius-sm);
}

.btn-print {
  flex: 1;
  height: 36px;
  font-size: var(--font-size-lg);
  background: var(--color-success);
  color: var(--color-bg-card);
  border-radius: var(--radius-sm);
}

.btn-print[disabled] {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}

/* 设备列表弹窗 */
.device-list-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-overlay);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-height: 60vh;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
  background: var(--color-bg-page);
  font-size: var(--font-size-lg);
  font-weight: 500;
}

.close-btn {
  font-size: var(--font-size-2xl);
  color: var(--color-text-secondary);
}

.device-list {
  padding: 12px;
  max-height: calc(60vh - 44px);
  overflow-y: auto;
}

.device-item {
  padding: 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  margin-bottom: 8px;
  border: 1px solid var(--color-border);
}

.device-item:active {
  background: var(--color-bg-page);
}

.device-name {
  font-size: var(--font-size-md);
  font-weight: 500;
  color: var(--color-text-primary);
}

.device-id {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4px;
}