<view wx:if="{{count > 0}}">
  <view wx:if="{{loading}}" class="loading-more">加载中...</view>
  <view wx:elif="{{hasMore}}" class="load-more"
        hover-class="load-more-hover" hover-stay-time="100" bindtap="onTap">
    <text>加载更多</text>
  </view>
  <view wx:else class="no-more">— 已加载全部 —</view>
</view>
