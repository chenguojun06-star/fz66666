<!-- 通用搜索+扫码组件 -->
<view class="ss-bar">
  <view class="ss-row">
    <view class="ss-box">
      <view class="ss-icon"><view class="line-icon icon-search"></view></view>
      <input
        class="ss-input"
        placeholder="{{placeholder}}"
        placeholder-class="ss-placeholder"
        value="{{value}}"
        bindinput="onInput"
        confirm-type="search"
        bindconfirm="onConfirm"
      />
      <view wx:if="{{value}}" class="ss-clear" catchtap="onClear">
        <view class="ss-clear-icon"></view>
      </view>
    </view>
    <view wx:if="{{showScan}}" class="ss-scan-btn" catchtap="onScan">
      <view class="ss-scan-icon"></view>
    </view>
  </view>
</view>
