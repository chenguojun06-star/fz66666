/* =========================================
   裁剪详情页 · 统一设计 Token
   ========================================= */
@import '/styles/page-utils.wxss';

.detail-page {
  min-height: 100vh;
  padding: 16rpx var(--page-padding-x) calc(env(safe-area-inset-bottom) + 120rpx);
  background: var(--color-bg-page);
}

/* =========================================
   通用卡片（与 order-detail 对齐）
   ========================================= */
.top-card,
.section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

.section-card {
  padding: 24rpx;
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-count,
.section-sub {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* =========================================
   ① 顶部信息卡（左封面图 + 右双行信息）
   ========================================= */
.top-card {
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

/* ════════════ 裁剪任务领取条 ════════════ */
.task-receive-bar {
  margin: 0 24rpx 16rpx;
  padding: 20rpx 24rpx;
  background: var(--color-warning-bg, #fff7e6);
  border: 1rpx solid var(--color-warning-border, #ffd591);
  border-radius: var(--radius-md, 12rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.task-receive-bar .receive-hint {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-secondary, #8c8c8c);
}

.task-receive-bar .receive-hint--mine {
  color: var(--color-success, #52c41a);
}

.task-receive-bar .receive-hint--other {
  color: var(--color-text-secondary, #8c8c8c);
}

.task-receive-bar .receive-btn {
  flex-shrink: 0;
  padding: 12rpx 32rpx;
  background: var(--color-primary, #1677ff);
  color: #fff;
  font-size: 28rpx;
  border-radius: var(--radius-sm, 8rpx);
  line-height: 1.4;
}

.top-left {
  width: 160rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-tertiary);
}

.top-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.top-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.order-no {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* 状态标签：统一类名前缀 status-tag + tag + tag-xxx */
.status-tag {
  display: inline-block;
}

.status-tag.tag {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 500;
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.status-tag.tag-warning {
  background: rgba(250, 157, 59, 0.12);
  color: var(--color-warning);
}

.status-tag.tag-success {
  background: rgba(7, 193, 96, 0.1);
  color: var(--color-success);
}

.status-tag.tag-danger {
  background: rgba(250, 81, 81, 0.12);
  color: var(--color-danger);
}

.status-tag.tag-processing {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

/* info-row：双行信息（label + value） */
.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.info-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  min-width: 56rpx;
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.info-value.highlight {
  color: var(--color-primary);
  font-weight: 600;
}

/* =========================================
   订单选择列表（首页入口）
   ========================================= */
.order-list-wrap {
  padding: 0;
}

.order-search-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--color-primary-border);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

.order-search-input {
  flex: 1;
  height: 80rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.order-search-icon {
  font-size: 36rpx;
  color: var(--color-text-tertiary);
  opacity: 0.6;
}

.order-list-loading,
.order-list-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: var(--color-text-secondary);
  font-size: 26rpx;
  gap: 16rpx;
}

.order-sel-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-lg);
  padding: var(--spacing-lg) var(--spacing-2xl);
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  margin-bottom: var(--spacing-md);
  border: 1rpx solid var(--color-border-light);
}

.sel-cover-box {
  width: 120rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
}

.sel-cover-img {
  width: 100%;
  height: 100%;
}

.sel-cover-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-tertiary);
}

.sel-card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 4rpx;
}

/* =========================================
   加载态
   ========================================= */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

/* =========================================
   ② 裁剪分扎表单区
   ========================================= */
.cutting-inputs-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.half-input {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
}

.half-input .input-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.input-field {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 10rpx 12rpx;
  box-sizing: border-box;
}

.input-suffix {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

/* 无数据提示 */
.empty-hint-box {
  padding: 60rpx 0;
  text-align: center;
}

.empty-hint-text {
  font-size: 26rpx;
  color: var(--color-text-tertiary);
}

/* 裁剪明细表 */
.cutting-table {
  border-top: 1rpx solid var(--color-border-light);
  padding-top: 12rpx;
  margin-top: 8rpx;
}

.table-header {
  display: flex;
  align-items: center;
  padding: 10rpx 0 14rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.th { text-align: center; flex-shrink: 0; }
.th-color { width: 110rpx; text-align: left; }
.th-size  { width: 80rpx; }
.th-order { width: 80rpx; }
.th-cut   { width: 80rpx; }
.th-bundles { width: 80rpx; }
.th-last  { flex: 1; }

.table-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.td {
  font-size: 26rpx;
  color: var(--color-text-primary);
  text-align: center;
}

.td-color { width: 110rpx; text-align: left; font-size: 24rpx; color: var(--color-text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.td-size  { width: 80rpx; }
.td-order { width: 80rpx; }
.td-cut   { width: 80rpx; font-weight: 600; color: var(--color-primary); }
.td-cut.highlight { color: var(--color-primary); }
.td-bundles { width: 80rpx; }
.td-last  { flex: 1; display: flex; justify-content: center; }

.td-last-input {
  width: 100rpx;
  text-align: center;
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 8rpx 4rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  box-sizing: border-box;
}

/* 分扎描述 */
.bundle-desc-area {
  margin-top: 16rpx;
  padding: 12rpx 0;
}

.bundle-desc-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}

.bundle-desc-label {
  width: 180rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.bundle-desc-value {
  flex: 1;
  font-size: 22rpx;
  color: var(--color-text-primary);
}

/* 汇总栏 */
.cutting-summary-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0 8rpx;
  border-top: 1rpx solid var(--color-border-light);
  margin-top: 12rpx;
}

.cutting-summary-item {
  text-align: center;
}

.cutting-summary-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  display: block;
}

.cutting-summary-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.cutting-summary-value.green  { color: var(--color-success); }
.cutting-summary-value.orange { color: var(--color-warning); }
.cutting-summary-value.purple { color: #9333ea; }

/* =========================================
   Tab 切换栏（菲号明细 / 转单）
   ========================================= */
.tabs-bar {
  display: flex;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  margin-bottom: 20rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.tab-item--active {
  color: var(--color-text-white);
  background: var(--color-primary);
  font-weight: 600;
}

/* =========================================
   ③ 数量明细 · 模式切换
   ========================================= */
.mode-toggle {
  display: flex;
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid var(--color-primary-border);
  background: var(--color-bg-card);
}

.mode-btn {
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  color: var(--color-primary);
  background: transparent;
  line-height: 1.5;
}

.mode-btn--active {
  background: var(--color-primary);
  color: var(--color-text-white);
}

/* 统计行 */
.stat-bar {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 4rpx;
}

.stat-item {
  display: inline-flex;
  align-items: center;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stat-value {
  font-size: 24rpx;
  font-weight: 600;
}

.stat-value.primary {
  color: var(--color-primary);
}

/* 裁货元信息 */
.cut-meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
  gap: 8rpx 0;
}

.cut-meta-item {
  display: flex;
  flex-direction: column;
  min-width: 120rpx;
}

.cut-meta-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 2rpx;
}

.cut-meta-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.cut-meta-time {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.cut-meta-value-sm {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 空状态提示 */
.empty-hint {
  padding: 32rpx 0;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 24rpx;
}

/* 简单模式列表 */
.simple-list {
  margin-top: 8rpx;
}

.simple-header {
  display: flex;
  background: var(--color-primary-bg);
  border-radius: var(--radius-sm);
  padding: 10rpx 12rpx;
  margin-bottom: 4rpx;
}

.simple-row {
  display: flex;
  padding: 12rpx 12rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.simple-row:last-child {
  border-bottom: none;
}

.simple-cell {
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.simple-cell--color {
  flex: 1;
}

.simple-cell--qty {
  width: 160rpx;
  text-align: right;
  color: var(--color-primary);
}

.simple-cell.bold {
  font-weight: 600;
}

/* =========================================
   ④ 菲号明细列表
   ========================================= */
.bundle-list {
  margin-top: 0;
}

.bundle-list-header {
  display: flex;
  align-items: center;
  background: var(--color-primary-bg);
  border-radius: var(--radius-sm);
  padding: 12rpx 8rpx;
  margin-bottom: 4rpx;
}

.bundle-row {
  display: flex;
  align-items: center;
  padding: 14rpx 8rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.bundle-row:last-child {
  border-bottom: none;
}

.bl-cell {
  font-size: 24rpx;
  color: var(--color-text-primary);
  text-align: center;
}

.bl-cell--no { width: 80rpx; flex-shrink: 0; }
.bl-cell--code { width: 140rpx; flex-shrink: 0; font-size: 22rpx; color: var(--color-text-secondary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bl-cell--color { width: 100rpx; flex-shrink: 0; }
.bl-cell--size { width: 80rpx; flex-shrink: 0; }
.bl-cell--qty { flex: 1; text-align: right; padding-right: 8rpx; }

.bl-cell.bold {
  font-weight: 700;
  color: var(--color-primary);
}

/* 列表头文字样式 */
.bundle-list-header .bl-cell {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* =========================================
   转单 Panel 样式
   ========================================= */

/* 模式选择 */
.tf-mode-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.tf-mode-options {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: 4rpx;
}

.tf-mode-opt {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.tf-mode-opt--active {
  background: var(--color-bg-card);
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.06);
}

.tf-mode-opt--disabled {
  color: var(--color-text-disabled);
  opacity: 0.5;
  cursor: not-allowed;
}

/* 分区标题 */
.tf-section {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.tf-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  display: block;
}

.tf-flex-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.tf-select-all {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--color-primary);
}

.tf-select-all-icon {
  font-size: 28rpx;
}

.tf-count {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-left: 12rpx;
  flex: 1;
}

/* 菲号列表 */
.tf-bundles-list {
  max-height: 300rpx;
  -webkit-overflow-scrolling: touch;
}

.tf-bundle-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.tf-bundle-item--disabled {
  opacity: 0.45;
}

.tf-bundle-item--checked {
  background: var(--color-info-bg);
  border-radius: var(--radius-sm);
  padding: 14rpx 8rpx;
  margin: 0 -8rpx;
}

.tf-bundle-check {
  width: 44rpx;
  font-size: 32rpx;
  color: var(--color-primary);
  text-align: center;
  flex-shrink: 0;
}

.tf-bundle-info {
  flex: 1;
  margin-left: 8rpx;
  min-width: 0;
}

.tf-bundle-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
}

.tf-bundle-detail {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
}

.tf-bundle-status {
  font-size: 22rpx;
  color: var(--color-danger);
  flex-shrink: 0;
}

/* 工序列表 */
.tf-processes-list {
  margin-top: 8rpx;
}

.tf-process-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
}

.tf-process-row--disabled {
  opacity: 0.5;
  pointer-events: none;
}

.tf-process-check {
  width: 52rpx;
  font-size: 34rpx;
  color: var(--color-primary);
  text-align: center;
  padding-top: 4rpx;
  flex-shrink: 0;
}

.tf-process-body {
  flex: 1;
  min-width: 0;
}

.tf-process-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tf-process-code {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  background: var(--color-bg-gray);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-sm);
}

.tf-process-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex: 1;
}

.tf-process-price {
  font-size: 28rpx;
  color: var(--color-danger);
  font-weight: 600;
}

.tf-process-status {
  font-size: 22rpx;
  color: var(--color-danger);
  margin-left: 8rpx;
}

.tf-process-status--partial {
  color: var(--color-warning);
}

.tf-process-price-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}

.tf-new-price-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.tf-price-input {
  width: 160rpx;
  height: 72rpx;
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  box-sizing: border-box;
}

.tf-price-unit {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 工厂/人员 Tab */
.tf-tab-row {
  display: flex;
  gap: 0;
  margin-bottom: 16rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: 4rpx;
}

.tf-tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
}

.tf-tab-item--active {
  color: var(--color-text-white);
  background: var(--color-primary);
  font-weight: 600;
}

/* 搜索行 */
.search-row {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
  gap: 8rpx;
}

.search-icon {
  font-size: 28rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.search-row-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-primary);
  background: transparent;
}

/* 搜索结果 */
.tf-result-list {
  max-height: 320rpx;
  -webkit-overflow-scrolling: touch;
}

.tf-result-item {
  display: flex;
  align-items: center;
  padding: 18rpx 12rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  gap: 8rpx;
}

.tf-result-item--active {
  background: var(--color-info-bg);
  border-radius: var(--radius-sm);
}

.tf-result-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  flex: 1;
}

.tf-result-sub {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-right: 12rpx;
}

.tf-result-check {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.tf-loading,
.tf-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.tf-more {
  color: var(--color-primary);
}

/* 备注 */
.tf-remark {
  width: 100%;
  min-height: 100rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: 16rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--color-border-light);
}

/* =========================================
   ⑤ 底部操作栏（固定）
   ========================================= */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-border-light);
  padding: 16rpx var(--page-padding-x) calc(env(safe-area-inset-bottom) + 16rpx);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
  display: flex;
  gap: 16rpx;
  align-items: center;
}

/* 单主按钮：生成菲号 / 转单提交 */
.btn-primary {
  flex: 1;
  height: 88rpx;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  letter-spacing: 2rpx;
  line-height: 1;
}

.btn-primary::after {
  border: none;
}

.btn-full {
  flex: 1;
}

/* 双按钮模式（白底蓝字空心）：打印 / 转单 */
.footer-bar--dual {
  justify-content: space-around;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 12rpx 24rpx;
  flex: 1;
  border-radius: var(--radius-md);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-primary-border);
  color: var(--color-primary);
  transition: opacity 0.2s ease;
}

.action-btn:active {
  opacity: 0.7;
}

.ab-icon {
  font-size: 36rpx;
  line-height: 1;
}

.ab-label {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* =========================================
   ⑥ 菲号标签打印弹窗
   ========================================= */
.bpo-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.bpo-panel {
  width: 100%;
  max-height: 90vh;
  background: var(--color-bg-card);
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.bpo-panel-header {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--color-border-light);
  flex-shrink: 0;
  gap: 16rpx;
}

.bpo-panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.bpo-panel-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.bpo-panel-close {
  margin-left: auto;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 配置栏 */
.bpo-config-bar {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 32rpx;
  background: var(--color-bg-gray);
  border-bottom: 1rpx solid var(--color-border-light);
  flex-shrink: 0;
  gap: 12rpx;
  flex-wrap: wrap;
}

.bpo-config-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  flex-shrink: 0;
  line-height: 56rpx;
}

.bpo-size-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.bpo-size-chip {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
  transition: all 0.15s ease;
}

.bpo-size-chip--active {
  color: var(--color-text-white);
  background: var(--color-primary);
  border-color: var(--color-primary);
  transform: scale(1.05);
}

/* 打印方式选择 */
.bpo-mode-options {
  display: flex;
  gap: 12rpx;
}

.bpo-mode-opt {
  padding: 8rpx 24rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border-light);
}

.bpo-mode-opt--active {
  color: var(--color-text-white);
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* WiFi 配置 */
.bpo-wifi-bar {
  gap: 8rpx;
}

.bpo-wifi-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--color-border-light);
  border-radius: var(--radius-sm);
  padding: 0 12rpx;
  font-size: 24rpx;
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  min-width: 0;
  box-sizing: border-box;
}

.bpo-wifi-port {
  flex: 0 0 120rpx;
}

.bpo-port-label {
  flex-shrink: 0;
}

.bpo-wifi-hint {
  padding: 8rpx 32rpx 12rpx;
  background: var(--color-bg-gray);
}

.bpo-wifi-hint-text {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

/* 打印方向 */
.bpo-orient-bar {
  padding: 8rpx 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.bpo-orient-btn {
  padding: 6rpx 20rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  margin-left: 8rpx;
}

.bpo-orient-btn--active {
  color: var(--color-text-white);
  background: var(--color-primary);
}

/* 预览区 */
.bpo-panel-body {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.bpo-label-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: center;
}

.bpo-size-indicator {
  width: 100%;
  text-align: center;
  padding: 8rpx 0;
}

.bpo-size-indicator-text {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* 菲号标签卡片 — 左QR + 右文字 */
.bpo-label-card {
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-text-primary);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  gap: 24rpx;
  margin: 0 auto;
  transition: width 0.2s ease, height 0.2s ease;
}

/* 竖版预览卡片 */
.bpo-label-card--vertical {
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
}

.bpol-qr {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr--vertical {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 10rpx;
}

.bpol-qr-img {
  border-radius: 4rpx;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr-loading {
  background: var(--color-bg-gray);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: width 0.2s ease, height 0.2s ease;
}

.bpol-qr-loading-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.bpol-text {
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
  min-width: 0;
}

.bpol-text--vertical {
  width: 100%;
  text-align: center;
  align-items: center;
}

.bpol-line {
  font-size: 24rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bpol-line--bold {
  font-weight: 700;
  font-size: 28rpx;
}

/* 弹层底部 */
.bpo-panel-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-border-light);
  flex-shrink: 0;
}

.bpo-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.bpo-btn--cancel {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
}

.bpo-btn--print {
  background: var(--color-primary);
  color: var(--color-text-white);
}

.bpo-btn::after {
  border: none;
}

/* =========================================
   底部间距
   ========================================= */
.bottom-gap {
  height: 40rpx;
}
