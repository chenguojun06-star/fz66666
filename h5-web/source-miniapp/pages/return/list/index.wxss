/* ============ 退货列表页 — Apple Design 风格 ============ */

.page-bg {
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* ============ 内嵌筛选区 ============ */

.sticky-header {
  position: relative;
  background: var(--color-bg-page);
  padding-top: 3px;
}

/* ============ 分段控件（类型标签） ============ */

.type-tabs {
  display: flex;
  gap: 8px;
  padding: 12px var(--page-padding-x) 0;
}

.type-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 36px;
  padding: 0 12px;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  white-space: nowrap;
  transition: all 0.2s ease;
}

.type-tab.active {
  color: var(--color-text-white);
  background: var(--color-primary);
  border-color: var(--color-primary);
}

/* ============ 状态标签（水平滚动 pill） ============ */

.status-tabs-scroll {
  white-space: nowrap;
  padding: 12px 0 2px;
}

.status-tabs {
  display: inline-flex;
  padding: 0 var(--page-padding-x);
  gap: 8px;
}

.status-tab {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  height: 32px;
  padding: 0 12px;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-full);
  flex-shrink: 0;
  box-sizing: border-box;
  transition: background-color 0.2s ease, color 0.2s ease;
}

.status-tab-label {
  white-space: nowrap;
}

.status-tab-count {
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

/* 状态标签颜色变体（未选中） */
.status-tab--all {
  background: var(--color-bg-muted);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
}

.status-tab--pending {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.status-tab--approved {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.status-tab--returned {
  background: var(--color-bg-muted);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
}

.status-tab--refunded {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.status-tab--rejected {
  background: var(--color-danger-bg);
  color: var(--color-danger);
}

/* 选中态统一覆盖为主色 */
.status-tab.active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

/* ============ 列表区域 ============ */

.list-wrap {
  padding: 12px var(--page-padding-x);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 本地覆盖：使用 text-align: center 而非全局 flex 布局，此页空状态为纯文本 */
.empty-state {
  text-align: center;
  padding: 60px 0;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

/* ============ 退货卡片（box-shadow 分隔，保留状态左边色条） ============ */

.card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  padding: 12px;
  box-sizing: border-box;
  overflow: hidden;
  transition: transform 0.18s ease, background-color 0.18s ease;
}

.card:active {
  transform: scale(0.99);
}

/* 卡片左边色条 — 按状态色 */
.card.border-warning { border-color: var(--color-warning); }
.card.border-success { border-color: var(--color-success); }
.card.border-gray { border-color: var(--color-text-quaternary); }
.card.border-blue { border-color: var(--color-primary); }
.card.border-danger { border-color: var(--color-danger); }

/* ============ 卡片头部 ============ */

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 12px;
}

.header-left {
  flex: 1;
  min-width: 0;
}

.return-no {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-sub-no {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  display: block;
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============ 状态标签（卡片内 pill） ============ */

.status-badge {
  display: inline-flex;
  align-items: center;
  height: 24px;
  padding: 0 10px;
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-full);
  white-space: nowrap;
  flex-shrink: 0;
}

/* 状态标签颜色 — 复用 design-tokens 全局定义，此处补充兜底 */
.tag-warning { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-success { background: var(--color-success-bg); color: var(--color-success); }
.tag-gray { background: var(--color-bg-page); color: var(--color-text-secondary); }
.tag-blue { background: var(--color-primary-bg); color: var(--color-primary); }
.tag-danger { background: var(--color-danger-bg); color: var(--color-danger); }

/* ============ 卡片详情网格 ============ */

.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px 12px;
  padding: 12px;
  border-top: 1px solid var(--color-border);
}

.grid-item {
  min-width: 0;
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.grid-item--full {
  grid-column: 1 / -1;
}

.row-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

.row-value {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ============ 卡片底部 ============ */

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 12px;
  border-top: 1px solid var(--color-border);
}

.amount {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

.time {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

/* ============ 加载更多 ============ */

.loading-more {
  text-align: center;
  padding: 16px 0;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
