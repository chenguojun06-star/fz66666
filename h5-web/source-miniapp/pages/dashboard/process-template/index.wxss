/* 工序模板配置页 - 苹果 Grouped List 风格 */
.page-bg {
  min-height: 100vh;
  background: #f2f2f7;
  padding-bottom: 120rpx;
}

/* 顶部款式信息卡 */
.status-card {
  margin: 16rpx 16rpx 0;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.04);
}
.status-card-row {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.status-card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1c1c1e;
}
.status-card-sub {
  font-size: 26rpx;
  color: #8e8e93;
}
.status-card-meta {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.meta-chip {
  font-size: 24rpx;
  color: #8e8e93;
  background: #f2f2f7;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.meta-chip--price {
  color: #007aff;
  background: rgba(0,122,255,0.08);
  font-variant-numeric: tabular-nums;
}

/* 加载 */
.loading-wrap {
  padding: 80rpx 0;
  text-align: center;
}
.loading-text {
  font-size: 28rpx;
  color: #8e8e93;
}

/* 阶段分组列表 */
.group-list {
  padding: 16rpx;
}
.group {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

/* 组头 */
.group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f2f2f7;
}
.group-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.group-header-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1c1e;
}
.group-header-count {
  font-size: 24rpx;
  color: #8e8e93;
  background: #f2f2f7;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  min-width: 32rpx;
  text-align: center;
}
.group-header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.group-header-add {
  font-size: 36rpx;
  color: #007aff;
  line-height: 1;
  padding: 0 8rpx;
}
.group-header-arrow {
  font-size: 32rpx;
  color: #c7c7cc;
  transform: rotate(90deg);
  transition: transform 0.2s;
}
.group-header-arrow.arrow-down {
  transform: rotate(270deg);
}

/* 工序列表 */
.cell-list {
  padding: 0;
}
.cell-empty {
  padding: 24rpx;
  text-align: center;
}
.cell-empty-text {
  font-size: 26rpx;
  color: #c7c7cc;
}
.cell {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f2f2f7;
}
.cell:last-child {
  border-bottom: none;
}
.cell-main {
  flex: 1;
  min-width: 0;
}
.cell-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.cell-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1c1c1e;
}
.cell-code {
  font-size: 22rpx;
  color: #8e8e93;
  background: #f2f2f7;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}
.cell-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.cell-meta {
  font-size: 24rpx;
  color: #8e8e93;
}
.cell-meta--price {
  color: #007aff;
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}
.cell-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8e8e93;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cell-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding-left: 16rpx;
}
.cell-action {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.cell-action--edit {
  color: #007aff;
}
.cell-action--del {
  color: #ff3b30;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.92);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 1rpx solid rgba(0,0,0,0.06);
}
.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  line-height: 88rpx;
}
.action-btn--secondary {
  background: #f2f2f7;
  color: #007aff;
}
.action-btn--primary {
  background: #007aff;
  color: #fff;
}
.action-btn--primary[loading]::before {
  display: none;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 1000;
}
.modal-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  border-radius: 24rpx;
  z-index: 1001;
  max-height: 80vh;
  overflow-y: auto;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f2f2f7;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1c1e;
}
.modal-close {
  font-size: 36rpx;
  color: #8e8e93;
  padding: 0 8rpx;
}
.modal-body {
  padding: 16rpx 24rpx;
}
.form-item {
  margin-bottom: 20rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  color: #8e8e93;
  margin-bottom: 8rpx;
}
.form-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1c1c1e;
  background: #f2f2f7;
  border-radius: 12rpx;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #1c1c1e;
  background: #f2f2f7;
  border-radius: 12rpx;
  box-sizing: border-box;
}
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1c1c1e;
  background: #f2f2f7;
  border-radius: 12rpx;
}
.form-picker-arrow {
  font-size: 32rpx;
  color: #c7c7cc;
  transform: rotate(90deg);
}
.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx 24rpx;
}
.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  line-height: 80rpx;
}
.modal-btn--cancel {
  background: #f2f2f7;
  color: #1c1c1e;
}
.modal-btn--confirm {
  background: #007aff;
  color: #fff;
}
