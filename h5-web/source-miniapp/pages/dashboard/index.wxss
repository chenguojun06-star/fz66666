/* ========================================
   生产管理 · 美团风格订单卡片
   与设计稿 dashboard.html 完全对齐
   ======================================== */
@import '/styles/page-utils.wxss';

.page {
  min-height: 100vh;
  padding: 0 var(--page-padding-x) calc(env(safe-area-inset-bottom) + 20px);
  background: var(--color-bg-page);
}

/* ============ 搜索栏 + 扫码：已迁移到通用组件 sticky-search-bar ============ */

/* ============ 筛选 pill ============ */
.filter-scroll {
  white-space: nowrap;
  padding: 0;
}
.filter-pill {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 4px;
  padding: 0 12px;
  height: 32px;
  border-radius: var(--radius-full);
  background: var(--color-bg-page);
  border: 1px solid var(--color-border);
  margin-right: 8px;
  min-width: 52px;
}
.filter-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.filter-num {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  line-height: 1.1;
}

/* 选中态：实心蓝底白字（优先级最高，覆盖所有类型样式） */
.filter-pill--on {
  background: var(--color-primary) !important;
  border-color: var(--color-primary) !important;
}
.filter-pill--on .filter-text,
.filter-pill--on .filter-num {
  color: var(--color-text-white) !important;
}

/* 未选中 - 生产中：浅蓝底蓝字 */
.filter-pill--prod {
  background: var(--color-primary-bg);
  border-color: transparent;
}
.filter-pill--prod .filter-text,
.filter-pill--prod .filter-num {
  color: var(--color-primary);
}

/* 未选中 - 已完成：浅绿底绿字 */
.filter-pill--done {
  background: var(--color-success-bg);
  border-color: transparent;
}
.filter-pill--done .filter-text,
.filter-pill--done .filter-num {
  color: var(--color-success);
}

/* 未选中 - 已延期：浅红底红字 */
.filter-pill--danger {
  background: var(--color-danger-bg);
  border-color: transparent;
}
.filter-pill--danger .filter-text,
.filter-pill--danger .filter-num {
  color: var(--color-danger);
}

/* ============ 订单列表 ============ */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 8px 0 0;
}

/* ============ 订单卡片 ============ */
.order-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  padding: 12px;
  box-sizing: border-box;
  transition: transform 0.18s ease, background-color 0.18s ease;
}

/* — 主行：封面 + 信息 — */
.order-main {
  display: flex;
  gap: 12px;
}

/* 封面图 80x80 圆角 */
.order-cover {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
}
.cover-pic {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-ph-text {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 信息区 */
.order-info {
  flex: 1;
  min-width: 0;
}

/* 行1：订单号 + 状态标签 */
.info-line1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.order-no {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

/* 急标签 + 状态标签容器 */
.info-badges {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

/* 急标签（橙色实心，方角偏圆） */
.urgent-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 20px;
  padding: 0 6px;
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-bold);
  border-radius: var(--radius-full);
  background: var(--color-warning);
  color: var(--color-text-white);
  line-height: 1;
  flex-shrink: 0;
}

/* 实心状态标签（h-5 实心背景 + 白字） */
.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 20px;
  padding: 0 8px;
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-full);
  color: var(--color-text-white);
  line-height: 1;
  flex-shrink: 0;
}
.status-badge--production { background: var(--color-primary); }
.status-badge--completed { background: var(--color-success); }
.status-badge--overdue { background: var(--color-danger); }
.status-badge--pending { background: var(--color-text-tertiary); }

/* 行2：款号 + 款名（合并单行，截断） */
.info-style {
  margin-top: 4px;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 行3：客户名 */
.info-customer {
  margin-top: 2px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 行4：工厂名 */
.info-factory {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* — 进度行：数量·交期 + 进度条 + 百分比 + 剩余天数（同一行） — */
.info-progress {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 12px;
}
.ip-left {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  white-space: nowrap;
}
.ip-qty {
  font-variant-numeric: tabular-nums;
}
.ip-dot {
  color: var(--color-text-quaternary);
}
.ip-delivery {
  font-variant-numeric: tabular-nums;
}
.ip-bar {
  flex: 1;
  min-width: 0;
  height: 6px;
  background: var(--color-border);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.ip-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  transition: width 0.3s;
}
/* 已完成：绿色 */
.ip-fill--done {
  background: var(--color-success);
}
/* 延期：橙色 */
.ip-fill--overdue {
  background: var(--color-warning);
}
.ip-pct {
  flex-shrink: 0;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
  min-width: 32px;
  text-align: right;
}
/* 剩余天数标签（h-5 圆角） */
.ip-remain {
  display: inline-flex;
  align-items: center;
  height: 20px;
  padding: 0 8px;
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-full);
  line-height: 1;
  flex-shrink: 0;
  white-space: nowrap;
}
/* 剩余天数颜色 */
.ip-remain.days-safe    { background: var(--color-success-bg); color: var(--color-success); }
.ip-remain.days-warn    { background: var(--color-warning-bg); color: var(--color-warning); }
.ip-remain.days-urgent  { background: var(--color-danger-bg); color: var(--color-danger); }
.ip-remain.days-overdue { background: var(--color-danger-bg); color: var(--color-danger); font-weight: var(--font-weight-semibold); }
.ip-remain.days-done    { background: var(--color-success-bg); color: var(--color-success); }

/* — 展开按钮（全宽 border-top）— */
.order-expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  border-top: 1px solid var(--color-border);
  margin-top: 12px;
  padding-top: 8px;
}
.expand-btn-text {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
}
.expand-btn-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  transition: transform 0.2s;
}
.expand-btn-arrow--up {
  transform: rotate(180deg);
}

/* — 菲号明细 — */
.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-subtle);
  padding: 6px 8px;
}
.detail-title {
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.detail-count {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
}
.detail-table {
  width: 100%;
}
.detail-row {
  display: flex;
  align-items: center;
  border-top: 1px solid var(--color-border);
}
.detail-row--head {
  background: transparent;
}
.detail-row--empty {
  justify-content: center;
}
.detail-cell {
  padding: 4px 8px;
  font-size: var(--font-size-2xs);
  line-height: 1.4;
}
.detail-cell--no {
  flex: none;
  width: 56px;
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.detail-cell--proc {
  flex: 1;
  min-width: 0;
  color: var(--color-text-secondary);
  overflow: hidden;
}
.detail-cell--qty {
  flex: none;
  width: 52px;
  text-align: right;
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.detail-cell--empty {
  flex: 1;
  text-align: center;
  color: var(--color-text-tertiary);
}
/* 表头单元格 */
.detail-row--head .detail-cell {
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}
.proc-node {
  font-variant-numeric: tabular-nums;
}
.proc-sep {
  color: var(--color-text-quaternary);
  margin: 0 2px;
}

/* ============ 加载 / 空状态 ============ */
.load-tip {
  text-align: center;
  padding: 16px 0 24px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.load-tip--end {
  font-size: var(--font-size-2xs);
}
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 0;
}
.empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10px;
}
.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
}

/* ============ 展开区功能 ============ */
.expand-section {
  margin-bottom: var(--spacing-md);
}
.expand-section:last-child {
  margin-bottom: 0;
}
.expand-title {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-sm);
}
/* 工序节点 */
.process-node {
  margin-bottom: var(--spacing-sm);
}
.process-node:last-child {
  margin-bottom: 0;
}
.node-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2px;
}
.node-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.node-pct {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-medium);
}
.node-pct--done {
  color: var(--color-success);
}
.node-meta {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: 1.4;
}
.node-qty {
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
}
.node-dot {
  margin: 0 6px;
  color: var(--color-text-tertiary);
}
.node-bundle-text {
  color: var(--color-text-tertiary);
}
.node-bar-bg {
  height: 4px;
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs);
  overflow: hidden;
  position: relative;
}
.node-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-xs);
  transition: width 0.3s;
}
.node-bar-fill--done {
  background: var(--color-success);
}
/* 子工序列表 */
.node-sub-procs {
  margin-top: 6px;
  padding-left: 4px;
  border-left: 2px solid var(--color-border);
}
.sub-proc-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 3px 0;
}
.sp-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex: 1;
}
.sp-price {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  margin-left: var(--spacing-sm);
}
.sp-price--free {
  color: var(--color-text-tertiary);
  font-weight: var(--font-weight-normal);
}
/* SKU 表格 */
.sku-scroll {
  width: 100%;
}
.sku-table {
  min-width: 100%;
}
.sku-row {
  display: flex;
  border-bottom: 1px solid var(--color-border-light);
}
.sku-row--head {
  background: var(--color-bg-hover);
  border-radius: var(--radius-xs) var(--radius-xs) 0 0;
}
.sku-cell {
  flex: 1;
  min-width: 36px;
  padding: 7px 2px;
  font-size: var(--font-size-xs);
  text-align: center;
  color: var(--color-text-primary);
}
.sku-cell--color {
  flex: none;
  width: 48px;
  text-align: left;
  padding-left: 8px;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.sku-cell--total {
  flex: none;
  width: 40px;
  font-weight: var(--font-weight-semibold);
  color: var(--color-primary);
}
/* 快捷操作 */
.expand-actions {
  display: flex;
  gap: var(--spacing-md);
  padding-top: var(--spacing-lg);
  margin-top: 2px;
  flex-wrap: wrap;
}
.act-btn {
  font-size: var(--font-size-xs);
  padding: 3px var(--spacing-md);
  border-radius: var(--radius-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg-gray);
  border: none;
  line-height: 1.4;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
}
.act-btn--primary {
  color: var(--color-primary);
  background: var(--color-info-bg);
}
.act-btn--warn {
  color: var(--color-warning);
  background: var(--color-warning-bg);
}
.act-btn--detail {
  color: #7c5cfc;
  background: rgba(124, 92, 252, 0.1);
  font-weight: 600;
}
.act-btn--remark {
  color: var(--color-primary);
  background: var(--color-primary-bg);
}
/* 展开区容器 */
.order-expand {
  padding: 12px;
  border-top: 1px solid var(--color-border-light);
}
