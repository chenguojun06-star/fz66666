<!-- 生产订单详情页 · 完整版 -->

<view class="detail-page">
  <!-- 加载骨架 -->
  <view class="skeleton-wrap" wx:if="{{loading && !order}}">
    <view class="skel-top">
      <view class="skel-cover"></view>
      <view class="skel-info">
        <view class="skel-line skel-line--lg"></view>
        <view class="skel-line"></view>
        <view class="skel-line"></view>
        <view class="skel-line skel-line--sm"></view>
      </view>
    </view>
    <view class="skel-block"></view>
    <view class="skel-block"></view>
    <view class="skel-block skel-block--sm"></view>
  </view>

  <block wx:if="{{!loading && order}}">
    <!-- ══ 顶部信息卡 ══ -->
    <view class="top-card">
      <!-- 图片轮播区 -->
      <view class="top-left {{hasMultipleImages ? 'top-left--carousel' : ''}}" bindtap="onPreviewImage">
        <swiper class="img-swiper" wx:if="{{imageList.length > 0}}" current="{{currentImageIndex}}" bindchange="onImageChange" autoplay="{{false}}" circular="{{false}}">
          <swiper-item wx:for="{{imageList}}" wx:key="index">
            <image class="cover-img" src="{{item.url}}" mode="aspectFill" lazy-load />
          </swiper-item>
        </swiper>
        <view wx:else class="cover-placeholder">
          <text class="icon-box"></text>
        </view>

        <!-- 左右切换箭头（多张图时显示） -->
        <view class="img-nav img-nav--prev" wx:if="{{hasMultipleImages && currentImageIndex > 0}}" catchtap="goPrevImage">
          <text class="icon-chevron-left"></text>
        </view>
        <view class="img-nav img-nav--next" wx:if="{{hasMultipleImages && currentImageIndex < imageList.length - 1}}" catchtap="goNextImage">
          <text class="icon-chevron-right"></text>
        </view>

        <!-- 图片索引指示器 -->
        <view class="img-indicator" wx:if="{{hasMultipleImages}}">
          <text class="img-indicator-text">{{currentImageIndex + 1}} / {{imageList.length}}</text>
        </view>

        <!-- 图片类型标签 -->
        <view class="img-type-tag" wx:if="{{imageList.length > 0}}">
          <text>{{imageList[currentImageIndex].label}}</text>
        </view>
      </view>
      <view class="top-right">
        <view class="top-title">
          <text class="order-no" bindtap="onCopyOrderNo">{{order.orderNo || '-'}}</text>
          <text class="status-tag tag {{statusInfo.cls}}">{{statusInfo.text}}</text>
          <text wx:if="{{order.urgencyLevel === 'urgent' || order.urgencyLevel === '急'}}" class="status-tag tag tag-warning">急</text>
          <text wx:if="{{order.plateType === 'FIRST'}}" class="status-tag tag tag-processing">首单</text>
          <text wx:if="{{order.plateType === 'REORDER' || order.plateType === '翻单'}}" class="status-tag tag tag-processing">翻单</text>
        </view>
        <view class="info-row">
          <text class="info-label">款号</text>
          <text class="info-value">{{order.styleNo || '-'}}</text>
        </view>
        <view class="info-row" wx:if="{{order.customerName}}">
          <text class="info-label">客户</text>
          <text class="info-value">{{order.customerName}}</text>
        </view>
        <view class="info-row" wx:if="{{order.factoryName}}">
          <text class="info-label">工厂</text>
          <text class="info-value">{{order.factoryName}}</text>
        </view>
        <view class="info-row" wx:if="{{order.salesman || order.merchandiser}}">
          <text class="info-label">业务员</text>
          <text class="info-value">{{order.salesman || order.merchandiser}}</text>
        </view>
        <view class="info-row" wx:if="{{order.company}}">
          <text class="info-label">公司</text>
          <text class="info-value">{{order.company}}</text>
        </view>
        <view class="info-row" wx:if="{{order.factoryTypeText || order.factoryType}}">
          <text class="info-label">类型</text>
          <text class="info-value">{{order.factoryTypeText || order.factoryType}}</text>
        </view>
        <view class="info-row" wx:if="{{order.productCategory}}">
          <text class="info-label">类别</text>
          <text class="info-value">{{order.productCategory}}</text>
        </view>
        <view class="info-row" wx:if="{{order.patternMaker}}">
          <text class="info-label">版师</text>
          <text class="info-value">{{order.patternMaker}}</text>
        </view>
        <view class="info-row" wx:if="{{order.createdByName}}">
          <text class="info-label">创建人</text>
          <text class="info-value">{{order.createdByName}}</text>
        </view>
        <view class="info-row" wx:if="{{specSummary.hasSpec}}">
          <text class="info-label">颜色</text>
          <text class="info-value info-value--strong">{{specSummary.colorText}}</text>
        </view>
        <view class="info-row" wx:if="{{specSummary.hasSpec}}">
          <text class="info-label">尺码</text>
          <text class="info-value info-value--strong">{{specSummary.sizeText}}</text>
        </view>
        <view class="info-row" wx:if="{{specSummary.hasSpec}}">
          <text class="info-label">下单数</text>
          <text class="info-value info-value--strong">{{specSummary.qtyText}}</text>
        </view>
        <view class="info-row" wx:if="{{deliveryDateStr}}">
          <text class="info-label">交期</text>
          <text class="info-value">{{deliveryDateStr}}</text>
          <text class="remain-badge {{remainDaysClass}}" wx:if="{{remainDaysText}}">{{remainDaysText}}</text>
        </view>
        <view class="info-row" wx:if="{{orderBizTypeText}}">
          <text class="info-label">业务</text>
          <text class="info-value">{{orderBizTypeText}}</text>
        </view>
        <view class="info-row" wx:if="{{ecPlatformName}}">
          <text class="info-label">平台来源</text>
          <text class="info-value">{{ecPlatformName}}</text>
        </view>
      </view>
    </view>

    <!-- ════════════ ② 数量进度卡 ════════════ -->
    <view class="qty-card">
      <view class="qty-col">
        <text class="qty-num">{{totalQuantity}}</text>
        <text class="qty-label">总数量</text>
      </view>
      <view class="qty-div"></view>
      <view class="qty-col">
        <text class="qty-num qty-done">{{completedQuantity}}</text>
        <text class="qty-label">已完成</text>
      </view>
      <view class="qty-div"></view>
      <view class="qty-col">
        <text class="qty-num qty-remain">{{remainQuantity}}</text>
        <text class="qty-label">剩余</text>
      </view>
      <view class="qty-div"></view>
      <view class="qty-col">
        <text class="qty-num qty-pct">{{progressPct}}%</text>
        <text class="qty-label">进度</text>
      </view>
    </view>

    <!-- 总进度条 -->
    <view class="progress-bar-wrap">
      <view class="progress-bar">
        <view class="progress-fill" style="width:{{progressPct > 100 ? 100 : progressPct}}%"></view>
      </view>
      <view class="progress-info">
        <text class="progress-qty">{{completedQuantity}}/{{totalQuantity}}件</text>
        <text class="progress-pct">{{progressPct}}%</text>
      </view>
    </view>

    <!-- ════════════ ③ 操作区 ════════════ -->
    <view class="action-bar {{isEditable ? '' : 'action-bar--disabled'}}">
      <view class="action-btn" bindtap="onActionProcurement" data-editable="{{isEditable}}">
        <view class="ab-icon-wrap ab-icon--purple">
          <text class="icon-box"></text>
        </view>
        <text class="ab-label">采购</text>
      </view>
      <view class="action-btn" bindtap="onActionCutting" data-editable="{{isEditable}}">
        <view class="ab-icon-wrap ab-icon--blue">
          <text class="icon-cut"></text>
        </view>
        <text class="ab-label">裁剪</text>
      </view>
      <view class="action-btn" wx:if="{{isEditable && order.status === 'production'}}" bindtap="onActionProcessEdit">
        <view class="ab-icon-wrap ab-icon--teal">
          <text class="icon-setting"></text>
        </view>
        <text class="ab-label">工序</text>
      </view>
      <view class="action-btn" bindtap="onActionTransfer" data-editable="{{isEditable}}">
        <view class="ab-icon-wrap ab-icon--orange">
          <text class="icon-refresh"></text>
        </view>
        <text class="ab-label">转单</text>
      </view>
      <view class="action-btn" bindtap="onActionRemark" data-editable="{{isEditable}}">
        <view class="ab-icon-wrap ab-icon--gray">
          <text class="icon-edit"></text>
        </view>
        <text class="ab-label">备注</text>
      </view>
    </view>

    <!-- ════════════ ④ 执行进度区 · 工序进度 ════════════ -->
    <view class="section-card" wx:if="{{stages.length > 0}}">
      <view class="section-hd">
        <text class="section-title">工序进度</text>
        <text class="section-count">{{stages.length}}个工序</text>
      </view>
      <view class="stage-list">
        <view class="stage-item" wx:for="{{stages}}" wx:key="name">
          <view class="stage-info">
            <view class="stage-left">
              <view class="stage-dot {{item.statusCls}}">
              <view class="icon-checkmark-sm" wx:if="{{item.statusCls === 'stage-done'}}"></view>
              <view class="icon-dot-sm" wx:if="{{item.statusCls === 'stage-doing'}}"></view>
            </view>
              <text class="stage-name">{{item.name}}</text>
            </view>
            <text class="stage-status {{item.statusCls}}">{{item.status}}</text>
          </view>
          <view class="stage-meta" wx:if="{{item.startTime || item.completeTime || item.startOperator || item.completeOperator}}">
            <text wx:if="{{item.startTime}}" class="meta-text">开始: {{item.startTime}}</text>
            <text wx:if="{{item.startOperator && item.startOperator !== '-'}}" class="meta-text">/ {{item.startOperator}}</text>
            <text wx:if="{{item.completeTime}}" class="meta-text">→ 完成: {{item.completeTime}}</text>
            <text wx:if="{{item.completeOperator && item.completeOperator !== '-'}}" class="meta-text">/ {{item.completeOperator}}</text>
          </view>
          <view class="stage-progress" wx:if="{{item.totalQty > 0}}">
            <text class="sp-text">{{item.scannedQty || 0}} / {{item.totalQty}}</text>
            <view class="sp-bar">
              <view class="sp-fill {{item.statusCls === 'stage-done' ? 'sp-fill--done' : ''}}" style="width:{{item.progress || 0}}%"></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ════════════ ⑤ 明细数据区 ════════════ -->

    <!-- 下单矩阵 -->
    <view class="section-card" wx:if="{{matrixModel && matrixModel.hasData}}">
      <view class="section-hd">
        <text class="section-title">下单明细</text>
        <text class="section-count">共 {{matrixModel.total}} 件 / {{matrixModel.colors.length}} 色 × {{matrixModel.allSizes.length}} 码</text>
      </view>
      <view class="matrix-table">
        <view class="matrix-thead">
          <view class="matrix-tr matrix-tr--head">
            <text class="matrix-th matrix-th--color">颜色</text>
            <text class="matrix-th" wx:for="{{matrixModel.allSizes}}" wx:for-item="sz" wx:key="*this">{{sz}}</text>
            <text class="matrix-th matrix-th--total">小计</text>
          </view>
        </view>
        <view class="matrix-tbody">
          <view class="matrix-tr" wx:for="{{matrixModel.rows}}" wx:key="label">
            <text class="matrix-td matrix-td--color">{{item.label}}</text>
            <text class="matrix-td" wx:for="{{item.quantities}}" wx:for-item="qty" wx:key="*this">{{qty > 0 ? qty : '-'}}</text>
            <text class="matrix-td matrix-td--total">{{item.rowTotal}}</text>
          </view>
          <view class="matrix-tr matrix-tr--total">
            <text class="matrix-td matrix-td--color">合计</text>
            <text class="matrix-td" wx:for="{{matrixModel.sizeSummary}}" wx:for-item="szSum" wx:key="size">{{szSum.qty > 0 ? szSum.qty : '-'}}</text>
            <text class="matrix-td matrix-td--total">{{matrixModel.total}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 裁剪明细（可领取） -->
    <view class="section-card" wx:if="{{cuttingBundleList.length > 0}}">
      <view class="section-hd">
        <text class="section-title">裁剪明细</text>
        <text class="section-count">{{bundleSummary.totalBundles}}扎 / {{bundleSummary.totalQty}}件</text>
      </view>
      <view class="cut-list">
        <view class="cut-item" wx:for="{{cuttingBundleList}}" wx:key="id">
          <view class="cut-top">
            <view class="cut-left">
              <text class="cut-no">#{{item.bundleNo}}</text>
              <text class="status-tag tag {{item.statusCls}}">{{item.status}}</text>
              <view class="claim-btn-inline" bindtap="onClaimCutting" data-bundle="{{item}}" wx:if="{{item.isClaimable && isEditable}}">
                <text>领取</text>
              </view>
            </view>
            <view class="cut-right">
              <text class="cut-qty">{{item.quantity}}件</text>
            </view>
          </view>
          <view class="cut-detail-row">
            <view class="cut-detail-cell" wx:if="{{item.color}}">
              <text class="cut-detail-label">颜色</text>
              <text class="cut-detail-value">{{item.color}}</text>
            </view>
            <view class="cut-detail-cell" wx:if="{{item.size}}">
              <text class="cut-detail-label">尺码</text>
              <text class="cut-detail-value">{{item.size}}</text>
            </view>
          </view>
          <view class="cut-receiver" wx:if="{{item.receiverName}}">
            <text class="cut-receiver-text">裁剪人：{{item.receiverName}}</text>
          </view>
        </view>
      </view>
      <view class="see-all-link" bindtap="onSeeAllBundles" wx:if="{{bundleSummary.totalBundles > cuttingBundleList.length}}">
        <text>查看全部 {{bundleSummary.totalBundles}} 扎 →</text>
      </view>
    </view>

    <!-- 物料采购（可领取） -->
    <view class="section-card" wx:if="{{hasMaterialPurchases}}">
      <view class="section-hd">
        <text class="section-title">物料采购</text>
        <text class="section-count">{{materialPurchases.length}}项</text>
      </view>
      <view class="mat-list">
        <view class="mat-item" wx:for="{{materialPurchases}}" wx:key="index">
          <view class="mat-top">
            <view class="mat-info">
              <text class="mat-name">{{item.materialName}}</text>
              <text class="mat-code" wx:if="{{item.materialCode !== '-' && item.materialCode !== item.materialName}}">{{item.materialCode}}</text>
            </view>
            <view class="mat-actions">
              <text class="status-tag tag {{item.statusCls}}">{{item.status}}</text>
              <view class="claim-btn-inline" bindtap="onClaimMaterial" data-item="{{item}}" wx:if="{{item.isClaimable && isEditable}}">
                <text>领取</text>
              </view>
            </view>
          </view>
          <view class="mat-detail-row">
            <view class="mat-detail-cell">
              <text class="mat-detail-label">采购数</text>
              <text class="mat-detail-value">{{item.quantity}}{{item.unit}}</text>
            </view>
            <view class="mat-detail-cell">
              <text class="mat-detail-label">已到货</text>
              <text class="mat-detail-value mat-detail-value--highlight" wx:if="{{item.arrivedQuantity > 0}}">{{item.arrivedQuantity}}{{item.unit}}</text>
              <text class="mat-detail-value mat-detail-value--gray" wx:else>-</text>
            </view>
            <view class="mat-detail-cell">
              <text class="mat-detail-label">预计到货</text>
              <text class="mat-detail-value">{{item.expectedArrivalDate || '-'}}</text>
            </view>
          </view>
          <view class="mat-receiver" wx:if="{{item.receiverName}}">
            <text class="mat-receiver-text">采购人：{{item.receiverName}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- BOM 物料清单 -->
    <view class="section-card" wx:if="{{hasBomList}}">
      <view class="section-hd">
        <text class="section-title">BOM 物料清单</text>
        <text class="section-count">{{bomList.length}}项</text>
      </view>
      <view class="bom-group" wx:for="{{bomList}}" wx:key="index">
        <view class="bom-item">
          <view class="bom-left">
            <text class="bom-type">{{item.materialTypeText}}</text>
            <text class="bom-name">{{item.materialName}}</text>
          </view>
          <view class="bom-right">
            <text class="bom-qty">{{item.quantity}}{{item.unit}}</text>
            <text class="bom-price" wx:if="{{item.unitPrice > 0}}">¥{{item.unitPrice}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 款式报价 -->
    <view class="section-card" wx:if="{{quotation}}">
      <view class="section-hd">
        <text class="section-title">款式报价</text>
      </view>
      <view class="quotation-grid">
        <view class="qt-cell" wx:if="{{quotation.totalPrice}}">
          <text class="qt-label">总价</text>
          <text class="qt-value qt-price">¥{{quotation.totalPrice}}</text>
        </view>
        <view class="qt-cell" wx:if="{{quotation.unitPrice}}">
          <text class="qt-label">单价</text>
          <text class="qt-value">¥{{quotation.unitPrice}}</text>
        </view>
        <view class="qt-cell" wx:if="{{quotation.pricingModeText}}">
          <text class="qt-label">计价方式</text>
          <text class="qt-value">{{quotation.pricingModeText}}</text>
        </view>
      </view>
    </view>

    <!-- ════════════ ⑥ 操作记录区 ════════════ -->
    <view class="section-card" wx:if="{{records.length > 0}}">
      <view class="section-hd">
        <text class="section-title">操作记录</text>
        <text class="section-count">{{records.length}}条</text>
      </view>
      <view class="record-list">
        <view class="record-item" wx:for="{{records}}" wx:key="index">
          <view class="record-left">
            <text class="record-scan-time">{{item.scanTime}}</text>
            <text class="record-type record-type-{{item.scanTypeClass}}">{{item.scanType}}</text>
            <text class="record-proc">{{item.processName}}</text>
          </view>
          <view class="record-right">
            <text class="record-operator">{{item.operatorName}}</text>
            <text class="record-qty" wx:if="{{item.quantity > 0}}">+{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部间距 -->
    <view class="bottom-gap"></view>
  </block>

  <!-- 加载失败/空数据兜底 -->
  <view class="detail-empty-state" wx:elif="{{!loading && !order}}">
    <text class="detail-empty-text">订单数据加载失败</text>
    <view class="detail-empty-retry" bindtap="onRetryLoad">点击重试</view>
  </view>
</view>
