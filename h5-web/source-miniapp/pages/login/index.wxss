/* ==========================================
   Login - Apple HIG clean style
   Restored to match design (login.html)
   ========================================== */

page {
  background: var(--color-bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  background: linear-gradient(180deg, var(--color-primary-lightest, #e8f2ff) 0%, var(--color-bg-page) 45%);
  position: relative;
  overflow: hidden;
  padding: 0 48rpx 48rpx;
  box-sizing: border-box;
}

/* ----- Header: logo + title (outside card, per design) ----- */
.login-header {
  text-align: center;
  padding-top: 40rpx;
  padding-bottom: 48rpx;
}

.login-logo-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.login-logo {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-2xl);
  background: var(--color-primary-lightest, #e8f2ff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-title {
  font-size: 28px;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  letter-spacing: -0.56px;
}

.login-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* ----- Form shell + card ----- */
.login-shell {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 420px;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-panel {
  width: 100%;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 40rpx;
  box-shadow: var(--shadow-sm);
}

/* ----- WeChat checking ----- */
.wechat-checking {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 0;
}
.wechat-checking-badge {
  background: var(--color-primary, var(--color-primary)); color: var(--color-bg-card); border-radius: var(--radius-full);
  padding: 8rpx 28rpx; font-size: var(--font-size-sm); font-weight: var(--font-weight-bold);
}
.wechat-checking-title { margin-top: 16rpx; font-size: var(--font-size-sm); color: var(--color-text-tertiary); }

/* ----- Invite banner ----- */
.invite-banner {
  display: flex; align-items: center; justify-content: center;
  padding: 16rpx 24rpx; margin-bottom: 24rpx;
  background: var(--color-primary-lightest, rgba(31,117,234,0.06)); border-radius: var(--radius-md);
}
.invite-banner-icon { color: var(--color-primary, var(--color-primary)); font-size: var(--font-size-md); margin-right: 8rpx; }
.invite-banner-text { font-size: var(--font-size-sm); color: var(--color-text-secondary); }

/* ----- Fields with labels ----- */
.login-field { margin-bottom: 28rpx; }

.login-field-label {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.login-input-wrap {
  display: flex; align-items: center;
  background: var(--color-bg-page);
  border: 1px solid #e5e5ea;
  border-radius: var(--radius-2xl);
  padding: 0 32rpx;
  height: 52px;
  transition: border-color 0.15s ease;
}
.login-input-wrap:focus-within {
  border-color: var(--color-primary, var(--color-primary));
}

.login-input-icon {
  margin-right: 20rpx;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

.login-input {
  flex: 1; height: 100%;
  font-size: var(--font-size-md-lg);
  color: var(--color-text-primary);
  background: transparent;
}
.login-input::placeholder { color: var(--color-text-placeholder); }

.login-input-clear { font-size: var(--font-size-md); color: var(--color-text-disabled); padding: 8rpx; }
.login-input-eye { font-size: var(--font-size-xs); color: var(--color-text-tertiary); padding: 8rpx; }

.tenant-selected-tag {
  margin-top: 12rpx; font-size: var(--font-size-xs); color: var(--color-primary, var(--color-primary));
  background: var(--color-primary-lightest, rgba(31,117,234,0.06)); display: inline-block;
  padding: 6rpx 18rpx; border-radius: var(--radius-md);
}

/* ----- Tenant dropdown ----- */
.tenant-results {
  margin-top: 8rpx;
  background: var(--color-bg-card); border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  max-height: 320rpx; overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.tenant-result-item {
  padding: 22rpx 28rpx; font-size: var(--font-size-md); color: var(--color-text-primary);
  border-bottom: 1px solid var(--color-border);
}
.tenant-result-item-hover { background: var(--color-primary-lightest, rgba(31,117,234,0.06)); }
.tenant-result-empty { padding: 22rpx 28rpx; font-size: var(--font-size-sm); color: var(--color-text-tertiary); }

/* ----- Button ----- */
.login-btn-wrap { margin-top: 12rpx; }

.login-btn {
  width: 100%; height: 52px;
  display: flex; align-items: center; justify-content: center;
  background: var(--color-primary, var(--color-primary)); color: var(--color-bg-card);
  font-size: var(--font-size-lg); font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-2xl);
  letter-spacing: 0;
  transition: filter 0.15s ease, transform 0.15s ease;
}
.login-btn-hover { filter: brightness(0.95); transform: scale(0.98); }
.login-btn-disabled { background: var(--color-text-disabled); color: rgba(255,255,255,0.7); }

/* ----- Dev fields ----- */
.login-field-dev { margin-top: 16rpx; }
.login-field-dev .login-input {
  font-size: var(--font-size-xs); color: var(--color-text-tertiary);
}

/* ----- Register link (outside card, per design) ----- */
.login-register-section {
  margin-top: 40rpx; text-align: center;
}
.login-register-link {
  font-size: var(--font-size-md);
  color: var(--color-primary, var(--color-primary));
  padding: 8rpx 16rpx;
  display: inline-flex;
  align-items: center; justify-content: center;
  transition: opacity 0.15s ease;
}
.login-register-link-hover { opacity: 0.7; }

/* ----- Tip text (bottom, per design) ----- */
.login-tip {
  margin-top: auto;
  padding-top: 48rpx;
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
