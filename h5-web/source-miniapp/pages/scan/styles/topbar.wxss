/* ===== 今日统计卡片（顶部） ===== */
.today-stats-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 16px;
  margin-bottom: 8px;
  box-shadow: var(--shadow-sm);
}
.tsc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}
.tsc-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
}
.refresh-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  background: var(--color-bg-page);
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  margin-right: 8px;
}
.refresh-btn-loading {
  opacity: 0.6;
}
.refresh-btn-hover {
  background: var(--color-bg-page);
}
.refresh-icon {
  font-size: var(--font-size-xs);
}
.refresh-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.tsc-refresh {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  padding: 2px 10px;
  border-radius: var(--radius-full);
  background: var(--color-bg-page);
}
.tsc-refresh.off { opacity: 0.4; pointer-events: none; }
.tsc-grid {
  display: flex;
  gap: 8px;
}
.tsc-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.tsc-item.tsc-item--mid {
  border-left: 1px solid var(--color-border);
  border-right: 1px solid var(--color-border);
}
.tsc-item.tsc-hl {
  background: var(--color-bg-page);
  border-color: var(--color-border);
}
.tsc-num {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1;
}
.tsc-num--primary {
  color: var(--color-primary);
}
.tsc-num--success {
  color: var(--color-success);
}
.tsc-num-row {
  display: flex;
  align-items: baseline;
  gap: 2px;
}
.tsc-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.tsc-item.tsc-hl .tsc-num {
  color: var(--color-primary);
}
.tsc-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

/* ===== 快捷入口卡片（横向紧凑，一行两列） ===== */
.quick-entry-row {
  display: flex;
  flex-direction: row;
  gap: 10px;
  margin-bottom: 8px;
}
.quick-entry-card {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8px 12px;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  gap: 8px;
  height: 40px;
  box-sizing: border-box;
}
.qe-hover {
  background: var(--color-primary-bg);
  opacity: 1;
}
.qe-icon {
  width: 24px;
  height: 24px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: var(--color-primary-bg);
}
.qe-icon--green {
  background: var(--color-success-bg);
}
.qe-icon--orange {
  background: var(--color-warning-bg);
}
.qe-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.qe-arrow {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  opacity: 0.3;
}

