/* ===== 聚合历史记录 ===== */
.hist-group {
  margin-bottom: 8px;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  overflow: hidden;
}

.hist-group-header {
  padding: 8px 10px;
  background: var(--color-bg-light);
  cursor: pointer;
}
.hist-group-header-hover {
  background: var(--color-bg-light);
}

.hgh-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  margin-bottom: 4px;
}

.hgh-main {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  flex: 1;
  min-width: 0;
}

.hgh-order {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 0.3px;
}

.hgh-style {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.hgh-stage {
  font-size: var(--font-size-sm);
  font-weight: 600;
  padding: 2px 9px;
  background: var(--color-bg-light);
  color: var(--color-primary);
  border-radius: var(--radius-full);
}

.delivery-days-tag {
  font-size: var(--font-size-xs);
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 5px;
}

.delivery-days-tag.days-safe {
  color: var(--color-success);
  background: var(--color-success-bg);
}

.delivery-days-tag.days-warn {
  color: var(--color-warning);
  background: var(--color-warning-bg);
}

.delivery-days-tag.days-urgent {
  color: var(--color-error);
  background: var(--color-error-bg);
}

.delivery-days-tag.days-overdue {
  color: var(--color-error);
  background: var(--color-error-bg);
  font-weight: 700;
}

/* 数量汇总行 → 改为底部行 */
.hgh-bottom {
  display: flex;
  align-items: center;
  gap: 8px;
}

.hgh-total {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.hgh-expand-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-disabled);
  margin-left: auto;
}

.hgh-delivery-tag {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.hgh-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* 分组详情 */
.hist-group-details {
  padding: 0 12px 8px;
  background: var(--color-bg-card);
}

.hist-detail-item {
  padding: 10px;
  margin-bottom: 8px;
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  border: 1px solid var(--color-border);
}

.hist-detail-item:last-child {
  margin-bottom: 0;
}

.hdi-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.hdi-row:last-child {
  margin-bottom: 0;
}

.hdi-label {
  font-size: var(--font-size-xs); /* 备注字体 */
  color: var(--color-text-secondary);
  min-width: 40px;
}

.hdi-value {
  font-size: var(--font-size-sm); /* 辅助字体 */
  color: var(--color-text-primary);
  font-weight: 500;
}

.hdi-time {
  font-size: var(--font-size-xs); /* 备注字体 */
  color: var(--color-text-disabled);
  flex: 1;
}

.hdi-operator {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary, var(--color-text-disabled));
  margin-left: 8px;
}

.hdi-action {
  font-size: var(--font-size-xs); /* 备注字体 */
  color: var(--color-primary);
  padding: 4px 10px;
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-xs);
  background: var(--color-bg-light);
  font-weight: 500;
}
.hdi-action-hover {
  background: var(--color-bg-light);
}

/* 每条记录的码数-数量上下对齐网格 */
.hdi-size-grid {
  margin: 4px 0 6px;
  padding: 4px 0;
}

.hdi-size-row {
  display: flex;
  align-items: center;
  gap: 0;
}

.hdi-size-cell {
  min-width: 32px;
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  padding: 2px 4px;
}

.hdi-size-cell.qty {
  font-weight: 600;
  color: var(--color-text-primary);
}

.load-more {
  text-align: center;
  padding: 10px;
  padding-bottom: 24px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.load-more-hover {
  background: rgba(var(--color-primary-rgb), 0.15);
}
.load-more .no-more {
  color: var(--color-text-disabled);
}

/* ===== 扫码结果醒目提示（历史记录下方） ===== */
.scan-result-banner {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 12px;
  padding: 14px 16px;
  border-radius: var(--radius-lg);
  animation: bannerSlideIn 0.3s ease-out;
}
.scan-result-banner.banner-success {
  background: linear-gradient(135deg, #e6f9ee 0%, #d1f2e0 100%);
  border: 2px solid #34c759;
}
.scan-result-banner.banner-fail {
  background: linear-gradient(135deg, #fff0f0 0%, #ffe0e0 100%);
  border: 2px solid #ff3b30;
}
.srb-icon {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 700;
  flex-shrink: 0;
}
.banner-success .srb-icon {
  background: #34c759;
  color: #fff;
}
.banner-fail .srb-icon {
  background: #ff3b30;
  color: #fff;
}
.srb-content {
  flex: 1;
  min-width: 0;
}
.srb-title {
  display: block;
  font-size: 17px;
  font-weight: 700;
  line-height: 1.3;
}
.banner-success .srb-title {
  color: #1a7a36;
}
.banner-fail .srb-title {
  color: #c4190c;
}
.srb-msg {
  display: block;
  font-size: 13px;
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.banner-success .srb-msg {
  color: #2d8f4e;
}
.banner-fail .srb-msg {
  color: #d43020;
}
.srb-qty {
  flex-shrink: 0;
  padding: 4px 10px;
  border-radius: var(--radius-full);
  background: rgba(52, 199, 89, 0.15);
}
.srb-qty-text {
  font-size: 13px;
  font-weight: 600;
  color: #1a7a36;
}
@keyframes bannerSlideIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

