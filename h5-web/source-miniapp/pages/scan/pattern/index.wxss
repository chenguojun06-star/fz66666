
/* ========= 页面容器（匹配设计稿：扁平背景） ========= */
.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--page-padding-y) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 160rpx);
}

/* ========= 状态卡片（对齐设计稿：圆形图标 + 标题 + 交期） ========= */
.status-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: var(--color-bg-card);
  
  
  box-shadow: var(--shadow-sm);
  margin-bottom: 40rpx;

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.status-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.status-icon-circle .line-icon {
  width: 24px;
  height: 24px;
  background-size: 24px 24px;
}
.status-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.status-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  line-height: 1.2;
}
.status-subtitle {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.status-date {
  flex-shrink: 0;
  text-align: right;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2rpx;
}
.status-date-label {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
}
.status-date-value {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

/* --- 状态标签（保留生产功能，右上角浮层） --- */
.status-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: var(--font-size-xxs);
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xs);
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}
.status-badge.status-pending   { background: var(--color-warning-bg); color: var(--color-warning); }
.status-badge.status-progress  { background: rgba(var(--color-primary-rgb, 0, 122, 255), 0.08); color: rgba(var(--color-primary-rgb, 0, 122, 255), 1); }
.status-badge.status-completed { background: var(--color-success-bg); color: var(--color-success); }
.status-badge.status-received  { background: var(--color-success-bg); color: var(--color-success); }

/* ========= 分区组（对齐设计稿：标题在卡片外） ========= */
.section-group {
  margin-bottom: 40rpx;
}
.section-group-title {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-tertiary);
  padding: 0 8rpx;
  margin-bottom: 16rpx;
}
.group-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  padding: 0;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* ========= 款式头部（对齐设计稿：缩略图 + 品名 + 款号） ========= */
.style-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
}
.style-thumb {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-page);
}
.style-header-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.style-header-name {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  line-height: 1.2;
}
.style-header-no {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========= 详情字段列表（对齐设计稿：行间分隔线） ========= */
.field-list {
  padding: 0 32rpx;
}
.field-list .field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}
.field-list .field-row:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border);
}
.field-list .field-label {
  width: auto;
  flex-shrink: 0;
  font-size: var(--font-size-md-lg);
  color: var(--color-text-secondary);
}
.field-list .field-value {
  flex: 1;
  text-align: right;
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  word-break: break-all;
}

/* --- 颜色码数聚合矩阵 --- */
.matrix-section {
  padding: 32rpx;
}
.matrix-table {
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.matrix-row {
  display: flex;
  border-bottom: 1rpx solid var(--color-border);
}
.matrix-row:last-child {
  border-bottom: none;
}
.matrix-header {
  background: var(--color-bg-page);
}
.matrix-header .matrix-cell {
  font-weight: 600;
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}
.matrix-cell {
  flex: 1;
  text-align: center;
  padding: 14rpx 4rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  min-width: 0;
}
.matrix-label-cell {
  flex: 0 0 120rpx;
  text-align: left;
  padding-left: 16rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}
.matrix-total-cell {
  font-weight: 600;
  color: rgba(var(--color-primary-rgb, 0, 122, 255), 1);
}
.matrix-footer {
  padding: 24rpx 0 0;
  text-align: right;
}
.matrix-grand-total {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: rgba(var(--color-primary-rgb, 0, 122, 255), 1);
}

/* ========= 操作区域卡片 ========= */
.section-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
  box-shadow: var(--shadow-sm);
  margin-bottom: 12px;
}
.section-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-tertiary);
  padding: 0 4rpx;
  margin-bottom: var(--spacing-sm);
}

/* --- 工序选择器 --- */
.ops-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}
.selector-list {
  max-height: 340rpx;
  background: rgba(var(--color-primary-rgb, 0, 122, 255), 0.02);
  border-radius: var(--radius-sm);
  padding: 8rpx;
  margin-bottom: 20rpx;
}
.selector-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 6rpx;
  border: 2rpx solid transparent;
  transition: all .15s;
}
.selector-item.active {
  background: rgba(var(--color-primary-rgb, 0, 122, 255), 0.08);
  border-color: rgba(var(--color-primary-rgb, 0, 122, 255), 1);
}
.selector-item.disabled {
  opacity: 0.4;
}
.selector-radio {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.selector-radio.checked {
  border-color: rgba(var(--color-primary-rgb, 0, 122, 255), 1);
  background: rgba(var(--color-primary-rgb, 0, 122, 255), 1);
}
.selector-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-bg-card);
}
.selector-label {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: 500;
}

/* --- 审核提示 --- */
.review-warning {
  background: var(--color-warning-bg);
  border: 1rpx solid var(--color-warning-border);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.review-warning-text {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
}

.review-selector {
  margin-bottom: 20rpx;
}
.review-options {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}
.review-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: var(--radius-sm);
  background: var(--color-bg-page);
  border: 2rpx solid var(--color-border);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
.review-option-active {
  background: rgba(var(--color-primary-rgb, 0, 122, 255), 0.08);
  border-color: var(--color-primary);
  color: var(--color-primary);
  font-weight: 600;
}

/* --- 输入行 --- */
.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.input-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  width: 140rpx;
  flex-shrink: 0;
}
.input-field {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--input-border);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--input-bg);
}
.input-suffix {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-left: 12rpx;
}

/* --- 备注 --- */
.remark-row {
  margin-bottom: 8rpx;
}
.remark-area {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 16rpx 20rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  background: rgba(var(--color-primary-rgb, 0, 122, 255), 0.02);
  box-sizing: border-box;
  margin-top: 8rpx;
}

/* 仓库选择（对齐主扫码页样式） */
.warehouse-section {
  margin-bottom: 20rpx;
  
  background: rgba(var(--color-primary-rgb, 0, 122, 255), 0.02);
  
  

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.warehouse-chip {
  padding: 4px 14px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  border: 1px solid var(--color-border);
  background: var(--color-bg-page);
  color: var(--color-text-primary);
}

.warehouse-chip--active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

.warehouse-chip--clear {
  background: rgba(254, 226, 226, 0.6);
  border-color: rgba(252, 165, 165, 0.5);
  color: var(--color-danger);
}

.warehouse-chip--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.warehouse-chip-hover {
  opacity: 0.75;
}

/* ===== SKU列表 ===== */
.sku-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.sku-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-page, #f5f5f5);
}
.sku-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  flex: 1;
  min-width: 0;
}
.sku-label {
  font-size: var(--font-size-base, 15px);
  font-weight: var(--font-weight-medium, 500);
  color: var(--color-text-primary, #000);
}
.sku-total {
  font-size: var(--font-size-xs, 12px);
  color: var(--color-text-tertiary, #999);
}
.sku-qty-wrap {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}
.sku-qty-input {
  width: 100rpx;
  height: 64rpx;
  text-align: center;
  border: 1rpx solid var(--input-border, #d9d9d9);
  border-radius: var(--radius-xs);
  font-size: var(--font-size-base, 15px);
  font-weight: var(--font-weight-semibold, 600);
  background: var(--input-bg, #fff);
}
.sku-unit {
  font-size: var(--font-size-xs, 12px);
  color: var(--color-text-tertiary, #999);
}

/* ===== 汇总卡片 ===== */
.summary-card {
  background: var(--color-primary-bg);
  
  
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6rpx 0;
}
.summary-label {
  font-size: var(--font-size-sm, 13px);
  color: var(--color-text-secondary, #666);
}
.summary-value {
  font-size: var(--font-size-base, 15px);
  font-weight: var(--font-weight-semibold, 600);
  color: var(--color-text-primary, #000);
  font-variant-numeric: tabular-nums;
}
