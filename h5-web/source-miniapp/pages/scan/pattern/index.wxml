<!-- 样衣扫码 -->
<view class="container">

  <!-- 状态卡片（对齐设计稿：圆形图标 + 标题 + 交期） -->
  <view class="status-card">
    <view class="status-icon-circle">
      <view class="line-icon line-icon--lg icon-check-white"></view>
    </view>
    <view class="status-content">
      <text class="status-title">{{detail.operationLabel || '样衣扫码'}}</text>
      <text class="status-subtitle">{{detail.styleNo || '-'}}</text>
    </view>
    <view wx:if="{{detail.deliveryTimeShort}}" class="status-date">
      <text class="status-date-label">交期</text>
      <text class="status-date-value">{{detail.deliveryTimeShort}}</text>
    </view>
    <!-- 状态标签（保留生产功能） -->
    <view wx:if="{{detail.statusLabel && detail.statusLabel !== '-'}}" class="status-badge status-{{detail.statusType}}">{{detail.statusLabel}}</view>
  </view>

  <!-- 菲号信息 -->
  <view wx:if="{{detail.hasMatrix || detail.colorText || detail.sizeText}}" class="section-group">
    <text class="section-group-title">菲号信息</text>
    <view class="group-card">
      <!-- 颜色码数聚合矩阵 -->
      <view wx:if="{{detail.hasMatrix}}" class="matrix-section">
        <view class="matrix-table">
          <!-- 表头 -->
          <view class="matrix-row matrix-header">
            <view class="matrix-cell matrix-label-cell">码数</view>
            <view wx:for="{{detail.matrixSizes}}" wx:key="*this" class="matrix-cell">{{item}}</view>
          </view>
          <!-- 数据行 -->
          <view wx:for="{{detail.matrixRows}}" wx:for-item="row" wx:key="color" class="matrix-row">
            <view class="matrix-cell matrix-label-cell">{{row.color}}</view>
            <view wx:for="{{row.quantities}}" wx:for-item="qty" wx:for-index="qIdx" wx:key="qIdx" class="matrix-cell">{{qty}}</view>
          </view>
        </view>
        <view class="matrix-footer">
          <text class="matrix-grand-total">总数: {{detail.matrixTotal}} 件</text>
        </view>
      </view>

      <view wx:if="{{!detail.hasMatrix}}" class="field-list">
        <view class="field-row" wx:if="{{detail.colorText}}">
          <text class="field-label">颜色</text>
          <text class="field-value">{{detail.colorText}}</text>
        </view>
        <view class="field-row" wx:if="{{detail.sizeText}}">
          <text class="field-label">码数</text>
          <text class="field-value">{{detail.sizeText}}</text>
        </view>
        <view class="field-row" wx:if="{{detail.totalQuantity}}">
          <text class="field-label">数量</text>
          <text class="field-value">{{detail.totalQuantity}} 件</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 款式信息 -->
  <view class="section-group">
    <text class="section-group-title">款式信息</text>
    <view class="group-card">
      <!-- 款式头部（对齐设计稿：缩略图 + 品名 + 款号） -->
      <view class="style-header">
        <image-preview class="style-thumb" src="{{detail.coverImage || ''}}" mode="aspectFill" />
        <view class="style-header-info">
          <text class="style-header-name">{{detail.styleName || detail.styleNo || '-'}}</text>
          <text class="style-header-no" wx:if="{{detail.styleNo}}">款号：{{detail.styleNo}}</text>
        </view>
      </view>
      <!-- 款式详情字段 -->
      <view class="field-list">
        <view class="field-row" wx:if="{{detail.sourceLabel}}">
          <text class="field-label">来源</text>
          <text class="field-value">{{detail.sourceLabel}}</text>
        </view>
        <view class="field-row" wx:if="{{detail.categoryLabel}}">
          <text class="field-label">品类</text>
          <text class="field-value">{{detail.categoryLabel}}</text>
        </view>
        <view class="field-row" wx:if="{{detail.customer}}">
          <text class="field-label">客户</text>
          <text class="field-value">{{detail.customer}}</text>
        </view>
        <view class="field-row">
          <text class="field-label">设计师</text>
          <text class="field-value">{{detail.designer || '-'}}</text>
        </view>
        <view class="field-row">
          <text class="field-label">纸样师</text>
          <text class="field-value">{{detail.patternDeveloper || '-'}}</text>
        </view>
        <view class="field-row" wx:if="{{detail.deliveryTime && detail.deliveryTime !== '-'}}">
          <text class="field-label">交板</text>
          <text class="field-value">{{detail.deliveryTime}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作区域 -->
  <view class="section-card">
    <view class="section-title">{{detail.operationLabel || '样衣操作'}}</view>

    <!-- 审核未完成提示 -->
    <view wx:if="{{detail.requiresReviewBeforeInbound}}" class="review-warning">
      <view class="review-warning-text"><view class="icon-warning-orange"></view> 当前未完成样衣审核，本次会先提交审核再执行入库</view>
    </view>

    <!-- 审批选择器（审核操作时显示） -->
    <view wx:if="{{detail.operationType === 'REVIEW'}}" class="review-selector">
      <text class="input-label">审批结论</text>
      <view class="review-options">
        <view class="review-option {{detail.reviewResult === 'PASS' ? 'review-option-active' : ''}}" data-result="PASS" bindtap="onReviewResultChange">
          <view><view class="icon-check-green"></view> 通过</view>
        </view>
        <view class="review-option {{detail.reviewResult === 'REWORK' ? 'review-option-active' : ''}}" data-result="REWORK" bindtap="onReviewResultChange">
          <text>返修</text>
        </view>
        <view class="review-option {{detail.reviewResult === 'REJECT' ? 'review-option-active' : ''}}" data-result="REJECT" bindtap="onReviewResultChange">
          <text>不通过</text>
        </view>
      </view>
    </view>

    <!-- 多色多码选择（当有 skuList 时显示） -->
    <view wx:if="{{skuList.length > 0 && detail.operationType !== 'COMPLETE' && detail.operationType !== 'REVIEW'}}" class="section-card" style="margin-top: 0; padding: 0; background: transparent;">
      <text class="section-title">扫码明细（{{skuList.length}}项）</text>
      <view class="sku-list">
        <view wx:for="{{skuList}}" wx:key="id" class="sku-item">
          <view class="sku-info">
            <text class="sku-label">{{item.label}}</text>
            <text class="sku-total">订单 {{item.totalQuantity}} 件</text>
          </view>
          <view class="sku-qty-wrap">
            <input class="sku-qty-input" type="number"
                   value="{{item.inputQuantity}}"
                   data-index="{{index}}" bindinput="onSkuInput"
                   placeholder="数量" />
            <text class="sku-unit">件</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 数量汇总（当有 skuList 时显示） -->
    <view wx:if="{{skuList.length > 0 && detail.operationType !== 'COMPLETE' && detail.operationType !== 'REVIEW'}}" class="summary-card">
      <view class="summary-row">
        <text class="summary-label">总数量</text>
        <text class="summary-value">{{summary.totalQuantity}} 件</text>
      </view>
    </view>

    <!-- 数量输入（完成/返修操作时隐藏，且没有 skuList 时显示） -->
    <view wx:if="{{(!skuList || skuList.length === 0) && detail.operationType !== 'COMPLETE' && detail.operationType !== 'REVIEW'}}" class="input-row">
      <text class="input-label">数量</text>
      <input
        class="input-field"
        type="digit"
        placeholder="请输入数量"
        value="{{detail.quantity}}"
        bindinput="onQuantityInput"
      />
      <text class="input-suffix">件（最多{{detail.maxQuantity || detail.quantity || 0}}件）</text>
    </view>

    <!-- 仓位编号（仓库操作时显示） -->
    <view wx:if="{{detail.requiresWarehouseInput}}" class="warehouse-section">
      <view class="input-label">入库仓库</view>
      <view class="warehouse-option-row">
        <view
          wx:for="{{warehouseOptions}}"
          wx:key="index"
          class="warehouse-chip {{detail.warehouseCode === item ? 'warehouse-chip--active' : ''}}"
          bindtap="onWarehouseChipTap"
          data-value="{{item}}"
          hover-class="warehouse-chip-hover"
        >{{item}}</view>
        <view
          class="warehouse-chip warehouse-chip--clear {{detail.warehouseCode ? '' : 'warehouse-chip--disabled'}}"
          bindtap="onWarehouseClear"
          hover-class="warehouse-chip-hover"
        >清除</view>
      </view>
      <input
        class="input-field"
        placeholder="或手动输入仓库编号"
        value="{{detail.warehouseCode}}"
        bindinput="onWarehouseInput"
      />

      <!-- 库位选择（仓库选择后出现） -->
      <view wx:if="{{detail.warehouseCode && locationOptions.length > 0}}" class="input-label" style="margin-top: 16rpx;">入库库位</view>
      <view wx:if="{{detail.warehouseCode && locationOptions.length > 0}}" class="warehouse-option-row">
        <view
          wx:for="{{locationOptions}}"
          wx:key="index"
          class="warehouse-chip {{warehouseLocationCode === item ? 'warehouse-chip--active' : ''}}"
          bindtap="onLocationChipTap"
          data-value="{{item}}"
          hover-class="warehouse-chip-hover"
        >{{item}}</view>
        <view
          class="warehouse-chip warehouse-chip--clear {{warehouseLocationCode ? '' : 'warehouse-chip--disabled'}}"
          bindtap="onLocationClear"
          hover-class="warehouse-chip-hover"
        >清除</view>
      </view>
      <input
        wx:if="{{detail.warehouseCode}}"
        class="input-field"
        placeholder="或手动输入库位编号"
        value="{{warehouseLocationCode}}"
        bindinput="onLocationCodeInput"
      />
    </view>

    <!-- 备注 -->
    <view class="remark-row">
      <text class="input-label">备注</text>
      <textarea
        class="remark-area"
        placeholder="请输入备注信息..."
        value="{{detail.remark}}"
        bindinput="onRemarkInput"
        maxlength="200"
      />
    </view>
  </view>

  <view class="footer-bar">
    <view class="btn-cancel" hover-class="footer-bar-hover" bindtap="goBack">取消</view>
    <view class="btn-submit {{loading ? 'btn-disabled' : ''}}" hover-class="footer-bar-hover" bindtap="submitOp">
      {{loading ? '提交中...' : (detail.submitLabel || '领取')}}
    </view>
  </view>
  <ai-assistant />
</view>
