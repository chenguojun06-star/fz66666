  <!-- ⑦ 今日扫码记录（扁平列表 — 订单号+工序标签+姓名·数量+时间） -->
  <view class="section history-section">
    <view class="sec-head">
      <text class="section-title">扫码记录</text>
      <text class="sec-head-link" bindtap="onGoToHistory">全部 ›</text>
    </view>
    <view wx:if="{{my.groupedHistory.length === 0 && !my.loadingHistory}}" class="empty">暂无今日记录</view>

    <view class="scan-history-list">
      <block wx:for="{{my.groupedHistory}}" wx:for-item="group" wx:key="id">
        <view wx:for="{{group.items}}" wx:for-item="record" wx:key="id" class="scan-history-item">
          <view class="scan-history-main">
            <view class="scan-history-order-row">
              <text class="scan-history-order">{{group.orderNo}}</text>
              <text class="scan-history-tag">{{group.stage}}</text>
            </view>
            <text class="scan-history-sub">{{record.displayOperator || '-'}} · {{record.quantity || 0}}件</text>
          </view>
          <text class="scan-history-time">{{record.createdAt || record.scanTime || record.time}}</text>
        </view>
      </block>
    </view>

    <view class="load-more" hover-class="load-more-hover" hover-stay-time="100" bindtap="loadMoreMyHistory">
      <text wx:if="{{my.loadingHistory}}">加载中...</text>
      <text wx:elif="{{my.history.hasMore}}">加载更多</text>
      <text wx:else class="no-more">— END —</text>
    </view>
  </view>
