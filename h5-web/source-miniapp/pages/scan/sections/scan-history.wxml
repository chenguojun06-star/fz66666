  <!-- ⑦ 今日扫码记录（只显示当天） -->
  <!-- money.wxs 已在宿主 pages/scan/index.wxml 中引入，include 模板内路径解析以宿主页为基准 -->
  <view class="section">
    <view class="sec-head">
      <text class="section-title">今日记录</text>
    </view>
    <view wx:if="{{my.groupedHistory.length === 0 && !my.loadingHistory}}" class="empty">暂无今日记录</view>

    <view wx:for="{{my.groupedHistory}}" wx:key="id" class="hist-group">
      <view class="hist-group-header" hover-class="hist-group-header-hover" hover-stay-time="100" bindtap="toggleGroupExpand" data-group-id="{{item.id}}">
        <view class="hgh-top">
          <view class="hgh-main">
            <text class="hgh-order">{{item.orderNo}}</text>
            <text class="hgh-style">{{item.styleNo}}</text>
            <text class="hgh-stage">{{item.stage}}</text>
          </view>
        </view>
        <view class="hgh-bottom">
          <text class="hgh-time">{{utils.formatRelativeTime(item.latestTime)}}</text>
          <text class="hgh-total">共{{item.totalQuantity}}件</text>
          <text wx:if="{{item.deliveryDateStr}}" class="hgh-delivery-tag">{{item.deliveryDateStr}}</text>
          <text wx:if="{{item.remainDaysText}}" class="delivery-days-tag {{item.remainDaysClass}}">{{item.remainDaysText}}</text>
          <text class="hgh-expand-hint">{{item.expanded ? '收起' : '展开'}} ›</text>
        </view>
      </view>

      <view wx:if="{{item.expanded}}" class="hist-group-details">
        <view wx:for="{{item.items}}" wx:for-item="record" wx:for-index="recordIdx" wx:key="id" class="hist-detail-item">
          <view class="hdi-row">
            <text class="hdi-label">颜色:</text>
            <text class="hdi-value">{{record.color || '-'}}</text>
            <text class="hdi-label">单价:</text>
            <text class="hdi-value" wx:if="{{!record.hidePrice}}">¥{{money.toFixed2(record.unitPrice || 0)}}</text>
            <text class="hdi-value" wx:else>-</text>
          </view>
          <view wx:if="{{record.sizeArr && record.sizeArr.length}}" class="hdi-size-grid">
            <view class="hdi-size-row">
              <text wx:for="{{record.sizeArr}}" wx:for-item="s" wx:key="*this" class="hdi-size-cell">{{s}}</text>
            </view>
            <view class="hdi-size-row">
              <text wx:for="{{record.qtyArr}}" wx:for-item="q" wx:key="index" class="hdi-size-cell qty">{{q}}</text>
            </view>
          </view>
          <view wx:else class="hdi-row">
            <text class="hdi-label">码数:</text>
            <text class="hdi-value">{{record.size || '-'}}</text>
            <text class="hdi-label">数量:</text>
            <text class="hdi-value">{{record.quantity || 0}}件</text>
          </view>
          <view class="hdi-row">
            <text class="hdi-time">{{record.createdAt || record.scanTime || record.time}}</text>
            <text wx:if="{{record.displayOperator}}" class="hdi-operator">{{record.displayOperator}}</text>
            <view wx:if="{{record.isProcurement && !record.procurementCompleted}}" class="hdi-action" hover-class="hdi-action-hover" hover-stay-time="100" bindtap="onHandleProcurement" data-group-id="{{item.id}}" data-record-idx="{{recordIdx}}">处理</view>
            <view wx:if="{{record.isQualityReceive}}" class="hdi-action" hover-class="hdi-action-hover" hover-stay-time="100" bindtap="onHandleQuality" data-group-id="{{item.id}}" data-record-idx="{{recordIdx}}">处理</view>
            <view wx:if="{{record.scanResult === 'success' && record.canUndo}}" class="hdi-action undo-btn" hover-class="undo-btn-hover" hover-stay-time="100" catchtap="onUndoHistoryRecord" data-record-id="{{record.id}}">撤回</view>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" hover-class="load-more-hover" hover-stay-time="100" bindtap="loadMoreMyHistory">
      <text wx:if="{{my.loadingHistory}}">加载中...</text>
      <text wx:elif="{{my.history.hasMore}}">加载更多</text>
      <text wx:else class="no-more">— END —</text>
    </view>

    <!-- 扫码结果醒目提示（历史记录下方） -->
    <view wx:if="{{lastResult}}" class="scan-result-banner {{lastResult.success ? 'banner-success' : 'banner-fail'}}">
      <view class="srb-icon">{{lastResult.success ? '✓' : '✗'}}</view>
      <view class="srb-content">
        <text class="srb-title">{{lastResult.success ? '扫码成功' : '扫码失败'}}</text>
        <text class="srb-msg">{{lastResult.message}}</text>
      </view>
      <view wx:if="{{lastResult.success && lastResult.sessionQty > 0}}" class="srb-qty">
        <text class="srb-qty-text">累计 {{lastResult.sessionQty}} 件</text>
      </view>
    </view>
  </view>

