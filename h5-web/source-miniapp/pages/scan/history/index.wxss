/**
 * 历史记录页面样式 — 卡片式布局
 * 统一使用 design-tokens，card + shadow + radius
 */

page {
  background: var(--color-bg-page);
  padding-bottom: env(safe-area-inset-bottom);
}

.container {
  padding: var(--page-padding-x);
}

/* ===== sticky-search-bar 容器：负 margin 抵消 .container 水平 padding ===== */
.ssb-wrap {
  margin: 0 calc(-1 * var(--page-padding-x));
}

/* ===== filter slot 容器 ===== */
.scan-history-filter {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ===== 模式切换 ===== */
.mode-tabs {
  display: flex;
  margin: 0 0 2px;
  background: var(--color-border);
  border-radius: var(--radius-2xl);
  padding: 4px;
  overflow: hidden;
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  transition: all 0.15s ease;
}
.mode-tab-active {
  color: var(--color-text-primary);
  font-weight: 600;
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
  border-radius: var(--radius-md);
}

/* ===== 月份选择器 ===== */
.month-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  padding: 14px;
  margin: 0;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
}
.month-arrow {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-lg-xl);
  font-weight: 600;
  color: var(--color-text-secondary);
}
.month-arrow-hover { opacity: 0.7; }
.month-text {
  font-size: var(--font-size-lg-xl);
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--color-text-primary);
  min-width: 120px;
  text-align: center;
}

/* ===== 日期范围选择（自定义模式） ===== */
.date-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px;
  margin: 0;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
}
.date-col {
  flex: 1;
}
.date-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  flex-shrink: 0;
  margin-bottom: 2px;
}
.date-separator {
  font-size: var(--font-size-sm);
  color: var(--color-text-disabled);
  flex-shrink: 0;
  padding: 0 2px;
}

/* ===== 汇总统计卡片 ===== */
.summary-card {
  display: flex;
  margin: 0 0 10px;
  
  background: var(--color-bg-card);
  
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 6px 4px;
  border-radius: var(--radius-md);
  transition: background 0.15s ease;
}
.summary-item + .summary-item {
  border-left: 1px solid var(--color-border);
}
.summary-item.summary-hl {
  background: transparent;
}
.summary-item.summary-payable {
  transition: all 0.15s ease;
}
.summary-payable-hover {
  opacity: 0.8;
}
.summary-item.summary-payable-active {
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
}
.summary-num {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: var(--line-height-normal);
}
.summary-item.summary-hl .summary-num {
  color: var(--color-primary);
}
.summary-label {
  font-size: var(--font-size-xxs);
  color: var(--color-text-secondary);
  margin-top: 4px;
}
.summary-sub-label {
  font-size: var(--font-size-xxs);
  color: var(--color-text-tertiary);
  margin-top: 2px;
}

/* ===== 记录卡片列表（对齐设计稿：卡片式，非表格） ===== */
.records-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin: 0;
}
.record-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
  box-shadow: var(--shadow-sm);
  transition: transform 0.18s ease, background-color 0.18s ease;
}
.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.record-top-left {
  display: flex;
  align-items: center;
  gap: 6px;
  min-width: 0;
  flex: 1;
}
.record-date {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
}
.record-order {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.record-amount {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  flex-shrink: 0;
}
.record-bottom {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 8px;
  font-size: var(--font-size-sm);
}
.record-bundle {
  color: var(--color-text-secondary);
}
.record-dot {
  color: var(--color-text-tertiary);
}
.record-process {
  color: var(--color-text-secondary);
}
.record-qty {
  margin-left: auto;
  flex-shrink: 0;
  white-space: nowrap;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}

.empty-icon { font-size: var(--font-size-2xl); opacity: 0.5; }
.empty-text { font-size: var(--font-size-base); color: var(--color-text-secondary); font-weight: 500; }
.empty-hint { margin-top: 6px; font-size: var(--font-size-xs); color: var(--color-text-disabled); }
.loading-row { text-align: center; padding: 16px; }
.loading-text { font-size: var(--font-size-sm); color: var(--color-text-disabled); }
.load-more {
  text-align: center;
  padding: 12px;
  margin: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: 500;
}
.load-more-hover { opacity: 0.7; }
.no-more-row { background: transparent; }
.no-more-text { color: var(--color-text-disabled); font-weight: 400; }
