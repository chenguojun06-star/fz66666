
.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--page-padding-x) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 160rpx);
}

/* ===== 头部卡片（对齐设计稿：图标盒 + 标题行 + 标签） ===== */
.info-card {
  background: var(--color-bg-card);
  
  
  margin-bottom: 32rpx;
  
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.card-header {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}
.cover-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-primary-bg);
  border: 1rpx solid var(--color-primary-bg-dark);
}
.header-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}
.procurement-badge {
  display: inline-block;
  align-self: flex-start;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-semibold);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 4rpx;
}
.cutting-badge {
  display: inline-block;
  align-self: flex-start;
  background: var(--color-success);
  color: var(--color-text-white);
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-semibold);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 4rpx;
}
/* 款号 + 工序标签同一行（对齐设计稿） */
.style-no-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}
.style-no {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  white-space: nowrap;
}
.sub-info {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.delivery-info {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  margin-top: 2rpx;
}
.delivery-date {
  color: var(--color-text-tertiary);
}
.delivery-sep {
  color: var(--color-text-tertiary);
}
.delivery-remain {
  font-weight: var(--font-weight-medium);
}
.delivery-remain.days-safe {
  color: var(--color-success);
}
.delivery-remain.days-warn {
  color: var(--color-warning);
}
.delivery-remain.days-urgent {
  color: var(--color-danger);
}
.delivery-remain.days-overdue {
  color: var(--color-danger);
}
.tag-process {
  display: inline-flex;
  align-items: center;
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  white-space: nowrap;
}

/* ===== 矩阵区域（独立卡片，对齐设计稿） ===== */
.matrix-card {
  padding: 32rpx;
}
.matrix-label {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
  display: block;
}

/* ===== 提示卡片 ===== */
.insight-card, .warn-card {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  border-radius: var(--radius-md);
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
  font-size: var(--font-size-sm);
  line-height: var(--line-height-normal);
}
.insight-card { background: var(--color-primary-bg); color: var(--color-primary); }
.warn-card { background: var(--color-warning-bg); color: var(--color-warning); }
.insight-icon, .warn-icon { flex-shrink: 0; font-size: var(--font-size-md); }
.insight-text, .warn-text { flex: 1; }

/* ===== 区段卡片（对齐设计稿：圆角 + 边框 + 阴影） ===== */
.section-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}
.section-title {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
  display: block;
}

/* ===== 工艺制单 ===== */
.description-content {
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 24rpx;
}
.description-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
  white-space: pre-wrap;
  word-break: break-all;
}

/* ===== 二次工艺（重点突出） ===== */
.process-highlight-card {
  border: 2rpx solid var(--color-warning);
  background: var(--color-bg-card);
}
.process-highlight-title {
  color: var(--color-warning);
}
.process-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.process-item {
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 24rpx;
  border-left: 4rpx solid var(--color-warning);
}
.process-item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.process-type-tag {
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-white);
  background: var(--color-warning);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xs);
}
.process-name {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  flex: 1;
}
.process-status {
  font-size: var(--font-size-2xs);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xs);
}
.status-done {
  color: var(--color-success);
  background: var(--color-success-bg);
}
.status-active {
  color: var(--color-warning);
  background: var(--color-warning-bg);
}
.process-item-desc {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}
.process-desc-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-normal);
  white-space: pre-wrap;
}
.process-item-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 12rpx;
}
.process-detail-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}
.process-item-remark {
  margin-top: 8rpx;
}
.process-remark-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  font-style: italic;
}

/* ===== 面辅料列表 ===== */
.material-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.material-item {
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  padding: 24rpx;
}
.mat-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}
.mat-row + .mat-row {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-border);
}
.mat-tag {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xs);
}
.mat-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.mat-row-qty {
  gap: 0;
}
.qty-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}
.qty-item + .qty-item {
  border-left: 1rpx solid var(--color-border);
  padding-left: 24rpx;
}
.qty-val {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.qty-val.arrived { color: var(--color-success); }
.qty-val.pending { color: var(--color-warning); }
.qty-lbl {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ===== 裁剪任务信息 ===== */
.cutting-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.cutting-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}
.cutting-row:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border);
}
.cutting-lbl {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  width: 160rpx;
  flex-shrink: 0;
}
.cutting-val {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  flex: 1;
  text-align: right;
}
.status-pending { color: var(--color-warning); }
.status-received { color: var(--color-success); }

.empty-cutting {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}
.empty-cutting-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}
.empty-cutting-hint {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  margin-top: 8rpx;
}

.tip-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  
  
  margin-bottom: 32rpx;
  background: var(--color-primary-bg);
  
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  line-height: var(--line-height-normal);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.tip-icon { flex-shrink: 0; font-size: var(--font-size-md); display: flex; align-items: center; }
.tip-text { flex: 1; }

/* ===== 汇总卡片（对齐设计稿：大号数字 + 左右布局） ===== */
.summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  
  
  margin-bottom: 32rpx;
  
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.summary-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.summary-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  text-align: right;
  gap: 4rpx;
}
.summary-item {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}
.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}
.summary-row + .summary-row {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}
.summary-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.summary-value {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.summary-value.amount { color: var(--color-primary); }
.arrived-text { color: var(--color-success); }
.pending-text { color: var(--color-warning); }

/* ===== SKU列表（对齐设计稿：行间分隔线 + 输入框样式） ===== */
.sku-list {
  display: flex;
  flex-direction: column;
}
.sku-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}
.sku-item:not(:last-child) {
  border-bottom: 1rpx solid var(--color-border);
}
.sku-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}
.sku-label {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.sku-total {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.sku-qty-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.sku-qty-input {
  width: 128rpx;
  height: 72rpx;
  text-align: center;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-lg);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  background: var(--color-bg-page);
  color: var(--color-text-primary);
}
.sku-qty-readonly {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
  border-color: transparent;
}
.sku-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* ===== AI 智能提示气泡（对齐设计稿：brand-50 底 + icon） ===== */
.ai-bubble {
  margin: 0 0 32rpx;
  padding: 24rpx 32rpx;
  border-radius: var(--radius-xl);
  background: var(--color-primary-bg);
  border: 1rpx solid var(--color-primary-bg-dark);
  position: relative;
}
.ai-bubble-high {
  background: var(--color-danger-bg);
  border-color: var(--color-danger);
}
.ai-bubble-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.ai-bubble-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ai-bubble-icon-wrap .line-icon {
  width: 20px;
  height: 20px;
  background-size: 20px 20px;
}
.ai-bubble-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary-dark);
}
.ai-bubble-high .ai-bubble-title {
  color: var(--color-danger);
}
.ai-bubble-stage {
  font-size: var(--font-size-2xs);
  color: var(--color-text-white);
  background: var(--color-primary);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xs);
}
.ai-bubble-high .ai-bubble-stage {
  background: var(--color-danger);
}
.ai-bubble-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ai-bubble-close .icon-close {
  width: 16px;
  height: 16px;
  background-size: 16px 16px;
}
.ai-bubble-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: var(--line-height-relaxed);
  white-space: pre-wrap;
}
.ai-bubble-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}
.ai-bubble-tag {
  font-size: var(--font-size-2xs);
  color: var(--color-primary);
  background: var(--color-bg-card);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xs);
}
.ai-bubble-high .ai-bubble-tag {
  color: var(--color-danger);
  background: var(--color-bg-card);
}
