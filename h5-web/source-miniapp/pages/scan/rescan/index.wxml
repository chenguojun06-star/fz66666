<view class="container">
  <!-- 信息卡片 -->
  <view class="info-card">
    <view class="card-header">
      <view class="cover-wrap">
        <image-preview src="{{detail.coverImage || ''}}" mode="aspectFill" />
      </view>
      <view class="header-info">
        <text class="style-no">{{detail.styleNo || detail.orderNo}}</text>
        <text class="style-name">{{detail.styleName || '扫码记录'}}</text>
      </view>
    </view>
  </view>

  <!-- 字段列表卡片 -->
  <view class="field-card">
    <view class="field-row">
      <text class="field-label">订单号</text>
      <text class="field-value">{{detail.orderNo}}</text>
    </view>
    <view class="field-row">
      <text class="field-label">菲号</text>
      <text class="field-value">{{detail.bundleNo}}</text>
    </view>
    <view class="field-row">
      <text class="field-label">数量</text>
      <text class="field-value highlight">{{detail.quantity}} 件</text>
    </view>
    <view class="field-row">
      <text class="field-label">扫码时间</text>
      <text class="field-value">{{detail.scanTime}}</text>
    </view>
    <view wx:if="{{detail.processName}}" class="field-row">
      <text class="field-label">工序</text>
      <text class="field-value">{{detail.processName}}</text>
    </view>
  </view>

  <!-- 退回警告 -->
  <view class="warning-card">
    <view class="warning-icon">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M12 3L22 20H2L12 3Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <line x1="12" y1="9" x2="12" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <circle cx="12" cy="17" r="1" fill="currentColor"/>
      </svg>
    </view>
    <view class="warning-content">
      <text class="warning-title">确认退回此扫码记录？</text>
      <text class="warning-desc">退回后该记录将被撤销，可重新扫码录入。退回操作有时间限制（1小时内）。</text>
    </view>
  </view>

  <view class="footer-bar">
    <view class="btn-secondary" hover-class="footer-bar-hover" bindtap="goBack">取消</view>
    <view class="btn-danger {{loading ? 'btn-disabled' : ''}}" hover-class="footer-bar-hover" bindtap="confirmRescan">
      {{loading ? '退回中...' : '确认退回'}}
    </view>
  </view>
</view>
