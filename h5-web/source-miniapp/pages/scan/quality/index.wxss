.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--page-padding-x) var(--page-padding-x) calc(env(safe-area-inset-bottom) + 80px);
}

/* ---- info-card ---- */
.info-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-md);
  /* Apple: removed hard border, use shadow */
}
.card-header { display: flex; align-items: flex-start; gap: var(--spacing-sm); }
.cover-wrap {
  width: 55px; height: 55px;
  border-radius: var(--radius-md); overflow: hidden;
  flex-shrink: 0; background: var(--color-border-light);
}
.header-info { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
.style-no { font-size: var(--font-size-base); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
.sub-info { font-size: var(--font-size-xs); color: var(--color-text-tertiary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tag-process {
  display: inline-block; align-self: flex-start;
  background: var(--color-primary-bg); color: var(--color-primary);
  font-size: var(--font-size-xs); padding: 1px 6px; border-radius: var(--radius-xs);
}

/* ---- insight ---- */
.insight-card {
  display: flex; align-items: flex-start; gap: var(--spacing-xs);
  border-radius: var(--radius-md); padding: var(--spacing-sm) var(--spacing-md); margin-bottom: var(--spacing-md);
  background: var(--color-primary-bg); color: var(--color-primary);
  font-size: var(--font-size-xs); line-height: var(--line-height-normal);
}
.insight-icon { flex-shrink: 0; font-size: var(--font-size-sm); }
.insight-body { display: flex; flex-direction: column; gap: 2px; flex: 1; }
.insight-text { font-size: var(--font-size-xs); }
.insight-urgent { color: var(--color-danger); font-weight: var(--font-weight-medium); }
.insight-label { font-size: var(--font-size-xs); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); margin-top: 2px; }
.insight-checkpoint { font-size: var(--font-size-xs); color: var(--color-text-secondary); line-height: var(--line-height-normal); }
.insight-action {
  align-self: flex-start; margin-top: 4px;
  font-size: var(--font-size-xs); font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  padding: 2px 8px; border-radius: var(--radius-xs);
  background: var(--color-primary-bg);
}

/* ---- section ---- */
.section-card {
  background: var(--color-bg-card); border-radius: var(--radius-lg);
  padding: var(--spacing-sm) var(--spacing-md); margin-bottom: var(--spacing-md);
  /* Apple: removed hard border, use shadow */
}
.section-title { font-size: var(--font-size-sm); font-weight: var(--font-weight-semibold); color: var(--color-text-primary); margin-bottom: var(--spacing-sm); display: block; }

/* ---- quality result ---- */
.result-group { display: flex; gap: var(--spacing-md); }
.result-btn {
  flex: 1; display: flex; align-items: center; justify-content: center; gap: var(--spacing-xs);
  height: var(--btn-height-md); border-radius: var(--radius-lg);
  background: transparent; font-size: var(--font-size-base); color: var(--color-text-secondary);
  border: 1.5px solid var(--color-border); transition: all 0.2s;
}
.result-btn.active-pass {
  background: transparent; color: var(--color-success);
  border-color: var(--color-success); font-weight: var(--font-weight-semibold);
}
.result-btn.active-fail {
  background: transparent; color: var(--color-danger);
  border-color: var(--color-danger); font-weight: var(--font-weight-semibold);
}
.result-icon { font-size: var(--font-size-lg); }

/* ---- form ---- */
.form-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 0; border-bottom: 1px solid var(--color-border-light);
}
.form-row:last-child { border-bottom: none; }
.form-row-col {
  display: flex; flex-direction: column; gap: 4px;
  padding: 10px 0;
}
.form-label { font-size: var(--font-size-sm); color: var(--color-text-primary); flex-shrink: 0; }
.form-input {
  width: 120px; height: 32px; text-align: right;
  border: 1px solid var(--color-border); border-radius: var(--radius-sm);
  padding: 0 var(--spacing-sm); font-size: var(--font-size-sm);
  background: var(--color-bg-card);
}
.form-picker {
  display: flex; align-items: center; gap: var(--spacing-xs);
  font-size: var(--font-size-sm); color: var(--color-text-primary);
}
.picker-arrow { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }

/* ---- photo grid ---- */
.photo-grid { display: flex; flex-wrap: wrap; gap: var(--spacing-sm); }
.photo-item { position: relative; width: 70px; height: 70px; border-radius: var(--radius-md); overflow: hidden; }
.photo-img { width: 100%; height: 100%; }
.photo-del {
  position: absolute; top: 2px; right: 2px;
  width: 18px; height: 18px; border-radius: var(--radius-full);
  background: var(--color-overlay); color: var(--color-text-white);
  display: flex; align-items: center; justify-content: center;
  font-size: var(--font-size-sm); line-height: 1;
}
.photo-add {
  width: 70px; height: 70px; border-radius: var(--radius-md);
  /* Apple: removed hard border, use shadow */
  align-items: center; justify-content: center; gap: 2px;
  background: var(--color-bg-gray);
}
.add-icon { font-size: var(--font-size-lg); }
.add-text { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }

/* ---- remark ---- */
.remark-area {
  width: 100%; min-height: 50px;
  padding: 6px; font-size: var(--font-size-sm);
  /* Apple: removed hard border, use shadow */
  box-sizing: border-box;
}

/* ---- AI image analysis ---- */
.ai-image-result {
  margin-top: var(--spacing-md);
  background: var(--color-primary-bg);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm);
}
.ai-image-header {
  display: flex; align-items: center; gap: var(--spacing-xs);
  margin-bottom: 4px;
}
.ai-image-icon { font-size: var(--font-size-sm); }
.ai-image-title {
  font-size: var(--font-size-sm); font-weight: var(--font-weight-medium);
  color: var(--color-text-primary); flex: 1;
}
.ai-image-adopt, .ai-image-retry {
  font-size: var(--font-size-xs); color: var(--color-primary);
  padding: 2px 6px; border-radius: var(--radius-xs);
  background: var(--color-primary-bg);
  font-weight: var(--font-weight-medium);
}
.ai-image-loading {
  font-size: var(--font-size-xs); color: var(--color-text-secondary);
  padding: 4px 0; text-align: center;
}
.ai-image-error {
  font-size: var(--font-size-xs); color: var(--color-danger);
  padding: 2px 0;
}
.ai-image-defects { display: flex; flex-direction: column; gap: 2px; }
.ai-severity {
  display: flex; align-items: center; gap: 4px;
  font-size: var(--font-size-xs); color: var(--color-text-secondary);
}
.severity-badge {
  font-size: var(--font-size-xs); font-weight: var(--font-weight-semibold);
  padding: 1px 5px; border-radius: var(--radius-xs);
}
.severity-CRITICAL { background: var(--color-danger-bg); color: var(--color-danger); }
.severity-HIGH { background: var(--color-warning-bg); color: var(--color-warning); }
.severity-MEDIUM { background: var(--color-warning-bg); color: var(--color-warning); }
.severity-LOW { background: var(--color-success-bg); color: var(--color-success); }
.severity-NONE { background: var(--color-success-bg); color: var(--color-success); }
.defect-item {
  display: flex; flex-direction: column; gap: 1px;
  padding-left: 4px;
}
.defect-type { font-size: var(--font-size-xs); color: var(--color-text-primary); font-weight: var(--font-weight-medium); }
.defect-desc { font-size: var(--font-size-xs); color: var(--color-text-secondary); }
.defect-confidence { font-size: var(--font-size-xs); color: var(--color-text-tertiary); }
.ai-image-report, .ai-image-recommend {
  margin-top: 4px; padding-top: 4px;
  border-top: 1px solid var(--color-border-light);
}
.report-label, .recommend-label {
  font-size: var(--font-size-xs); color: var(--color-text-secondary);
  display: block; margin-bottom: 1px;
}
.report-text, .recommend-text {
  font-size: var(--font-size-xs); color: var(--color-text-primary);
  line-height: var(--line-height-normal);
}
.ai-image-clean {
  font-size: var(--font-size-xs); color: var(--color-success);
  padding: 4px 0; text-align: center;
}
