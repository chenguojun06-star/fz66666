<view class="container">

  <!-- 订单信息 -->
  <view class="info-card">
    <view class="card-header">
      <image-preview class="cover-wrap" src="{{coverImage || ''}}" mode="aspectFill" />
      <view class="header-info">
        <text class="style-no">{{detail.styleNo || detail.orderNo}}</text>
        <text class="sub-info">订单 {{detail.orderNo}}</text>
        <text wx:if="{{detail.bundleNo}}" class="sub-info">菲号 {{detail.bundleNo}}</text>
      </view>
    </view>
    <view class="info-divider"></view>
    <view class="kv-grid">
      <view class="kv-item">
        <text class="kv-label">颜色</text>
        <text class="kv-value">{{detail.color || '-'}}</text>
      </view>
      <view class="kv-item kv-item-border">
        <text class="kv-label">码数</text>
        <text class="kv-value">{{detail.size || '-'}}</text>
      </view>
      <view class="kv-item">
        <text class="kv-label">数量</text>
        <text class="kv-value">{{detail.quantity}}件</text>
      </view>
      <view class="kv-item kv-item-border">
        <text class="kv-label">工序</text>
        <text class="kv-value">{{detail.processName || '-'}}</text>
      </view>
    </view>
  </view>

  <!-- AI 建议 -->
  <view wx:if="{{aiSuggestion}}" class="insight-card">
    <view class="line-icon icon-ai insight-icon"></view>
    <view class="insight-body">
      <text wx:if="{{historicalDefectRate}}" class="insight-text">历史不良率 {{historicalDefectRate}}</text>
      <view wx:if="{{aiSuggestion.urgentTip}}" class="insight-text insight-urgent"><view class="icon-warning-orange"></view> {{aiSuggestion.urgentTip}}</view>
      <block wx:if="{{aiSuggestion.checkpoints && aiSuggestion.checkpoints.length > 0}}">
        <text class="insight-label">质检要点：</text>
        <text wx:for="{{aiSuggestion.checkpoints}}" wx:key="*this" class="insight-checkpoint">• {{item}}</text>
      </block>
      <block wx:if="{{aiSuggestionList.length > 0}}">
        <text class="insight-label">缺陷提示：</text>
        <text wx:for="{{aiSuggestionList}}" wx:key="category" class="insight-checkpoint">【{{item.label}}】{{item.text}}</text>
      </block>
      <view wx:if="{{aiSuggestionList.length > 0}}" class="insight-action" bindtap="onAdoptAiSuggestion">采纳建议</view>
    </view>
  </view>

  <!-- 质检结果选择 -->
  <view class="section-group">
    <text class="section-group-title">质检结果</text>
    <view class="result-group">
      <view class="result-btn {{result === 'qualified' ? 'active-pass' : ''}}"
            bindtap="onSelectResult" data-value="qualified">
        <view class="result-icon"><view class="icon-check-green"></view></view>
        <text>合格</text>
      </view>
      <view class="result-btn {{result === 'unqualified' ? 'active-fail' : ''}}"
            bindtap="onSelectResult" data-value="unqualified">
        <view class="line-icon icon-close result-icon"></view>
        <text>不合格</text>
      </view>
    </view>
  </view>

  <!-- 不合格详情 -->
  <view wx:if="{{result === 'unqualified'}}" class="section-group">
    <text class="section-group-title">不良品详情</text>
    <view class="group-card">
      <view class="group-field-list">
        <view class="form-row">
          <text class="form-label">不良数量</text>
          <input class="form-input" type="number" value="{{defectQuantity}}"
                 bindinput="onDefectQuantityInput" placeholder="请输入不良数量" />
        </view>

        <view class="form-row">
          <text class="form-label">缺陷类别</text>
          <picker range="{{defectCategories}}" value="{{defectCategoryIndex}}" bindchange="onDefectCategoryChange">
            <view class="form-picker">
              {{defectCategoryIndex >= 0 ? defectCategories[defectCategoryIndex] : '请选择'}}
              <view class="picker-arrow"><view class="icon-chevron-down-sm"></view></view>
            </view>
          </picker>
        </view>

        <view class="form-row">
          <text class="form-label">处理方式</text>
          <picker range="{{handleMethods}}" value="{{handleMethodIndex}}" bindchange="onHandleMethodChange">
            <view class="form-picker">
              {{handleMethodIndex >= 0 ? handleMethods[handleMethodIndex] : '请选择'}}
              <view class="picker-arrow"><view class="icon-chevron-down-sm"></view></view>
            </view>
          </picker>
        </view>
      </view>
    </view>

    <!-- 图片上传 -->
    <view class="section-group" style="margin-top: 20rpx;">
      <view class="photo-title-row">
        <text class="section-group-title" style="margin-bottom: 0;">不良品照片</text>
        <text class="photo-count-hint">最多 5 张</text>
      </view>
      <view class="photo-grid">
        <view wx:for="{{images}}" wx:key="*this" class="photo-item">
          <image-preview class="photo-img" src="{{item}}" mode="aspectFill" />
          <view class="photo-del" data-index="{{index}}" catchtap="onDeleteImage"><view class="icon-multiply-sm"></view></view>
        </view>
        <view wx:if="{{images.length < 5}}" class="photo-add" bindtap="onUploadImage">
          <view class="add-icon"><view class="line-icon icon-camera"></view></view>
          <text class="add-text">拍照/选图</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="section-group">
    <text class="section-group-title">质检备注</text>
    <view class="group-card">
      <textarea class="remark-area" value="{{remark}}" bindinput="onRemarkInput"
                placeholder="可填写质检备注" maxlength="500" auto-height />
    </view>
  </view>

  <view class="footer-bar">
    <view class="btn-cancel" hover-class="footer-bar-hover" bindtap="goBack">取消</view>
    <view class="btn-submit {{loading ? 'btn-disabled' : ''}}" hover-class="footer-bar-hover" bindtap="submitQuality">
      {{loading ? '提交中...' : '提交质检'}}
    </view>
  </view>

  <privacy-dialog id="privacyDialog" />
  <ai-assistant />
</view>
