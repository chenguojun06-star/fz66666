.page {
  padding: 40px 20px;
  background: var(--color-bg-card);
  box-sizing: border-box;
  height: 100vh;
}

/* Header */
.doc-header {
  text-align: center;
  margin-bottom: 40px;
}

.doc-title {
  display: block;
  font-size: 22px;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  letter-spacing: -0.02em;
}

.doc-date {
  display: block;
  margin-top: 12px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* Sections */
.doc-section {
  margin-bottom: 32px;
}

.doc-heading {
  display: block;
  margin-bottom: 12px;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  letter-spacing: -0.01em;
}

/* Sub-sections (space-y-4 = 16px) */
.doc-sub-section {
  margin-top: 16px;
}

.doc-sub-section:first-child {
  margin-top: 0;
}

.doc-sub-heading {
  display: block;
  margin-bottom: 4px;
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}

.doc-body {
  display: block;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  line-height: 1.7;
}

/* Styled bullet list (circle bullets like design) */
.doc-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.doc-list-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.doc-bullet {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-border);
  flex-shrink: 0;
  margin-top: 10px;
}

/* Email link (brand-500 color) */
.doc-contact {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
}

.doc-email {
  font-size: var(--font-size-base);
  color: var(--color-primary);
  line-height: 1.7;
}

/* Footer */
.doc-footer {
  margin-top: 48px;
  padding-top: 24px;
  border-top: 1px solid var(--color-border);
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}
