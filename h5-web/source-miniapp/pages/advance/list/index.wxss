@import '/styles/page-utils.wxss';
@import '/styles/modal-form.wxss';

.page {
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--color-bg-page);
  min-height: 100vh;
}

/* ===== Filter Bar ===== */
.filter-bar {
  display: flex;
  gap: 8px;
  padding: 8px 16px;
}

.filter-item {
  flex: 1;
  min-width: 0;
}

.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4px;
  padding: 10px 12px;
  background: var(--color-bg-card);
  border-radius: 19px;
  box-shadow: var(--shadow-sm);
}

.picker-text {
  font-size: 13px;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-chevron {
  flex-shrink: 0;
  width: 0;
  height: 0;
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-top: 4px solid var(--color-text-tertiary);
}

/* ===== Search Row ===== */
.search-row {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 16px 8px;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
  height: 40px;
  padding: 0 12px;
  background: var(--color-bg-card);
  border-radius: 19px;
  border: 1px solid #e5e5ea;
}
.search-box:focus-within {
  border-color: var(--color-primary);
}

.search-icon {
  flex-shrink: 0;
  width: 14px;
  height: 14px;
  border: 2px solid var(--color-text-tertiary);
  border-radius: 50%;
  position: relative;
}
.search-icon::after {
  content: '';
  position: absolute;
  right: -5px;
  bottom: -5px;
  width: 6px;
  height: 2px;
  background: var(--color-text-tertiary);
  transform: rotate(45deg);
  border-radius: 1px;
}

.search-input {
  font-size: 14px;
  color: var(--color-text-primary);
  flex: 1;
  min-width: 0;
}

.search-btn {
  flex-shrink: 0;
  height: 40px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-white);
  background: var(--color-primary);
  border-radius: 19px;
  white-space: nowrap;
}

.search-btn-hover {
  opacity: 0.9;
}

/* ===== List ===== */
.list-section {
  padding: 4px 16px 16px;
}

.advance-card {
  background: var(--color-bg-card);
  border-radius: 19px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
  border-left: 3px solid var(--color-border);
  overflow: hidden;
}
.advance-card.tag-orange { border-left-color: var(--color-warning); }
.advance-card.tag-green { border-left-color: var(--color-success); }
.advance-card.tag-red { border-left-color: var(--color-danger); }

.card-hover {
  background: var(--color-bg-hover);
}

/* Row 1: order# + status tag */
.card-row1 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.advance-no {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 6px;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}
.status-tag.tag-orange { background: var(--color-warning-bg); color: var(--color-warning); }
.status-tag.tag-green { background: var(--color-success-bg); color: var(--color-success); }
.status-tag.tag-red { background: var(--color-danger-bg); color: var(--color-danger); }

/* Row 2: person icon + name + separator + factory */
.card-row2 {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 8px;
  font-size: 13px;
  color: var(--color-text-secondary);
}

.person-icon {
  flex-shrink: 0;
  width: 14px;
  height: 14px;
  position: relative;
}
.person-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  border: 1.5px solid var(--color-text-tertiary);
}
.person-icon::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 14px;
  height: 7px;
  border-radius: 7px 7px 0 0;
  border: 1.5px solid var(--color-text-tertiary);
  border-bottom: none;
}

.person-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--color-text-secondary);
}

.row-separator {
  flex-shrink: 0;
  color: var(--color-text-tertiary);
}

.factory-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--color-text-secondary);
}

/* Row 3: amount + deduction tag */
.card-row3 {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8px;
  margin-top: 12px;
}

.amount-text {
  font-size: 22px;
  font-weight: 700;
  line-height: 1;
  color: var(--color-text-primary);
}

.deduct-tag {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 6px;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}
.deduct-tag.tag-orange { background: rgba(255, 149, 0, 0.12); color: var(--color-warning); }
.deduct-tag.tag-green { background: var(--color-bg-hover); color: var(--color-text-secondary); }
.deduct-tag.tag-red { background: rgba(255, 59, 48, 0.12); color: var(--color-danger); }

.remaining-text {
  display: block;
  margin-top: 6px;
  font-size: 12px;
  color: var(--color-text-tertiary);
}

/* Footer */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border);
}

.time-text {
  font-size: 12px;
  color: var(--color-text-tertiary);
  white-space: nowrap;
}

.click-hint {
  font-size: 12px;
  color: var(--color-warning);
  white-space: nowrap;
}

/* ===== FAB ===== */
.fab-btn {
  position: fixed;
  right: 16px;
  bottom: calc(24px + env(safe-area-inset-bottom));
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  z-index: var(--z-float-trigger);
}

.fab-icon-circle {
  position: relative;
  width: 24px;
  height: 24px;
  border: 2px solid var(--color-text-white);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fab-icon-plus-h {
  position: absolute;
  width: 12px;
  height: 2px;
  background: var(--color-text-white);
  border-radius: 1px;
}

.fab-icon-plus-v {
  position: absolute;
  width: 2px;
  height: 12px;
  background: var(--color-text-white);
  border-radius: 1px;
}

/* ===== Inline Form Card (replaces modal & action-sheet overlays) ===== */
.inline-form-card {
  background: var(--color-bg-card);
  border-radius: 19px;
  padding: 16px;
  margin: 12px 0;
  box-shadow: var(--shadow-sm);
}

.inline-form-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 12px;
  margin-bottom: 12px;
  border-bottom: 1px solid var(--color-border);
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.inline-form-body {
  padding: 0;
}

.inline-form-actions {
  display: flex;
  gap: 12px;
  padding-top: 12px;
  margin-top: 4px;
  border-top: 1px solid var(--color-border);
}

/* ===== Action Items (inline) ===== */
.action-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 14px 0;
  text-align: center;
  font-size: 15px;
  font-weight: 500;
  border-radius: 19px;
}

.action-icon {
  width: 18px;
  height: 18px;
  position: relative;
  flex-shrink: 0;
}

.action-icon-check::before {
  content: '';
  position: absolute;
  top: 2px;
  left: 5px;
  width: 6px;
  height: 10px;
  border-right: 2px solid var(--color-success);
  border-bottom: 2px solid var(--color-success);
  transform: rotate(45deg);
}

.action-icon-warn {
  border: 2px solid var(--color-danger);
  border-radius: 50%;
}
.action-icon-warn::after {
  content: '!';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 12px;
  font-weight: 700;
  color: var(--color-danger);
  line-height: 1;
}

.action-approve {
  color: var(--color-success);
}

.action-reject {
  color: var(--color-danger);
}

.action-cancel {
  color: var(--color-text-secondary);
  padding: 14px 16px;
  margin: 0 16px 12px;
}

/* ===== Create Form sub-components (inline) ===== */
.modal-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.modal-close {
  position: relative;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-close-line1 {
  position: absolute;
  width: 16px;
  height: 2px;
  background: var(--color-text-tertiary);
  transform: rotate(45deg);
  border-radius: 1px;
}

.modal-close-line2 {
  position: absolute;
  width: 16px;
  height: 2px;
  background: var(--color-text-tertiary);
  transform: rotate(-45deg);
  border-radius: 1px;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  border-radius: 19px;
  font-size: 15px;
  font-weight: 500;
}

.modal-btn.cancel {
  background: var(--color-bg-hover);
  color: var(--color-text-secondary);
}

.modal-btn.confirm {
  background: var(--color-primary);
  color: var(--color-text-white);
}

/* ===== Form Items ===== */
.mf-item {
  margin-bottom: 16px;
}

.mf-label {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: var(--color-text-secondary);
  margin-bottom: 6px;
}

.mf-required::after {
  content: ' *';
  color: var(--color-danger);
}

.mf-input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  font-size: 14px;
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 19px;
}

.mf-amount-wrap {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 12px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
}

.mf-amount-prefix {
  flex-shrink: 0;
  font-size: 14px;
  color: var(--color-text-tertiary);
  margin-right: 4px;
}

.mf-amount-input {
  flex: 1;
  min-width: 0;
  font-size: 14px;
  color: var(--color-text-primary);
}

.mf-textarea {
  width: 100%;
  min-height: 72px;
  padding: 10px 12px;
  font-size: 14px;
  color: var(--color-text-primary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 19px;
}

.load-more {
  text-align: center;
  padding: 16px 0;
  font-size: 12px;
  color: var(--color-text-tertiary);
}
