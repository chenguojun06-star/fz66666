<view class="page">
  <!-- 问候卡片 -->
  <view class="header">
    <view class="header-avatar">{{userName ? userName[0] : '用户'}}</view>
    <view class="header-info">
      <text class="greeting-name">{{greeting}}，{{userName}}</text>
      <text class="greeting-sub">{{orgName || '欢迎使用衣智链'}}</text>
      <text class="greeting-date">{{dateInfo.date}} {{dateInfo.day}}</text>
    </view>
  </view>

  <!-- 今日小贴士 -->
  <view class="tip-card">
    <view class="tip-icon-circle">
      <text class="tip-icon-text">i</text>
    </view>
    <view class="tip-content">
      <text class="tip-title">今日小贴士</text>
      <text class="tip-text">{{dateInfo.dailyTip}}</text>
    </view>
  </view>

  <!-- 应用网格 -->
  <view class="menu-section">
    <view class="menu-grid">
      <view 
        class="menu-item" 
        wx:for="{{menuItems}}" 
        wx:key="id" 
        bindtap="onMenuTap" 
        data-index="{{index}}"
        hover-class="menu-item-hover" 
        hover-stay-time="100"
      >
        <view class="menu-icon-circle {{item.circleClass}}">
          <view class="line-icon line-icon--lg {{item.iconClass}}"></view>
        </view>
        <text class="menu-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- AI助手卡片 -->
  <view class="ai-card">
    <view class="ai-card-header">
      <view class="ai-card-avatar">
        <view class="line-icon line-icon--lg icon-menu-ai"></view>
      </view>
      <view class="ai-card-info">
        <text class="ai-card-title">小云AI助手</text>
        <text class="ai-card-sub">有什么可以帮你的？</text>
      </view>
    </view>
    <view class="ai-card-input-row">
      <text class="ai-card-input-text">输入你的问题...</text>
      <view class="ai-card-send-btn">
        <view class="icon-send-arrow"></view>
      </view>
    </view>
  </view>

  <ai-assistant id="homeAiAssistant" notice-count="{{unreadNoticeCount}}" />
</view>
