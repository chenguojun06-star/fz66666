/* ============ 首页 ============ */
page {
  background: var(--color-bg-page);
}

.page {
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

/* -- 问候卡片 -- */
.greeting-card {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding: var(--spacing-xl) var(--page-padding-x) var(--spacing-md);
  background: var(--color-bg-card);
}

.greeting-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.greeting-avatar-text {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--color-text-white);
}

.greeting-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.greeting-title {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: -0.5px;
}

.greeting-org {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.greeting-date {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* -- 今日小贴士 -- */
.tip-card {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
  margin: 0 var(--page-padding-x) var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-info-50);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-info-100);
}

.tip-icon-circle {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--color-info-100);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-icon-circle .line-icon--sm {
  width: 16px;
  height: 16px;
  background-size: 16px 16px;
}

.tip-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.tip-title {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-info-700);
}

.tip-text {
  font-size: var(--font-size-sm);
  color: var(--color-info-700);
  line-height: var(--line-height-medium);
}

/* -- 常用应用 -- */
.apps-card {
  padding: var(--spacing-lg) var(--page-padding-x);
}

.apps-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: var(--spacing-xl);
}

.app-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
}

.app-item-hover {
  opacity: 0.7;
}

.app-item-hover .app-icon-circle {
  transform: scale(0.92);
}

.app-icon-circle {
  width: 56px;
  height: 56px;
  border-radius: var(--radius-card);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease;
  position: relative;
}

.app-icon-circle .line-icon--lg {
  width: 30px;
  height: 30px;
  background-size: 30px 30px;
}

.app-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  text-align: center;
  font-weight: var(--font-weight-medium);
  line-height: 1.3;
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.app-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--color-danger);
  color: var(--color-text-white);
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 10px;
  line-height: 1.2;
}

/* 拖拽模式 */
.app-item--dragging {
  opacity: 0.8;
  transform: scale(1.1);
  transition: transform 0.1s ease;
}

/* 空状态 */
.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 0 20px;
}

.empty-text {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  text-align: center;
}

/* -- 图标背景色（Apple 风格：淡色背景） -- */
.menu-icon-circle--purple,
.app-icon-circle.menu-icon-circle--purple {
  background: var(--icon-bg-purple);
}

.menu-icon-circle--blue,
.app-icon-circle.menu-icon-circle--blue {
  background: var(--icon-bg-blue);
}

.menu-icon-circle--teal,
.app-icon-circle.menu-icon-circle--teal {
  background: var(--icon-bg-teal);
}

.menu-icon-circle--amber,
.app-icon-circle.menu-icon-circle--amber {
  background: var(--icon-bg-amber);
}

.menu-icon-circle--green,
.app-icon-circle.menu-icon-circle--green {
  background: var(--icon-bg-green);
}

.menu-icon-circle--orange,
.app-icon-circle.menu-icon-circle--orange {
  background: var(--icon-bg-orange);
}

.menu-icon-circle--rose,
.app-icon-circle.menu-icon-circle--rose {
  background: var(--icon-bg-rose);
}

.menu-icon-circle--indigo,
.app-icon-circle.menu-icon-circle--indigo {
  background: var(--icon-bg-indigo);
}

.menu-icon-circle--cyan,
.app-icon-circle.menu-icon-circle--cyan {
  background: var(--icon-bg-cyan);
}

.menu-icon-circle--red,
.app-icon-circle.menu-icon-circle--red {
  background: var(--icon-bg-red);
}

.menu-icon-circle--magenta,
.app-icon-circle.menu-icon-circle--magenta {
  background: var(--icon-bg-rose);
}

.menu-icon-circle--lightblue,
.app-icon-circle.menu-icon-circle--lightblue {
  background: var(--icon-bg-cyan);
}

.menu-icon-circle--gray,
.app-icon-circle.menu-icon-circle--gray {
  background: var(--icon-bg-gray);
}
