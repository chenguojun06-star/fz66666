/* =========================================
   质检详情页 · 六段式结构样式
   ========================================= */

.quality-page {
  min-height: 100vh;
  padding: 16rpx var(--page-padding-x) calc(env(safe-area-inset-bottom) + 40rpx);
  background: var(--color-bg-page);
}

/* ============ 通用卡片（section-card 风格） ============ */
.top-card, .qty-card, .section-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

/* ============ ① 基础信息卡 ============ */
.top-card {
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.top-left {
  width: 160rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-primary-bg);
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.cover-icon {
  font-size: 56rpx;
  color: var(--color-primary);
  font-weight: 700;
  line-height: 1;
}

.cover-label {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.top-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.top-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 4rpx;
}

.order-no {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  min-width: 72rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  word-break: break-all;
  flex: 1;
}

.text-error {
  color: var(--color-error);
}

/* ============ ② 数量进度卡 ============ */
.qty-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
}

.qty-col {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.qty-num {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1;
}

.qty-success {
  color: var(--color-success);
}

.qty-error {
  color: var(--color-error);
}

.qty-label {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.qty-div {
  width: 1rpx;
  height: 60rpx;
  background: var(--color-border-light);
}

/* ============ 区块通用（④ / ⑤） ============ */
.section-card {
  padding: 24rpx;
}

.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-count {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

/* ============ ④ 质检信息 · 信息列表 ============ */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.info-list .info-row {
  padding: 6rpx 0;
}

/* ============ ⑤ 不良品照片 ============ */
.photo-wrap {
  margin-top: 12rpx;
}

.photo-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.photo-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.defect-photo {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border-light);
  background: var(--color-bg-gray);
}

/* ============ 底部间距 ============ */
.bottom-gap {
  height: 40rpx;
}
