<!-- 样衣仓库管理页 -->
<view class="container">
  
  <!-- ==================== 列表视图 ==================== -->
  <view wx:if="{{viewMode === 'list'}}">
    <!-- 搜索框 + 扫码按钮 + 筛选器：复用通用组件 sticky-search-bar -->
    <view class="ssb-wrap">
      <sticky-search-bar
        sticky="{{false}}"
        placeholder="搜索款号/颜色/尺码"
        value="{{searchKeyword}}"
        show-scan="{{true}}"
        show-filter="{{true}}"
        bind:input="onSearchInput"
        bind:confirm="onSearchConfirm"
        bind:clear="onSearchClear"
        bind:scan="onScanCode"
      >
        <view slot="filter">
          <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
            <view
              wx:for="{{statusTabs}}"
              wx:key="key"
              class="filter-pill {{activeStatus === item.key ? 'filter-pill--on' : ''}} {{item.pillClass}}"
              data-key="{{item.key}}"
              bindtap="onStatusTabTap"
            >
              <text class="filter-text">{{item.label}}</text>
              <text wx:if="{{item.count > 0}}" class="filter-num">{{item.count}}</text>
            </view>
          </scroll-view>
        </view>
      </sticky-search-bar>
    </view>

    <!-- 列表 -->
    <view class="stock-list">
      <view wx:if="{{stockListLoading && stockList.length === 0}}" class="loading-wrap">
        <text class="loading-text">加载中...</text>
      </view>
      
      <view wx:elif="{{stockListError}}" class="error-card">
        <view class="line-icon icon-alert error-icon"></view>
        <text class="error-msg">{{stockListError}}</text>
        <view class="btn-retry" bindtap="loadStockList" data-refresh="true">重试</view>
      </view>
      
      <view wx:elif="{{stockList.length === 0}}" class="empty-wrap">
        <view class="line-icon icon-shirt empty-icon"></view>
        <text class="empty-text">暂无样衣库存</text>
      </view>
      
      <block wx:else>
      <view
        class="stock-item"
        wx:for="{{filteredStockList}}"
        wx:key="id"
        bindtap="onStockItemTap"
        data-stock="{{item}}"
      >
        <image wx:if="{{item._imageUrl}}" class="stock-thumb" src="{{item._imageUrl}}" mode="aspectFill" catchtap="onPreviewImage" data-src="{{item._imageUrl}}" />
        <view wx:else class="stock-thumb-placeholder">
        </view>
        <view class="stock-info">
          <view class="stock-row">
            <text class="stock-label">款号</text>
            <text class="stock-value">{{item.styleNo || '-'}}</text>
          </view>
          <view class="stock-row">
            <text class="stock-label">颜色</text>
            <text class="stock-value">{{item.color || '-'}}</text>
          </view>
          <view class="stock-row">
            <text class="stock-label">尺码</text>
            <text class="stock-value">{{item.size || '-'}}</text>
          </view>
          <view class="stock-row" wx:if="{{item._sampleTypeLabel}}">
            <text class="stock-label">类型</text>
            <text class="stock-value">{{item._sampleTypeLabel}}</text>
          </view>
        </view>
        <view class="stock-status">
          <view class="stock-quantity">
            <text class="qty-num">{{item.quantity || 0}}</text>
            <text class="qty-unit">件</text>
          </view>
          <text class="stock-loan" wx:if="{{item.loanedQuantity > 0}}">借出 {{item.loanedQuantity}}</text>
          <text class="stock-arrow">›</text>
        </view>
      </view>
      </block>
      
      <!-- 加载更多 -->
      <view class="load-more" wx:if="{{stockList.length > 0}}">
        <text wx:if="{{stockListLoading}}" class="load-text">加载中...</text>
        <text wx:elif="{{hasMore}}" class="load-text" bindtap="loadStockList">加载更多</text>
        <text wx:else class="load-text">— 没有更多了 —</text>
      </view>
    </view>
  </view>
  
  <!-- ==================== 详情视图 ==================== -->
  <view wx:if="{{viewMode === 'detail'}}">
    <!-- 头部 -->
    <view class="header">
      <text class="header-title">样衣详情</text>
      <view class="header-scan" bindtap="onScanCode">扫码</view>
    </view>
    
    <view class="header-info">
      <text class="header-sub">{{styleNo}} · {{color}} · {{size}}</text>
    </view>
    
    <!-- 加载中 -->
    <view class="loading-wrap" wx:if="{{loading}}">
      <text class="loading-text">查询中...</text>
    </view>
    
    <!-- 错误提示 -->
    <view class="error-card" wx:elif="{{errorMsg}}">
      <view class="line-icon icon-alert error-icon"></view>
      <text class="error-msg">{{errorMsg}}</text>
      <view class="btn-retry" bindtap="onRetry">重试</view>
    </view>
    
    <!-- 成功提示 -->
    <view class="success-banner" wx:if="{{successMsg}}">
      <view class="line-icon icon-checkmark success-icon"></view>
      <text class="success-text">{{successMsg}}</text>
    </view>
    
    <!-- 库存信息卡片 -->
    <block wx:if="{{stockInfo && !loading}}">
      <!-- 未找到库存记录 -->
      <view class="info-card" wx:if="{{!stockInfo.found}}">
        <view class="info-row">
          <text class="info-label">状态</text>
          <text class="info-value">
            <text class="status-tag tag-orange">未入库</text>
          </text>
        </view>
        <view class="info-row">
          <text class="info-label">款号</text>
          <text class="info-value bold">{{styleNo}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">颜色</text>
          <text class="info-value">{{color}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">尺码</text>
          <text class="info-value">{{size}}</text>
        </view>
      </view>
      
      <!-- 已有库存记录 -->
      <view class="info-card" wx:if="{{stockInfo.found && stockInfo.stock}}">
        <image
          wx:if="{{stockInfo.stock._imageUrl}}"
          class="detail-image"
          src="{{stockInfo.stock._imageUrl}}"
          mode="aspectFit"
          bindtap="onPreviewImage"
          data-src="{{stockInfo.stock._imageUrl}}"
        />
        <view class="info-row">
          <text class="info-label">状态</text>
          <text class="info-value">
            <text class="status-tag tag-green" wx:if="{{stockInfo.availableQuantity > 0}}">在库</text>
            <text class="status-tag tag-orange" wx:else>全部借出</text>
          </text>
        </view>
        <view class="info-row">
          <text class="info-label">款号</text>
          <text class="info-value bold">{{stockInfo.stock.styleNo}}</text>
        </view>
        <view class="info-row" wx:if="{{stockInfo.stock.styleName}}">
          <text class="info-label">款名</text>
          <text class="info-value">{{stockInfo.stock.styleName}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">颜色</text>
          <text class="info-value">{{stockInfo.stock.color}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">尺码</text>
          <text class="info-value">{{stockInfo.stock.size}}</text>
        </view>
        <view class="info-row" wx:if="{{stockInfo.stock.sampleType}}">
          <text class="info-label">类型</text>
          <text class="info-value">{{stockInfo.stock._sampleTypeLabel || stockInfo.stock.sampleType}}</text>
        </view>
        <view class="info-row" wx:if="{{stockInfo.stock.location}}">
          <text class="info-label">仓位</text>
          <text class="info-value">{{stockInfo.stock.location}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">库存</text>
          <text class="info-value bold">{{stockInfo.stock.quantity}} 件</text>
        </view>
        <view class="info-row">
          <text class="info-label">可用</text>
          <text class="info-value bold">{{stockInfo.availableQuantity}} 件</text>
        </view>
        <view class="info-row" wx:if="{{stockInfo.stock.loanedQuantity > 0}}">
          <text class="info-label">借出</text>
          <text class="info-value">{{stockInfo.stock.loanedQuantity}} 件</text>
        </view>

        <!-- 库存统计：总数量/已借调/待归还/报废（复用项目统一 stats-row/stat-card 样式） -->
        <view class="stats-row">
          <view class="stat-card">
            <text class="stat-value">{{stockInfo.stock.quantity || 0}}</text>
            <text class="stat-label">总数量</text>
          </view>
          <view class="stat-card">
            <text class="stat-value stat-value--warning">{{stockInfo.stock.loanedQuantity || 0}}</text>
            <text class="stat-label">已借调</text>
          </view>
          <view class="stat-card">
            <text class="stat-value stat-value--danger">{{stockInfo.pendingReturnCount || 0}}</text>
            <text class="stat-label">待归还</text>
          </view>
          <view class="stat-card">
            <text class="stat-value stat-value--secondary">{{stockInfo.scrappedCount || 0}}</text>
            <text class="stat-label">报废</text>
          </view>
        </view>
      </view>
      
      <!-- 借调记录 -->
      <view class="info-card" wx:if="{{stockInfo.activeLoans && stockInfo.activeLoans.length > 0}}">
        <view class="info-row">
          <text class="info-label bold" style="width:auto">当前借调记录</text>
        </view>
        <view class="loan-item" wx:for="{{stockInfo.activeLoans}}" wx:key="id">
          <view class="info-row">
            <text class="info-label">借调人</text>
            <text class="info-value">{{item.borrower}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">数量</text>
            <text class="info-value">{{item.quantity}} 件</text>
          </view>
          <view class="info-row">
            <text class="info-label">时间</text>
            <text class="info-value">{{item.createTime}}</text>
          </view>
        </view>
      </view>
      
      <!-- 操作按钮区域 -->
      <view class="action-area" wx:if="{{!successMsg}}">
        <!-- 出库库位提示（已入库时显示，让用户清楚样衣在哪里） -->
        <view wx:if="{{stockInfo.found && stockInfo.stock && (stockInfo.stock.warehouseAreaName || stockInfo.stock.location)}}" class="stock-location-banner">
          <text class="stock-location-label">出库库位：</text>
          <text class="stock-location-value">{{stockInfo.stock.warehouseAreaName || '-'}}{{stockInfo.stock.location ? ' / ' + stockInfo.stock.location : ''}}</text>
        </view>

        <!-- 仓库区域选择（入库时显示） -->
        <view wx:if="{{actions.indexOf('inbound') !== -1}}" class="warehouse-section">
          <view class="warehouse-label">入库仓库：</view>
          <view class="warehouse-option-row">
            <view
              wx:for="{{warehouseOptions}}"
              wx:key="index"
              class="warehouse-chip {{warehouse === item ? 'warehouse-chip--active' : ''}}"
              bindtap="onWarehouseChipTap"
              data-value="{{item}}"
              hover-class="warehouse-chip-hover"
            >{{item}}</view>
            <view
              class="warehouse-chip warehouse-chip--clear {{warehouse ? '' : 'warehouse-chip--disabled'}}"
              bindtap="onWarehouseClear"
              hover-class="warehouse-chip-hover"
            >清除</view>
          </view>
          <input
            class="input-box"
            placeholder="或手动输入仓库编号"
            value="{{warehouse}}"
            bindinput="onWarehouseCodeInput"
          />
          
          <!-- 库位选择 -->
          <view wx:if="{{warehouse && locationOptions.length > 0}}" class="warehouse-label" style="margin-top: 12rpx;">入库库位：</view>
          <view wx:if="{{warehouse && locationOptions.length > 0}}" class="warehouse-option-row">
            <view
              wx:for="{{locationOptions}}"
              wx:key="index"
              class="warehouse-chip {{warehouseLocationCode === item ? 'warehouse-chip--active' : ''}}"
              bindtap="onLocationChipTap"
              data-value="{{item}}"
              hover-class="warehouse-chip-hover"
            >{{item}}</view>
            <view
              class="warehouse-chip warehouse-chip--clear {{warehouseLocationCode ? '' : 'warehouse-chip--disabled'}}"
              bindtap="onLocationClear"
              hover-class="warehouse-chip-hover"
            >清除</view>
          </view>
          <input
            wx:if="{{warehouse}}"
            class="input-box"
            placeholder="或手动输入库位编号"
            value="{{warehouseLocationCode}}"
            bindinput="onLocationCodeInput"
          />
        </view>
        
        <!-- 操作按钮：一行3个 + 镂空风格（遵循项目铁律：所有按钮必须镂空） -->
        <view class="action-btn-row">
          <view
            class="action-btn action-btn--inbound {{submitting ? 'action-btn--disabled' : ''}}"
            wx:if="{{actions.indexOf('inbound') !== -1}}"
            bindtap="onInbound"
            hover-class="action-btn--hover"
          >入库</view>
          <view
            class="action-btn action-btn--loan {{submitting ? 'action-btn--disabled' : ''}}"
            wx:if="{{actions.indexOf('loan') !== -1}}"
            bindtap="onLoan"
            hover-class="action-btn--hover"
          >借调</view>
          <view
            class="action-btn action-btn--return {{submitting ? 'action-btn--disabled' : ''}}"
            wx:if="{{actions.indexOf('return') !== -1}}"
            bindtap="onReturn"
            hover-class="action-btn--hover"
          >归还</view>
        </view>
      </view>
    </block>
  </view>
  
  <!-- 借调目标选择弹窗 -->
  <view wx:if="{{showLoanPicker}}" class="loan-picker-mask" catchtap="onLoanCancel">
    <view class="loan-picker" catchtap="noop">
      <view class="loan-picker-header">
        <text class="loan-picker-title">选择借调对象</text>
        <view class="loan-picker-close" bindtap="onLoanCancel">×</view>
      </view>

      <!-- 借调对象类型切换 -->
      <view class="loan-type-tabs">
        <view
          class="loan-type-tab {{loanTargetType === 'person' ? 'loan-type-tab--active' : ''}}"
          bindtap="onLoanTargetTypeChange"
          data-type="person"
        >借给员工</view>
        <view
          class="loan-type-tab {{loanTargetType === 'factory' ? 'loan-type-tab--active' : ''}}"
          bindtap="onLoanTargetTypeChange"
          data-type="factory"
        >借给外发工厂</view>
      </view>

      <!-- 借调数量 -->
      <view class="loan-qty-row">
        <text class="loan-qty-label">借调数量</text>
        <input
          class="loan-qty-input"
          type="number"
          value="{{loanQuantity}}"
          bindinput="onLoanQuantityInput"
        />
        <text class="loan-qty-max">可用 {{stockInfo.availableQuantity}} 件</text>
      </view>

      <!-- 搜索框：过滤员工/工厂列表 -->
      <view class="loan-search-row">
        <input
          class="loan-search-input"
          placeholder="{{loanTargetType === 'person' ? '搜索员工姓名' : '搜索工厂名称'}}"
          value="{{loanSearchKeyword}}"
          bindinput="onLoanSearchInput"
          confirm-type="search"
        />
        <view wx:if="{{loanSearchKeyword}}" class="loan-search-clear" bindtap="onLoanSearchClear">×</view>
      </view>

      <!-- 借调对象列表（基于过滤后的列表渲染） -->
      <view wx:if="{{loanPickerLoading}}" class="loan-loading">加载中...</view>
      <view wx:elif="{{loanTargetType === 'person'}}" class="loan-target-list">
        <view wx:if="{{filteredWorkerList.length === 0}}" class="loan-empty">{{loanSearchKeyword ? '未匹配到员工' : '暂无员工数据'}}</view>
        <view
          wx:for="{{filteredWorkerList}}"
          wx:key="id"
          class="loan-target-item {{loanTargetId === item.id ? 'loan-target-item--active' : ''}}"
          bindtap="onLoanTargetSelect"
          data-id="{{item.id}}"
          data-name="{{item.name || item.workerName || item.username}}"
        >
          <text class="loan-target-name">{{item.name || item.workerName || item.username}}</text>
          <text wx:if="{{item.factoryName}}" class="loan-target-sub">{{item.factoryName}}</text>
          <text wx:if="{{loanTargetId === item.id}}" class="loan-target-check">✓</text>
        </view>
      </view>
      <view wx:elif="{{loanTargetType === 'factory'}}" class="loan-target-list">
        <view wx:if="{{filteredFactoryList.length === 0}}" class="loan-empty">{{loanSearchKeyword ? '未匹配到工厂' : '暂无外发工厂数据'}}</view>
        <view
          wx:for="{{filteredFactoryList}}"
          wx:key="id"
          class="loan-target-item {{loanTargetId === item.id ? 'loan-target-item--active' : ''}}"
          bindtap="onLoanTargetSelect"
          data-id="{{item.id}}"
          data-name="{{item.factoryName || item.name}}"
        >
          <text class="loan-target-name">{{item.factoryName || item.name}}</text>
          <text wx:if="{{item.contactPerson}}" class="loan-target-sub">联系人：{{item.contactPerson}}</text>
          <text wx:if="{{loanTargetId === item.id}}" class="loan-target-check">✓</text>
        </view>
      </view>

      <!-- 确认按钮 -->
      <view class="loan-picker-footer">
        <view class="loan-btn loan-btn--cancel" bindtap="onLoanCancel">取消</view>
        <view
          class="loan-btn loan-btn--confirm {{(!loanTargetId || submitting) ? 'loan-btn--disabled' : ''}}"
          bindtap="onLoanConfirm"
        >确认借调</view>
      </view>
    </view>
  </view>

  <!-- 隐私协议 -->
  <privacy-dialog
    wx:if="{{showPrivacy}}"
    bind:agree="onPrivacyAgree"
    bind:disagree="onPrivacyDisagree"
  />
  <ai-assistant />
</view>
