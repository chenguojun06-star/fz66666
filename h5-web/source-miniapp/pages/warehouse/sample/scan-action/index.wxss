/* 样衣仓库管理页 */

.container {
  padding: 12rpx var(--page-padding-x);
  background: var(--color-bg-page, var(--color-bg-page));
  min-height: 100vh;
}

/* ===== sticky-search-bar 容器：负 margin 抵消 .container 水平 padding ===== */
.ssb-wrap {
  margin: 0 calc(-1 * var(--page-padding-x));
}

/* ==================== 列表 ==================== */
.stock-list {
  margin-top: 8rpx;
}

.stock-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  
  
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.stock-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-xs);
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg-page);
}

.stock-thumb-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-xs);
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-4xl);
}

.stock-info {
  flex: 1;
}

.stock-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.stock-row:last-child {
  margin-bottom: 0;
}

.stock-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  width: 60rpx;
  flex-shrink: 0;
}

.stock-value {
  font-size: var(--font-size-md);
  color: var(--color-text);
}

.stock-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.stock-quantity {
  display: flex;
  align-items: baseline;
}

.qty-num {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-primary);
}

.qty-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-left: 4rpx;
}

.stock-loan {
  font-size: var(--font-size-2xs);
  color: var(--color-warning);
  margin-top: 4rpx;
}

.stock-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 40px;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
}

.load-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ==================== 详情页头部 ==================== */
.header {
  position: relative;
  margin-bottom: 12rpx;
}

.header-back {
  position: absolute;
  left: 0;
  top: 0;
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: 8rpx 0;
}

.header-title {
  text-align: center;
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text);
  display: block;
}

.header-scan {
  position: absolute;
  right: 0;
  top: 0;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  padding: 8rpx 0;
}

.header-info {
  text-align: center;
  margin-bottom: 16rpx;
}

.header-sub {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* ==================== 通用组件 ==================== */

/* 加载 */
.loading-wrap { 
  display: flex; 
  justify-content: center; 
  align-items: center; 
  padding: 60px 0; 
}
.loading-text { 
  font-size: var(--font-size-md); 
  color: var(--color-text-secondary); 
}

/* 错误 */
.error-card {
  background: var(--color-danger-bg);
  border: 1px solid var(--color-danger);
  border-radius: var(--radius-md);
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.error-icon { font-size: var(--font-size-4xl); margin-bottom: 8px; }
.error-msg { font-size: var(--font-size-md); color: var(--color-danger); text-align: center; margin-bottom: 12px; }
.btn-retry {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: 6px 20px;
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-xs);
}

/* 成功 */
.success-banner {
  background: var(--color-success-bg);
  border: 1px solid var(--color-success);
  border-radius: var(--radius-md);
  padding: 10px 14px;
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}
.success-icon { font-size: var(--font-size-lg-xl); margin-right: 8px; }
.success-text { font-size: var(--font-size-md); color: var(--color-success); }

/* 信息卡片 */
.info-card {
  background: var(--color-bg-card);
  
  
  margin-bottom: 10px;
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

/* 详情图：限定高度 + aspectFit 完整显示不裁剪 + 居中 */
.detail-image-wrap {
  width: 100%;
  max-height: 160rpx;
  margin-bottom: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: var(--color-bg-page);
  border-radius: var(--radius-xs);
  overflow: hidden;
}
.detail-image {
  width: auto;
  height: 160rpx;
  max-width: 100%;
  border-radius: var(--radius-xs);
  background: var(--color-bg-page);
}

.info-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid var(--color-border);
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: var(--font-size-sm); color: var(--color-text-secondary); width: 60px; flex-shrink: 0; }
.info-value { font-size: var(--font-size-md); color: var(--color-text); flex: 1; }
.info-value.bold,
.bold { font-weight: bold; font-size: var(--font-size-md-lg); color: var(--color-primary); }

/* 状态标签 */
.status-tag { padding: 2px 8px; border-radius: var(--radius-xl); font-size: var(--font-size-xs); }
.tag-green { background: var(--color-success-bg); color: var(--color-success); }
.tag-orange { background: var(--color-warning-bg); color: var(--color-warning); }

/* 借调记录 */
.loan-item { margin-top: 4px; padding-top: 4px; border-top: 1px dashed var(--color-border); }

/* 操作按钮 */
.action-area { margin-bottom: 10px; }

/* 仓库选择区域 */
.warehouse-section {
  margin-bottom: 12rpx;
  
  background: var(--color-bg-page);
  
  

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.warehouse-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 6px;
}

.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 8px;
}

.warehouse-chip {
  padding: 4px 14px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  border: 1px solid var(--color-border);
  background: var(--color-bg-page);
  color: var(--color-text-primary);
}

.warehouse-chip--active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

.warehouse-chip--clear {
  background: rgba(254, 226, 226, 0.6);
  border-color: rgba(252, 165, 165, 0.5);
  color: var(--color-danger);
}

.warehouse-chip--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.warehouse-chip-hover {
  opacity: 0.75;
}

.input-box {
  width: 100%;
  height: 40px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 12px;
  font-size: var(--font-size-sm);
  box-sizing: border-box;
}

/* 出库库位提示条（已入库时显示，让用户清楚样衣在哪里） */
.stock-location-banner {
  background: #e8f2ff;
  border-radius: var(--radius-md);
  padding: 10px 12px;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
}
.stock-location-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-right: 6px;
}
.stock-location-value {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  font-weight: 500;
  flex: 1;
}

/* ==================== 操作按钮：一行3个 + 镂空风格 ==================== */
/* 遵循项目铁律：所有按钮必须采用镂空风格（透明背景+彩色边框+彩色文字），禁止实心 */
.action-btn-row {
  display: flex;
  gap: 10px;
  margin-bottom: 10px;
}
.action-btn {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-md);
  font-weight: 500;
  border-radius: var(--radius-md);
  border: 2rpx solid;
  background: transparent;
  transition: opacity 0.2s ease;
}
.action-btn--inbound {
  color: var(--color-primary);
  border-color: var(--color-primary);
}
.action-btn--loan {
  color: var(--color-warning);
  border-color: var(--color-warning);
}
.action-btn--return {
  color: var(--color-text-secondary);
  border-color: var(--color-text-secondary);
}
.action-btn--hover {
  opacity: 0.7;
}
.action-btn--disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ==================== 借调目标选择弹窗 ==================== */
.loan-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.loan-picker {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.loan-picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}
.loan-picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.loan-picker-close {
  font-size: 48rpx;
  color: #999;
  padding: 0 8rpx;
  line-height: 1;
}
.loan-type-tabs {
  display: flex;
  padding: 16rpx 32rpx 0;
  gap: 16rpx;
}
.loan-type-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
}
.loan-type-tab--active {
  color: #1890ff;
  border-color: #1890ff;
  background: #e8f2ff;
  font-weight: 500;
}
.loan-qty-row {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.loan-qty-label {
  font-size: 28rpx;
  color: #333;
  width: 160rpx;
}
.loan-qty-input {
  flex: 1;
  height: 64rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  background: #fff;
  text-align: center;
}
.loan-qty-max {
  margin-left: 16rpx;
  font-size: 24rpx;
  color: #999;
  width: 200rpx;
  text-align: right;
}

/* 搜索框 */
.loan-search-row {
  display: flex;
  align-items: center;
  margin: 16rpx 32rpx 0;
  padding: 0 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
}
.loan-search-input {
  flex: 1;
  height: 64rpx;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}
.loan-search-clear {
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  color: #999;
  font-size: 36rpx;
  border-radius: 50%;
  background: #e0e0e0;
  margin-left: 8rpx;
}
.loan-loading,
.loan-empty {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
.loan-target-list {
  flex: 1;
  overflow-y: auto;
  max-height: 50vh;
  padding: 8rpx 32rpx;
}
.loan-target-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
}
.loan-target-item--active {
  background: #e8f2ff;
  border-color: #1890ff;
}
.loan-target-name {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}
.loan-target-sub {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}
.loan-target-check {
  color: #1890ff;
  font-size: 32rpx;
  font-weight: bold;
  margin-left: 16rpx;
}
.loan-picker-footer {
  display: flex;
  padding: 16rpx 32rpx 32rpx;
  gap: 16rpx;
  border-top: 1rpx solid #eee;
}
.loan-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  border-radius: 12rpx;
  border: 2rpx solid;
}
.loan-btn--cancel {
  color: #666;
  border-color: #d9d9d9;
  background: #fafafa;
}
.loan-btn--confirm {
  color: #fff;
  border-color: #faad14;
  background: #faad14;
  font-weight: 500;
}
.loan-btn--disabled {
  opacity: 0.5;
  pointer-events: none;
}
