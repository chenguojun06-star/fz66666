/* 样衣仓库管理页 */

.container {
  padding: var(--spacing-sm) var(--page-padding-x);
  background: var(--color-bg-page);
  min-height: 100vh;
}

/* ==================== 操作栏 ==================== */
.action-bar {
  margin-bottom: var(--spacing-sm);
}

.btn-scan {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-card);
  /* Apple: removed hard border, use shadow */
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
}

.btn-scan .btn-icon {
  font-size: var(--font-size-2xl);
  margin-right: var(--spacing-xs);
}

.btn-scan .btn-text {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

/* ==================== 列表 ==================== */
.stock-list {
  margin-top: var(--spacing-xs);
}

.stock-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-card);
  /* Apple: removed hard border, use shadow */
}

.stock-thumb {
  width: 50px;
  height: 50px;
  border-radius: var(--radius-xs);
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  background: var(--color-bg-light);
}

.stock-thumb-placeholder {
  width: 50px;
  height: 50px;
  border-radius: var(--radius-xs);
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  background: var(--color-bg-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-3xl);
}

.stock-info {
  flex: 1;
}

.stock-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-xs);
}

.stock-row:last-child {
  margin-bottom: 0;
}

.stock-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  width: 30px;
  flex-shrink: 0;
}

.stock-value {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
}

.stock-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.stock-quantity {
  display: flex;
  align-items: baseline;
}

.qty-num {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
}

.qty-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-left: 2px;
}

.stock-loan {
  font-size: var(--font-size-xs);
  color: var(--color-warning);
  margin-top: 2px;
}

.stock-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
  margin-top: 2px;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 0;
}

.empty-icon {
  font-size: 20px;
  margin-bottom: var(--spacing-sm);
  opacity: 0.6;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: var(--spacing-md) 0;
}

.load-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ==================== 详情页头部 ==================== */
.header {
  position: relative;
  margin-bottom: var(--spacing-sm);
}

.header-back {
  position: absolute;
  left: 0;
  top: 0;
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: var(--spacing-xs) 0;
}

.header-title {
  text-align: center;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  display: block;
}

.header-scan {
  position: absolute;
  right: 0;
  top: 0;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  padding: var(--spacing-xs) 0;
}

.header-info {
  text-align: center;
  margin-bottom: var(--spacing-md);
}

.header-sub {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* ==================== 通用组件 ==================== */

/* 加载 */
.loading-wrap { 
  display: flex; 
  justify-content: center; 
  align-items: center; 
  padding: 30px 0; 
}

.loading-text { 
  font-size: var(--font-size-md); 
  color: var(--color-text-secondary); 
}

/* 错误 */
.error-card {
  background: var(--color-danger-bg);
  border: 1px solid var(--color-danger-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.error-icon { font-size: var(--font-size-4xl); margin-bottom: var(--spacing-xs); }
.error-msg { font-size: var(--font-size-md); color: var(--color-danger); text-align: center; margin-bottom: var(--spacing-sm); }
.btn-retry {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: 3px var(--spacing-lg);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-xs);
}

/* 成功 */
.success-banner {
  background: var(--color-success-bg);
  border: 1px solid var(--color-success-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.success-icon { font-size: var(--font-size-xl); margin-right: var(--spacing-xs); }
.success-text { font-size: var(--font-size-md); color: var(--color-success); }

/* 信息卡片 */
.info-card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-card);
  /* Apple: removed hard border, use shadow */
}

.detail-header {
  display: flex;
  align-items: flex-start;
}

.detail-info {
  flex: 1;
  min-width: 0;
}

.detail-thumb {
  width: 60px;
  height: 60px;
  border-radius: var(--radius-xs);
  margin-left: var(--spacing-md);
  flex-shrink: 0;
  background: var(--color-bg-light);
}

.info-row {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs) 0;
  border-bottom: 1px solid var(--color-border-light);
}

.info-row:last-child { border-bottom: none; }

.info-label { font-size: var(--font-size-sm); color: var(--color-text-secondary); width: 60px; flex-shrink: 0; }
.info-label--wide { width: auto; font-weight: var(--font-weight-bold); color: var(--color-text-primary); }
.info-value { font-size: var(--font-size-md); color: var(--color-text-primary); flex: 1; }
.info-value.bold,
.bold { font-weight: var(--font-weight-bold); font-size: var(--font-size-md); color: var(--color-primary); }

/* 借调记录 */
.loan-item { margin-top: var(--spacing-xs); padding-top: var(--spacing-xs); border-top: 1px dashed var(--color-border-light); }

/* 操作按钮 */
.action-area { margin-bottom: var(--spacing-sm); }

/* 仓库选择区域 */
.warehouse-section {
  margin-bottom: var(--spacing-sm);
  padding: var(--spacing-md);
  background: var(--color-bg-light);
  border-radius: var(--radius-md);
  /* Apple: removed hard border, use shadow */
}

.warehouse-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
}

.warehouse-label--mt {
  margin-top: var(--spacing-sm);
}

.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
  margin-bottom: var(--spacing-xs);
}

.warehouse-chip {
  padding: 2px var(--spacing-md);
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  /* Apple: removed hard border, use shadow */
  background: var(--color-bg-light);
  color: var(--color-text-primary);
}

.warehouse-chip--active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

.warehouse-chip--clear {
  background: var(--color-danger-bg);
  border-color: var(--color-danger-border);
  color: var(--color-danger);
}

.warehouse-chip--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.warehouse-chip-hover {
  opacity: 0.75;
}

.input-box {
  width: 100%;
  height: var(--input-height-sm);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-sm);
  box-sizing: border-box;
  background: var(--color-bg-card);
}

.btn-inbound {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  text-align: center;
  border-radius: var(--radius-md);
  padding: var(--spacing-md) 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--spacing-xs);
}

.btn-loan {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  text-align: center;
  border-radius: var(--radius-md);
  padding: var(--spacing-md) 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--spacing-xs);
}

/* ==================== 借调内联表单 ==================== */
.loan-inline {
  background: var(--color-bg-gray);
  /* Apple: removed hard border, use shadow */
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-xs);
}

.loan-inline-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.loan-inline-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  width: 60px;
  flex-shrink: 0;
}

.loan-inline-radios {
  display: flex;
  gap: var(--spacing-lg);
}

.loan-inline-input {
  flex: 1;
  font-size: var(--font-size-md);
  padding: var(--spacing-xs) var(--spacing-md);
  /* Apple: removed hard border, use shadow */
  border-radius: var(--radius-sm);
  background: var(--color-bg-card);
  height: var(--input-height-sm);
  box-sizing: border-box;
}

.loan-inline-actions {
  display: flex;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-xs);
}

.loan-inline-btn {
  flex: 1;
  text-align: center;
  padding: var(--spacing-sm) 0;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
}

.loan-inline-btn--cancel {
  background: var(--color-bg-gray);
  color: var(--color-text-secondary);
  /* Apple: removed hard border, use shadow */
}

.loan-inline-btn--confirm {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

.loan-inline-selected {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 3px 5px;
  border-radius: var(--radius-xs);
  margin-bottom: var(--spacing-sm);
  display: inline-block;
}

.loan-inline-list {
  max-height: 100px;
  overflow-y: auto;
  /* Apple: removed hard border, use shadow */
  border-radius: var(--radius-sm);
  margin-bottom: var(--spacing-sm);
}

.loan-inline-option {
  padding: var(--spacing-xs) var(--spacing-md);
  font-size: var(--font-size-sm);
  border-bottom: 1px solid var(--color-border-light);
}

.loan-inline-option:last-child {
  border-bottom: none;
}

.loan-inline-option:active {
  background: var(--color-primary-bg);
}

.btn-return {
  background: var(--color-warning);
  color: var(--color-text-white);
  text-align: center;
  border-radius: var(--radius-md);
  padding: var(--spacing-md) 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--spacing-xs);
}

.btn-disabled { opacity: 0.6; pointer-events: none; }

/* ==================== 借调记录操作 ==================== */
.loan-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 3px;
}

.btn-transfer-sm {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-xs);
  padding: 2px 6px;
}

.transfer-tag {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 1px 4px;
  border-radius: var(--radius-xs);
}

/* ==================== 弹窗通用 ==================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--color-overlay);
  z-index: var(--z-modal);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 85%;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.modal-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  text-align: center;
  padding: var(--spacing-lg) 0 var(--spacing-md);
  color: var(--color-text-primary);
}

.modal-body {
  padding: var(--spacing-sm) var(--spacing-xl) var(--spacing-lg);
}

.modal-actions {
  display: flex;
  border-top: 1px solid var(--color-border-light);
}

.modal-btn-cancel,
.modal-btn-confirm {
  flex: 1;
  text-align: center;
  padding: var(--spacing-lg) 0;
  font-size: var(--font-size-md);
}

.modal-btn-cancel {
  color: var(--color-text-secondary);
  border-right: 1px solid var(--color-border-light);
}

.modal-btn-confirm {
  color: var(--color-primary);
  font-weight: var(--font-weight-bold);
}

/* 表单项 */
.form-item {
  margin-bottom: var(--spacing-md);
}

.form-item .form-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-xs);
  display: block;
  width: auto;
}

.form-input {
  width: 100%;
  height: var(--input-height-sm);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-md);
  box-sizing: border-box;
  background: var(--color-bg-card);
}

.radio-item {
  display: inline-block;
  margin-right: var(--spacing-lg);
  font-size: var(--font-size-md);
}

/* 归还选择 */
.return-pick-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-md) var(--spacing-sm);
  /* Apple: removed hard border, use shadow */
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-xs);
  font-size: var(--font-size-md);
}

.return-pick-item--active {
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
}
