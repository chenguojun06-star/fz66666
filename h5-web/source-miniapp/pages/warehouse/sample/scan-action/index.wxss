/* 样衣仓库管理页 */

.container {
  padding: 12rpx var(--page-padding-x);
  background: var(--color-bg-page, var(--color-bg-page));
  min-height: 100vh;
}

/* ===== sticky-search-bar 容器：负 margin 抵消 .container 水平 padding ===== */
.ssb-wrap {
  margin: 0 calc(-1 * var(--page-padding-x));
}

/* ==================== 列表 ==================== */
.stock-list {
  margin-top: 8rpx;
}

.stock-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-card);
  
  
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.stock-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-xs);
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg-page);
}

.stock-thumb-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-xs);
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-4xl);
}

.stock-info {
  flex: 1;
}

.stock-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.stock-row:last-child {
  margin-bottom: 0;
}

.stock-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  width: 60rpx;
  flex-shrink: 0;
}

.stock-value {
  font-size: var(--font-size-md);
  color: var(--color-text);
}

.stock-status {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.stock-quantity {
  display: flex;
  align-items: baseline;
}

.qty-num {
  font-size: var(--font-size-xl);
  font-weight: bold;
  color: var(--color-primary);
}

.qty-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-left: 4rpx;
}

.stock-loan {
  font-size: var(--font-size-2xs);
  color: var(--color-warning);
  margin-top: 4rpx;
}

.stock-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 40px;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
}

.load-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* ==================== 详情页头部 ==================== */
.header {
  position: relative;
  margin-bottom: 12rpx;
}

.header-back {
  position: absolute;
  left: 0;
  top: 0;
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: 8rpx 0;
}

.header-title {
  text-align: center;
  font-size: var(--font-size-lg);
  font-weight: bold;
  color: var(--color-text);
  display: block;
}

.header-scan {
  position: absolute;
  right: 0;
  top: 0;
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  padding: 8rpx 0;
}

.header-info {
  text-align: center;
  margin-bottom: 16rpx;
}

.header-sub {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}

/* ==================== 通用组件 ==================== */

/* 加载 */
.loading-wrap { 
  display: flex; 
  justify-content: center; 
  align-items: center; 
  padding: 60px 0; 
}
.loading-text { 
  font-size: var(--font-size-md); 
  color: var(--color-text-secondary); 
}

/* 错误 */
.error-card {
  background: var(--color-danger-bg);
  border: 1px solid var(--color-danger);
  border-radius: var(--radius-md);
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.error-icon { font-size: var(--font-size-4xl); margin-bottom: 8px; }
.error-msg { font-size: var(--font-size-md); color: var(--color-danger); text-align: center; margin-bottom: 12px; }
.btn-retry {
  font-size: var(--font-size-md);
  color: var(--color-primary);
  padding: 6px 20px;
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-xs);
}

/* 成功 */
.success-banner {
  background: var(--color-success-bg);
  border: 1px solid var(--color-success);
  border-radius: var(--radius-md);
  padding: 10px 14px;
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}
.success-icon { font-size: var(--font-size-lg-xl); margin-right: 8px; }
.success-text { font-size: var(--font-size-md); color: var(--color-success); }

/* 信息卡片 */
.info-card {
  background: var(--color-bg-card);
  
  
  margin-bottom: 10px;
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.detail-image {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius-xs);
  margin-bottom: 12rpx;
  background: var(--color-bg-page);
}

.info-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  border-bottom: 1px solid var(--color-border);
}
.info-row:last-child { border-bottom: none; }
.info-label { font-size: var(--font-size-sm); color: var(--color-text-secondary); width: 60px; flex-shrink: 0; }
.info-value { font-size: var(--font-size-md); color: var(--color-text); flex: 1; }
.info-value.bold,
.bold { font-weight: bold; font-size: var(--font-size-md-lg); color: var(--color-primary); }

/* 状态标签 */
.status-tag { padding: 2px 8px; border-radius: var(--radius-xl); font-size: var(--font-size-xs); }
.tag-green { background: var(--color-success-bg); color: var(--color-success); }
.tag-orange { background: var(--color-warning-bg); color: var(--color-warning); }

/* 借调记录 */
.loan-item { margin-top: 4px; padding-top: 4px; border-top: 1px dashed var(--color-border); }

/* 操作按钮 */
.action-area { margin-bottom: 10px; }

/* 仓库选择区域 */
.warehouse-section {
  margin-bottom: 12rpx;
  
  background: var(--color-bg-page);
  
  

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.warehouse-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 6px;
}

.warehouse-option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 8px;
}

.warehouse-chip {
  padding: 4px 14px;
  border-radius: var(--radius-full);
  font-size: var(--font-size-sm);
  border: 1px solid var(--color-border);
  background: var(--color-bg-page);
  color: var(--color-text-primary);
}

.warehouse-chip--active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

.warehouse-chip--clear {
  background: rgba(254, 226, 226, 0.6);
  border-color: rgba(252, 165, 165, 0.5);
  color: var(--color-danger);
}

.warehouse-chip--disabled {
  opacity: 0.4;
  pointer-events: none;
}

.warehouse-chip-hover {
  opacity: 0.75;
}

.input-box {
  width: 100%;
  height: 40px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 12px;
  font-size: var(--font-size-sm);
  box-sizing: border-box;
}

.btn-inbound {
  background: var(--color-primary);
  color: var(--color-text-white);
  text-align: center;
  border-radius: var(--radius-md);
  padding: 14px 0;
  font-size: var(--font-size-md-lg);
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(24,144,255,0.25);
  margin-bottom: 8px;
}

.btn-loan {
  background: var(--color-primary);
  color: var(--color-text-white);
  text-align: center;
  border-radius: var(--radius-md);
  padding: 14px 0;
  font-size: var(--font-size-md-lg);
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(24,144,255,0.25);
  margin-bottom: 8px;
}

.btn-return {
  background: var(--color-warning);
  color: var(--color-text-white);
  text-align: center;
  border-radius: var(--radius-md);
  padding: 14px 0;
  font-size: var(--font-size-md-lg);
  font-weight: bold;
  box-shadow: 0 2px 8px rgba(250,173,20,0.25);
  margin-bottom: 8px;
}
