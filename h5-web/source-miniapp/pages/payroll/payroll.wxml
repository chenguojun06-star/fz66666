<!-- pages/payroll/payroll.wxml -->
<view class="page">

  <!-- 品牌渐变汇总卡 -->
  <view class="summary-card">
    <text class="summary-month">{{monthLabel}}</text>
    <text class="summary-amount">¥{{totalAmount}}</text>

    <!-- 环比对比 -->
    <view class="summary-mom" wx:if="{{momText}}">
      <text class="mom-arrow {{momIsUp ? 'mom-up' : 'mom-down'}}">{{momIsUp ? '↑' : '↓'}}</text>
      <text class="mom-text {{momIsUp ? 'mom-up' : 'mom-down'}}">较上月 {{momText}}</text>
    </view>

    <!-- 分类明细：计件 | 奖金 -->
    <view class="summary-breakdown">
      <view class="breakdown-item">
        <text class="breakdown-label">计件工资</text>
        <text class="breakdown-value">¥{{pieceworkTotal}}</text>
      </view>
      <view class="breakdown-divider"></view>
      <view class="breakdown-item">
        <text class="breakdown-label">奖金</text>
        <text class="breakdown-value">¥{{bonusTotal}}</text>
      </view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <view
      class="filter-tab {{typeFilter === 'all' ? 'active' : ''}}"
      hover-class="filter-tab-hover"
      hover-stay-time="100"
      bindtap="onTypeFilterChange"
      data-filter="all"
    >全部</view>
    <view
      class="filter-tab {{typeFilter === 'piecework' ? 'active' : ''}}"
      hover-class="filter-tab-hover"
      hover-stay-time="100"
      bindtap="onTypeFilterChange"
      data-filter="piecework"
    >计件</view>
    <view
      class="filter-tab {{typeFilter === 'hourly' ? 'active' : ''}}"
      hover-class="filter-tab-hover"
      hover-stay-time="100"
      bindtap="onTypeFilterChange"
      data-filter="hourly"
    >计时</view>
    <view
      class="filter-tab {{typeFilter === 'bonus' ? 'active' : ''}}"
      hover-class="filter-tab-hover"
      hover-stay-time="100"
      bindtap="onTypeFilterChange"
      data-filter="bonus"
    >奖金</view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 工明细记录 -->
  <view class="records-list" wx:if="{{!loading && filteredRecords.length > 0}}">
    <view
      class="record-card"
      wx:for="{{filteredRecords}}"
      wx:key="index"
      hover-class="record-card-hover"
      hover-stay-time="100"
    >
      <view class="record-left">
        <view class="record-tag-row">
          <text class="process-tag {{item.isBonus ? 'tag-orange' : 'tag-blue'}}">{{item.processTag}}</text>
          <text class="record-product">{{item.productName}}</text>
        </view>
        <text class="record-meta">{{item.metaText}}</text>
      </view>
      <view class="record-right">
        <text class="record-calc">{{item.calcText}}</text>
        <text class="record-amount">¥{{item.totalAmount}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:if="{{!loading && filteredRecords.length === 0}}"
    icon="icon-clipboard"
    text="{{emptyText}}"
  ></empty-state>

</view>

<!-- 底部固定合计栏 -->
<view class="total-bar" wx:if="{{!loading && records.length > 0}}">
  <view class="total-bar-content">
    <text class="total-bar-label">合计</text>
    <text class="total-bar-value">¥{{filteredTotal}}</text>
  </view>
</view>
