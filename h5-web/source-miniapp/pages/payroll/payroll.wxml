<!-- pages/payroll/payroll.wxml -->
<view class="page">
  <!-- 汇总渐变卡片 (brand-50 -> brand-100) -->
  <view class="summary-card">
    <text class="summary-month">{{currentMonthLabel}}</text>
    <text class="summary-amount">¥{{totalAmount}}</text>
    <view class="summary-mom" wx:if="{{momChange}}">
      <view class="mom-arrow {{momChange >= 0 ? 'mom-up' : 'mom-down'}}"></view>
      <text class="mom-text {{momChange >= 0 ? 'mom-up' : 'mom-down'}}">较上月 {{momChange >= 0 ? '+' : ''}}{{momChange}}%</text>
    </view>
    <view class="summary-stats">
      <view class="summary-stat-item">
        <text class="summary-stat-label">计件工资</text>
        <text class="summary-stat-value">¥{{pieceworkAmount}}</text>
      </view>
      <view class="summary-stat-divider"></view>
      <view class="summary-stat-item">
        <text class="summary-stat-label">奖金</text>
        <text class="summary-stat-value">¥{{bonusAmount}}</text>
      </view>
    </view>
  </view>

  <!-- 日期选择栏 -->
  <view class="date-bar">
    <picker mode="date" value="{{startDate}}" end="{{endDate}}" bindchange="onStartDateChange">
      <view class="date-picker">
        <text class="date-label">开始</text>
        <text class="date-value">{{startDate}}</text>
      </view>
    </picker>
    <text class="date-sep">~</text>
    <picker mode="date" value="{{endDate}}" start="{{startDate}}" bindchange="onEndDateChange">
      <view class="date-picker">
        <text class="date-label">结束</text>
        <text class="date-value">{{endDate}}</text>
      </view>
    </picker>
  </view>

  <!-- 类型筛选 tabs (Apple 风格下划线) -->
  <view class="filter-tabs">
    <view class="filter-tab {{wageTypeFilter === 'all' ? 'active' : ''}}"
      data-filter="all" bindtap="onWageTypeChange">全部</view>
    <view class="filter-tab {{wageTypeFilter === 'piecework' ? 'active' : ''}}"
      data-filter="piecework" bindtap="onWageTypeChange">计件</view>
    <view class="filter-tab {{wageTypeFilter === 'hourly' ? 'active' : ''}}"
      data-filter="hourly" bindtap="onWageTypeChange">计时</view>
    <view class="filter-tab {{wageTypeFilter === 'bonus' ? 'active' : ''}}"
      data-filter="bonus" bindtap="onWageTypeChange">奖金</view>
  </view>

  <!-- 明细记录列表 -->
  <view class="detail-list">
    <block wx:for="{{filteredRecords}}" wx:key="index">
      <view class="record-item">
        <view class="record-main">
          <view class="record-left">
            <view class="record-tag-line">
              <text class="process-tag {{item.wageType === 'bonus' ? 'tag-bonus' : 'tag-piecework'}}">{{item.processName}}</text>
              <text class="record-product">{{item.styleName || item.styleNo}}</text>
            </view>
            <text class="record-sub">{{item.orderNo}} · {{item.shortDate}}</text>
          </view>
          <view class="record-right">
            <text class="record-calc">{{item.quantity}}{{item.wageType === 'bonus' ? '' : '件'}} × ¥{{item.unitPrice}}</text>
            <text class="record-amount">¥{{item.totalAmount}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{filteredRecords.length === 0 && !loading}}">
      <view class="line-icon line-icon--lg icon-clipboard-gray"></view>
      <text class="empty-text">暂无工资记录</text>
    </view>
  </view>

  <!-- 底部间距（为固定合计栏留位） -->
  <view class="bottom-bar-spacer"></view>

  <!-- 底部固定合计栏 -->
  <view class="bottom-bar">
    <view class="bottom-bar-inner">
      <text class="bottom-bar-label">本月合计</text>
      <text class="bottom-bar-amount">¥{{filteredTotalAmount}}</text>
    </view>
  </view>
  <ai-assistant />
</view>
