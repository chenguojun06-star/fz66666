.page {
  padding-bottom: 100px;
  background: var(--color-bg-page);
  min-height: 100vh;
}

.section {
  background: var(--color-bg-card);
  margin-bottom: 12px;
  padding: 16px;
  border-radius: var(--radius-lg);
  /* Apple: removed hard border, use shadow */
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 16px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.add-btn {
  color: var(--color-primary);
  font-size: var(--font-size-md);
  padding: 4px 12px;
  background: var(--color-primary-bg);
  border-radius: 16px;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
}

.form-item.search-input-wrapper {
  flex-direction: column;
  align-items: flex-start;
  position: relative;
}

.search-input-container {
  display: flex;
  width: 100%;
  align-items: center;
  position: relative;
}

.search-input {
  flex: 1;
  padding-right: 70px;
}

.search-loading {
  position: absolute;
  right: 40px;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}

.clear-icon {
  position: absolute;
  right: 12px;
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  padding: 4px;
}

.search-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  margin-top: 4px;
  background: var(--color-bg-card);
  /* Apple: removed hard border, use shadow */
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  z-index: var(--z-dropdown);
  max-height: 200px;
  overflow-y: auto;
}

.search-dropdown-item {
  padding: 12px 16px;
  border-bottom: 1px solid var(--color-border-light);
}

.search-dropdown-item:last-child {
  border-bottom: none;
}

.search-dropdown-item:active {
  background: var(--color-bg-hover);
}

.dropdown-item-main {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
}

.dropdown-item-sub {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 4px;
}

.form-row {
  display: flex;
  gap: 12px;
}

.form-item.half {
  flex: 1;
}

.label {
  width: 80px;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.search-input-wrapper .label {
  margin-bottom: 8px;
  width: 100%;
}

.label.required::before {
  content: '*';
  color: var(--color-danger);
  margin-right: 4px;
}

.input {
  flex: 1;
  height: 40px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0 12px;
  font-size: var(--font-size-md);
  background: var(--color-bg-gray);
  transition: all 0.3s;
  box-sizing: border-box;
}

.input:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
  box-shadow: 0 0 0 3px var(--color-primary-bg);
}

.picker {
  flex: 1;
  height: 40px;
  line-height: 40px;
  /* Apple: removed hard border, use shadow */
  border-radius: var(--radius-md);
  padding: 0 12px;
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  background: var(--color-bg-gray);
  box-sizing: border-box;
}

.radio-group {
  flex: 1;
  display: flex;
  gap: 24px;
}

.mode-radio-group {
  display: flex;
  gap: 32px;
  margin-bottom: 16px;
}

.mode-radio {
  display: flex;
  align-items: center;
  gap: 6px;
}

.image-upload {
  width: 100%;
  height: 180px;
  border: 2px dashed var(--color-border);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  background: var(--color-bg-gray);
  transition: all 0.3s ease;
}

.image-upload:active {
  background: var(--color-bg-hover);
  border-color: var(--color-primary);
}

.image-upload image {
  width: 100%;
  height: 100%;
}

.delete-image {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 28px;
  height: 28px;
  background: rgba(250, 81, 81, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-white);
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-bold);
  box-shadow: 0 2px 8px rgba(250, 81, 81, 0.4);
  z-index: 10;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-md);
}

.upload-icon {
  font-size: var(--font-size-6xl);
  opacity: 0.6;
}

.order-lines {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.order-line {
  background: var(--color-bg-light);
  border-radius: var(--radius-md);
  padding: 14px;
  display: flex;
  gap: 12px;
  align-items: center;
  /* Apple: removed hard border, use shadow */
}

.line-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.line-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

.line-input {
  height: 36px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0 10px;
  font-size: var(--font-size-md);
  background: var(--color-bg-card);
  box-sizing: border-box;
}

.line-input:focus {
  border-color: var(--color-primary);
}

.line-del {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-danger);
  font-size: var(--font-size-lg);
  flex-shrink: 0;
  background: var(--color-danger-bg);
  border-radius: 50%;
}

.textarea {
  width: 100%;
  min-height: 100px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 12px;
  font-size: var(--font-size-md);
  box-sizing: border-box;
  background: var(--color-bg-gray);
  transition: all 0.3s ease;
  line-height: 1.5;
}

.textarea:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-card);
  box-shadow: 0 0 0 3px var(--color-primary-bg);
}

.submit-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-sm) var(--spacing-lg) calc(var(--spacing-sm) + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1px solid var(--color-border-light);
  box-shadow: var(--shadow-lg);
}

.submit-btn {
  width: 100%;
  height: var(--btn-height-md);
  line-height: var(--btn-height-md);
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  border-radius: var(--radius-md);
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
}

.submit-btn:active {
  opacity: 0.9;
}

.submit-btn::after {
  border: none;
}
