<!-- 外发管理 · 设计稿对齐 factory-shipment.html -->
<view class="page">
  <!-- ===== Sticky 头部：Tab + 工厂筛选 + 搜索 + 扫码 + 筛选器（统一吸顶）===== -->
  <view class="sticky-header">
    <!-- Tab 切换（segmented control：rounded-lg bg-muted p-0.5） -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab===0?'tab-active':''}}" data-tab="0" bindtap="switchTab">我的订单</view>
      <view class="tab-item {{activeTab===1?'tab-active':''}}" data-tab="1" bindtap="switchTab">发货记录</view>
    </view>

    <!-- 工厂筛选 · 横向滚动卡 -->
    <scroll-view wx:if="{{activeTab===0 && factoryStats.length > 0}}" class="factory-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="factory-card {{selectedFactoryId === item.factoryId ? 'factory-card--active' : ''}}"
            wx:for="{{factoryStats}}" wx:key="factoryId"
            data-id="{{item.factoryId}}" bindtap="onSelectFactory">
        <text class="factory-name">{{item.factoryName}}</text>
        <view class="factory-nums">
          <view class="fn-item">
            <text class="fn-val fn-val--primary">{{item.orderCount}}</text>
            <text class="fn-lbl">单</text>
          </view>
          <view class="fn-item">
            <text class="fn-val">{{item.totalQuantity}}</text>
            <text class="fn-lbl">件</text>
          </view>
          <view class="fn-item">
            <text class="fn-val fn-val--sm">{{item.styleCount}}</text>
            <text class="fn-lbl">款</text>
          </view>
        </view>
        <view class="factory-tags">
          <text class="ftag ftag--primary" wx:if="{{item.inProgress > 0}}">{{item.inProgress}}进行中</text>
          <text class="ftag ftag--success" wx:if="{{item.completed > 0}}">{{item.completed}}已完成</text>
          <text class="ftag ftag--danger" wx:if="{{item.overdue > 0}}">{{item.overdue}}逾期</text>
          <text class="ftag ftag--warning" wx:if="{{item.warning > 0}}">{{item.warning}}预警</text>
        </view>
      </view>
    </scroll-view>

    <!-- 搜索栏 + 扫码 + 筛选器（嵌入已有 sticky-header 内，sticky=false） -->
    <sticky-search-bar
      sticky="{{false}}"
      placeholder="搜索订单号 / 款号"
      value="{{keyword}}"
      show-scan="{{true}}"
      show-filter="{{activeTab===0}}"
      bind:input="onKeywordInput"
      bind:confirm="onKeywordSearch"
      bind:scan="onScan"
    >
      <view slot="filter">
        <!-- 筛选 pill（生产中 / 已完成） -->
        <view class="filter-pills">
          <view class="filter-pill {{activeFilter==='production'?'filter-pill--active':''}}" data-filter="production" bindtap="onFilterTap">
            <text>生产中</text>
            <text class="pill-count">{{filterStats.production}}</text>
          </view>
          <view class="filter-pill {{activeFilter==='completed'?'filter-pill--active':''}}" data-filter="completed" bindtap="onFilterTap">
            <text>已完成</text>
            <text class="pill-count">{{filterStats.completed}}</text>
          </view>
        </view>

        <!-- 智能提示标签（已延期 / 临近交期，可点击筛选） -->
        <view class="hint-row">
          <view class="hint-tag hint-tag--danger {{activeFilter==='overdue'?'hint-tag--active':''}}" data-filter="overdue" bindtap="onFilterTap">
            <view class="hint-tag__icon icon-alert-red"></view>
            <text>已延期</text>
            <text class="hint-tag__count">{{filterStats.overdue}}</text>
          </view>
          <view class="hint-tag hint-tag--warning {{activeFilter==='warning'?'hint-tag--active':''}}" data-filter="warning" bindtap="onFilterTap">
            <view class="hint-tag__icon icon-clock-gray"></view>
            <text>临近交期</text>
            <text class="hint-tag__count">{{filterStats.warning}}</text>
          </view>
        </view>
      </view>
    </sticky-search-bar>
  </view>

  <!-- ===== 我的订单 ===== -->
  <view wx:if="{{activeTab===0}}" class="tab-content">
    <!-- 空状态 -->
    <view wx:if="{{orders.length===0 && !orderLoading}}" class="empty">
      <view class="line-icon line-icon--xl icon-clipboard-gray"></view>
      <text class="empty-text">暂无订单数据</text>
    </view>

    <!-- 订单列表 -->
    <view class="order-list" wx:if="{{orders.length > 0}}">
      <view class="order-card {{item.expanded ? 'order-card--open' : ''}} {{item.remainDaysClass === 'days-overdue' ? 'order-card--overdue' : ''}}"
            wx:for="{{orders}}" wx:key="id">

        <!-- 主行：封面图 + 基本信息 -->
        <view class="order-main" data-index="{{index}}" bindtap="onCardToggle">
          <view class="order-cover" catchtap="onCoverPreview" data-url="{{item.styleCoverUrl}}">
            <image wx:if="{{item.styleCoverUrl}}" class="cover-pic" src="{{item.styleCoverUrl}}" mode="aspectFill" lazy-load />
            <view wx:else class="cover-placeholder">
              <view class="cover-ph-text"><view class="line-icon line-icon--xl icon-package"></view></view>
            </view>
          </view>

          <view class="order-info">
            <!-- 行1：订单号 + 急标签 + 状态标签 -->
            <view class="info-line1">
              <text class="order-no">{{item.orderNo}}</text>
              <view class="info-badges">
                <text wx:if="{{item.urgencyTagText === '急'}}" class="urgent-badge">急</text>
                <text wx:if="{{item.statusText}}" class="status-badge status-badge--{{item.statusCls}}">{{item.statusText}}</text>
              </view>
            </view>
            <!-- 行2：款名 -->
            <view class="info-style">{{item.styleName || item.styleNo || '暂无款名'}}</view>
            <!-- 行3：客户名 -->
            <view class="info-customer" wx:if="{{item.customerName}}">{{item.customerName}}</view>
            <!-- 行4：工厂名 -->
            <view class="info-factory" wx:if="{{item.factoryName}}">{{item.factoryName}}</view>
          </view>
        </view>

        <!-- 进度行：数量·交期 + 进度条 + 百分比 + 剩余天数（同一行） -->
        <view class="info-progress">
          <view class="ip-left">
            <text class="ip-qty">{{item.cuttingQty || item.totalQuantity || item.orderQuantity || 0}}件</text>
            <text class="ip-dot">·</text>
            <text class="ip-delivery" wx:if="{{item.deliveryDateStr}}">交期 {{item.deliveryDateStr}}</text>
          </view>
          <view class="ip-bar">
            <view class="ip-fill {{item.remainDaysClass === 'days-overdue' ? 'ip-fill--overdue' : ''}} {{item.isClosed ? 'ip-fill--done' : ''}}" style="width: {{item.progressWidth}}%"></view>
          </view>
          <text class="ip-pct">{{item.calculatedProgress || 0}}%</text>
          <text class="ip-remain {{item.remainDaysClass}}" wx:if="{{item.remainDaysText}}">{{item.remainDaysText}}</text>
        </view>

        <!-- 展开按钮 -->
        <view class="order-expand-btn" data-index="{{index}}" catchtap="onCardToggle">
          <text class="expand-btn-text">{{item.expanded ? '收起菲号明细' : '展开菲号明细'}}</text>
          <view class="expand-btn-arrow {{item.expanded ? 'expand-btn-arrow--up' : ''}}"><view class="icon-chevron-down-sm"></view></view>
        </view>

        <!-- 展开区域 -->
        <view class="order-expand" wx:if="{{item.expanded}}">
          <!-- 菲号明细 -->
          <view class="detail-head">
            <text class="detail-title">菲号明细</text>
            <text class="detail-count">共{{item.colorGroups.length || 0}}菲</text>
          </view>
          <view class="detail-table">
            <view class="detail-row detail-row--head">
              <view class="detail-cell detail-cell--no">菲号</view>
              <view class="detail-cell detail-cell--proc">工序明细</view>
              <view class="detail-cell detail-cell--qty">数量</view>
            </view>
            <block wx:if="{{item.colorGroups && item.colorGroups.length > 0}}">
              <view class="detail-row" wx:for="{{item.colorGroups}}" wx:for-item="cg" wx:key="color">
                <view class="detail-cell detail-cell--no">{{cg.color}}</view>
                <view class="detail-cell detail-cell--proc">
                  <text wx:for="{{item.processNodes}}" wx:for-item="pn" wx:for-index="pni" wx:key="name" class="proc-node">{{pn.name}}<text wx:if="{{pni < item.processNodes.length - 1}}" class="proc-sep">→</text></text>
                </view>
                <view class="detail-cell detail-cell--qty">{{cg.total}}件</view>
              </view>
            </block>
            <view class="detail-row detail-row--empty" wx:else>
              <view class="detail-cell detail-cell--empty">暂无菲号明细</view>
            </view>
          </view>

          <!-- 工序进度明细 -->
          <view class="expand-section" wx:if="{{item.processNodes && item.processNodes.length > 0}}">
            <text class="expand-title">工序进度</text>
            <view class="process-node" wx:for="{{item.processNodes}}" wx:for-item="node" wx:key="name">
              <view class="node-hd">
                <text class="node-name">{{node.name}}</text>
                <text class="node-pct {{node.percent >= 100 ? 'node-pct--done' : ''}}">{{node.percent}}%</text>
              </view>
              <view class="node-meta">
                <text class="node-qty" wx:if="{{node.qtyInfo}}">{{node.qtyInfo.completed}}/{{node.qtyInfo.total}}件</text>
                <text class="node-dot" wx:if="{{node.qtyInfo && node.bundleInfo}}">·</text>
                <text class="node-bundle-text" wx:if="{{node.bundleInfo}}">{{node.bundleInfo.scanned}}/{{node.bundleInfo.total}}菲</text>
              </view>
              <view class="node-bar-bg">
                <view class="node-bar-fill {{node.percent >= 100 ? 'node-bar-fill--done' : ''}}" style="width: {{node.percentWidth}}%"></view>
              </view>
              <!-- 子工序列表 -->
              <view class="node-sub-procs" wx:if="{{node.children && node.children.length > 0}}">
                <view class="sub-proc-item" wx:for="{{node.children}}" wx:for-item="sp" wx:key="name">
                  <text class="sp-name">{{sp.name}}</text>
                  <text class="sp-price" wx:if="{{sp.unitPrice > 0}}">¥{{sp.unitPrice}}</text>
                  <text class="sp-price sp-price--free" wx:else>待定价</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 颜色尺码矩阵 -->
          <view class="expand-section" wx:if="{{item.colorGroups && item.colorGroups.length > 0}}">
            <text class="expand-title">颜色尺码</text>
            <scroll-view scroll-x class="sku-scroll" enhanced show-scrollbar="{{false}}">
              <view class="sku-table">
                <view class="sku-row sku-row--head">
                  <text class="sku-cell sku-cell--color">颜色</text>
                  <text class="sku-cell" wx:for="{{item.allSizes}}" wx:for-item="sz" wx:key="*this">{{sz}}</text>
                  <text class="sku-cell sku-cell--total">合计</text>
                </view>
                <view class="sku-row" wx:for="{{item.colorGroups}}" wx:for-item="cg" wx:key="color">
                  <text class="sku-cell sku-cell--color">{{cg.color}}</text>
                  <text class="sku-cell" wx:for="{{item.allSizes}}" wx:for-item="sz" wx:key="*this">{{cg.sizeMap[sz] || '-'}}</text>
                  <text class="sku-cell sku-cell--total">{{cg.total}}</text>
                </view>
              </view>
            </scroll-view>
          </view>

          <!-- 快捷操作 -->
          <view class="expand-actions">
            <view class="act-btn act-btn--detail" catchtap="onGoOrderDetail" data-index="{{index}}">详情</view>
            <view class="act-btn act-btn--primary" catchtap="onGoOrderProcurement" data-index="{{index}}">采购</view>
            <view class="act-btn act-btn--primary" catchtap="onGoOrderCutting" data-index="{{index}}">裁剪</view>
            <view class="act-btn act-btn--primary" catchtap="onGoOrderProcessEdit" data-index="{{index}}">工序</view>
            <view class="act-btn act-btn--warn" catchtap="onOpenShip" data-index="{{index}}" wx:if="{{isFactory || isTenantAdmin}}">发货</view>
            <view class="act-btn act-btn--remark" catchtap="onViewShipment" data-index="{{index}}">发货记录</view>
            <view class="act-btn act-btn--remark" catchtap="onOpenRemark" data-index="{{index}}">备注</view>
            <view class="act-btn" catchtap="onCopyOrderNo" data-order-no="{{item.orderNo}}">复制单号</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载提示 -->
    <view class="load-tip" wx:if="{{orderLoading}}">加载中…</view>
    <view class="load-tip load-tip--end" wx:if="{{!orderHasMore && orders.length>0}}">— 没有更多了 —</view>
  </view>

  <!-- ===== 发货记录 ===== -->
  <view wx:if="{{activeTab===1}}" class="tab-content">
    <view wx:if="{{shipments.length===0 && !shipmentLoading}}" class="empty">
      <view class="line-icon line-icon--xl icon-package"></view>
      <text class="empty-text">暂无发货记录</text>
    </view>
    <view wx:for="{{shipments}}" wx:key="id" class="shipment-card" data-index="{{index}}" bindtap="onTapShipment">
      <view class="shipment-top">
        <text class="shipment-no">{{item.orderNo || item.shipmentNo || ''}}</text>
        <text class="shipment-status {{item.statusCls}}">{{item.statusText}}</text>
      </view>
      <view class="shipment-info">
        <text>发货: {{item.totalQuantity || 0}}件</text>
        <text>{{item.shipDate || item.createdAt || ''}}</text>
      </view>
    </view>
    <view class="load-tip" wx:if="{{shipmentLoading}}">加载中…</view>
    <view class="load-tip load-tip--end" wx:if="{{!shipmentHasMore && shipments.length>0}}">— 没有更多了 —</view>
  </view>
  <ai-assistant />
</view>

