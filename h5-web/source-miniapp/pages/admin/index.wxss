page {
  background: var(--color-bg-page);
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

.container {
  min-height: 100vh;
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
}

/* ===== 用户信息卡 ===== */
.user-profile-card {
  position: relative;
  margin: 0 0 0;
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
  color: var(--color-text-primary);
}

.profile-edit-btn {
  position: absolute;
  right: 16px;
  top: 16px;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-tertiary);
  z-index: 1;
}

.profile-edit-btn-hover {
  background: rgba(255, 255, 255, 0.25);
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding-right: 40px;
}

.profile-avatar {
  width: 64px;
  height: 64px;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-letter {
  font-size: var(--font-size-4xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-white);
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.profile-name {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-badge {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}

.profile-sub {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-sub--phone {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

.profile-online {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

.online-icon {
  opacity: 0.8;
}

/* ===== 退出登录 ===== */
.logout-section {
  margin-top: var(--card-gap-y);
  padding: 0 var(--page-padding-x);
}

.logout-btn-full {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.logout-btn-full-hover {
  background: var(--color-bg-page);
}

.logout-btn-text {
  font-size: var(--font-size-base);
  color: var(--color-danger);
  font-weight: var(--font-weight-medium);
}

/* ===== 快速统计 ===== */
.stats-row {
  display: flex;
  margin: 12px 0 var(--card-gap-y);
  padding: 16px;
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
  position: relative;
  z-index: 1;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stats-item--divider {
  border-left: 1px solid var(--color-border);
  border-right: 1px solid var(--color-border);
}

.stats-value {
  font-size: var(--font-size-3xl);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  line-height: 1.2;
}

.stats-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ===== 功能菜单 ===== */
.menu-group {
  margin-bottom: var(--card-gap-y);
}

.menu-list {
  background: var(--color-bg-card);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  position: relative;
}

.menu-item::after {
  content: '';
  position: absolute;
  left: 60px;
  right: 0;
  bottom: 0;
  height: 1px;
  background: var(--color-border);
}

.menu-item:last-child::after {
  display: none;
}

.menu-item-hover {
  background: var(--color-bg-page);
}

.menu-icon-wrap {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  color: var(--color-text-white);
  flex-shrink: 0;
}

.menu-label {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-right: 4px;
}

.menu-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 20px;
  height: 20px;
  padding: 0 6px;
  border-radius: var(--radius-full);
  background: var(--color-danger);
  color: var(--color-text-white);
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-semibold);
  white-space: nowrap;
  flex-shrink: 0;
}

.menu-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

/* ===== 菜单管理弹窗 ===== */
.mm-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: var(--z-notification);
}

.mm-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg-card);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 20px 16px calc(20px + env(safe-area-inset-bottom));
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  z-index: var(--z-notification);
}

.mm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.mm-title {
  font-size: var(--font-size-lg-xl);
  font-weight: 600;
  color: var(--color-text-primary);
}

.mm-close {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-bg-page);
}

.mm-close-hover {
  background: var(--color-border);
}

.mm-close-text {
  font-size: var(--font-size-lg);
  color: var(--color-text-secondary);
}

.mm-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-bottom: 16px;
  line-height: 1.5;
}

.mm-list {
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.mm-scroll {
  flex: 1;
  max-height: 55vh;
}

.mm-role-group {
  margin-bottom: 12px;
}

.mm-role-header {
  padding: 8px 12px;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  margin-bottom: 4px;
}

.mm-role-label {
  font-size: var(--font-size-md);
  font-weight: 600;
  color: var(--color-primary);
}

.mm-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0;
  border-bottom: 1px solid var(--color-border);
}

.mm-item:last-child {
  border-bottom: none;
}

.mm-item-label {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: 500;
}

.mm-switch {
  width: 48px;
  height: 28px;
  border-radius: var(--radius-lg);
  position: relative;
  transition: background 0.2s;
  flex-shrink: 0;
}

.mm-switch-on {
  background: var(--color-primary);
}

.mm-switch-off {
  background: var(--color-border, #d9d9d9);
}

.mm-switch-dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--color-bg-card);
  position: absolute;
  top: 3px;
  transition: left 0.2s;
  box-shadow: var(--shadow-md);
}

.mm-switch-on .mm-switch-dot {
  left: 23px;
}

.mm-switch-off .mm-switch-dot {
  left: 3px;
}

.mm-footer {
  display: flex;
  gap: 12px;
  margin-top: 20px;
}

.mm-btn {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-xl);
  font-size: var(--font-size-base);
  font-weight: 500;
}

.mm-btn-hover {
  opacity: 0.8;
}

.mm-btn-cancel {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}

.mm-btn-save {
  background: var(--color-primary);
  color: var(--color-text-white);
}

.mm-btn-disabled {
  opacity: 0.5;
}
