<view class="container">
  <!-- 用户信息卡 -->
  <view wx:if="{{userInfo}}" class="user-profile-card">
    <view class="profile-edit-btn" hover-class="profile-edit-btn-hover" hover-stay-time="100" bindtap="onEditProfile">
      <view class="line-icon line-icon--sm icon-edit"></view>
    </view>
    <view class="profile-header">
      <view class="profile-avatar">
        <image wx:if="{{avatarImgUrl}}" src="{{avatarImgUrl}}" mode="aspectFill" style="width:100%;height:100%;border-radius:50%;display:block;" binderror="onAvatarError" />
        <text wx:else class="avatar-letter">{{avatarLetter}}</text>
      </view>
      <view class="profile-info">
        <view class="profile-name-row">
          <text class="profile-name">{{userInfo.name || userInfo.username || '未知用户'}}</text>
          <view class="role-badge">{{roleDisplayName || '普通用户'}}</view>
        </view>
        <view wx:if="{{tenantName}}" class="profile-sub">{{tenantName}}</view>
        <view wx:if="{{phoneText}}" class="profile-sub profile-sub--phone">{{phoneText}}</view>
        <view wx:if="{{showApprovalEntry}}" class="profile-online">
          <view class="line-icon line-icon--sm icon-user-group online-icon"></view>
          <text>{{onlineCount}}人在线</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速统计 -->
  <view class="stats-row">
    <view class="stats-item">
      <text class="stats-value">{{stats.workHours}}</text>
      <text class="stats-label">本月工时</text>
    </view>
    <view class="stats-item stats-item--divider">
      <text class="stats-value">{{stats.wageText}}</text>
      <text class="stats-label">本月工资</text>
    </view>
    <view class="stats-item">
      <text class="stats-value">{{stats.scanCount}}</text>
      <text class="stats-label">扫码次数</text>
    </view>
  </view>

  <!-- 功能菜单 - 分组卡片 -->
  <view class="menu-group" wx:for="{{menuGroups}}" wx:key="groupId" wx:for-item="group" wx:for-index="groupIdx">
    <view class="menu-list">
      <view class="menu-item" wx:for="{{group.items}}" wx:key="id" hover-class="menu-item-hover" data-index="{{item.flatIndex}}" bindtap="onMenuTap">
        <view class="menu-icon-wrap" style="background: {{item.iconBg}};">
          <view class="line-icon {{item.iconClass}}"></view>
        </view>
        <text class="menu-label">{{item.label}}</text>
        <view wx:if="{{item.badge}}" class="menu-badge">{{item.badge}}</view>
        <view class="menu-arrow icon-arrow-right-sm"></view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <view class="logout-btn-full" hover-class="logout-btn-full-hover" hover-stay-time="100" bindtap="onLogout">
      <text class="logout-btn-text">退出登录</text>
    </view>
  </view>

</view>

<!-- 菜单管理弹窗 -->
<view wx:if="{{menuManageVisible}}" class="mm-overlay" bindtap="closeMenuManage"></view>
<view wx:if="{{menuManageVisible}}" class="mm-panel">
  <view class="mm-header">
    <text class="mm-title">菜单管理</text>
    <view class="mm-close" hover-class="mm-close-hover" bindtap="closeMenuManage">
      <view class="mm-close-text icon-close"></view>
    </view>
  </view>
  <view class="mm-desc">按角色控制首页各功能入口的显示与隐藏，关闭后该角色用户首页不可见。</view>
  <scroll-view scroll-y class="mm-scroll">
    <view class="mm-role-group" wx:for="{{menuManageGroups}}" wx:key="role" wx:for-item="group" wx:for-index="roleIdx">
      <view class="mm-role-header">
        <text class="mm-role-label">{{group.roleLabel}}</text>
      </view>
      <view class="mm-list">
        <view class="mm-item" wx:for="{{group.menus}}" wx:key="shortKey" wx:for-item="menu" wx:for-index="menuIdx">
          <text class="mm-item-label">{{menu.label}}</text>
          <view class="mm-switch {{menu.enabled ? 'mm-switch-on' : 'mm-switch-off'}}" data-role-idx="{{roleIdx}}" data-menu-idx="{{menuIdx}}" bindtap="onMenuSwitch">
            <view class="mm-switch-dot"></view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  <view class="mm-footer">
    <view class="mm-btn mm-btn-cancel" hover-class="mm-btn-hover" bindtap="closeMenuManage">
      <text>取消</text>
    </view>
    <view class="mm-btn mm-btn-save {{savingMenuConfig ? 'mm-btn-disabled' : ''}}" bindtap="saveMenuConfig">
      <text>{{savingMenuConfig ? '保存中...' : '保存'}}</text>
    </view>
  </view>
</view>

<!-- 小云 AI 助手（全页面悬浮） -->
<ai-assistant visible="{{!menuManageVisible}}" />
