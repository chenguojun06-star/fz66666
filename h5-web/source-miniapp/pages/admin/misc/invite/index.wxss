
.container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
  padding-bottom: calc(env(safe-area-inset-bottom) + 16px);
}

/* QR Section */
.qr-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8px 0 0;
}

.qr-card {
  width: 176px;
  height: 176px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
  box-shadow: var(--shadow-sm);
}

.qr-image {
  width: 128px;
  height: 128px;
  display: block;
}

.qr-label {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  display: block;
  margin-top: 12px;
}

.qr-card-fail {
  padding: 40rpx 32rpx;
}

.qr-fail-text {
  font-size: var(--font-size-md);
  color: var(--color-text-tertiary);
  display: block;
  margin-bottom: 24rpx;
}

.retry-btn {
  display: inline-block;
  padding: 10px 28px;
  background: var(--color-primary);
  color: var(--color-text-white);
  border-radius: var(--radius-full);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-semibold);
}

.retry-btn-hover {
  opacity: 0.85;
}

.qr-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.qr-loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: qr-spin 0.8s linear infinite;
}

@keyframes qr-spin {
  to { transform: rotate(360deg); }
}

.qr-loading-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
}

/* Invite Card */
.invite-card {
  margin: 16px 0;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
  padding: 16px;
  box-shadow: var(--shadow-sm);
}

.card-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-label {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.copy-text-btn {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: transparent;
}

.copy-text-btn-hover {
  opacity: 0.7;
}

.code-display {
  margin-top: 8px;
  font-size: 36px;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
  letter-spacing: 0.1em;
}

.divider {
  height: 1px;
  background: var(--color-border);
  margin: 16px 0;
}

.hint-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
  line-height: var(--line-height-relaxed);
  margin-top: 4px;
  margin-bottom: 12px;
}

.copy-link-btn {
  width: 100%;
  text-align: center;
  padding: 10px 0;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--color-primary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
}

.copy-link-btn-hover {
  opacity: 0.7;
}

/* Steps Card */
.steps-card {
  margin: 0 0 16px;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
  padding: 16px;
  box-shadow: var(--shadow-sm);
}

.steps-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  margin-bottom: 16px;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-num {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  padding-top: 2px;
}

.step-text {
  font-size: var(--font-size-md);
  color: var(--color-text-primary);
  line-height: var(--line-height-relaxed);
}

/* Share Button */
.share-btn {
  margin: 0 0 16px;
  height: 48px;
  background: var(--color-primary);
  color: var(--color-text-white);
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  border-radius: var(--radius-xl);
  border: none;
  padding: 0;
  line-height: normal;
}

.share-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  height: 100%;
}

.share-btn-icon {
  font-size: 16px;
  line-height: 1;
}

.share-btn-text {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
}

.share-btn::after {
  border: none;
}

.button-hover {
  opacity: 0.85;
}
