page {
  background: var(--color-bg-page);
}

.container {
  min-height: 100vh;
  padding-bottom: calc(60px + env(safe-area-inset-bottom));
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 40vh;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 12px;
  font-size: 14px;
  color: var(--color-text-tertiary);
}

.content {
  padding: 0 var(--page-padding-x);
  padding-top: calc(var(--page-padding-x) + env(safe-area-inset-top));
}

/* ===== 应用头部 ===== */
.app-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 0 20px;
}

.app-logo {
  width: 64px;
  height: 64px;
  border-radius: var(--radius-xl);
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
}

.app-logo-text {
  font-size: 28px;
  font-weight: 700;
  color: #fff;
}

.app-name {
  margin-top: 12px;
  font-size: 18px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.app-slogan {
  margin-top: 4px;
  font-size: 13px;
  color: var(--color-text-tertiary);
}

/* ===== 信息卡片 ===== */
.info-card {
  margin-top: 16px;
  background: var(--color-bg-card);
  
  
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}

.info-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 12px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--color-border-light);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
}

.info-row + .info-row {
  border-top: 1px solid var(--color-border-lighter);
}

.info-label {
  font-size: 14px;
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.info-value {
  font-size: 14px;
  color: var(--color-text-primary);
  text-align: right;
  word-break: break-all;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.progress-bar {
  width: 80px;
  height: 6px;
  background: var(--color-border-lighter);
  border-radius: var(--radius-xs);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: var(--radius-xs);
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 13px;
  color: var(--color-text-secondary);
}

.text-error { color: var(--color-error); }
.text-success { color: var(--color-success); }

/* ===== 操作按钮 ===== */
.action-card {
  margin-top: 16px;
}

.action-btn {
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  padding: 14px;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.action-btn-hover {
  opacity: 0.85;
}

.action-btn-text {
  font-size: 15px;
  color: var(--color-primary);
  font-weight: 500;
}

/* ===== 版权 ===== */
.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 0 16px;
}

.copyright-text {
  font-size: 13px;
  color: var(--color-text-tertiary);
}

.copyright-sub {
  font-size: 11px;
  color: var(--color-text-quaternary);
  margin-top: 4px;
}
