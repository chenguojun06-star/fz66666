/**
 * 样衣阶段详情页样式
 * 严格对照设计稿 sample-stage-detail.html
 * 全部使用 design-tokens CSS 变量，禁止硬编码颜色
 * 卡片用 border + box-shadow，圆角用 var(--radius-xl) / var(--radius-md)
 */

/* ═══════════════════════════════════════════
   页面容器
   ═══════════════════════════════════════════ */
.stage-detail-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 0 var(--page-padding-x);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ═══════════════════════════════════════════
   加载状态
   ═══════════════════════════════════════════ */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: var(--radius-full);
  animation: spin 0.8s linear infinite;
}
.loading-text {
  margin-top: 16rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ═══════════════════════════════════════════
   ① 开发阶段快捷入口
   ═══════════════════════════════════════════ */
.dev-stage-section {
  margin-top: 24rpx;
}
.ds-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.ds-title {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.ds-sub {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.ds-scroll {
  width: 100%;
  white-space: nowrap;
}
.ds-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0 12rpx;
}
.ds-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  min-width: 120rpx;
  transition: all 0.2s ease;
}
.ds-item-active {
  background: var(--color-primary-bg);
  box-shadow: var(--shadow-md);
}
.ds-item-done {
  background: var(--color-success-bg);
}
.ds-icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ds-icon-text {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  line-height: 1.3;
}
.ds-item-active .ds-icon-text {
  color: var(--color-primary);
}
.ds-item-done .ds-icon-text {
  color: var(--color-success);
}
.ds-check {
  position: absolute;
  top: -8rpx;
  right: -12rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: var(--radius-full);
  background: var(--color-success);
  display: flex;
  align-items: center;
  justify-content: center;
}
.ds-check .line-icon {
  color: var(--color-text-white);
}
.ds-status {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  line-height: 1.2;
}
.ds-item-active .ds-status {
  color: var(--color-primary);
}
.ds-item-done .ds-status {
  color: var(--color-success);
}

/* ═══════════════════════════════════════════
   ② 当前阶段详情卡
   ═══════════════════════════════════════════ */
.sdc-card {
  margin-top: 24rpx;
  
  background: var(--color-bg-card);
  
  
  box-shadow: var(--shadow-sm);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
/* 进行中阶段：主色边框 + 阴影 */
.sdc-in_progress {
  border-color: var(--color-primary-border);
  box-shadow: var(--shadow-md);
}
/* 已完成阶段：成功色调 */
.sdc-completed {
  box-shadow: 0 4rpx 16rpx -4rpx var(--color-success-border);
}
/* 未开始阶段：普通阴影 */
.sdc-not_started {
  box-shadow: var(--shadow-2xs);
}

/* 头部 */
.sdc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.sdc-title-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.sdc-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.sdc-icon-completed {
  background: var(--color-success);
}
.sdc-icon-in_progress {
  background: var(--color-primary);
}
.sdc-icon-not_started {
  background: var(--color-text-quaternary);
}
.sdc-icon .line-icon {
  color: var(--color-text-white);
}
.sdc-title {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}

/* 状态标签 */
.sdc-status {
  font-size: var(--font-size-2xs);
  padding: 0 8px;
  height: 20px;
  line-height: 20px;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}
.tag-completed {
  background: var(--color-success-bg);
  color: var(--color-success);
}
.tag-in_progress {
  background: var(--color-primary);
  color: var(--color-text-white);
}
.tag-not_started {
  background: var(--color-bg-page);
  color: var(--color-text-tertiary);
}

/* 详情网格 */
.sdc-detail-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx 32rpx;
}
.sdc-grid-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}
.sdc-grid-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}
.sdc-grid-value {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: right;
}
.sdc-grid-value-success {
  color: var(--color-success);
}
.sdc-grid-value-warning {
  color: var(--color-warning);
}

/* 分割线 */
.sdc-divider {
  margin: 24rpx 0;
  height: 1rpx;
  background: var(--color-border);
}

/* 时间信息 */
.sdc-time-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.sdc-time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.sdc-time-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}
.sdc-time-value {
  margin-left: auto;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 现场照片 */
.sdc-photos {
  margin-top: 24rpx;
}
.sdc-photos-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sdc-photos-label {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.sdc-photos-count {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}
.sdc-photos-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.sdc-photo {
  width: 100%;
  height: 200rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-page);
}

/* 操作按钮 */
.sdc-actions {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.sdc-btn {
  flex: 1;
  height: 72rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: opacity 0.2s ease;
}
.sdc-btn:active {
  opacity: 0.7;
}
.sdc-btn-primary {
  background: transparent;
  border: 1px solid var(--color-primary);
}
.sdc-btn-primary .line-icon,
.sdc-btn-primary .sdc-btn-text {
  color: var(--color-primary);
}
.sdc-btn-outline {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
}
.sdc-btn-outline .line-icon {
  color: var(--color-text-primary);
}
.sdc-btn-outline .sdc-btn-text {
  color: var(--color-text-primary);
}
.sdc-btn-text {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
}

/* 已完成提示横幅 */
.sdc-completed-banner {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: var(--color-success-bg);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.sdc-completed-banner .line-icon {
  color: var(--color-success);
}
.sdc-completed-text {
  font-size: var(--font-size-xs);
  color: var(--color-success);
  font-weight: var(--font-weight-medium);
}

/* ═══════════════════════════════════════════
   区块标题
   ═══════════════════════════════════════════ */
.section-label {
  margin-top: 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sl-text {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.sl-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

/* ═══════════════════════════════════════════
   空状态
   ═══════════════════════════════════════════ */
.empty-state.compact {
  padding: 32rpx;
}
.empty-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.empty-hint {
  font-size: var(--font-size-2xs);
  color: var(--color-text-quaternary, #999);
}

/* ═══════════════════════════════════════════
   数据卡片（通用）
   ═══════════════════════════════════════════ */
.data-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}
.dc-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.dc-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}
.dc-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}
.dc-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.dc-amount {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-warning);
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.dc-tag {
  font-size: var(--font-size-2xs);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary-bg);
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
}
.dc-body {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.dc-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.dc-row.align-top {
  align-items: flex-start;
}
.dc-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  flex-shrink: 0;
  min-width: 120rpx;
}
.dc-value {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  font-weight: var(--font-weight-medium);
  flex: 1;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.dc-value.dc-amount {
  color: var(--color-warning);
}
.dc-row.align-top .dc-value {
  text-align: left;
  white-space: normal;
  word-break: break-all;
}
.dc-text-block {
  font-size: var(--font-size-xs);
  color: var(--color-text-primary);
  line-height: var(--line-height-medium);
  text-align: left;
  white-space: normal;
  word-break: break-all;
}
.dc-requirement-text {
  padding: 16rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  display: block;
}
.dc-image-wrap {
  margin-top: 16rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.dc-thumb {
  width: 100%;
  height: 240rpx;
  background: var(--color-bg-page);
}

/* BOM 部位标签 */
.dc-part-tag {
  font-size: var(--font-size-2xs);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
}
.dc-part-whole {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}
.dc-part-other {
  background: var(--color-bg-page);
  color: var(--color-text-secondary);
}
.dc-part-sub {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

/* ═══════════════════════════════════════════
   BOM 汇总条
   ═══════════════════════════════════════════ */
.bom-summary-bar {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
}
.bsb-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.bsb-label {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
}
.bsb-value {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  font-variant-numeric: tabular-nums;
}
.bsb-amount {
  color: var(--color-warning);
}
.bsb-divider {
  width: 1rpx;
  height: 48rpx;
  background: var(--color-border);
  flex-shrink: 0;
}

/* BOM 分组标题 */
.group-title {
  margin-top: 24rpx;
  margin-bottom: 12rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.gt-name {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
}
.gt-count {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

/* ═══════════════════════════════════════════
   尺码表
   ═══════════════════════════════════════════ */
.size-tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.size-tag {
  padding: 8rpx 20rpx;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  background: var(--color-bg-page);
  border-radius: var(--radius-full);
}
.size-table-wrap {
  margin-top: 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.size-table-header {
  display: flex;
  align-items: center;
  min-width: 100%;
}
.size-table-header.psth-header .sth-method {
  flex: 1.5;
}
.size-table-row {
  display: flex;
  align-items: center;
  min-width: 100%;
}
.size-table-row + .size-table-row {
  border-top: 1rpx solid var(--color-border-light);
}
.sth-cell {
  padding: 16rpx 12rpx;
  font-size: var(--font-size-2xs);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  text-align: center;
  flex-shrink: 0;
}
.str-cell {
  padding: 16rpx 12rpx;
  font-size: var(--font-size-2xs);
  color: var(--color-text-primary);
  text-align: center;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sth-part,
.str-part {
  width: 140rpx;
  text-align: left;
}
.sth-method,
.str-method {
  width: 160rpx;
  text-align: left;
}
.sth-tol,
.str-tol {
  width: 100rpx;
}
.sth-base,
.str-base {
  width: 100rpx;
}
.sth-size,
.str-size {
  width: 100rpx;
  font-variant-numeric: tabular-nums;
}
.size-table-card .size-table-wrap {
  margin-top: 0;
}

/* ═══════════════════════════════════════════
   工序卡片
   ═══════════════════════════════════════════ */
.process-stage-card {
  margin-bottom: 16rpx;
  transition: box-shadow 0.2s ease;
}
.process-stage-card.psc-expanded {
  box-shadow: 0 4rpx 24rpx rgba(0, 122, 255, 0.12);
}
.dc-status-tag {
  font-size: var(--font-size-2xs);
  padding: 2rpx 12rpx;
  border-radius: var(--radius-full);
  font-weight: var(--font-weight-medium);
  flex-shrink: 0;
}
.dst-completed {
  background: var(--color-success-bg);
  color: var(--color-success);
}
.dst-in_progress {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}
.dst-not_started {
  background: var(--color-bg-page);
  color: var(--color-text-tertiary);
}

/* 展开/收起指示器 */
.psc-toggle-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 12rpx 0 4rpx;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}
.psc-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 8rpx solid var(--color-text-tertiary);
  transition: transform 0.2s ease;
}
.psc-arrow-up {
  transform: rotate(180deg);
}

/* 工序分组标题（同步PC端父子结构） */
.process-group-header {
  margin-top: 24rpx;
  margin-bottom: 12rpx;
  padding: 12rpx 20rpx;
  background: var(--color-bg-secondary, #f4f5f7);
  border-radius: var(--radius-xs);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.pgg-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.pgg-count {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}

/* 展开区域：扫码记录列表 */
.psc-expand-area {
  padding: 16rpx 0 8rpx;
  border-top: 1rpx solid var(--color-border-light);
}
.psc-scan-header {
  padding: 0 0 12rpx;
}
.psc-scan-title {
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.psc-scan-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.psc-scan-item {
  padding: 16rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-md);
  position: relative;
}
.psc-scan-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.psc-scan-operator {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.psc-scan-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  flex-shrink: 0;
}
.psc-scan-name {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.psc-scan-time {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  font-variant-numeric: tabular-nums;
}
.psc-scan-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
  margin-left: 22rpx;
}
.psc-scan-op {
  font-size: var(--font-size-2xs);
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-full);
}
.psc-scan-cs {
  font-size: var(--font-size-2xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-full);
}
.psc-scan-qty {
  font-size: var(--font-size-2xs);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}
.psc-scan-price {
  font-size: var(--font-size-2xs);
  color: var(--color-text-secondary);
  font-variant-numeric: tabular-nums;
}
.psc-scan-wage {
  font-size: var(--font-size-2xs);
  color: var(--color-success);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}
.psc-scan-wh {
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
}
.psc-scan-remark {
  margin-top: 8rpx;
  margin-left: 22rpx;
  font-size: var(--font-size-2xs);
  color: var(--color-text-tertiary);
  line-height: 1.5;
}
.psc-scan-undo {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: var(--font-size-2xs);
  color: var(--color-danger);
  font-weight: var(--font-weight-medium);
  padding: 4rpx 12rpx;
}
.psc-no-records {
  padding: 24rpx 0;
  text-align: center;
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
}

/* ═══════════════════════════════════════════
   生产制单
   ═══════════════════════════════════════════ */
.production-header-card {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.ph-cover-wrap {
  width: 100%;
  margin-bottom: 16rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
}
.ph-cover {
  width: 100%;
  height: 320rpx;
  background: var(--color-bg-page);
}
.ph-meta {
  width: 100%;
}
.ph-meta .dc-header {
  margin-bottom: 0;
}
.ph-meta .dc-body {
  margin-top: 12rpx;
}
/* 审核状态 */
.review-status {
  font-weight: var(--font-weight-semibold);
}
.review-status-positive {
  color: var(--color-success);
}
.review-status-negative {
  color: var(--color-danger);
}
.review-status-neutral {
  color: var(--color-warning);
}

/* ═══════════════════════════════════════════
   审核表单
   ═══════════════════════════════════════════ */
.review-form-card {
  margin-top: 32rpx;
  
  background: var(--color-bg-card);
  
  
  box-shadow: var(--shadow-lg);

  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  padding: 12px;
  box-sizing: border-box;
}
.rf-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.rf-title {
  font-size: var(--font-size-md-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.rf-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--radius-full);
  background: var(--color-bg-page);
  display: flex;
  align-items: center;
  justify-content: center;
}
.rf-close .line-icon {
  color: var(--color-text-tertiary);
}
.rf-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.rf-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.rf-label {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.rf-picker {
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.rf-picker-text {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
}
.rf-pass {
  color: var(--color-success);
}
.rf-rework {
  color: var(--color-warning);
}
.rf-reject {
  color: var(--color-danger);
}
.rf-picker .line-icon {
  color: var(--color-text-tertiary);
}
.rf-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg-page);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  line-height: var(--line-height-medium);
  box-sizing: border-box;
}
.rf-actions {
  margin-top: 32rpx;
  display: flex;
  gap: 24rpx;
}
.rf-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  transition: opacity 0.2s ease;
}
.rf-btn:active {
  opacity: 0.7;
}
.rf-btn-secondary {
  background: transparent;
  box-shadow: inset 0 0 0 2rpx var(--color-border);
  color: var(--color-text-secondary);
}
.rf-btn-primary {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
}

/* ═══════════════════════════════════════════
   底部固定操作栏
   ═══════════════════════════════════════════ */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: var(--z-sticky);
  background: var(--color-bg-card);
  box-shadow: 0 -1rpx 0 0 var(--color-border);
}
.bottom-bar-inner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.bb-btn {
  flex: 1;
  height: 88rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease;
}
.bb-btn:active {
  opacity: 0.7;
}
.bb-btn-secondary {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
}
.bb-btn-secondary .bb-btn-text {
  color: var(--color-text-primary);
}
.bb-btn-primary {
  background: transparent;
  border: 1px solid var(--color-primary);
}
.bb-btn-primary .bb-btn-text {
  color: var(--color-primary);
}
.bb-btn-text {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
}
