<!--
  样衣开发详情页 · 按 PC 端逻辑重做
  核心交互：
  1. 默认进入只读模式
  2. 每个阶段区块顶部内嵌「阶段控制栏」(状态Tag + 领取人 + 开始/标记完成/退回修改)
  3. 未开始阶段：仅显示控制栏，无内容
  4. 进行中阶段：控制栏 + 可编辑内容
  5. 已完成阶段：控制栏 + 只读内容
-->
<view class="detail-page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:else>
    <!-- ══ ① 顶部基础信息卡（增强版，渐变色） ══ -->
    <view class="top-card-enhanced">
      <view class="tce-content">
        <block wx:if="{{styleImages.length > 0}}">
          <view class="tce-image-wrap" bindtap="onCoverTap">
            <image src="{{styleImages[0]}}" mode="aspectFill" />
          </view>
        </block>
        <block wx:else>
          <view class="tce-placeholder">
            <view class="tce-ph-icon"></view>
          </view>
        </block>
        <view class="tce-info">
          <text class="tce-style-no">{{styleInfo.styleNo || styleInfo.styleCode || ''}}</text>
          <text class="tce-style-name">{{styleInfo.styleName || styleInfo.name || '未命名款式'}}</text>
          <text class="tce-customer" wx:if="{{styleInfo.customer}}">{{styleInfo.customer}} · {{styleInfo.category || '-'}} · {{styleInfo.season || '-'}}</text>
          <view class="tce-tags">
            <text class="tce-tag">{{styleInfo._mainStatus || '未开始'}}</text>
            <text class="tce-tag" wx:if="{{styleInfo.color || styleInfo.size}}">{{styleInfo.color || '-'}} · {{styleInfo.size || '-'}}</text>
            <text class="tce-tag" wx:if="{{styleInfo.quantity}}">{{styleInfo.quantity}}件</text>
          </view>
        </view>
      </view>
      <view wx:if="{{styleInfo._deliveryTime || styleInfo._deliveryLabel}}" class="tce-delivery-bar">
        <view class="tce-delivery-left">
          <text class="tce-delivery-label">交板日期</text>
          <text class="tce-delivery-date">{{styleInfo._deliveryTime || '待补交期'}}</text>
        </view>
        <view class="tce-delivery-right">
          <block wx:if="{{styleInfo._countdownDays !== null && styleInfo._countdownDays !== undefined}}">
            <text class="tce-countdown-num">{{styleInfo._countdownDays >= 0 ? styleInfo._countdownDays : Math.abs(styleInfo._countdownDays)}}</text>
            <text class="tce-countdown-unit">天</text>
            <view class="tce-countdown-label">{{styleInfo._countdownDays >= 0 ? '剩余' : '已延期'}}</view>
          </block>
          <block wx:else>
            <text class="tce-countdown-num" style="font-size: 16px;">{{styleInfo._deliveryLabel || '待补交期'}}</text>
          </block>
        </view>
      </view>

      <!-- 进度与节点（合并到顶部卡片） -->
      <view wx:if="{{stages.length > 0}}" class="tce-progress-section">
        <view class="tce-progress-row">
          <view class="tce-progress-item">
            <text class="tce-progress-value">{{_overallProgress}}%</text>
            <text class="tce-progress-label">总进度</text>
          </view>
          <view class="tce-progress-divider"></view>
          <view class="tce-progress-item">
            <text class="tce-progress-value">{{_completedStages}}/{{stages.length}}</text>
            <text class="tce-progress-label">已完成节点</text>
          </view>
          <view class="tce-progress-divider"></view>
          <view class="tce-progress-item">
            <text class="tce-progress-value tce-progress-{{styleInfo._deliveryTone || 'normal'}}">
              <block wx:if="{{styleInfo._countdownDays !== null && styleInfo._countdownDays !== undefined}}">
                <block wx:if="{{styleInfo._countdownDays >= 0}}">{{styleInfo._countdownDays}}天</block>
                <block wx:else>延期{{styleInfo._countdownDays * -1}}天</block>
              </block>
              <block wx:else>待补</block>
            </text>
            <text class="tce-progress-label">{{styleInfo._countdownDays !== null && styleInfo._countdownDays >= 0 ? '距交板' : (styleInfo._countdownDays !== null && styleInfo._countdownDays < 0 ? '已延期' : '交期')}}</text>
          </view>
        </view>
        <view class="tce-progress-bar">
          <view class="tce-progress-fill" style="width: {{_overallProgress}}%;"></view>
        </view>
        <scroll-view scroll-x class="tce-stage-scroll" enhanced show-scrollbar="{{false}}">
          <view class="tce-stage-list">
            <view wx:for="{{stages}}" wx:key="key" wx:for-item="stage" wx:for-index="sIdx"
                  class="tce-stage-item tce-stage-{{stage.status}}" data-key="{{stage.key}}" bindtap="onStageJump">
              <view class="tce-stage-dot">
                <view wx:if="{{stage.status === 'completed'}}" class="tce-stage-check">✓</view>
                <text wx:else class="tce-stage-num">{{sIdx + 1}}</text>
              </view>
              <text class="tce-stage-name">{{stage.name}}</text>
              <text class="tce-stage-status tce-ss-{{stage.status}}">{{stage.statusText}}</text>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- ══ ② 扩展字段（自定义字段展示） ══ -->
    <ext-fields wx:if="{{extFields.length > 0}}" mode="view" fields="{{extFields}}" data="{{styleInfo}}" customOnly="{{true}}" />

    <!-- ══ ⑫ 附件文件 ══ -->
    <view class="section-card">
      <view class="section-hd">
        <text class="section-title">附件文件</text>
        <view class="section-actions">
          <text class="section-count">{{attachmentList.length}} 个</text>
          <view class="upload-btn" catchtap="onUploadAttachment">
            <text class="upload-icon icon-plus"></text>
            <text class="upload-text">上传</text>
          </view>
        </view>
      </view>
      <view wx:if="{{attachmentLoading}}" class="empty-inline">加载中...</view>
      <view wx:elif="{{attachmentList.length === 0}}" class="empty-inline">
        <text>暂无附件，点击</text>
        <text class="section-link" catchtap="onUploadAttachment">上传附件</text>
      </view>
      <view wx:else class="attach-card-list">
        <view class="attach-card" wx:for="{{attachmentList}}" wx:key="id">
          <view class="attach-icon {{item._iconClass}}"></view>
          <view class="attach-info">
            <text class="attach-name">{{item.fileName || item.name || '文件'}}</text>
            <view class="attach-meta">
              <text>{{item.fileSizeText}}</text>
              <text wx:if="{{item.uploader}}">· {{item.uploader}}</text>
              <text wx:if="{{item.createTimeText}}">· {{item.createTimeText}}</text>
            </view>
          </view>
          <view class="attach-actions">
            <view class="attach-icon-btn aib-download" catchtap="onAttachmentDownload"
                  data-url="{{item.url || item.fileUrl}}"
                  data-name="{{item.fileName || item.name || '文件'}}">
              <text class="icon-download"></text>
            </view>
            <view class="attach-icon-btn aib-delete" catchtap="onAttachmentDelete"
                  data-id="{{item.id}}"
                  data-name="{{item.fileName || item.name || '文件'}}">
              <text class="icon-delete"></text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- ══ ⑬ 备注日志（与PC端 RemarkTimelineModal 一致：输入在上，列表在下） ══ -->
    <view class="section-card remark-section-card">
      <view class="section-hd">
        <text class="section-title">款式备注 — {{styleInfo.styleNo || ''}}</text>
        <text class="section-count">{{remarkList.length}} 条</text>
      </view>

      <!-- 输入区（顶部，与PC端一致） -->
      <view class="remark-input-bar">
        <view class="rib-role-row">
          <input class="rib-role-input" placeholder="角色/工序（可选，如：裁剪、车缝、质检）" value="{{remarkRoleInput}}" bindinput="onRemarkRoleInput" maxlength="50" />
          <view class="rib-submit-btn {{remarkSubmitting ? 'rib-submitting' : ''}}" bindtap="onSubmitRemark">
            <text>{{remarkSubmitting ? '提交中' : '提交备注'}}</text>
          </view>
        </view>
        <textarea
          class="rib-textarea"
          placeholder="输入备注内容…"
          value="{{remarkInput}}"
          bindinput="onRemarkInput"
          maxlength="1000"
          auto-height
        />
      </view>

      <!-- 备注列表 -->
      <view wx:if="{{remarkLoading}}" class="empty-inline">加载中...</view>
      <view wx:elif="{{remarkList.length === 0}}" class="empty-inline">暂无备注</view>
      <block wx:else>
        <view wx:for="{{remarkList}}" wx:key="id" class="remark-card">
          <view class="rc-header">
            <view class="rc-author-row">
              <view class="rc-avatar">{{item._authorInitial}}</view>
              <view class="rc-author-info">
                <text class="rc-author">{{item._author}}</text>
                <text wx:if="{{item._authorRole}}" class="rc-role">{{item._authorRole}}</text>
              </view>
            </view>
            <text class="rc-time">{{item._createTimeText}}</text>
          </view>
          <view wx:if="{{item._content}}" class="rc-content">{{item._content}}</view>
          <view wx:if="{{item._images.length > 0}}" class="rc-images">
            <image wx:for="{{item._images}}" wx:for-item="img" wx:key="*this"
                   src="{{img}}" mode="aspectFill" class="rc-img"
                   data-url="{{img}}" bindtap="onPreviewRemarkImage" />
          </view>
        </view>
      </block>
    </view>

    <view class="bottom-gap"></view>
  </block>
</view>
