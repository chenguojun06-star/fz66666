@import '/styles/page-utils.wxss';

.container {
  min-height: 100vh;
  background:
    radial-gradient(ellipse at 20% 0%, rgba(var(--color-primary-rgb), 0.06) 0%, transparent 60%),
    var(--color-bg-page);
  padding: 0 var(--page-padding-x) calc(20px + env(safe-area-inset-bottom));
}

/* ---- 统计标签 + 智能提示（一行 flex wrap，对齐 PC 端 PageStatCards） ---- */
.stat-cards-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
  margin: 0 0 var(--spacing-md);
  min-height: 32px;
}
.stat-tag {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 4px 9px;
  border-radius: var(--radius-sm);
  /* Apple: removed hard border, use shadow */
  background: var(--color-bg-gray);
  font-size: var(--font-size-xs);
  line-height: 1.5;
  white-space: nowrap;
}
.stat-tag-active {
  border-width: 1px;
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
}
.stat-tag-active-primary { border-color: var(--color-primary); background: var(--color-primary-bg); }
.stat-tag-active-success { border-color: var(--color-success); background: var(--color-success-bg); }
.stat-tag-active-danger { border-color: var(--color-danger); background: var(--color-danger-bg); }

.stat-tag-primary .stat-value { color: var(--color-primary); }
.stat-tag-success .stat-value { color: var(--color-success); }
.stat-tag-danger .stat-value { color: var(--color-danger); }

.stat-label { color: var(--color-text-secondary); font-size: var(--font-size-xs); }
.stat-value { font-weight: var(--font-weight-semibold); color: var(--color-text-primary); font-variant-numeric: tabular-nums; }
.stat-unit { color: var(--color-text-secondary); font-size: var(--font-size-xs); }

/* 竖分隔线 */
.stat-divider {
  width: 1px;
  height: 16px;
  background: var(--color-border-light);
  flex-shrink: 0;
}

/* 智能提示标题 */
.hint-title {
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
  font-size: var(--font-size-xs);
  flex-shrink: 0;
}

/* 智能提示标签 */
.hint-tag {
  display: inline-flex;
  align-items: center;
  padding: 3px 8px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-semibold);
  line-height: 1.4;
  white-space: nowrap;
  /* Apple: removed hard border, use shadow */
  background: var(--color-bg-card);
}
.hint-tag.hint-red {
  color: var(--color-danger);
  border-color: var(--color-danger);
  background: var(--color-danger-bg);
}
.hint-tag.hint-orange {
  color: var(--color-warning);
  border-color: var(--color-warning);
  background: var(--color-warning-bg);
}
.hint-tag.hint-tag-active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

/* ---- 跨岗位提示条 ---- */
.role-hint-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin: var(--spacing-sm) 0 var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-lg);
  background: var(--color-warning-bg);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-warning-border);
}
.role-hint-icon { font-size: var(--font-size-sm); flex-shrink: 0; }
.role-hint-text { font-size: var(--font-size-sm); color: var(--color-warning); line-height: 1.5; }

/* ---- 搜索栏：搜索框使用全局 .search-bar/.search-box/.search-input/.search-icon/.search-clear，仅保留扫码按钮样式 ---- */
.search-bar .search-box {
  flex: 4;
}
.scan-btn {
  flex: 1;
  height: 28px;
  line-height: 28px;
  border-radius: var(--radius-full);
  padding: 0;
  background: transparent;
  border: 1px solid var(--color-primary);
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}
.scan-btn .scan-icon { font-size: 16px; width: 18px; height: 18px; }
.scan-btn-hover { background: var(--color-primary-bg); }

/* ---- 状态筛选条 ---- */
.filter-tabs {
  display: flex;
  padding: var(--spacing-sm) 0 var(--spacing-md);
  gap: var(--spacing-sm);
  white-space: nowrap;
}
.filter-tab {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 5px 12px;
  border-radius: var(--radius-xl);
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 1px solid transparent;
}
.filter-tab.active {
  background: var(--color-primary);
  color: var(--color-text-white);
  border-color: var(--color-primary);
}

/* ---- 加载态 ---- */
.loading-state {
  text-align: center;
  padding: 60px 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-md);
}

/* ---- 任务卡片（精简版：整卡可点击） ---- */
.task-card {
  margin: 0 0 var(--card-gap);
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  padding: var(--spacing-md) var(--spacing-lg);
  /* Apple: removed hard border, use shadow */
}
.task-card-hover {
  opacity: 0.85;
  transform: scale(0.995);
}

/* ===== 第一行：封面图 + 主信息 ===== */
.card-main-row {
  display: flex;
  gap: var(--spacing-md);
  align-items: flex-start;
}
.card-cover-wrap {
  width: 60px;
  height: 75px;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  background: var(--color-bg-gray);
  position: relative;
}
.cover-img {
  width: 100%;
  height: 100%;
}
.cover-placeholder-box {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-gray);
}
.cover-placeholder {
  font-size: var(--font-size-xl);
}

/* 右侧信息块 */
.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--spacing-sm);
}
.style-no {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
  font-variant-numeric: tabular-nums;
}
.style-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-meta-row {
  display: flex;
  align-items: center;
  gap: 3px;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
  flex-wrap: wrap;
}
.meta-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
}

/* 状态标签：与扫码页统一苹果系统色 */
.tag-row {
  display: flex;
  align-items: center;
  gap: 3px;
  flex-wrap: wrap;
  flex-shrink: 0;
}
.status-tag.tag {
  display: inline-block;
  padding: 1px 6px;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-xs);
  line-height: 1.6;
  font-weight: var(--font-weight-medium);
  white-space: nowrap;
}
.tag-default  { background: var(--color-bg-gray); color: var(--color-text-tertiary); }
.tag-success  { background: var(--color-success-bg); color: var(--color-success); }
.tag-warning  { background: var(--color-warning-bg); color: var(--color-warning); }
.tag-error    { background: var(--color-danger-bg); color: var(--color-danger); }
.tag-processing { background: var(--color-primary-bg); color: var(--color-primary); }

/* ===== 数量行 + 进度条（与 dashboard 统一风格） ===== */
.info-qty-row {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding-top: 3px;
}
.iq-main {
  display: flex;
  align-items: baseline;
  gap: 2px;
}
.iq-num {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-primary);
}
.iq-unit {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.iq-sub {
  display: flex;
  align-items: center;
  gap: 3px;
}
.iq-num--done {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-success);
}
.iq-num--remain {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}
.iq-lbl {
  font-size: var(--font-size-sm);
  color: var(--color-text-tertiary);
}
.iq-divider {
  color: var(--color-text-tertiary);
  font-size: var(--font-size-sm);
}
.info-progress {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  padding-top: 3px;
}
.ip-bar {
  flex: 1;
  height: 3px;
  background: var(--color-border-light);
  border-radius: 2px;
  overflow: hidden;
}
.ip-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 2px;
  transition: width 0.3s ease;
}
.ip-pct {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  min-width: 32px;
  text-align: right;
}

/* ===== 第二行：阶段进度条（紧凑 5 点） ===== */
.stage-bar {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1px solid var(--color-border-light);
}
.stage-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  min-width: 0;
}
.sb-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--color-border-light);
  /* Apple: removed hard border, use shadow */
  transition: all 0.2s;
}
.sb-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-tertiary);
  line-height: 1.2;
}
/* 状态颜色 */
.stage-bar-item.completed .sb-dot {
  background: var(--color-success);
  border-color: var(--color-success);
}
.stage-bar-item.completed .sb-name {
  color: var(--color-success);
  font-weight: var(--font-weight-medium);
}
.stage-bar-item.in_progress .sb-dot {
  background: var(--color-primary);
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px var(--color-primary-bg);
}
.stage-bar-item.in_progress .sb-name {
  color: var(--color-primary);
  font-weight: var(--font-weight-medium);
}
.stage-bar-item.not_started .sb-dot {
  background: var(--color-bg-gray);
  border-color: var(--color-border-light);
}
.stage-bar-item.not_started .sb-name {
  color: var(--color-text-tertiary);
}

/* ---- 加载更多 / 已显示全部 ---- */
.load-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-primary);
  font-size: var(--font-size-sm);
}
.no-more {
  text-align: center;
  padding: var(--spacing-lg) 0;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-xs);
}
