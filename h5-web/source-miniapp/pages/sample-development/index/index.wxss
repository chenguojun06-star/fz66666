.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 顶部扫码按钮栏 */
.top-action-bar {
  display: flex;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.scan-top-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #1677ff 0%, #1890ff 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-top-btn .scan-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-hover {
  opacity: 0.85;
}

/* 跨岗位提示条 */
.role-hint-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin: 16rpx 24rpx 0;
  padding: 16rpx 24rpx;
  background: #fff7e6;
  border-radius: 16rpx;
  border: 1rpx solid #ffe58f;
}
.role-hint-icon { font-size: 26rpx; flex-shrink: 0; }
.role-hint-text { font-size: 24rpx; color: #d46b08; line-height: 1.5; }

.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 0 8rpx;
}

.filter-tabs {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
}

.tab-item.active {
  color: #fff;
  background: #1677ff;
}

.count-bar {
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #999;
  background: #fff;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 96rpx;
}

.empty-text {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999;
}

.list {
  padding: 0 24rpx;
}

.card {
  margin-top: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
}

.card-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.card-cover-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.status-badge {
  padding: 2rpx 14rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
  white-space: nowrap;
}

.card-subtitle {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.card-dates {
  display: flex;
  gap: 20rpx;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.delivery-date {
  color: #cf1322;
}

.card-arrow {
  font-size: 32rpx;
  color: #ccc;
  padding-left: 12rpx;
  flex-shrink: 0;
}

.card-detail {
  border-top: 1rpx solid #f0f0f0;
  padding: 20rpx;
}

.detail-loading {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 24rpx 0;
}

.stages {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.stage-section {
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.stage-row {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  overflow-x: auto;
  gap: 8rpx;
}

.stage-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 0 0 auto;
  min-width: 72rpx;
}

.stage-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #d9d9d9;
  margin-bottom: 8rpx;
}

.stage-node.done .stage-dot {
  background: #52c41a;
}

.stage-name {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  white-space: nowrap;
}

.stage-node.done .stage-name {
  color: #52c41a;
}

.stage-time {
  font-size: 18rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.stage-line {
  width: 32rpx;
  height: 2rpx;
  background: #d9d9d9;
  margin-top: -20rpx;
}

.stage-node.done + .stage-line {
  background: #52c41a;
}

.detail-more {
  margin-top: 8rpx;
}

.detail-row {
  padding: 8rpx 0;
  font-size: 24rpx;
  color: #666;
}

.detail-action-single {
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
}

.action-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
  border: none;
  padding: 0 48rpx;
}

.action-btn.detail-btn {
  color: #1677ff;
  background: #e6f4ff;
}

/* 工序区标题行 */
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-hint {
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
}

/* 未配置工序提示 */
.no-process-hint {
  padding: 48rpx 24rpx;
  text-align: center;
  background: #fafafa;
  border-radius: 16rpx;
  border: 2rpx dashed #d9d9d9;
}

.no-process-icon {
  display: block;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.no-process-text {
  font-size: 26rpx;
  color: #999;
}

.load-more {
  padding: 32rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #999;
}

/* 新的工序阶段列表 */
.process-section {
  margin-top: 24rpx;
}

.process-stages-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.process-stage-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border: 1rpx solid #f0f0f0;
}

.process-stage-item.done {
  background: #f6ffed;
  border-color: #b7eb8f;
}

.process-stage-item.can-operate {
  background: #e6f4ff;
  border-color: #91caff;
}

.process-stage-item.locked {
  background: #fffbe6;
  border-color: #ffe58f;
  opacity: 0.85;
}

.process-stage-dot {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  background: #f0f0f0;
  color: #999;
}

.process-stage-item.done .process-stage-dot {
  background: #52c41a;
  color: #fff;
}

.process-stage-item.can-operate .process-stage-dot {
  background: #1677ff;
  color: #fff;
}

.process-stage-item.locked .process-stage-dot {
  background: #faad14;
  color: #fff;
}

.dot-check, .dot-arrow, .dot-empty {
  font-size: 24rpx;
}

.process-stage-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.process-stage-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.process-stage-item.done .process-stage-name {
  color: #389e0d;
}

.process-stage-item.can-operate .process-stage-name {
  color: #0958d9;
}

.process-stage-item.locked .process-stage-name {
  color: #874d00;
}

.process-stage-time {
  font-size: 22rpx;
  color: #999;
}

.process-stage-item.done .process-stage-time {
  color: #52c41a;
}

.process-stage-action {
  font-size: 22rpx;
  color: #1677ff;
  font-weight: 600;
}

.process-stage-lock {
  font-size: 22rpx;
  color: #d46b08;
}

.process-stage-pending {
  font-size: 22rpx;
  color: #999;
}