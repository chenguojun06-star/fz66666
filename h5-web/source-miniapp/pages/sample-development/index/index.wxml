<view class="page-container">
  <!-- 顶部操作栏：通用扫码按钮 -->
  <view class="top-action-bar">
    <button class="scan-top-btn" hover-class="btn-hover" bindtap="onTopScan">
      <text class="scan-icon">📷</text>
      <text>扫码样衣</text>
    </button>
  </view>

  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索款号/款式名" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" />
      <text wx:if="{{keyword}}" class="search-clear" data-clear="1" bindtap="onSearchInput">✕</text>
    </view>
  </view>

  <scroll-view class="filter-tabs" scroll-x="true">
    <view class="tab-item {{activeFilter === item.key ? 'active' : ''}}" wx:for="{{statusTabs}}" wx:key="key" data-key="{{item.key}}" bindtap="onFilterTap">
      {{item.label}}
    </view>
  </scroll-view>

  <view class="count-bar">
    <text>共 {{total}} 条</text>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{list.length === 0}}" class="empty-wrap">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无样衣开发记录</text>
  </view>

  <view wx:else class="list">
    <view class="card {{expandedId === item.id ? 'expanded' : ''}}" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" data-item="{{item}}" bindtap="onCardTap">
      <view class="card-header">
        <image wx:if="{{item._cover}}" class="card-cover" src="{{item._cover}}" mode="aspectFill" data-src="{{item._cover}}" catchtap="onPreviewImage" />
        <view wx:else class="card-cover-placeholder">
          <text>👔</text>
        </view>
        <view class="card-info">
          <view class="card-title-row">
            <text class="card-title">{{item.styleNo || '-'}}</text>
            <view class="status-badge" style="background:{{item._statusColor}}">{{item._statusLabel}}</view>
          </view>
          <text wx:if="{{item.styleName}}" class="card-subtitle">{{item.styleName}}</text>
          <view class="card-meta">
            <text wx:if="{{item.color}}">颜色: {{item.color}}</text>
            <text wx:if="{{item.quantity}}">数量: {{item.quantity}}件</text>
          </view>
          <view class="card-dates">
            <text wx:if="{{item._createDate}}">发放: {{item._createDate}}</text>
            <text wx:if="{{item._deliveryDate}}" class="delivery-date">交期: {{item._deliveryDate}}</text>
          </view>
        </view>
        <text class="card-arrow">{{expandedId === item.id ? '▾' : '▸'}}</text>
      </view>

      <!-- 展开详情：仅显示工序列表和查看详情 -->
      <view wx:if="{{expandedId === item.id}}" class="card-detail">
        <view wx:if="{{detailLoading}}" class="detail-loading">加载详情中...</view>
        <view wx:else>
          <!-- 开发阶段（只读显示） -->
          <view class="stage-section">
            <text class="section-title">开发阶段</text>
            <view class="stage-row">
              <view class="stage-node {{s.completed ? 'done' : ''}}" wx:for="{{item._devStages}}" wx:key="key" wx:for-item="s">
                <view class="stage-dot"></view>
                <text class="stage-name">{{s.name}}</text>
              </view>
            </view>
          </view>

          <!-- 生产工序（核心：父子关系展示，可点击操作） -->
          <view class="stage-section process-section">
            <view class="section-title-row">
              <text class="section-title">生产工序</text>
              <text wx:if="{{!hasProcessSystem}}" class="section-hint">未配置工序</text>
            </view>

            <!-- 没有工序配置 -->
            <view wx:if="{{!hasProcessSystem || processStages.length === 0}}" class="no-process-hint">
              <text class="no-process-icon">📋</text>
              <text class="no-process-text">请在 PC 端配置样衣生产工序</text>
            </view>

            <!-- 工序列表（按配置顺序展示，带父子门禁） -->
            <view wx:else class="process-stages-list">
              <view wx:for="{{processStages}}" wx:key="name" wx:for-item="stage"
                    class="process-stage-item {{stage.completed ? 'done' : ''}} {{stage.canOperate ? 'can-operate' : ''}} {{stage.locked ? 'locked' : ''}}"
                    data-stage="{{stage}}" data-pattern-id="{{item.id}}" catchtap="onProcessOperate">
                <view class="process-stage-dot">
                  <text wx:if="{{stage.completed}}" class="dot-check">✓</text>
                  <text wx:elif="{{stage.canOperate}}" class="dot-arrow">→</text>
                  <text wx:elif="{{stage.locked}}" class="dot-lock">🔒</text>
                  <text wx:else class="dot-empty">○</text>
                </view>
                <view class="process-stage-content">
                  <text class="process-stage-name">{{stage.name}}</text>
                  <text wx:if="{{stage.time}}" class="process-stage-time">{{stage.time}}</text>
                  <text wx:elif="{{stage.completed}}" class="process-stage-time">已完成</text>
                  <text wx:elif="{{stage.canOperate}}" class="process-stage-action">点击操作</text>
                  <text wx:elif="{{stage.locked}}" class="process-stage-lock">{{stage.lockReason}}</text>
                  <text wx:else class="process-stage-pending">待执行</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 查看详情 -->
          <view class="detail-action-single">
            <button class="action-btn detail-btn" data-item="{{item}}" bindtap="onGoDetail" catchtap="onGoDetail">查看详情</button>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{hasMore}}" class="load-more">
      <text wx:if="{{loadingMore}}">加载中...</text>
      <text wx:else bindtap="onLoadMore">加载更多</text>
    </view>
  </view>
</view>
