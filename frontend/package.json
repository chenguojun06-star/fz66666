{
  "name": "fashion-supplychain-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.7.0",
  "scripts": {
    "dev": "NODE_OPTIONS=--experimental-global-webcrypto vite",
    "dev:host": "NODE_OPTIONS=--experimental-global-webcrypto vite --host 0.0.0.0 --port 5173",
    "dev:all": "concurrently -k -n backend,frontend -c blue,green \"bash -lc 'set -a; [ -f ../.run/backend.env ] && . ../.run/backend.env; set +a; cd ../backend && mvn -q spring-boot:run'\" \"npm run dev:host\"",
    "build": "NODE_OPTIONS=--experimental-global-webcrypto tsc && NODE_OPTIONS=--experimental-global-webcrypto vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\" \"scripts/**/*.{mjs,js,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"scripts/**/*.{mjs,js,json}\"",
    "test": "NODE_OPTIONS=--experimental-global-webcrypto vitest run",
    "test:watch": "NODE_OPTIONS=--experimental-global-webcrypto vitest",
    "quality:score": "node ./scripts/qualityScore.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "antd": "^6.1.3",
    "axios": "^1.13.2",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "prettier": "^3.6.2",
    "terser": "^5.36.0",
    "typescript": "5.3.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
