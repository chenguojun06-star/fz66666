{
  "version": "2.0",
  "envId": "{{TCB_ENV_ID}}",
  "services": [
    {
      "name": "fashion-backend",
      "dockerfile": "./backend/Dockerfile",
      "containerPort": 8088,
      "minNum": 1,
      "maxNum": 5,
      "cpu": 1,
      "mem": 2,
      "docker": {
        "buildType": "Dockerfile",
        "dockerfilePath": "./backend/Dockerfile"
      },
      "envVariables": {
        "SPRING_PROFILES_ACTIVE": "prod",
        "WECHAT_TRUST_ALL_CERTS": "true",
        "APP_AUTH_JWT_SECRET": "{{JWT_SECRET}}",
        "APP_DB_HOST": "{{DB_HOST}}",
        "APP_DB_NAME": "{{DB_NAME}}",
        "APP_DB_USERNAME": "{{DB_USERNAME}}",
        "APP_DB_PASSWORD": "{{DB_PASSWORD}}",
        "APP_COS_SECRET_ID": "{{COS_SECRET_ID}}",
        "APP_COS_SECRET_KEY": "{{COS_SECRET_KEY}}",
        "APP_COS_BUCKET": "{{COS_BUCKET}}",
        "APP_COS_REGION": "{{COS_REGION}}"
      }
    }
  ],
  "static": [
    {
      "name": "fashion-h5",
      "localPath": "./h5-web/dist",
      "cloudPath": "/h5"
    },
    {
      "name": "fashion-admin",
      "localPath": "./frontend/dist",
      "cloudPath": "/"
    }
  ]
}
