{
  "version": "2.0",
  "envId": "{{TCB_ENV_ID}}",
  "framework": {
    "name": "fashion-supplychain",
    "plugins": {
      "backend": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "fashion-backend",
          "servicePath": "/api",
          "localPath": "./backend",
          "dockerfilePath": "./backend/Dockerfile",
          "containerPort": 8088,
          "initialDelaySeconds": 300,
          "minNum": 1,
          "maxNum": 5,
          "cpu": 1,
          "mem": 2,
          "envVariables": {
            "SPRING_PROFILES_ACTIVE": "prod",
            "WECHAT_TRUST_ALL_CERTS": "true",
            "APP_AUTH_JWT_SECRET": "{{JWT_SECRET}}",
            "APP_DB_HOST": "{{DB_HOST}}",
            "APP_DB_NAME": "{{DB_NAME}}",
            "APP_DB_USERNAME": "{{DB_USERNAME}}",
            "APP_DB_PASSWORD": "{{DB_PASSWORD}}",
            "APP_COS_SECRET_ID": "{{COS_SECRET_ID}}",
            "APP_COS_SECRET_KEY": "{{COS_SECRET_KEY}}",
            "APP_COS_BUCKET": "{{COS_BUCKET}}",
            "APP_COS_REGION": "{{COS_REGION}}",
            "DEEPSEEK_API_KEY": "{{DEEPSEEK_API_KEY}}",
            "AGNES_API_KEY": "{{AGNES_API_KEY}}",
            "VOYAGE_API_KEY": "{{VOYAGE_API_KEY}}",
            "QDRANT_URL": "{{QDRANT_URL}}",
            "QDRANT_API_KEY": "{{QDRANT_API_KEY}}",
            "WECHAT_MP_APPID": "{{WECHAT_MP_APPID}}",
            "WECHAT_MP_SECRET": "{{WECHAT_MP_SECRET}}",
            "APP_SECURITY_PII_ENCRYPTION_KEY": "{{PII_ENCRYPTION_KEY}}",
            "AI_OPENAI_COMPAT_ENABLED": "{{AI_OPENAI_COMPAT_ENABLED}}",
            "AI_OPENAI_COMPAT_API_KEY": "{{AI_OPENAI_COMPAT_API_KEY}}",
            "AI_OPENAI_COMPAT_TENANT_ID": "{{AI_OPENAI_COMPAT_TENANT_ID}}",
            "AI_IM_AI_FEISHU_ENABLED": "true",
            "AI_IM_AI_FEISHU_VERIFICATION_TOKEN": "dxZCfyFE816hLOrPbpE3pzdHJpmcXAMQ",
            "AI_IM_AI_FEISHU_ENCRYPT_KEY": "7qZik8wobG3FJVt8rrg97esIHfRRV6dc"
          }
        }
      },
      "frontend": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "fashion-admin",
          "servicePath": "/",
          "localPath": "./frontend",
          "dockerfilePath": "./frontend/Dockerfile",
          "containerPort": 80,
          "initialDelaySeconds": 30,
          "minNum": 1,
          "maxNum": 3,
          "cpu": 0.5,
          "mem": 1,
          "envVariables": {
            "BACKEND_URL": "https://api.webyszl.cn"
          }
        }
      },
      "h5": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "fashion-h5",
          "servicePath": "/h5",
          "localPath": "./h5-web",
          "dockerfilePath": "./h5-web/Dockerfile",
          "containerPort": 80,
          "initialDelaySeconds": 30,
          "minNum": 1,
          "maxNum": 3,
          "cpu": 0.25,
          "mem": 0.5
        }
      }
    }
  }
}